<%
seo = { title: 'Trận của tôi - BLV - ' + brand.name, description: 'Tất cả trận BLV đã được duyệt', canonical: '/blv-matches', noindex: true };
var _blvName = (typeof myBlvName !== 'undefined') ? myBlvName : 'BLV';
var _schedules = (typeof schedules !== 'undefined' && Array.isArray(schedules)) ? schedules : [];
function _fmt(ts){
  if (!ts) return '-';
  var d = new Date(ts);
  return ('0'+d.getDate()).slice(-2)+'/'+('0'+(d.getMonth()+1)).slice(-2)+' '+('0'+d.getHours()).slice(-2)+':'+('0'+d.getMinutes()).slice(-2);
}
%>
<%- include('partials/tw-layout-start') %>

<section class="max-w-6xl mx-auto mb-6 px-2 md:px-4">
  <div class="flex items-center gap-3 mb-3 bg-bg-card border border-line rounded-xl p-3">
    <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-pri to-rose-500 grid place-items-center text-xl">🎙️</div>
    <div class="flex-1 min-w-0"><div class="text-sm font-bold text-white truncate"><%= _blvName %></div><div class="text-[10.5px] text-muted">Bình luận viên</div></div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-[220px_minmax(0,1fr)] gap-4">
    <%- include('partials/tw-blv-sidebar', { activeBlv: 'matches', myBlvName: _blvName }) %>

    <main class="space-y-4 min-w-0">
      <div class="bg-bg-card border border-line rounded-xl p-4">
        <h2 class="text-white font-extrabold text-lg flex items-center gap-2 mb-2">
          <span class="text-2xl">📋</span> Trận Của Tôi (đã duyệt) — <span class="text-pri-light text-base">(<%= _schedules.length %>)</span>
        </h2>
        <p class="text-[12px] text-muted">Tất cả trận đã được admin duyệt. Click "Kết nối OBS" để lấy Stream Key.</p>
      </div>

      <div class="bg-bg-card border border-line rounded-xl p-4">
        <% if (_schedules.length === 0) { %>
          <div class="text-center py-10 text-muted">
            <div class="text-5xl mb-2 opacity-60">📭</div>
            <div class="text-sm font-bold mb-1">Chưa có trận nào được duyệt</div>
            <div class="text-xs">Vào <a href="/blv-register" class="text-pri-light underline">📝 Đăng Ký BLV</a> để chọn trận từ lịch.</div>
          </div>
        <% } else { %>
          <div class="space-y-2.5">
            <% _schedules.forEach(function(s){ %>
              <div class="bg-bg-deep border border-line rounded-xl p-3 hover:border-pri/40 transition-colors">
                <div class="flex items-start justify-between gap-3 flex-wrap">
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 flex-wrap">
                      <span class="text-sm font-extrabold text-white"><%= s.matchTitle || s.title %></span>
                      <% if (s.streamActive) { %><span class="px-2 py-0.5 bg-red-600 text-white text-[10px] font-extrabold rounded animate-pulse">🔴 LIVE</span><% } %>
                      <% if (s.streamKey && !s.streamActive) { %><span class="px-2 py-0.5 bg-emerald-700 text-white text-[10px] font-extrabold rounded">✓ KEY READY</span><% } %>
                    </div>
                    <div class="text-[11px] text-muted mt-0.5">📅 <%= _fmt(s.startTime) %> → <%= _fmt(s.endTime) %><% if (s.description) { %> · 🏆 <%= s.description %><% } %></div>
                  </div>
                  <a href="/blv-obs?date=<%= new Date(s.startTime).toISOString().slice(0,10) %>" class="bg-emerald-600 hover:bg-emerald-500 text-white text-xs font-bold px-3 py-1.5 rounded-lg flex items-center gap-1.5">
                    <span>📡</span> Kết nối OBS
                  </a>
                </div>
              </div>
            <% }); %>
          </div>
        <% } %>
      </div>
    </main>
  </div>
</section>
