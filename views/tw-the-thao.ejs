<%
seo = {
  title: 'Xem '+cat.name+' Trực Tiếp Full HD Miễn Phí | XOSO66 TV',
  description: 'Xem trực tiếp '+cat.name+' Full HD miễn phí tại XOSO66 TV (xổ số 66). '+live.length+' trận đang live + '+upcoming.length+' trận sắp diễn ra. BLV tiếng Việt, không quảng cáo.',
  keywords: 'xem '+cat.name.toLowerCase()+' trực tiếp, livestream '+cat.name.toLowerCase()+', xoso66, xổ số 66, xoso66 tv, xem trực tiếp bóng đá',
  canonical: '/the-thao/'+activeCat,
  breadcrumb: [{ name:cat.name, url:'/the-thao/'+activeCat }]
};
%>
<%- include('partials/tw-layout-start') %>
<%- include('partials/tw-breadcrumb') %>

<header class="px-8 py-7 rounded-2xl mb-5 text-white flex flex-wrap items-center gap-5" style="background:linear-gradient(135deg,<%= cat.color %>,#1a1f29)">
  <div class="text-6xl"><%= cat.icon %></div>
  <div class="flex-1 min-w-[240px]">
    <h1 class="text-2xl md:text-3xl font-black mb-1">Live <%= cat.name %> Trực Tiếp HD</h1>
    <p class="text-sm opacity-95"><strong><%= live.length %></strong> trận trực tiếp &middot; <strong><%= upcoming.length %></strong> sắp diễn ra &middot; Bình luận tiếng Việt 24/7</p>
  </div>
  <a href="<%= partner.sportbet %>" target="_blank" rel="noopener" class="bg-white px-7 py-3 rounded-lg font-extrabold shadow-lg" style="color:<%= cat.color %>">&#128176; Đặt cược <%= cat.name %></a>
</header>

<nav class="flex gap-2 flex-wrap bg-bg-card border border-line rounded-xl p-2 mb-5 overflow-x-auto scrollbar-hide">
  <a href="/" class="flex items-center gap-1.5 px-4 py-2 rounded-lg font-bold text-[13px] whitespace-nowrap text-gray-100 hover:bg-bg-soft"><span class="bg-pri w-5 h-5 rounded grid place-items-center text-[10px]">&check;</span> Tất cả</a>
  <% Object.entries(cats).forEach(function(pair){ var k=pair[0], c=pair[1]; if (c.partnerOnly) return; %>
    <a href="/the-thao/<%= k %>" class="flex items-center gap-1.5 px-4 py-2 rounded-lg font-bold text-[13px] whitespace-nowrap <%= activeCat===k ? 'bg-gradient-to-br from-pri to-live text-white shadow-pri' : 'text-gray-100 hover:bg-bg-soft' %>"><span><%= c.icon %></span> <%= c.name %></a>
  <% }); %>
</nav>

<% if (live.length) { %>
<section class="mb-6" aria-label="Live">
  <div class="flex items-center gap-2.5 mb-3.5"><span class="w-1 h-5 bg-pri rounded-sm"></span><h2 class="text-lg font-extrabold text-white flex items-center gap-2">&#128308; Đang trực tiếp <span class="bg-live text-white text-[11px] px-2 py-0.5 rounded font-extrabold">LIVE &middot; <%= live.length %></span></h2></div>
  <div class="grid gap-3.5 grid-cols-[repeat(auto-fill,minmax(260px,1fr))]"><%- include('partials/tw-stream-card', { list: live }) %></div>
</section>
<% } %>

<section class="mb-6">
  <div class="flex items-center gap-2.5 mb-3.5"><span class="w-1 h-5 bg-pri rounded-sm"></span><h2 class="text-lg font-extrabold text-white">&#9200; Sắp diễn ra</h2></div>
  <% if (!upcoming.length) { %>
    <div class="p-12 text-center bg-bg-card border border-dashed border-line rounded-xl text-muted"><div class="text-5xl mb-2 opacity-60">&#128197;</div>Không có trận <%= cat.name.toLowerCase() %> sắp diễn ra trong 2 ngày tới.</div>
  <% } else { %>
    <div class="grid gap-3.5 grid-cols-[repeat(auto-fill,minmax(260px,1fr))]"><%- include('partials/tw-stream-card', { list: upcoming }) %></div>
  <% } %>
</section>

<% if (finished.length) { %>
<section class="mb-6">
  <div class="flex items-center gap-2.5 mb-3.5"><span class="w-1 h-5 bg-pri rounded-sm"></span><h2 class="text-lg font-extrabold text-white">&#127916; Mới kết thúc</h2></div>
  <div class="grid gap-3.5 grid-cols-[repeat(auto-fill,minmax(260px,1fr))]"><%- include('partials/tw-stream-card', { list: finished }) %></div>
</section>
<% } %>

<%- include('partials/tw-seo-bottom', { seoContent: {
  h2: 'Xem live '+cat.name+' miễn phí tại '+brand.name,
  intro: 'Trang chuyên biệt phục vụ các fan <strong>'+cat.name+'</strong>. Tất cả trận từ giải lớn nhất thế giới đến giải địa phương đều được livestream HD miễn phí.',
  sections: [
    { h3:'Chất lượng & trải nghiệm', p:'Stream Full HD 1080p, độ trễ thấp dưới 5s, bình luận tiếng Việt 24/7. Hỗ trợ xem trên PC, mobile, smart TV, Chromecast.' },
    { h3:'Nhận khuyến mãi khi xem', p:'Đăng ký tại <a href="'+partner.register+'" target="_blank" rel="noopener">'+brand.domain+'</a> để nhận thưởng 100% nạp lần đầu + voucher cá cược.' }
  ],
  faqs: [
    { q:'Có cần đăng ký để xem không?', a:'Không. Tài khoản chỉ cần để chat, đặt cược hoặc nhận khuyến mãi.' },
    { q:'Bao nhiêu trận '+cat.name+' mỗi ngày?', a:'Trung bình 10-30 trận/ngày. Cuối tuần và Champions League/NBA Playoff có thể lên 40+.' }
  ]
}}) %>

<%- include('partials/tw-footer') %>
