<%
var tab = (typeof tabName!=='undefined' && tabName) ? tabName : 'checkin';
// Tab "studio" chỉ hiện cho idol/blv - được filter ở client-side JS (server không biết role lúc render)
var TABS = [
  { key:'studio',   text:'Quản Lý Kênh',       streamerOnly: true, icon:'<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/><circle cx="5" cy="12" r="1.5" fill="currentColor"/></svg>' },
  { key:'info',     text:'Thông Tin Cá Nhân', icon:'<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>' },
  { key:'password', text:'Thay Đổi Mật Khẩu', icon:'<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>' },
  { key:'wallet',   text:'Ví Của Tôi',         icon:'<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12V7H5a2 2 0 0 1 0-4h14v4"/><path d="M3 5v14a2 2 0 0 0 2 2h16v-5"/><path d="M18 12a2 2 0 0 0 0 4h4v-4Z"/></svg>' },
  { key:'history',  text:'Lịch Sử Đổi Quà',    icon:'<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/></svg>' },
  { key:'checkin',  text:'Điểm Danh',          icon:'<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>' },
  { key:'follow',   text:'Theo Dõi',           icon:'<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>' },
  { key:'link',     text:'Liên kết Xoso66',    icon:'<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>' }
];
var tabTitleMap = { studio:'Quản Lý Kênh Live', info:'Thông Tin Cá Nhân', password:'Đổi Mật Khẩu', wallet:'Ví Của Tôi', history:'Lịch Sử Đổi Quà', checkin:'Điểm Danh Nhận X COIN', follow:'Theo Dõi', link:'Liên Kết Xoso66' };
// User role - server-side (set bởi pubAuth middleware)
var __userRole = (typeof publicUser !== 'undefined' && publicUser && publicUser.role) ? publicUser.role : 'user';
var __isStreamer = (__userRole === 'idol' || __userRole === 'blv' || __userRole === 'admin');
seo = {
  title: (tabTitleMap[tab] || 'Hồ sơ') + ' - ' + brand.name,
  canonical: '/profile?tab=' + tab,
  noindex: true
};
%>
<%- include('partials/tw-layout-start') %>

<script>
(function(){ try { if (!localStorage.getItem('x66_user')) { location.href='/dang-nhap'; } } catch(e){} })();
</script>

<style>
/* ===== MOBILE PROFILE OPTIMIZE ===== */
@media (max-width: 1023px) {
  /* Profile section: stack vertical */
  #profileSection { grid-template-columns: 1fr !important; padding: 8px 12px; }
  /* Avatar header smaller */
  #profileSection .border-b.border-line .w-28 { width: 80px !important; height: 80px !important; font-size: 28px !important; }
  /* Tab nav: horizontal scroll instead of vertical */
  #profileSection nav[role="tablist"] {
    display: flex !important; gap: 6px !important; padding: 8px !important;
    overflow-x: auto; -ms-overflow-style: none; scrollbar-width: none;
    border-bottom: 1px solid var(--line, #2a3344);
  }
  #profileSection nav[role="tablist"]::-webkit-scrollbar { display: none; }
  #profileSection nav[role="tablist"] a {
    flex-shrink: 0; padding: 8px 12px !important;
    background: #1a1f29; border-radius: 999px !important;
    font-size: 12px !important; white-space: nowrap;
    border: 1px solid #2a3344;
  }
  #profileSection nav[role="tablist"] a.bg-gradient-to-r,
  #profileSection nav[role="tablist"] a[class*="text-pri-light"] {
    background: linear-gradient(135deg, #ff7a18, #ea580c) !important;
    border-color: #ff7a18 !important; color: #fff !important;
  }
  #profileSection nav[role="tablist"] a span.absolute { display: none; }
  /* Content card: padding nhỏ hơn */
  #profileSection > section { padding: 16px !important; min-height: auto !important; }
  /* Toast position - tránh đè bottom nav */
  #toast { top: 70px !important; right: 12px !important; left: 12px !important; }
}
</style>

<section id="profileSection" class="grid lg:grid-cols-[300px_1fr] gap-4 mb-6" aria-label="Hồ sơ">

  <!-- LEFT: Gộp avatar + info + menu + X COIN + logout vào 1 card -->
  <aside class="bg-bg-card border border-line rounded-xl overflow-hidden flex flex-col h-fit lg:sticky lg:top-20">

    <!-- Avatar header -->
    <div class="p-5 text-center border-b border-line bg-gradient-to-b from-bg-soft/40 to-transparent">
      <div class="relative w-28 h-28 mx-auto group">
        <!-- Avatar wrapper (text fallback hoặc ảnh) -->
        <div class="w-28 h-28 rounded-full border-4 border-pri bg-bg-deep grid place-items-center text-5xl font-black text-pri shadow-pri overflow-hidden" id="pfAvatar">U</div>
        <!-- Camera button góc dưới phải -->
        <button onclick="pfTriggerUpload()" type="button"
                class="absolute bottom-0 right-0 w-9 h-9 rounded-full bg-gradient-to-br from-pri to-live border-2 border-bg-card grid place-items-center shadow-lg hover:scale-110 transition-transform"
                aria-label="Đổi ảnh đại diện">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/>
            <circle cx="12" cy="13" r="4"/>
          </svg>
        </button>
        <!-- Hidden file input - capture=user trên mobile sẽ mở thẳng camera trước, không capture = thư viện+camera -->
        <input id="pfAvatarFile" type="file" accept="image/jpeg,image/png,image/webp,image/gif" class="hidden" onchange="pfUploadAvatar(this)">
      </div>
      <h2 class="text-lg font-extrabold text-white mt-3 tracking-wide" id="pfName">USER</h2>
      <div class="text-[10px] text-muted mt-0.5">ID: <span class="text-pri-light font-mono" id="pfId">XX</span></div>
      <div id="pfAvatarStatus" class="text-[10px] mt-1.5 hidden"></div>
    </div>

    <!-- Info compact (4 dòng) -->
    <div class="px-4 py-3 space-y-1.5 text-[12.5px] border-b border-line">
      <div class="flex items-center gap-2 text-muted">
        <span class="text-pri-light w-4">&#9998;</span>
        <span class="w-16">Tiểu sử:</span>
        <span class="text-white flex-1 truncate" id="pfBio">—</span>
      </div>
      <div class="flex items-center gap-2 text-muted">
        <span class="text-pri-light w-4">&#9792;</span>
        <span class="w-16">Giới tính:</span>
        <span class="text-white flex-1" id="pfGender">—</span>
      </div>
      <div class="flex items-center gap-2 text-muted">
        <span class="text-pri-light w-4">&#127874;</span>
        <span class="w-16">Sinh nhật:</span>
        <span class="text-white flex-1" id="pfBirthday">—</span>
      </div>
      <div class="flex items-center gap-2 text-muted">
        <span class="text-pri-light w-4">&#127968;</span>
        <span class="w-16">Tỉnh:</span>
        <span class="text-white flex-1" id="pfProvince">—</span>
      </div>
    </div>

    <!-- X COIN card -->
    <div class="px-4 py-3 border-b border-line">
      <div class="bg-gradient-to-br from-pri/15 to-pri-dark/10 border border-pri/40 rounded-lg p-3 flex items-center gap-3">
        <div class="w-10 h-10 rounded-full bg-gold/20 grid place-items-center text-xl">&#129689;</div>
        <div class="flex-1">
          <div class="text-[10px] text-muted uppercase tracking-wide font-bold">X COIN</div>
          <div class="text-xl font-black text-gold tabular-nums" id="pfCoin">79</div>
        </div>
        <a href="/nap-tien" class="text-[10px] bg-emerald-600 hover:bg-emerald-700 text-white font-bold px-2.5 py-1 rounded">+ Nạp</a>
      </div>
    </div>

    <!-- Menu tabs trong cùng card -->
    <nav class="p-2 space-y-1" role="tablist">
      <% TABS.forEach(function(t){
        var ac = t.key===tab;
        // streamerOnly tabs: chỉ render cho idol/blv/admin
        if (t.streamerOnly && !__isStreamer) return;
      %>
        <a href="/profile?tab=<%= t.key %>" class="relative flex items-center gap-2.5 px-3 py-2.5 rounded-lg text-[13px] font-bold transition-colors <%= ac ? 'bg-gradient-to-r from-pri/25 to-transparent text-pri-light' : 'text-gray-200 hover:bg-bg-soft hover:text-white' %> <%= t.streamerOnly ? 'border border-pri/30 bg-pri/5' : '' %>" role="tab">
          <% if (ac) { %><span class="absolute left-0 top-1.5 bottom-1.5 w-[3px] bg-pri rounded-r"></span><% } %>
          <span class="<%= ac ? 'text-pri-light' : 'text-pri' %>"><%- t.icon %></span>
          <span class="flex-1"><%= t.text %></span>
          <% if (t.streamerOnly) { %><span class="bg-live text-white text-[9px] font-extrabold px-1.5 py-0.5 rounded animate-pulse-live">LIVE</span><% } %>
        </a>
      <% }); %>
    </nav>

    <!-- Logout button -->
    <div class="p-2 border-t border-line">
      <button onclick="doLogout()" class="w-full flex items-center justify-center gap-2 px-3 py-2.5 rounded-lg text-sm font-extrabold bg-gradient-to-br from-pri to-pri-dark text-white hover:brightness-110 transition-all shadow-pri">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        Đăng Xuất
      </button>
    </div>
  </aside>

  <!-- RIGHT: Tab content -->
  <section class="bg-bg-card border border-line rounded-xl p-5 md:p-6 min-h-[500px]">
    <% if (tab === 'studio')   { %><%- include('partials/tw-profile-studio') %>
    <% } else if (tab === 'checkin')   { %><%- include('partials/tw-profile-checkin') %>
    <% } else if (tab === 'info'){ %><%- include('partials/tw-profile-info') %>
    <% } else if (tab === 'password'){ %><%- include('partials/tw-profile-password') %>
    <% } else if (tab === 'wallet')  { %><%- include('partials/tw-profile-wallet') %>
    <% } else if (tab === 'history') { %><%- include('partials/tw-profile-history') %>
    <% } else if (tab === 'follow')  { %><%- include('partials/tw-profile-follow') %>
    <% } else if (tab === 'link')    { %><%- include('partials/tw-profile-link') %>
    <% } %>
  </section>
</section>

<div id="toast" class="fixed top-20 right-5 bg-bg-card border border-line border-l-4 border-l-pri px-4 py-3 rounded-lg text-white text-[13px] font-semibold z-[100] shadow-2xl translate-x-[120%] transition-transform"></div>

<script>
function pfRenderAvatar(avatarUrl, displayName){
  var el = document.getElementById('pfAvatar');
  if (!el) return;
  if (avatarUrl) {
    el.innerHTML = '<img src="' + avatarUrl + '?t=' + Date.now() + '" alt="Avatar" class="w-full h-full object-cover" style="display:block">';
    el.classList.remove('grid','place-items-center','text-5xl','font-black','text-pri');
  } else {
    el.classList.add('grid','place-items-center','text-5xl','font-black','text-pri');
    el.textContent = String(displayName || 'U').charAt(0).toUpperCase();
  }
}

function loadUser(){
  // 1) Render từ localStorage trước (instant)
  try {
    var u = JSON.parse(localStorage.getItem('x66_user') || '{}');
    if (u.username) {
      document.getElementById('pfName').textContent = (u.fullname || u.username || 'USER').toUpperCase();
      pfRenderAvatar(u.avatar || '', u.fullname || u.username);
      var id = u.id || (u.username.toUpperCase() + Math.floor(Math.random()*1e6).toString(16).toUpperCase().padStart(6,'0'));
      document.getElementById('pfId').textContent = id;
      if (u.bio)      document.getElementById('pfBio').textContent = u.bio;
      if (u.gender)   document.getElementById('pfGender').textContent = u.gender==='male'?'Nam':u.gender==='female'?'Nữ':'Khác';
      if (u.birthday) document.getElementById('pfBirthday').textContent = u.birthday;
      if (u.province) document.getElementById('pfProvince').textContent = u.province;
      if (typeof u.coin==='number') document.getElementById('pfCoin').textContent = u.coin.toLocaleString('vi-VN');
    }
  } catch(e){}

  // 2) Fetch server để lấy avatar mới nhất + sync localStorage
  fetch('/api/auth/me', { credentials:'same-origin' })
    .then(function(r){ return r.json(); })
    .then(function(d){
      if (!d || !d.ok || !d.user) return;
      pfRenderAvatar(d.user.avatar || '', d.user.fullname || d.user.username);
      try {
        var u = JSON.parse(localStorage.getItem('x66_user') || '{}');
        u.username = d.user.username;
        u.avatar = d.user.avatar || '';
        if (d.user.fullname) u.fullname = d.user.fullname;
        if (typeof d.user.vnd === 'number') u.vnd = d.user.vnd;
        if (typeof d.user.coin === 'number') u.coin = d.user.coin;
        localStorage.setItem('x66_user', JSON.stringify(u));
      } catch(e){}
    })
    .catch(function(){});
}
loadUser();

// ═══════════ UPLOAD AVATAR ═══════════
function pfTriggerUpload(){
  document.getElementById('pfAvatarFile').click();
}

function pfUploadAvatar(input){
  var file = input.files && input.files[0];
  if (!file) return;
  if (file.size > 5 * 1024 * 1024) {
    alert('Ảnh quá lớn! Tối đa 5MB.');
    input.value = '';
    return;
  }
  if (!/^image\/(jpeg|jpg|png|webp|gif)$/i.test(file.type)) {
    alert('Chỉ chấp nhận ảnh JPG/PNG/WEBP/GIF.');
    input.value = '';
    return;
  }

  var status = document.getElementById('pfAvatarStatus');
  status.classList.remove('hidden', 'text-emerald-400', 'text-red-400');
  status.classList.add('text-yellow-400');
  status.textContent = '⏳ Đang tải ảnh lên...';

  // Preview ngay (instant feedback) bằng FileReader
  var reader = new FileReader();
  reader.onload = function(e){
    pfRenderAvatar(e.target.result, 'U');
  };
  reader.readAsDataURL(file);

  // Upload thật lên server
  var fd = new FormData();
  fd.append('avatar', file);

  fetch('/api/upload/avatar', {
    method: 'POST',
    credentials: 'same-origin',
    body: fd
  })
    .then(function(r){ return r.json(); })
    .then(function(d){
      input.value = ''; // reset để upload lại được cùng file
      if (d.ok) {
        status.classList.remove('text-yellow-400', 'text-red-400');
        status.classList.add('text-emerald-400');
        status.textContent = '✅ ' + (d.message || 'Đã cập nhật ảnh đại diện');
        // Re-render với URL thật
        pfRenderAvatar(d.avatar, '');
        // Sync localStorage
        try {
          var u = JSON.parse(localStorage.getItem('x66_user') || '{}');
          u.avatar = d.avatar;
          localStorage.setItem('x66_user', JSON.stringify(u));
        } catch(e){}
        // Broadcast cho header/sidebar
        try { window.dispatchEvent(new CustomEvent('x66:avatarChanged', { detail:{ avatar: d.avatar } })); } catch(e){}
        setTimeout(function(){ status.classList.add('hidden'); }, 3000);
      } else {
        status.classList.remove('text-yellow-400', 'text-emerald-400');
        status.classList.add('text-red-400');
        status.textContent = '❌ ' + (d.error || 'Tải lên thất bại');
        // Revert preview về avatar cũ
        loadUser();
      }
    })
    .catch(function(){
      input.value = '';
      status.classList.remove('text-yellow-400', 'text-emerald-400');
      status.classList.add('text-red-400');
      status.textContent = '❌ Lỗi kết nối server';
      loadUser();
    });
}

function doLogout(){
  if (!confirm('Bạn có chắc muốn đăng xuất?')) return;
  try { localStorage.removeItem('x66_user'); } catch(e){}
  location.href = '/';
}

function showToast(msg, kind){
  var t=document.getElementById('toast');
  var c=kind==='success'?'!border-l-emerald-500':kind==='error'?'!border-l-live':'!border-l-pri';
  t.className='fixed top-20 right-5 bg-bg-card border border-line border-l-4 px-4 py-3 rounded-lg text-white text-[13px] font-semibold z-[100] shadow-2xl translate-x-0 transition-transform '+c;
  t.textContent=msg;
  setTimeout(function(){ t.className=t.className.replace('translate-x-0','translate-x-[120%]') }, 3000);
}
window.showToast = showToast;
</script>

<%- include('partials/tw-footer') %>
