<%
const _today = new Date();
const _todayVi = _today.getDate()+'/'+(_today.getMonth()+1)+'/'+_today.getFullYear();
seo = {
  title: brand.name + ' - Xem trực tiếp bóng đá, casino, idol live HD ngày ' + _todayVi,
  description: 'Kênh xem trực tiếp '+brand.name+' HD miễn phí: bóng đá, bóng rổ, tennis, esports, casino, idol live 24/7. Hôm nay '+_todayVi+' có '+live.length+' trận live, '+upcoming.length+' trận sắp diễn ra. Đối tác '+brand.domain+'.',
  keywords: 'xem bóng đá trực tiếp, livescore, casino trực tuyến, idol live, xoso66tv, '+brand.short+', trực tiếp ngoại hạng anh, la liga, champions league',
  canonical: '/',
  ogType: 'website',
};
%>
<%- include('partials/layout-start', { title: seo.title, seo }) %>

<!-- H1 hero banner SEO -->
<header class="seo-hero">
  <h1>📺 <%= brand.name %> - Xem Trực Tiếp Thể Thao &amp; Giải Trí Số 1 Việt Nam</h1>
  <p class="lead">Nền tảng livestream chất lượng HD miễn phí 24/7. Cập nhật <strong><%= live.length %> trận đang trực tiếp</strong>, <strong><%= upcoming.length %> trận sắp diễn ra</strong> hôm nay <%= _todayVi %>. Phủ sóng đầy đủ
    <a href="/the-thao/bong-da">bóng đá</a>, <a href="/the-thao/bong-ro">bóng rổ</a>, <a href="/the-thao/tennis">tennis</a>, <a href="/esports">esports</a>, <a href="/casino">casino</a> và <a href="/idol-live">idol live</a>. Đối tác chính thức <a href="<%= partner.home %>" target="_blank" rel="noopener"><%= brand.domain %></a>.</p>
</header>

<!-- Hero banner carousel -->
<div class="hero-banner" id="heroBanner" aria-label="Khuyến mãi">
  <% banners.forEach((b, i) => { %>
    <div class="hero-slide" style="background:<%= b.bg %>; <%= i>0?'display:none':'' %>">
      <div class="info">
        <div class="ttl"><%= b.title %></div>
        <div class="desc"><%= b.desc %></div>
        <a href="<%= b.url %>" target="_blank" rel="noopener" class="cta"><%= b.cta %> →</a>
      </div>
    </div>
  <% }); %>
  <div class="hero-dots">
    <% banners.forEach((b, i) => { %><span class="<%= i===0?'active':'' %>" role="button" aria-label="Slide <%= i+1 %>"></span><% }); %>
  </div>
</div>

<% const featured = (live && live[0]) || null;
   const featuredSide = (live || []).slice(1, 3); %>

<% if (featured) { %>
<section class="featured" aria-label="Trận nổi bật">
  <article class="featured-main" itemscope itemtype="https://schema.org/SportsEvent">
    <div class="placeholder">
      <% if (featured.poster) { %><img class="bg" src="<%= featured.poster %>" loading="lazy" alt="" onerror="this.style.display='none'"><% } %>
      <span class="live-pill">LIVE</span>
      <span class="quality-pill">HD 1080p</span>
      <div class="inner">
        <div style="font-size:14px;color:#aaa;margin-bottom:6px;font-weight:700;letter-spacing:1px"><%= featured.league %></div>
        <h2 style="font-size:22px;font-weight:800;color:#fff;margin-bottom:8px" itemprop="name"><span itemprop="homeTeam"><%= featured.home %></span> vs <span itemprop="awayTeam"><%= featured.away %></span></h2>
        <% if (featured.score) { %>
          <div style="font-size:48px;font-weight:900;color:var(--acc);margin:6px 0;text-shadow:0 4px 12px rgba(0,0,0,.6)"><%= featured.score[0] %> : <%= featured.score[1] %></div>
        <% } %>
        <a href="/live/<%= featured.slug || featured.id %>" class="enter-btn" itemprop="url">▶ VÀO PHÒNG</a>
      </div>
    </div>
    <meta itemprop="eventStatus" content="https://schema.org/EventScheduled">
    <meta itemprop="eventAttendanceMode" content="https://schema.org/OnlineEventAttendanceMode">
  </article>

  <div class="featured-side">
    <% featuredSide.forEach(m => { %>
      <a href="/live/<%= m.slug || m.id %>" class="stream-card">
        <div class="stream-thumb">
          <% if (m.poster) { %><img class="bg" src="<%= m.poster %>" loading="lazy" alt=""><% } %>
          <span class="live-pill">LIVE</span>
          <div class="teams">
            <% if (m.homeBadge) { %><div class="team-logo"><img src="<%= m.homeBadge %>" alt="<%= m.home %>"></div><% } %>
            <% if (m.score) { %><div class="score" style="font-size:22px"><%= m.score[0] %>:<%= m.score[1] %></div><% } else { %><div class="vs-time">VS</div><% } %>
            <% if (m.awayBadge) { %><div class="team-logo"><img src="<%= m.awayBadge %>" alt="<%= m.away %>"></div><% } %>
          </div>
        </div>
        <div class="stream-info">
          <div class="league">🏆 <%= m.league %></div>
          <div class="matchname"><%= m.home %> vs <%= m.away %></div>
        </div>
      </a>
    <% }); %>
    <% if (featuredSide.length === 0) { %>
      <a href="<%= partner.idol %>" target="_blank" rel="noopener" class="stream-card">
        <div class="stream-thumb" style="background:linear-gradient(135deg,#8e44ad,#e91e63)">
          <span class="live-pill">LIVE</span>
          <div style="text-align:center;color:#fff;position:relative;z-index:1">
            <div style="font-size:48px">👑</div>
            <div style="font-weight:800;font-size:16px;margin-top:6px">Idol Live</div>
            <div style="font-size:12px;opacity:.9">Hotgirl độc quyền</div>
          </div>
        </div>
        <div class="stream-info"><div class="league" style="color:#e91e63">👑 Idol Show</div><div class="matchname">100+ phòng đang live</div></div>
      </a>
    <% } %>
  </div>
</section>
<% } %>

<!-- Tabs danh mục -->
<nav class="cat-tabs" aria-label="Danh mục thể thao">
  <a href="/" class="cat-tab active"><span class="all-ico">✓</span> Tất cả</a>
  <% Object.entries(cats).forEach(([key, cat]) => {
       const href = key==='casino'?'/casino':key==='idol'?'/idol-live':key==='esports'?'/esports':key==='hot'?'/':'/the-thao/'+key;
  %>
    <a href="<%= href %>" class="cat-tab"><span class="ico"><%= cat.icon %></span> <%= cat.name %></a>
  <% }); %>
  <a href="/lich-phat-song" style="margin-left:auto" class="cat-tab">Xem tất cả <span style="margin-left:4px">↗</span></a>
</nav>

<section class="sec" aria-label="Trận đang trực tiếp">
  <div class="sec-head">
    <h2 class="ttl">Đang trực tiếp <span class="live-badge">LIVE • <%= live.length %></span></h2>
    <a href="/lich-phat-song" class="more">Xem tất cả →</a>
  </div>
  <% if (!live || live.length === 0) { %>
    <div class="empty"><div class="ico">📭</div><div>Hiện không có trận trực tiếp. Xem <a href="/lich-phat-song" style="color:var(--pri-2)">lịch phát sóng</a> hoặc <a href="<%= partner.idol %>" target="_blank" style="color:var(--pink)">vào idol live</a>.</div></div>
  <% } else { %>
    <div class="stream-grid"><%- include('partials/stream-card', { list: live.slice(0,12) }) %></div>
  <% } %>
</section>

<section class="sec" aria-label="Sắp diễn ra">
  <div class="sec-head"><h2 class="ttl">⏰ Sắp diễn ra</h2><a href="/lich-phat-song" class="more">Lịch đầy đủ →</a></div>
  <% if (upcoming.length === 0) { %>
    <div class="empty"><div class="ico">📅</div><div>Chưa có trận sắp diễn ra.</div></div>
  <% } else { %>
    <div class="stream-grid"><%- include('partials/stream-card', { list: upcoming }) %></div>
  <% } %>
</section>

<% if (finished && finished.length) { %>
<section class="sec" aria-label="Highlight">
  <div class="sec-head"><h2 class="ttl">🎬 Highlight mới nhất</h2><a href="/video-noi-bat" class="more">Xem tất cả →</a></div>
  <div class="stream-grid"><%- include('partials/stream-card', { list: finished }) %></div>
</section>
<% } %>

<!-- Related links -->
<section class="seo-related" aria-label="Liên kết liên quan">
  <h3>🔗 Khám phá thêm</h3>
  <ul>
    <li><a href="/the-thao/bong-da">⚽ Bóng đá hôm nay</a></li>
    <li><a href="/the-thao/bong-ro">🏀 Bóng rổ NBA</a></li>
    <li><a href="/the-thao/tennis">🎾 Tennis ATP/WTA</a></li>
    <li><a href="/esports">🎮 Esports LCK/LPL</a></li>
    <li><a href="/casino">🎰 Casino trực tuyến</a></li>
    <li><a href="/idol-live">👑 Idol Live 24/7</a></li>
    <li><a href="/lich-phat-song?mon=bong-da">📅 Lịch bóng đá</a></li>
    <li><a href="/video-noi-bat">🎬 Highlight</a></li>
    <li><a href="/tin-tuc">📰 Tin tức</a></li>
    <li><a href="/su-kien">🎁 Khuyến mãi</a></li>
  </ul>
</section>

