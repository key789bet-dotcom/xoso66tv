<%- include('partials/layout-start', { title:'Quan ly Idol', active:'idol', obsPending: obsPending, adminUser: adminUser }) %>

<nav class="flex gap-2 mb-5 bg-bg-card border border-line rounded-xl p-2">
  <% var tabs = [{k:'',l:'Tat ca',n:counts.all},{k:'active',l:'Active',n:counts.active},{k:'pending',l:'Cho duyet',n:counts.pending,hot:true},{k:'rejected',l:'Tu choi',n:counts.rejected}]; %>
  <% tabs.forEach(function(t){ var ac=statusFilter===t.k; %>
    <a href="/admin/idol<%= t.k?'?status='+t.k:'' %>" class="flex items-center gap-2 px-4 py-2 rounded-lg font-bold text-[13px] transition-colors <%= ac ? 'bg-gradient-to-br from-pink to-purple text-white' : 'text-gray-100 hover:bg-bg-soft' %>">
      <%= t.l %>
      <% if (t.n>0) { %><span class="<%= ac?'bg-white/20':'bg-bg-deep' %> text-[11px] px-2 py-0.5 rounded-full font-extrabold <%= t.hot && !ac ? 'text-pink animate-pulse-live':'text-pri-light' %>"><%= t.n %></span><% } %>
    </a>
  <% }); %>
</nav>

<% if (!list.length) { %>
  <div class="p-16 text-center bg-bg-card border border-dashed border-line rounded-xl text-muted">
    <div class="text-5xl mb-3 opacity-60">&#128081;</div>
    <div>Khong co idol nao trong nhom nay</div>
  </div>
<% } else { %>
<div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
  <% list.forEach(function(i){ %>
    <article class="bg-bg-card border border-line rounded-xl overflow-hidden <%= i.status==='pending' ? 'border-pink/40 ring-2 ring-pink/10' : '' %>">
      <div class="relative aspect-square bg-gradient-to-br from-purple to-pink">
        <img src="<%= i.avatar %>" alt="<%= i.name %>" class="absolute inset-0 w-full h-full object-cover opacity-80">
        <% if (i.liveNow) { %>
          <span class="absolute top-2 left-2 bg-live text-white px-2 py-0.5 rounded text-[11px] font-extrabold flex items-center gap-1"><span class="w-1.5 h-1.5 bg-white rounded-full animate-pulse-live"></span>LIVE</span>
        <% } %>
        <% if (i.status==='pending') { %>
          <span class="absolute top-2 right-2 bg-pri text-white px-2 py-0.5 rounded text-[11px] font-extrabold animate-pulse-live">Cho duyet</span>
        <% } else if (i.status==='rejected') { %>
          <span class="absolute top-2 right-2 bg-live text-white px-2 py-0.5 rounded text-[11px] font-extrabold">Tu choi</span>
        <% } %>
        <% if (i.viewers>0) { %>
          <span class="absolute bottom-2 right-2 bg-black/70 text-gold px-2 py-0.5 rounded text-[11px] font-bold">&#128065; <%= i.viewers.toLocaleString('vi-VN') %></span>
        <% } %>
      </div>
      <div class="p-3">
        <div class="flex items-start justify-between mb-1">
          <h3 class="font-extrabold text-white text-sm"><%= i.name %></h3>
          <span class="text-[10px] text-muted"><%= i.age %> tuoi</span>
        </div>
        <div class="text-[10px] text-dim mb-2">ID: <code class="text-pri-light"><%= i.id %></code> &middot; <%= i.totalStreams %> streams</div>
        <% if (i.note) { %><div class="text-xs bg-bg-soft border border-line px-2 py-1.5 rounded text-muted mb-2 line-clamp-2">&#128221; <%= i.note %></div><% } %>

        <!-- LIVE PERMISSION TOGGLE -->
        <div class="mb-2 flex items-center justify-between bg-bg-soft border border-line rounded px-2 py-1.5">
          <span class="text-[11px] font-bold flex items-center gap-1">
            <span>📡</span>
            <span class="<%= i.canLive ? 'text-emerald-400' : 'text-muted' %>">Quyen Live: <%= i.canLive ? 'CHO PHEP ✅' : 'CHUA CAP ❌' %></span>
          </span>
          <button onclick="adminAction('/admin/api/idol/<%= i.id %>/toggle-live', {}, function(r){ if(r.ok) location.reload(); })" class="<%= i.canLive ? 'bg-live hover:bg-red-700' : 'bg-emerald-600 hover:bg-emerald-700' %> text-white px-2 py-1 rounded text-[10px] font-extrabold transition-colors">
            <%= i.canLive ? '🚫 THU HOI' : '✅ CAP QUYEN' %>
          </button>
        </div>

        <!-- CATEGORY SELECT (chuyên mục live) -->
        <div class="mb-2 flex items-center gap-2 bg-bg-soft border border-line rounded px-2 py-1.5">
          <span class="text-[11px] font-bold text-white shrink-0">🎯 Chuyên mục:</span>
          <select onchange="adminAction('/admin/api/idol/<%= i.id %>/set-category', { category: this.value }, function(r){ if(r.ok){ showToast(r.message,'success'); } })" class="flex-1 bg-bg-deep border border-line text-white text-[11px] font-bold rounded px-1.5 py-1 outline-none focus:border-pri">
            <option value="idol"   <%= (i.category||'idol')==='idol'   ? 'selected' : '' %>>👑 Idol Show (mặc định)</option>
            <option value="bongda" <%= i.category==='bongda' ? 'selected' : '' %>>⚽ BLV Bóng Đá</option>
            <option value="casino" <%= i.category==='casino' ? 'selected' : '' %>>🎰 Live Sòng Bài</option>
            <option value="esport" <%= i.category==='esport' ? 'selected' : '' %>>🎮 BLV Esports</option>
          </select>
        </div>

        <div class="flex flex-wrap gap-1.5">
          <% if (i.status==='pending') { %>
            <button onclick="confirmAction('Duyet idol <%= i.name %>?', function(){ adminAction('/admin/api/idol/<%= i.id %>/approve') })" class="flex-1 px-2 py-1.5 bg-emerald-600 hover:bg-emerald-700 text-white rounded text-[11px] font-bold">&check; Duyet</button>
            <button onclick="var r=prompt('Ly do tu choi?'); if(r) adminAction('/admin/api/idol/<%= i.id %>/reject', { reason: r })" class="flex-1 px-2 py-1.5 bg-live hover:bg-red-700 text-white rounded text-[11px] font-bold">&times;</button>
          <% } else if (i.status==='active') { %>
            <button onclick="confirmAction('Tam khoa idol <%= i.name %>?', function(){ adminAction('/admin/api/idol/<%= i.id %>/reject', { reason:'Khoa boi admin' }) })" class="flex-1 px-2 py-1.5 bg-live/15 hover:bg-live text-live hover:text-white rounded text-[11px] font-bold">Khoa</button>
          <% } else { %>
            <button onclick="confirmAction('Phuc hoi idol <%= i.name %>?', function(){ adminAction('/admin/api/idol/<%= i.id %>/approve') })" class="flex-1 px-2 py-1.5 bg-emerald-600/15 hover:bg-emerald-600 text-emerald-400 hover:text-white rounded text-[11px] font-bold">Phuc hoi</button>
          <% } %>
          <button onclick="confirmAction('Xoa idol <%= i.name %>?', function(){ adminAction('/admin/api/idol/<%= i.id %>/delete') })" class="px-2 py-1.5 bg-bg-deep hover:bg-live text-muted hover:text-white rounded text-[11px] font-bold">&#128465;</button>
        </div>
      </div>
    </article>
  <% }); %>
</div>
<% } %>

<%- include('partials/layout-end') %>
