<%- include('partials/layout-start', { title:'Duyệt lịch live', active:'schedules', obsPending: 0, adminUser: typeof adminUser !== 'undefined' ? adminUser : {} }) %>

<div class="bg-bg-card border border-line rounded-xl p-5 mb-5">
  <div class="flex items-start gap-3">
    <div class="text-3xl">📅</div>
    <div class="flex-1">
      <h2 class="text-base font-extrabold text-white">Duyệt lịch live Idol & BLV</h2>
      <p class="text-muted text-xs mt-1">Idol/BLV đăng ký lịch live → admin duyệt → mới được push OBS. Lịch theo giờ tự do hoặc gắn với trận đấu.</p>
    </div>
  </div>
</div>

<!-- Tabs filter -->
<nav class="flex gap-2 mb-5 bg-bg-card border border-line rounded-xl p-2 overflow-x-auto" id="schTabs">
  <button data-status="pending" class="sch-tab is-active flex items-center gap-2 px-4 py-2 rounded-lg font-bold text-[13px] whitespace-nowrap">
    Chờ duyệt <span class="sch-count bg-bg-deep text-pri-light text-[11px] px-2 py-0.5 rounded-full font-extrabold" data-key="pending">0</span>
  </button>
  <button data-status="approved" class="sch-tab flex items-center gap-2 px-4 py-2 rounded-lg font-bold text-[13px] whitespace-nowrap">
    Đã duyệt <span class="sch-count bg-bg-deep text-emerald-400 text-[11px] px-2 py-0.5 rounded-full font-extrabold" data-key="approved">0</span>
  </button>
  <button data-status="rejected" class="sch-tab flex items-center gap-2 px-4 py-2 rounded-lg font-bold text-[13px] whitespace-nowrap">
    Từ chối <span class="sch-count bg-bg-deep text-red-400 text-[11px] px-2 py-0.5 rounded-full font-extrabold" data-key="rejected">0</span>
  </button>
  <button data-status="" class="sch-tab flex items-center gap-2 px-4 py-2 rounded-lg font-bold text-[13px] whitespace-nowrap">
    Tất cả <span class="sch-count bg-bg-deep text-gray-300 text-[11px] px-2 py-0.5 rounded-full font-extrabold" data-key="total">0</span>
  </button>
</nav>

<!-- List -->
<div id="schList" class="space-y-3">
  <div class="p-8 text-center text-muted bg-bg-card border border-line rounded-xl">Đang tải...</div>
</div>

<style>
.sch-tab { background:transparent; color:#cbd5e1; border:none; cursor:pointer; }
.sch-tab.is-active { background:linear-gradient(135deg,#f97316,#ef4444); color:#fff; }
.sch-tab.is-active .sch-count { background:rgba(255,255,255,.2); color:#fff !important; }
</style>

<script>
(function(){
  var currentStatus = 'pending';

  function $(id){ return document.getElementById(id); }

  function fmtTime(ts){
    if (!ts) return '-';
    var d = new Date(ts);
    return d.getDate()+'/'+(d.getMonth()+1)+' '+String(d.getHours()).padStart(2,'0')+':'+String(d.getMinutes()).padStart(2,'0');
  }
  function fmtDateFull(ts){
    return ts ? new Date(ts).toLocaleString('vi-VN') : '-';
  }
  function statusBadge(s){
    if (s === 'pending')  return '<span class="bg-yellow-500/20 text-yellow-300 text-[10px] font-extrabold px-2 py-0.5 rounded">CHỜ DUYỆT</span>';
    if (s === 'approved') return '<span class="bg-emerald-500/20 text-emerald-300 text-[10px] font-extrabold px-2 py-0.5 rounded">✅ ĐÃ DUYỆT</span>';
    if (s === 'rejected') return '<span class="bg-red-500/20 text-red-300 text-[10px] font-extrabold px-2 py-0.5 rounded">❌ TỪ CHỐI</span>';
    return s;
  }

  function fetchList(){
    var url = '/api/admin/schedules/list' + (currentStatus ? '?status='+currentStatus : '');
    fetch(url, { credentials:'same-origin' })
      .then(function(r){ return r.json(); })
      .then(function(data){
        if (!data.ok) { $('schList').innerHTML = '<div class="p-8 text-center text-red-400">Lỗi: ' + (data.error||'') + '</div>'; return; }
        // Update counts
        var s = data.stats || {};
        document.querySelectorAll('.sch-count').forEach(function(el){
          var k = el.getAttribute('data-key');
          el.textContent = s[k] || 0;
        });
        // Render list
        var list = data.list || [];
        if (list.length === 0) {
          $('schList').innerHTML = '<div class="p-8 text-center text-muted bg-bg-card border border-line rounded-xl"><div class="text-4xl mb-2 opacity-60">📭</div>Không có lịch nào trong mục này.</div>';
          return;
        }
        $('schList').innerHTML = list.map(renderCard).join('');
      })
      .catch(function(e){ $('schList').innerHTML = '<div class="p-8 text-center text-red-400">Lỗi kết nối</div>'; });
  }

  function renderCard(s){
    var typeIcon = s.type === 'match' ? '⚽' : '⏰';
    var typeText = s.type === 'match' ? 'Theo trận' : 'Theo giờ tự do';
    var userTypeBadge = s.userType === 'blv'
      ? '<span class="bg-blue-500/20 text-blue-300 text-[9px] font-bold px-1.5 py-0.5 rounded">BLV</span>'
      : '<span class="bg-pink-500/20 text-pink-300 text-[9px] font-bold px-1.5 py-0.5 rounded">IDOL</span>';
    var actions = '';
    if (s.status === 'pending') {
      actions = ''
        + '<button onclick="schApprove(\'' + s.id + '\')" class="bg-emerald-600 hover:bg-emerald-700 text-white px-4 py-1.5 rounded text-xs font-bold">✅ Duyệt</button>'
        + '<button onclick="schReject(\'' + s.id + '\')" class="bg-red-600 hover:bg-red-700 text-white px-4 py-1.5 rounded text-xs font-bold">❌ Từ chối</button>';
    }
    var reviewInfo = '';
    if (s.reviewedAt) {
      reviewInfo = '<div class="text-[10px] text-muted mt-1">Reviewed: ' + fmtDateFull(s.reviewedAt) + ' by ' + (s.reviewedBy||'admin') + '</div>';
    }
    var rejectInfo = s.rejectReason ? '<div class="text-[11px] text-red-400 mt-1.5"><b>Lý do:</b> ' + escapeHtml(s.rejectReason) + '</div>' : '';
    var matchInfo = s.matchTitle ? '<div class="text-[11px] text-pri-light mt-1">⚽ ' + escapeHtml(s.matchTitle) + '</div>' : '';
    var descInfo = s.description ? '<div class="text-[11px] text-gray-300 mt-1">📝 ' + escapeHtml(s.description) + '</div>' : '';

    return ''
      + '<div class="bg-bg-card border border-line rounded-xl p-4">'
      +   '<div class="flex items-start gap-3 mb-2">'
      +     '<div class="text-2xl">' + typeIcon + '</div>'
      +     '<div class="flex-1 min-w-0">'
      +       '<div class="flex items-center gap-2 mb-1">'
      +         '<span class="font-extrabold text-white text-sm truncate">' + escapeHtml(s.title) + '</span>'
      +         statusBadge(s.status)
      +       '</div>'
      +       '<div class="flex items-center gap-2 text-[11px] text-muted">'
      +         '<span><b class="text-pri-light">@' + escapeHtml(s.username) + '</b></span>'
      +         userTypeBadge
      +         '<span>• ' + typeText + '</span>'
      +       '</div>'
      +       '<div class="text-[12px] text-gray-200 mt-1.5">⏰ <b>' + fmtTime(s.startTime) + '</b> → ' + fmtTime(s.endTime) + '</div>'
      +       matchInfo
      +       descInfo
      +       reviewInfo
      +       rejectInfo
      +     '</div>'
      +     '<div class="flex flex-col gap-1.5">' + actions + '</div>'
      +   '</div>'
      + '</div>';
  }

  function escapeHtml(s){
    return String(s||'').replace(/[<>&"]/g, function(c){return ({'<':'&lt;','>':'&gt;','&':'&amp;','"':'&quot;'})[c];});
  }

  window.schApprove = function(id){
    if (!confirm('Duyệt lịch này?')) return;
    fetch('/api/admin/schedules/' + id + '/approve', { method:'POST', credentials:'same-origin' })
      .then(function(r){ return r.json(); })
      .then(function(data){
        if (data.ok) { alert('✅ Đã duyệt'); fetchList(); }
        else alert('Lỗi: ' + (data.error||''));
      });
  };

  window.schReject = function(id){
    var reason = prompt('Lý do từ chối (gửi cho idol/BLV):');
    if (!reason || !reason.trim()) return;
    fetch('/api/admin/schedules/' + id + '/reject', {
      method:'POST', credentials:'same-origin',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ reason: reason.trim() })
    })
      .then(function(r){ return r.json(); })
      .then(function(data){
        if (data.ok) { alert('❌ Đã từ chối'); fetchList(); }
        else alert('Lỗi: ' + (data.error||''));
      });
  };

  // Tab clicks
  document.querySelectorAll('.sch-tab').forEach(function(b){
    b.addEventListener('click', function(){
      document.querySelectorAll('.sch-tab').forEach(function(x){ x.classList.remove('is-active'); });
      b.classList.add('is-active');
      currentStatus = b.getAttribute('data-status');
      fetchList();
    });
  });

  // Initial load + auto refresh mỗi 30s
  fetchList();
  setInterval(fetchList, 30000);
})();
</script>

<%- include('partials/layout-end') %>
