<%- include('partials/layout-start', { title:'Quản lý Dự đoán', active:'predictions', obsPending: obsPending, adminUser: adminUser }) %>

<!-- Stats row -->
<div class="grid grid-cols-2 md:grid-cols-5 gap-3 mb-5">
  <div class="bg-bg-card border border-line rounded-lg p-3 text-center">
    <div class="text-2xl mb-1">📊</div>
    <div class="text-2xl font-black text-pri-light"><%= (stats.total||0).toLocaleString('vi-VN') %></div>
    <div class="text-[10px] text-muted uppercase">Tổng dự đoán</div>
  </div>
  <div class="bg-bg-card border border-line rounded-lg p-3 text-center">
    <div class="text-2xl mb-1">⏳</div>
    <div class="text-2xl font-black text-yellow-400"><%= (stats.pending||0).toLocaleString('vi-VN') %></div>
    <div class="text-[10px] text-muted uppercase">Chờ settle</div>
  </div>
  <div class="bg-bg-card border border-line rounded-lg p-3 text-center">
    <div class="text-2xl mb-1">✅</div>
    <div class="text-2xl font-black text-emerald-400"><%= (stats.settled||0).toLocaleString('vi-VN') %></div>
    <div class="text-[10px] text-muted uppercase">Đã settle</div>
  </div>
  <div class="bg-bg-card border border-line rounded-lg p-3 text-center">
    <div class="text-2xl mb-1">🎯</div>
    <div class="text-2xl font-black text-yellow-300"><%= (stats.exactPredictions||0).toLocaleString('vi-VN') %></div>
    <div class="text-[10px] text-muted uppercase">Đúng chính xác</div>
  </div>
  <div class="bg-bg-card border border-line rounded-lg p-3 text-center">
    <div class="text-2xl mb-1">💰</div>
    <div class="text-2xl font-black text-pink-400"><%= (stats.totalRewarded||0).toLocaleString('vi-VN') %></div>
    <div class="text-[10px] text-muted uppercase">X COIN đã trao</div>
  </div>
</div>

<!-- Tab pending / settled -->
<nav class="flex gap-2 mb-5 bg-bg-card border border-line rounded-xl p-2">
  <a href="/admin/predictions?status=pending" class="flex items-center gap-2 px-4 py-2 rounded-lg font-bold text-[13px] transition-colors <%= statusFilter==='pending' ? 'bg-gradient-to-br from-yellow-500 to-orange-600 text-white' : 'text-gray-100 hover:bg-bg-soft' %>">
    ⏳ Chờ Settle <span class="<%= statusFilter==='pending'?'bg-white/20':'bg-bg-deep' %> text-[11px] px-2 py-0.5 rounded-full font-extrabold"><%= matches.pending.length %></span>
  </a>
  <a href="/admin/predictions?status=settled" class="flex items-center gap-2 px-4 py-2 rounded-lg font-bold text-[13px] transition-colors <%= statusFilter==='settled' ? 'bg-gradient-to-br from-emerald-500 to-emerald-700 text-white' : 'text-gray-100 hover:bg-bg-soft' %>">
    ✅ Đã Settle <span class="<%= statusFilter==='settled'?'bg-white/20':'bg-bg-deep' %> text-[11px] px-2 py-0.5 rounded-full font-extrabold"><%= matches.settled.length %></span>
  </a>
</nav>

<% var list = statusFilter==='settled' ? matches.settled : matches.pending; %>

<% if (!list.length) { %>
  <div class="p-16 text-center bg-bg-card border border-dashed border-line rounded-xl text-muted">
    <div class="text-5xl mb-3 opacity-60">🎯</div>
    <div>Không có dự đoán nào trong nhóm này</div>
  </div>
<% } else { %>
<div class="grid lg:grid-cols-2 gap-4">
  <% list.forEach(function(m){
    var settled = !!m.result;
    var totalReward = m.predictions.reduce(function(s,p){ return s + (p.reward||0); }, 0);
    var exactCount = m.predictions.filter(function(p){ return p.points >= 100; }).length;
  %>
    <article class="bg-bg-card border border-line rounded-xl p-4 <%= settled ? 'border-emerald-500/40' : 'border-yellow-500/40' %>">
      <!-- Match info -->
      <div class="flex items-start justify-between gap-3 mb-3 pb-3 border-b border-line">
        <div class="flex-1 min-w-0">
          <h3 class="font-extrabold text-white text-base mb-1 truncate"><%= m.home %> vs <%= m.away %></h3>
          <div class="text-xs text-muted">🏆 <%= m.league %> · 🆔 <code class="text-pri-light"><%= m.matchId %></code></div>
        </div>
        <% if (settled) { %>
          <span class="px-2.5 py-1 bg-emerald-500/15 text-emerald-400 rounded text-[11px] font-bold whitespace-nowrap">✅ <%= m.result.home %>-<%= m.result.away %></span>
        <% } else { %>
          <span class="px-2.5 py-1 bg-yellow-500/15 text-yellow-400 rounded text-[11px] font-bold whitespace-nowrap">⏳ Chờ kết quả</span>
        <% } %>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-3 gap-2 mb-3 text-center text-xs">
        <div class="bg-bg-soft px-2 py-1.5 rounded">
          <div class="text-muted text-[10px]">USERS</div>
          <div class="font-extrabold text-white"><%= m.predictions.length %></div>
        </div>
        <% if (settled) { %>
        <div class="bg-bg-soft px-2 py-1.5 rounded">
          <div class="text-muted text-[10px]">ĐÚNG CHÍNH XÁC</div>
          <div class="font-extrabold text-yellow-300"><%= exactCount %></div>
        </div>
        <div class="bg-bg-soft px-2 py-1.5 rounded">
          <div class="text-muted text-[10px]">X COIN TRAO</div>
          <div class="font-extrabold text-pink-300"><%= totalReward.toLocaleString('vi-VN') %></div>
        </div>
        <% } else { %>
        <div class="bg-bg-soft px-2 py-1.5 rounded col-span-2">
          <div class="text-muted text-[10px]">TỈ SỐ DỰ ĐOÁN PHỔ BIẾN NHẤT</div>
          <%
            var counts = {};
            m.predictions.forEach(function(p){ var k = p.homeScore+'-'+p.awayScore; counts[k]=(counts[k]||0)+1; });
            var top = Object.entries(counts).sort(function(a,b){return b[1]-a[1];}).slice(0,3);
          %>
          <div class="font-extrabold text-white text-[13px]">
            <% top.forEach(function(t,i){ %>
              <span class="<%= i===0?'text-yellow-300':'text-gray-300' %>"><%= t[0] %> (<%= t[1] %>)</span><%= i<top.length-1 ? ' · ' : '' %>
            <% }); %>
          </div>
        </div>
        <% } %>
      </div>

      <% if (!settled) { %>
      <!-- Settle form -->
      <form onsubmit="event.preventDefault(); settleMatch('<%= m.matchId %>', this);" class="flex items-center gap-2">
        <span class="text-[12px] text-muted">Tỉ số thật:</span>
        <input type="number" name="actualHome" min="0" max="20" required class="w-14 bg-bg-deep border border-line text-white text-center font-bold rounded-lg py-1.5 px-2 focus:border-pri outline-none">
        <span class="text-white font-black">-</span>
        <input type="number" name="actualAway" min="0" max="20" required class="w-14 bg-bg-deep border border-line text-white text-center font-bold rounded-lg py-1.5 px-2 focus:border-pri outline-none">
        <button type="submit" class="ml-auto px-4 py-1.5 bg-gradient-to-r from-emerald-500 to-emerald-700 text-white font-extrabold text-xs rounded-lg hover:brightness-110">⚡ SETTLE</button>
      </form>
      <% } else { %>
      <!-- List winners -->
      <details class="text-[12px]">
        <summary class="cursor-pointer text-pri-light font-bold hover:underline">👥 Xem danh sách dự đoán (<%= m.predictions.length %>)</summary>
        <div class="mt-2 max-h-64 overflow-y-auto bg-bg-deep rounded p-2">
          <% m.predictions.sort(function(a,b){return b.points-a.points;}).forEach(function(p){ %>
            <div class="flex items-center gap-2 py-1 border-b border-line/30 last:border-0">
              <span class="font-bold text-white flex-1 truncate"><%= p.username %></span>
              <span class="text-muted"><%= p.homeScore %>-<%= p.awayScore %></span>
              <% if (p.points >= 100) { %><span class="text-yellow-300 font-bold">🎯 +<%= p.reward %></span>
              <% } else if (p.points >= 30) { %><span class="text-emerald-400 font-bold">✅ +<%= p.reward %></span>
              <% } else if (p.points >= 10) { %><span class="text-blue-400">✓ +<%= p.reward %></span>
              <% } else { %><span class="text-muted">—</span><% } %>
            </div>
          <% }); %>
        </div>
      </details>
      <% } %>
    </article>
  <% }); %>
</div>
<% } %>

<script>
function settleMatch(matchId, form) {
  var actualHome = parseInt(form.actualHome.value, 10);
  var actualAway = parseInt(form.actualAway.value, 10);
  if (!confirm('Settle trận với tỉ số ' + actualHome + '-' + actualAway + '?\nSẽ tự động tính điểm + trao X COIN cho tất cả user dự đoán.')) return;
  fetch('/api/admin/predict/settle', {
    method:'POST',
    headers:{'Content-Type':'application/json'},
    credentials:'same-origin',
    body: JSON.stringify({ matchId: matchId, actualHome: actualHome, actualAway: actualAway })
  }).then(function(r){ return r.json(); }).then(function(j){
    if (j.ok) {
      alert('✅ Đã settle ' + j.result.predictionsSettled + ' dự đoán, trao ' + j.result.totalRewarded + ' X COIN');
      location.reload();
    } else {
      alert('❌ ' + (j.error || 'Lỗi'));
    }
  }).catch(function(){ alert('❌ Lỗi kết nối'); });
}
</script>

<%- include('partials/layout-end') %>
