<%- include('partials/layout-start', { title:'Quản lý Banner Hero', active:'banners', obsPending:obsPending, adminUser:adminUser }) %>

<!-- Guideline card -->
<section class="bg-gradient-to-br from-pri/15 to-pri-dark/5 border-2 border-pri/40 rounded-xl p-5 mb-5">
  <h2 class="text-pri-light font-extrabold text-base mb-3 flex items-center gap-2">📐 Hướng dẫn kích thước ảnh chuẩn</h2>
  <div class="grid sm:grid-cols-2 md:grid-cols-4 gap-3 text-sm">
    <div class="bg-bg-soft border border-line rounded-lg p-3">
      <div class="text-[11px] text-muted uppercase tracking-wide font-bold mb-1">Khuyến nghị</div>
      <div class="text-white font-extrabold text-lg">1400 × 140 px</div>
      <div class="text-[11px] text-pri-light mt-1">Tỉ lệ 10:1 (rất rộng)</div>
    </div>
    <div class="bg-bg-soft border border-line rounded-lg p-3">
      <div class="text-[11px] text-muted uppercase tracking-wide font-bold mb-1">Tối thiểu</div>
      <div class="text-white font-extrabold text-lg">1000 × 100 px</div>
      <div class="text-[11px] text-muted mt-1">Để sắc nét trên màn HD</div>
    </div>
    <div class="bg-bg-soft border border-line rounded-lg p-3">
      <div class="text-[11px] text-muted uppercase tracking-wide font-bold mb-1">Định dạng</div>
      <div class="text-white font-extrabold text-base">JPG · PNG · WEBP</div>
      <div class="text-[11px] text-emerald-400 mt-1">WEBP tối ưu nhất</div>
    </div>
    <div class="bg-bg-soft border border-line rounded-lg p-3">
      <div class="text-[11px] text-muted uppercase tracking-wide font-bold mb-1">Dung lượng</div>
      <div class="text-white font-extrabold text-lg">&le; 500 KB</div>
      <div class="text-[11px] text-muted mt-1">Tối đa 2 MB</div>
    </div>
  </div>
  <ul class="mt-4 space-y-1 text-[12.5px] text-gray-200">
    <li>✅ <strong>Nên</strong>: ảnh tỉ lệ <strong class="text-pri-light">10:1</strong> (rộng × cao), VD: 1400×140, 2000×200, 1500×150. Cao gấp 10 lần chiều rộng.</li>
    <li>✅ <strong>Nên</strong>: vùng quan trọng (nhân vật, logo, text chính) nên nằm <strong>chính giữa</strong> hoặc <strong>bên trái</strong> vì bên phải sẽ có nút "Nhận ngay"</li>
    <li>❌ <strong>Tránh</strong>: ảnh có chữ to chiếm trên 30% diện tích (text sẽ trùng với title)</li>
    <li>❌ <strong>Tránh</strong>: ảnh tỉ lệ vuông hoặc dọc (sẽ bị cắt méo)</li>
  </ul>
</section>

<!-- Add new banner form -->
<details class="bg-bg-card border border-line rounded-xl mb-5 group">
  <summary class="px-5 py-3 cursor-pointer font-extrabold text-white flex items-center gap-2 select-none list-none hover:bg-bg-soft">
    <span class="w-6 h-6 bg-pri rounded-full grid place-items-center font-black group-open:bg-live transition-colors">+</span>
    Thêm banner mới
  </summary>
  <form action="/admin/banners" method="POST" enctype="multipart/form-data" class="p-5 border-t border-line space-y-3">
    <div class="grid md:grid-cols-2 gap-3">
      <label class="block">
        <span class="block text-xs font-bold text-muted mb-1.5 uppercase tracking-wide">Tiêu đề *</span>
        <input name="title" required maxlength="80" class="w-full bg-bg-deep border border-line text-white px-3 py-2.5 rounded-lg outline-none focus:border-pri" placeholder="VD: VÉ CƯỢC THUA THỂ THAO ĐẦU TIÊN - HOÀN 100%">
      </label>
      <label class="block">
        <span class="block text-xs font-bold text-muted mb-1.5 uppercase tracking-wide">CTA Button text *</span>
        <input name="cta" required maxlength="20" value="Nhận ngay" class="w-full bg-bg-deep border border-line text-white px-3 py-2.5 rounded-lg outline-none focus:border-pri">
      </label>
      <label class="block md:col-span-2">
        <span class="block text-xs font-bold text-muted mb-1.5 uppercase tracking-wide">Mô tả</span>
        <input name="desc" maxlength="200" class="w-full bg-bg-deep border border-line text-white px-3 py-2.5 rounded-lg outline-none focus:border-pri" placeholder="Hoàn 100% tối đa 5.000.000đ cho vé cược thua đầu tiên">
      </label>
      <label class="block md:col-span-2">
        <span class="block text-xs font-bold text-muted mb-1.5 uppercase tracking-wide">Link URL khi click *</span>
        <input name="url" required type="url" class="w-full bg-bg-deep border border-line text-white px-3 py-2.5 rounded-lg outline-none focus:border-pri" placeholder="https://xoso66tv.com/promo/...?ref=live">
      </label>
      <label class="block">
        <span class="block text-xs font-bold text-muted mb-1.5 uppercase tracking-wide">📷 Upload ảnh nền (1400×140)</span>
        <input name="image" type="file" accept="image/jpeg,image/png,image/webp" class="w-full bg-bg-deep border border-line text-white px-3 py-2 rounded-lg outline-none file:mr-3 file:py-1.5 file:px-3 file:rounded file:border-0 file:bg-pri file:text-white file:font-bold file:cursor-pointer">
        <div class="text-[11px] text-muted mt-1">Nếu không upload → dùng gradient màu mặc định</div>
      </label>
      <label class="block">
        <span class="block text-xs font-bold text-muted mb-1.5 uppercase tracking-wide">Hoặc gradient CSS (fallback)</span>
        <input name="bg" maxlength="200" value="linear-gradient(90deg,#c0392b,#e67e22,#f1c40f)" class="w-full bg-bg-deep border border-line text-white px-3 py-2.5 rounded-lg outline-none focus:border-pri text-xs font-mono">
      </label>
      <label class="flex items-center gap-2 md:col-span-2">
        <input name="active" type="checkbox" checked class="accent-pri w-4 h-4">
        <span class="text-sm">Kích hoạt banner ngay (hiển thị trên trang chủ)</span>
      </label>
    </div>
    <button type="submit" class="px-6 py-2.5 bg-gradient-to-br from-pri to-pri-dark hover:brightness-110 text-white rounded-lg font-extrabold shadow-pri">💾 Lưu banner</button>
  </form>
</details>

<!-- List existing banners -->
<section class="bg-bg-card border border-line rounded-xl overflow-hidden">
  <header class="px-5 py-3 border-b border-line flex items-center gap-2">
    <h2 class="text-white font-extrabold text-base">📋 Danh sách Banner (<%= banners.length %>)</h2>
    <span class="ml-auto text-xs text-muted">Hiển thị trên trang chủ theo thứ tự dưới đây</span>
  </header>

  <% if (!banners.length) { %>
    <div class="p-12 text-center text-muted"><div class="text-5xl mb-2 opacity-50">📷</div>Chưa có banner nào. Thêm banner đầu tiên ở trên!</div>
  <% } %>

  <div class="divide-y divide-line/40">
    <% banners.forEach(function(b, i){ %>
      <div class="p-4 flex flex-col md:flex-row gap-4">
        <!-- Preview -->
        <div class="md:w-[280px] shrink-0">
          <div class="aspect-[10/1] rounded-lg overflow-hidden relative" style="background:<%= b.bg || 'linear-gradient(90deg,#c0392b,#e67e22,#f1c40f)' %>;<% if (b.image) { %>background-image:url(<%= b.image %>);background-size:cover;background-position:center;<% } %>">
            <% if (b.image) { %><img src="<%= b.image %>" alt="" class="absolute inset-0 w-full h-full object-cover" onerror="this.style.display='none'"><% } %>
            <div class="absolute inset-0 bg-gradient-to-r from-black/40 to-transparent grid place-items-center text-white text-center p-3">
              <div>
                <div class="text-[11px] font-extrabold drop-shadow leading-tight"><%= b.title %></div>
                <div class="text-[9px] opacity-90 mt-0.5"><%= b.cta %> &rarr;</div>
              </div>
            </div>
            <% if (!b.active) { %>
              <div class="absolute inset-0 bg-black/70 grid place-items-center text-white font-bold text-xs">ĐÃ TẮT</div>
            <% } %>
          </div>
          <div class="text-[10px] text-muted text-center mt-1">Banner #<%= i+1 %> · <%= b.active?'<span class="text-emerald-400">▶ Đang hiển thị</span>':'<span class="text-muted">⏸ Đã tắt</span>' %></div>
        </div>

        <!-- Edit form -->
        <form action="/admin/banners/<%= b.id %>" method="POST" enctype="multipart/form-data" class="flex-1 grid md:grid-cols-2 gap-2 text-sm">
          <input name="_method" type="hidden" value="PATCH">
          <label class="md:col-span-2">
            <span class="block text-[10px] font-bold text-muted uppercase mb-1">Tiêu đề</span>
            <input name="title" value="<%= b.title %>" maxlength="80" class="w-full bg-bg-deep border border-line text-white px-2.5 py-2 rounded outline-none focus:border-pri text-xs">
          </label>
          <label>
            <span class="block text-[10px] font-bold text-muted uppercase mb-1">Mô tả</span>
            <input name="desc" value="<%= b.desc || '' %>" maxlength="200" class="w-full bg-bg-deep border border-line text-white px-2.5 py-2 rounded outline-none focus:border-pri text-xs">
          </label>
          <label>
            <span class="block text-[10px] font-bold text-muted uppercase mb-1">CTA</span>
            <input name="cta" value="<%= b.cta %>" maxlength="20" class="w-full bg-bg-deep border border-line text-white px-2.5 py-2 rounded outline-none focus:border-pri text-xs">
          </label>
          <label class="md:col-span-2">
            <span class="block text-[10px] font-bold text-muted uppercase mb-1">URL</span>
            <input name="url" value="<%= b.url %>" type="url" class="w-full bg-bg-deep border border-line text-white px-2.5 py-2 rounded outline-none focus:border-pri text-xs font-mono">
          </label>
          <label>
            <span class="block text-[10px] font-bold text-muted uppercase mb-1">📷 Thay ảnh nền (1400×140)</span>
            <input name="image" type="file" accept="image/*" class="w-full bg-bg-deep border border-line text-white px-2 py-1.5 rounded outline-none text-[11px] file:mr-2 file:py-1 file:px-2 file:rounded file:border-0 file:bg-pri file:text-white file:font-bold file:text-[10px] file:cursor-pointer">
          </label>
          <label>
            <span class="block text-[10px] font-bold text-muted uppercase mb-1">Gradient fallback</span>
            <input name="bg" value="<%= b.bg %>" class="w-full bg-bg-deep border border-line text-white px-2.5 py-2 rounded outline-none focus:border-pri text-[11px] font-mono">
          </label>
          <div class="md:col-span-2 flex items-center justify-between gap-2 pt-1 flex-wrap">
            <label class="flex items-center gap-2 text-xs">
              <input name="active" type="checkbox" <%= b.active?'checked':'' %> class="accent-pri w-4 h-4">
              <span>Đang hiển thị trên trang chủ</span>
            </label>
            <div class="flex gap-1.5">
              <button type="submit" class="px-3 py-1.5 bg-emerald-600 hover:bg-emerald-700 text-white rounded font-bold text-xs">💾 Cập nhật</button>
              <button type="button" onclick="if(confirm('Xóa banner này?')) location.href='/admin/banners/<%= b.id %>/delete'" class="px-3 py-1.5 bg-live/20 hover:bg-live text-live hover:text-white rounded font-bold text-xs">🗑 Xóa</button>
            </div>
          </div>
        </form>
      </div>
    <% }); %>
  </div>
</section>

<%- include('partials/layout-end') %>
