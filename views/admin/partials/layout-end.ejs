    </div>
  </main>
</div>
<div id="toast" class="fixed bottom-5 right-5 bg-bg-card border border-line border-l-4 border-l-pri px-4 py-3 rounded-lg text-white text-[13px] font-semibold z-[100] shadow-2xl translate-x-[120%] transition-transform"></div>
<script>
/* 🛡️ CSRF auto-inject cho TẤT CẢ fetch + HTML form trong admin */
(function(){
  function getCsrfToken(){
    var m = document.querySelector('meta[name="csrf-token"]');
    return m ? m.getAttribute('content') : '';
  }
  window.__csrf = getCsrfToken;

  /* === 1. Wrap fetch — auto X-CSRF-Token header === */
  var _origFetch = window.fetch;
  if (_origFetch) {
    window.fetch = function(input, init){
      try {
        var url = (input && input.url) ? input.url : input;
        var method = (init && init.method) ? init.method.toUpperCase() : 'GET';
        if (method !== 'GET' && method !== 'HEAD' && method !== 'OPTIONS') {
          init = init || {};
          init.headers = init.headers || {};
          var tok = getCsrfToken();
          if (tok) {
            if (init.headers instanceof Headers) init.headers.set('X-CSRF-Token', tok);
            else init.headers['X-CSRF-Token'] = tok;
          }
          if (!init.credentials) init.credentials = 'same-origin';
        }
      } catch(e){}
      return _origFetch.call(this, input, init);
    };
  }

  /* === 2. Auto-inject hidden <input name="_csrf"> vào MỌI form POST/PUT/DELETE === */
  function injectCsrfIntoForms(){
    var tok = getCsrfToken();
    if (!tok) return;
    var forms = document.querySelectorAll('form');
    forms.forEach(function(form){
      var method = (form.getAttribute('method') || 'GET').toUpperCase();
      if (method === 'GET' || method === 'HEAD') return;
      // Bỏ qua nếu form đã có input _csrf
      if (form.querySelector('input[name="_csrf"]')) return;
      var input = document.createElement('input');
      input.type = 'hidden';
      input.name = '_csrf';
      input.value = tok;
      form.appendChild(input);
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', injectCsrfIntoForms);
  } else {
    injectCsrfIntoForms();
  }
  /* Re-run khi DOM thay đổi (form thêm động qua JS) */
  if (window.MutationObserver) {
    new MutationObserver(injectCsrfIntoForms).observe(document.body, { childList: true, subtree: true });
  }
})();

function showToast(msg, kind){
  var t=document.getElementById('toast');
  var c=kind==='success'?'!border-l-emerald-500':kind==='error'?'!border-l-live':'!border-l-pri';
  t.className='fixed bottom-5 right-5 bg-bg-card border border-line border-l-4 px-4 py-3 rounded-lg text-white text-[13px] font-semibold z-[100] shadow-2xl translate-x-0 transition-transform '+c;
  t.textContent=msg;
  setTimeout(function(){ t.className=t.className.replace('translate-x-0','translate-x-[120%]') }, 3500);
}
async function adminAction(url, body, callback){
  try {
    var r = await fetch(url, { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body||{}) });
    var j = await r.json();
    if (typeof callback === 'function') return callback(j);
    if (j.ok) { showToast(j.message||'Thanh cong','success'); setTimeout(function(){ location.reload() }, 800); }
    else { showToast(j.message||'That bai','error'); }
  } catch(e){ showToast('Loi ket noi','error'); }
}
function confirmAction(msg, fn){ if (confirm(msg)) fn(); }

// Upload card image via FormData (multipart)
async function uploadCardImage(form, url){
  var fd = new FormData(form);
  var btn = form.querySelector('button[type=submit]');
  var oldTxt = btn ? btn.textContent : '';
  if (btn) { btn.textContent = '...'; btn.disabled = true; }
  try {
    var r = await fetch(url, { method:'POST', body: fd });
    var j = await r.json();
    if (j.ok) {
      showToast(j.message||'Upload thanh cong','success');
      setTimeout(function(){ location.reload(); }, 800);
    } else {
      showToast(j.message||'Upload that bai','error');
      if (btn) { btn.textContent = oldTxt; btn.disabled = false; }
    }
  } catch(e){
    showToast('Loi upload: ' + e.message,'error');
    if (btn) { btn.textContent = oldTxt; btn.disabled = false; }
  }
}
</script>
</body>
</html>
