<%- include('partials/layout-start', { title:'Quan ly BLV', active:'blv', obsPending: obsPending, adminUser: adminUser }) %>

<nav class="flex gap-2 mb-5 bg-bg-card border border-line rounded-xl p-2">
  <% var tabs = [{k:'',l:'Tat ca',n:counts.all},{k:'active',l:'Active',n:counts.active},{k:'pending',l:'Cho duyet',n:counts.pending,hot:true},{k:'rejected',l:'Tu choi',n:counts.rejected}]; %>
  <% tabs.forEach(function(t){ var ac=statusFilter===t.k; %>
    <a href="/admin/blv<%= t.k?'?status='+t.k:'' %>" class="flex items-center gap-2 px-4 py-2 rounded-lg font-bold text-[13px] transition-colors <%= ac ? 'bg-gradient-to-br from-pri to-live text-white' : 'text-gray-100 hover:bg-bg-soft' %>">
      <%= t.l %>
      <% if (t.n>0) { %><span class="<%= ac?'bg-white/20':'bg-bg-deep' %> text-[11px] px-2 py-0.5 rounded-full font-extrabold <%= t.hot && !ac ? 'text-live animate-pulse-live':'text-pri-light' %>"><%= t.n %></span><% } %>
    </a>
  <% }); %>
</nav>

<% if (!list.length) { %>
  <div class="p-16 text-center bg-bg-card border border-dashed border-line rounded-xl text-muted">
    <div class="text-5xl mb-3 opacity-60">&#127908;</div>
    <div>Khong co BLV nao trong nhom nay</div>
  </div>
<% } else { %>
<div class="grid lg:grid-cols-2 gap-4">
  <% list.forEach(function(b){ %>
    <article class="bg-bg-card border border-line rounded-xl p-5 <%= b.status==='pending' ? 'border-pri/40 ring-2 ring-pri/10' : '' %>">
      <div class="flex items-start gap-4">
        <img src="<%= b.avatar %>" alt="<%= b.name %>" class="w-16 h-16 rounded-full border-2 border-line shrink-0">
        <div class="flex-1 min-w-0">
          <div class="flex items-start justify-between gap-2">
            <div>
              <h3 class="font-extrabold text-white text-base"><%= b.name %></h3>
              <div class="text-xs text-muted mt-0.5">ID: <code class="text-pri-light"><%= b.id %></code> &middot; <%= new Date(b.registeredAt).toLocaleDateString('vi-VN') %></div>
            </div>
            <% if (b.status==='active') { %>
              <span class="px-2 py-0.5 bg-emerald-500/15 text-emerald-400 rounded text-[11px] font-bold whitespace-nowrap">Active</span>
            <% } else if (b.status==='pending') { %>
              <span class="px-2 py-0.5 bg-pri/15 text-pri-light rounded text-[11px] font-bold whitespace-nowrap animate-pulse-live">Cho duyet</span>
            <% } else { %>
              <span class="px-2 py-0.5 bg-live/15 text-live rounded text-[11px] font-bold whitespace-nowrap">Tu choi</span>
            <% } %>
            <% if (b.liveNow) { %><span class="px-2 py-0.5 bg-live text-white rounded text-[11px] font-extrabold flex items-center gap-1"><span class="w-1.5 h-1.5 bg-white rounded-full animate-pulse-live"></span>LIVE</span><% } %>
          </div>

          <% if (b.note) { %><div class="mt-2 text-xs bg-bg-soft border border-line px-3 py-2 rounded text-muted">&#128221; <%= b.note %></div><% } %>

          <% if (b.status==='active') { %>
          <div class="mt-3 grid grid-cols-3 gap-2 text-xs">
            <div class="bg-bg-soft px-2.5 py-2 rounded text-center"><div class="text-muted text-[10px]">RATING</div><div class="font-extrabold text-gold"><%= b.rating.toFixed(1) %>&#9733;</div></div>
            <div class="bg-bg-soft px-2.5 py-2 rounded text-center"><div class="text-muted text-[10px]">FOLLOWERS</div><div class="font-extrabold text-pri-light"><%= b.followers.toLocaleString('vi-VN') %></div></div>
            <div class="bg-bg-soft px-2.5 py-2 rounded text-center"><div class="text-muted text-[10px]">STREAMS</div><div class="font-extrabold text-white"><%= b.totalStreams %></div></div>
          </div>
          <% } %>

          <!-- LIVE PERMISSION TOGGLE -->
          <div class="mt-3 flex items-center justify-between bg-bg-soft border border-line rounded-lg px-3 py-2">
            <span class="text-xs font-bold flex items-center gap-1.5">
              <span class="text-base">📡</span>
              <span class="<%= b.canLive ? 'text-emerald-400' : 'text-muted' %>">
                Quyen Live: <%= b.canLive ? 'CHO PHEP ✅' : 'CHUA CAP ❌' %>
              </span>
            </span>
            <button onclick="adminAction('/admin/api/blv/<%= b.id %>/toggle-live', {}, function(r){ if(r.ok) location.reload(); })" class="<%= b.canLive ? 'bg-live hover:bg-red-700' : 'bg-emerald-600 hover:bg-emerald-700' %> text-white px-3 py-1 rounded text-xs font-extrabold transition-colors">
              <%= b.canLive ? '🚫 THU HOI' : '✅ CAP QUYEN' %>
            </button>
          </div>

          <!-- CATEGORY SELECT (chuyên mục live) -->
          <div class="mt-2 flex items-center gap-2 bg-bg-soft border border-line rounded px-2 py-1.5">
            <span class="text-xs font-bold text-white shrink-0">🎯 Chuyên mục:</span>
            <select onchange="adminAction('/admin/api/blv/<%= b.id %>/set-category', { category: this.value }, function(r){ if(r.ok){ showToast(r.message,'success'); } })" class="flex-1 bg-bg-deep border border-line text-white text-xs font-bold rounded px-2 py-1 outline-none focus:border-pri">
              <option value="bongda" <%= (b.category||'bongda')==='bongda' ? 'selected' : '' %>>⚽ BLV Bóng Đá (mặc định)</option>
              <option value="esport" <%= b.category==='esport' ? 'selected' : '' %>>🎮 BLV Esports</option>
              <option value="casino" <%= b.category==='casino' ? 'selected' : '' %>>🎰 Live Sòng Bài</option>
              <option value="idol"   <%= b.category==='idol'   ? 'selected' : '' %>>👑 Idol Show</option>
            </select>
          </div>

          <div class="mt-3 flex flex-wrap gap-2">
            <% if (b.status==='pending') { %>
              <button onclick="confirmAction('Duyet BLV <%= b.name %>?', function(){ adminAction('/admin/api/blv/<%= b.id %>/approve') })" class="px-3 py-1.5 bg-emerald-600 hover:bg-emerald-700 text-white rounded text-xs font-bold">&check; Duyet</button>
              <button onclick="var r=prompt('Ly do tu choi?'); if(r) adminAction('/admin/api/blv/<%= b.id %>/reject', { reason: r })" class="px-3 py-1.5 bg-live hover:bg-red-700 text-white rounded text-xs font-bold">&times; Tu choi</button>
            <% } else if (b.status==='active') { %>
              <button onclick="confirmAction('Tam khoa BLV <%= b.name %>?', function(){ adminAction('/admin/api/blv/<%= b.id %>/reject', { reason:'Khoa boi admin' }) })" class="px-3 py-1.5 bg-live/15 hover:bg-live text-live hover:text-white rounded text-xs font-bold">Tam khoa</button>
            <% } else { %>
              <button onclick="confirmAction('Phuc hoi BLV <%= b.name %>?', function(){ adminAction('/admin/api/blv/<%= b.id %>/approve') })" class="px-3 py-1.5 bg-emerald-600/15 hover:bg-emerald-600 text-emerald-400 hover:text-white rounded text-xs font-bold">Phuc hoi</button>
            <% } %>
            <button onclick="confirmAction('Xoa vinh vien BLV <%= b.name %>?', function(){ adminAction('/admin/api/blv/<%= b.id %>/delete') })" class="px-3 py-1.5 bg-bg-deep hover:bg-live text-muted hover:text-white rounded text-xs font-bold">Xoa</button>
          </div>
        </div>
      </div>
    </article>
  <% }); %>
</div>
<% } %>

<%- include('partials/layout-end') %>
