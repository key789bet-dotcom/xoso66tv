<%- include('partials/layout-start', { active: 'tab-icons' }) %>

<div class="space-y-6">
  <header class="bg-bg-card border border-line rounded-xl p-5">
    <h2 class="text-lg font-extrabold text-white mb-1">🎨 Ảnh tab + nút CTA</h2>
    <p class="text-sm text-muted leading-relaxed">
      Upload ảnh thay <b>emoji + text</b> cho các tab và nút trên site. Ảnh có sẵn cả icon + chữ, thay toàn bộ button. Không upload → fallback emoji mặc định.
    </p>
  </header>

  <%
    function _section(title, hint, items) {
      return { title: title, hint: hint, items: items };
    }
    var sections = [
      {
        title: '🏠 Tab trang chủ',
        hint: 'Khuyến nghị tỉ lệ ~3:1, vd 240×80px. Hiển thị nhỏ (max-width 140px).',
        items: [
          { key:'hot',     name:'🔥 Hot',         emoji:'🔥' },
          { key:'thethao', name:'⚽ Thể thao',    emoji:'⚽' },
          { key:'idol',    name:'👑 Idol Live',   emoji:'👑' },
          { key:'casino',  name:'🎰 Casino',      emoji:'🎰' },
          { key:'esport',  name:'🎮 Esports',     emoji:'🎮' }
        ]
      },
      {
        title: '💬 Tab chat phòng live (BLV/Idol)',
        hint: 'Khuyến nghị tỉ lệ ~3:1, vd 240×80px. Hiển thị chiếm 1/3 width chat panel.',
        items: [
          { key:'chat_room',     name:'💬 Chat phòng', emoji:'💬' },
          { key:'chat_telegram', name:'📨 Telegram',   emoji:'📨' },
          { key:'chat_facebook', name:'🔔 Facebook',   emoji:'🔔' }
        ]
      },
      {
        title: '🎁 Nút CTA BLV "ĐĂNG KÝ NHẬN 100% TIỀN THƯỞNG"',
        hint: 'Banner gradient dưới chat phòng BLV. Khuyến nghị tỉ lệ ~10:1, vd 600×60px hoặc 800×80px.',
        items: [
          { key:'cta_register', name:'🎁 ĐĂNG KÝ NHẬN 100%', emoji:'🎁' }
        ]
      },
      {
        title: '👑 Tab chat phòng IDOL (Chat + Quà)',
        hint: 'Khuyến nghị tỉ lệ ~3:1, vd 240×80px. Hiển thị chiếm 1/2 width chat panel idol.',
        items: [
          { key:'idol_chat', name:'💬 Chat phòng (idol)', emoji:'💬' },
          { key:'idol_gift', name:'🎁 Quà (idol)',         emoji:'🎁' }
        ]
      },
      {
        title: '🎰 Nút CTA IDOL "ĐĂNG KÝ TÀI KHOẢN XOSO66"',
        hint: 'Banner gradient cam-vàng dưới chat phòng idol. Khuyến nghị tỉ lệ ~10:1, vd 600×60px.',
        items: [
          { key:'cta_register_xoso66', name:'🎰 ĐĂNG KÝ XOSO66', emoji:'🎰' }
        ]
      }
    ];
  %>

  <% sections.forEach(function(sec){ %>
    <section class="bg-bg-card border border-line rounded-xl p-5">
      <h3 class="text-base font-extrabold text-pri-light mb-1"><%= sec.title %></h3>
      <p class="text-xs text-yellow-300 mb-4">💡 <%= sec.hint %></p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-4">
        <% sec.items.forEach(function(c){
             var url = (icons && icons[c.key]) || ''; %>
          <div class="bg-bg-deep border border-line rounded-lg p-3">
            <div class="flex items-center justify-between mb-2">
              <h4 class="text-white font-bold text-sm truncate"><%= c.name %></h4>
              <span class="text-[10px] uppercase font-bold shrink-0 ml-1 <%= url ? 'text-emerald-400' : 'text-muted' %>">
                <%= url ? '✓' : 'emoji' %>
              </span>
            </div>

            <div class="aspect-[3/1] bg-bg-card border border-line rounded grid place-items-center mb-2 overflow-hidden p-1">
              <% if (url) { %>
                <img src="<%= url %>?v=<%= Date.now() %>" alt="<%= c.key %>" class="max-w-full max-h-full object-contain">
              <% } else { %>
                <div class="text-center">
                  <div class="text-2xl"><%= c.emoji %></div>
                  <div class="text-[9px] text-muted">(mặc định)</div>
                </div>
              <% } %>
            </div>

            <input type="file" id="file_<%= c.key %>" accept="image/png,image/webp,image/jpeg,image/gif" class="block w-full text-[11px] text-gray-300 file:mr-2 file:py-1 file:px-2 file:rounded file:border-0 file:bg-pri file:text-white file:font-bold file:cursor-pointer">

            <div class="flex gap-1 mt-2">
              <button type="button" data-key="<%= c.key %>" class="ti-upload-btn flex-1 px-2 py-1.5 rounded bg-emerald-600 hover:bg-emerald-500 text-white text-[11px] font-bold">
                💾 Upload
              </button>
              <% if (url) { %>
                <button type="button" data-key="<%= c.key %>" class="ti-remove-btn px-2 py-1.5 rounded bg-red-600/80 hover:bg-red-600 text-white text-[11px] font-bold">
                  🗑
                </button>
              <% } %>
            </div>
          </div>
        <% }); %>
      </div>
    </section>
  <% }); %>

  <div id="tiStatus" class="hidden p-3 rounded text-sm sticky bottom-4"></div>
</div>

<script>
(function(){
  function _csrf(){
    var m = document.querySelector('meta[name="csrf-token"]');
    return m ? m.getAttribute('content') : '';
  }
  function showStatus(msg, ok){
    var box = document.getElementById('tiStatus');
    box.className = 'p-3 rounded text-sm sticky bottom-4 ' + (ok ? 'bg-emerald-500/10 border border-emerald-500 text-emerald-300' : 'bg-red-500/10 border border-red-500 text-red-300');
    box.textContent = msg;
    box.classList.remove('hidden');
    setTimeout(function(){ box.classList.add('hidden'); }, 4000);
  }

  document.querySelectorAll('.ti-upload-btn').forEach(function(btn){
    btn.addEventListener('click', function(){
      var key = btn.dataset.key;
      var fileInput = document.getElementById('file_' + key);
      if (!fileInput.files || !fileInput.files[0]) return showStatus('Chọn file trước khi upload', false);
      var file = fileInput.files[0];
      if (file.size > 2 * 1024 * 1024) return showStatus('Ảnh quá lớn (>2MB). Nén lại trước khi upload.', false);
      var fd = new FormData();
      fd.append('_csrf', _csrf());
      fd.append('key', key);
      fd.append('file', file);
      btn.disabled = true; btn.textContent = '⏳';
      var resetBtn = function(){ btn.disabled = false; btn.textContent = '💾 Upload'; };
      fetch('/admin/api/tab-icons/upload?_csrf=' + encodeURIComponent(_csrf()), {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'X-CSRF-Token': _csrf() },
        body: fd
      }).then(function(r){
        if (!r.ok) {
          return r.text().then(function(txt){
            throw new Error('HTTP ' + r.status + ': ' + (txt || '').slice(0, 200));
          });
        }
        return r.json();
      }).then(function(d){
        resetBtn();
        if (d.ok) { showStatus('Đã upload "' + key + '"', true); setTimeout(function(){ location.reload(); }, 600); }
        else { showStatus('✗ ' + (d.error || 'Lỗi'), false); }
      }).catch(function(err){
        resetBtn();
        showStatus('✗ ' + (err.message || 'Network error'), false);
      });
    });
  });

  document.querySelectorAll('.ti-remove-btn').forEach(function(btn){
    btn.addEventListener('click', function(){
      var key = btn.dataset.key;
      if (!confirm('Xoá "' + key + '"? Sẽ revert về emoji mặc định.')) return;
      fetch('/admin/api/tab-icons/remove', {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': _csrf() },
        body: JSON.stringify({ key: key, _csrf: _csrf() })
      }).then(function(r){ return r.json(); }).then(function(d){
        if (d.ok) { showStatus('Đã xoá "' + key + '"', true); setTimeout(function(){ location.reload(); }, 600); }
        else { showStatus('✗ ' + (d.error || 'Lỗi'), false); }
      });
    });
  });
})();
</script>

<%- include('partials/layout-end') %>
