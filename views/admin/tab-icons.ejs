<%- include('partials/layout-start', { active: 'tab-icons' }) %>

<div class="space-y-5">
  <header class="bg-bg-card border border-line rounded-xl p-5">
    <h2 class="text-lg font-extrabold text-white mb-1">🎨 Ảnh 4 tab trang chủ</h2>
    <p class="text-sm text-muted leading-relaxed">
      Upload ảnh riêng cho 4 tab <b>Hot · Thể thao · Idol Live · Casino</b> trên trang chủ.
      Ảnh sẽ <b>thay toàn bộ button</b> (icon + chữ trong ảnh), không hiện text label nữa.
      Nếu không upload → fallback dùng emoji + text mặc định.
    </p>
    <p class="text-xs text-yellow-300 mt-2">
      💡 Khuyến nghị: ảnh <b>tỉ lệ ~3:1 (chữ nhật ngang)</b>, ví dụ <b>240×80px</b> hoặc <b>300×100px</b>. Hỗ trợ: <b>PNG / WEBP / JPG / GIF (animated OK)</b>. Nền trong suốt, dung lượng &lt;2MB. Ảnh nên có sẵn cả icon + chữ "Hot/Thể thao/..." bên trong.
    </p>
  </header>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-4">
    <% var cats = [
      { key:'hot',     name:'🔥 Hot',         emoji:'🔥' },
      { key:'thethao', name:'⚽ Thể thao',    emoji:'⚽' },
      { key:'idol',    name:'👑 Idol Live',   emoji:'👑' },
      { key:'casino',  name:'🎰 Casino',      emoji:'🎰' },
      { key:'esport',  name:'🎮 Esports',     emoji:'🎮' }
    ]; %>

    <% cats.forEach(function(c){
         var url = (icons && icons[c.key]) || ''; %>
      <div class="bg-bg-card border border-line rounded-xl p-4">
        <div class="flex items-center justify-between mb-3">
          <h3 class="text-white font-extrabold text-sm"><%= c.name %></h3>
          <span class="text-[10px] uppercase font-bold <%= url ? 'text-emerald-400' : 'text-muted' %>">
            <%= url ? '✓ Có ảnh' : 'Dùng emoji' %>
          </span>
        </div>

        <!-- Preview - tỉ lệ ~3:1 cho ảnh chữ nhật -->
        <div class="aspect-[3/1] bg-bg-deep border border-line rounded-lg grid place-items-center mb-3 overflow-hidden p-2">
          <% if (url) { %>
            <img src="<%= url %>?v=<%= Date.now() %>" alt="<%= c.key %>" class="max-w-full max-h-full object-contain">
          <% } else { %>
            <div class="text-center">
              <div class="text-3xl"><%= c.emoji %></div>
              <div class="text-[10px] text-muted mt-1">(emoji mặc định)</div>
            </div>
          <% } %>
        </div>

        <!-- Upload form -->
        <input type="file" id="file_<%= c.key %>" accept="image/png,image/webp,image/jpeg,image/gif" class="block w-full text-xs text-gray-300 file:mr-2 file:py-1.5 file:px-3 file:rounded file:border-0 file:bg-pri file:text-white file:font-bold file:cursor-pointer">

        <div class="flex gap-2 mt-3">
          <button type="button" data-key="<%= c.key %>" class="ti-upload-btn flex-1 px-3 py-1.5 rounded bg-emerald-600 hover:bg-emerald-500 text-white text-xs font-bold">
            💾 Upload
          </button>
          <% if (url) { %>
            <button type="button" data-key="<%= c.key %>" class="ti-remove-btn px-3 py-1.5 rounded bg-red-600/80 hover:bg-red-600 text-white text-xs font-bold">
              🗑
            </button>
          <% } %>
        </div>
      </div>
    <% }); %>
  </div>

  <div id="tiStatus" class="hidden p-3 rounded text-sm"></div>
</div>

<script>
(function(){
  function _csrf(){
    var m = document.querySelector('meta[name="csrf-token"]');
    return m ? m.getAttribute('content') : '';
  }
  function showStatus(msg, ok){
    var box = document.getElementById('tiStatus');
    box.className = 'p-3 rounded text-sm ' + (ok ? 'bg-emerald-500/10 border border-emerald-500 text-emerald-300' : 'bg-red-500/10 border border-red-500 text-red-300');
    box.textContent = msg;
    box.classList.remove('hidden');
    setTimeout(function(){ box.classList.add('hidden'); }, 4000);
  }

  document.querySelectorAll('.ti-upload-btn').forEach(function(btn){
    btn.addEventListener('click', function(){
      var key = btn.dataset.key;
      var fileInput = document.getElementById('file_' + key);
      if (!fileInput.files || !fileInput.files[0]) return showStatus('Chọn file trước khi upload', false);
      var file = fileInput.files[0];
      if (file.size > 2 * 1024 * 1024) return showStatus('Ảnh quá lớn (>2MB). Nén lại trước khi upload.', false);
      var fd = new FormData();
      fd.append('_csrf', _csrf());
      fd.append('key', key);
      fd.append('file', file);
      btn.disabled = true; btn.textContent = '⏳';
      var resetBtn = function(){ btn.disabled = false; btn.textContent = '💾 Upload'; };
      fetch('/admin/api/tab-icons/upload?_csrf=' + encodeURIComponent(_csrf()), {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'X-CSRF-Token': _csrf() },
        body: fd
      }).then(function(r){
        // Catch HTTP error (403 CSRF, 413 too large, 500 server) trước khi parse JSON
        if (!r.ok) {
          return r.text().then(function(txt){
            throw new Error('HTTP ' + r.status + ': ' + (txt || '').slice(0, 200));
          });
        }
        return r.json();
      }).then(function(d){
        resetBtn();
        if (d.ok) { showStatus('Đã upload icon "' + key + '"', true); setTimeout(function(){ location.reload(); }, 600); }
        else { showStatus('✗ ' + (d.error || 'Lỗi không xác định'), false); }
      }).catch(function(err){
        resetBtn();
        showStatus('✗ ' + (err.message || 'Network error'), false);
      });
    });
  });

  document.querySelectorAll('.ti-remove-btn').forEach(function(btn){
    btn.addEventListener('click', function(){
      var key = btn.dataset.key;
      if (!confirm('Xoá icon "' + key + '"? Sẽ revert về emoji mặc định.')) return;
      fetch('/admin/api/tab-icons/remove', {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': _csrf() },
        body: JSON.stringify({ key: key, _csrf: _csrf() })
      }).then(function(r){ return r.json(); }).then(function(d){
        if (d.ok) { showStatus('Đã xoá icon "' + key + '"', true); setTimeout(function(){ location.reload(); }, 600); }
        else { showStatus('✗ ' + (d.error || 'Lỗi'), false); }
      });
    });
  });
})();
</script>

<%- include('partials/layout-end') %>
