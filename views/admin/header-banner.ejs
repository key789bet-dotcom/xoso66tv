<%- include('partials/layout-start', { active: 'header-banner' }) %>

<div class="space-y-6">
  <header class="bg-bg-card border border-line rounded-xl p-5 flex items-center justify-between gap-4 flex-wrap">
    <div>
      <h2 class="text-lg font-extrabold text-white mb-1">🎁 Banner thông báo trên header</h2>
      <p class="text-sm text-muted">Banner dải ngang trên cùng (cạnh logo). Click vào → mở link partner trong tab mới.</p>
      <p class="text-xs text-muted mt-1">Cập nhật cuối: <%= cfg.updatedAt ? new Date(cfg.updatedAt).toLocaleString('vi-VN') : '(chưa có)' %></p>
    </div>
    <%# Toggle bật/tắt %>
    <label class="inline-flex items-center gap-3 cursor-pointer select-none">
      <span class="text-sm font-bold text-white"><%= cfg.enabled ? 'ĐANG BẬT' : 'ĐANG TẮT' %></span>
      <span class="relative inline-block w-14 h-7 rounded-full <%= cfg.enabled ? 'bg-emerald-500' : 'bg-bg-deep border border-line' %>">
        <span class="absolute top-0.5 <%= cfg.enabled ? 'right-0.5' : 'left-0.5' %> w-6 h-6 rounded-full bg-white shadow transition-all"></span>
      </span>
      <button id="toggleBtn" type="button" class="px-3 py-1.5 rounded-lg bg-pri hover:opacity-90 text-white text-xs font-bold">
        <%= cfg.enabled ? '⛔ Tắt' : '✅ Bật' %>
      </button>
    </label>
  </header>

  <%# Preview %>
  <% if (cfg.image) { %>
  <div class="bg-bg-card border border-line rounded-xl p-5">
    <div class="text-xs font-bold text-muted uppercase mb-3">PREVIEW (chính xác như user thấy)</div>
    <div class="bg-bg-deep rounded-lg overflow-hidden grid place-items-center min-h-[80px] p-3" style="background-image:linear-gradient(45deg, #1a1f29 25%, transparent 25%), linear-gradient(-45deg, #1a1f29 25%, transparent 25%), linear-gradient(45deg, transparent 75%, #1a1f29 75%), linear-gradient(-45deg, transparent 75%, #1a1f29 75%); background-size: 16px 16px; background-position: 0 0, 0 8px, 8px -8px, -8px 0;">
      <img src="<%= cfg.image %>?v=<%= Date.now() %>" alt="<%= cfg.alt %>" class="w-full max-w-[1400px] h-auto rounded-lg" style="max-height:80px;object-fit:contain">
    </div>
    <div class="mt-3 text-xs text-muted">Ảnh: <code class="text-pri-light"><%= cfg.image %></code></div>
    <% if (cfg.link) { %>
    <div class="mt-1 text-xs text-muted">Link: <a href="<%= cfg.link %>" target="_blank" rel="noopener" class="text-pri-light underline"><%= cfg.link %></a></div>
    <% } %>
  </div>
  <% } %>

  <%# Form upload + cấu hình link %>
  <form id="bannerForm" class="bg-bg-card border border-line rounded-xl p-5 space-y-4">
    <div>
      <label class="block text-xs font-bold text-muted uppercase mb-2">Ảnh banner</label>
      <div class="flex items-center gap-3 flex-wrap">
        <label class="cursor-pointer">
          <input type="file" id="imgFile" accept="image/png,image/jpeg,image/webp" class="hidden">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-gradient-to-r from-pri to-pri-dark hover:opacity-90 text-white text-sm font-bold transition-opacity">
            📤 <%= cfg.image ? 'Thay ảnh banner' : 'Upload ảnh banner' %>
          </span>
        </label>
        <% if (cfg.image) { %>
          <button id="removeImgBtn" type="button" class="px-3 py-2 rounded-lg bg-red-500/20 text-red-400 hover:bg-red-500 hover:text-white text-xs font-bold transition-colors">🗑️ Xoá ảnh</button>
        <% } %>
        <span id="uploadStatus" class="text-xs text-muted"></span>
      </div>
      <p class="text-[11px] text-muted mt-1.5">Khuyến nghị: <b>1400×80px</b> hoặc tỉ lệ <b>17.5:1</b> · PNG/JPG/WebP · max 8MB</p>
    </div>

    <div>
      <label class="block text-xs font-bold text-muted uppercase mb-1.5">URL khi click (link partner)</label>
      <input type="url" id="linkInput" value="<%= cfg.link %>" placeholder="https://qt99.click/..."
             class="w-full bg-bg-deep border border-line text-gray-100 px-3 py-2 rounded-lg outline-none text-sm focus:border-pri">
      <p class="text-[11px] text-muted mt-1">Để trống → dùng link partner mặc định (từ Tích hợp Xoso66)</p>
    </div>

    <div>
      <label class="block text-xs font-bold text-muted uppercase mb-1.5">Mô tả ảnh (alt text — SEO)</label>
      <input type="text" id="altInput" value="<%= cfg.alt %>" placeholder="Khuyến mãi XOSO66"
             class="w-full bg-bg-deep border border-line text-gray-100 px-3 py-2 rounded-lg outline-none text-sm focus:border-pri">
    </div>

    <button type="button" id="saveBtn" class="px-5 py-2.5 rounded-lg bg-gradient-to-r from-emerald-500 to-emerald-600 text-white text-sm font-bold hover:opacity-90">
      💾 Lưu cấu hình
    </button>
  </form>

  <%# Hướng dẫn %>
  <div class="bg-bg-card border border-line rounded-xl p-5">
    <h3 class="text-sm font-extrabold text-pri-light mb-2">💡 Lưu ý</h3>
    <ul class="text-xs text-gray-300 space-y-1.5 list-disc pl-5">
      <li>Banner hiển thị trên cùng <b>mọi trang</b> (cạnh logo) khi BẬT toggle</li>
      <li>Kích thước tối ưu: <b>1400×80px</b> (tỉ lệ 17.5:1), nền liền không trong suốt</li>
      <li>Nếu chưa upload ảnh → header hiển thị text mặc định "VÉ CƯỢC THUA THỂ THAO ĐẦU TIÊN - HOÀN 100%"</li>
      <li>Click vào banner sẽ mở <b>link partner</b> trong tab mới</li>
      <li>Mobile cũng hiển thị banner (responsive scale theo width)</li>
    </ul>
  </div>
</div>

<script>
(function(){
  var fileInput = document.getElementById('imgFile');
  var status = document.getElementById('uploadStatus');
  var saveBtn = document.getElementById('saveBtn');
  var removeBtn = document.getElementById('removeImgBtn');
  var toggleBtn = document.getElementById('toggleBtn');

  fileInput.addEventListener('change', function(){
    var file = this.files[0];
    if (!file) return;
    if (file.size > 8*1024*1024) { showToast('File quá lớn, max 8MB','error'); return; }
    status.textContent = '⏳ Đang upload...';
    var fd = new FormData();
    fd.append('imageFile', file);
    fetch('/admin/api/header-banner/upload', { method:'POST', body: fd, credentials:'same-origin' })
      .then(function(r){ return r.json(); })
      .then(function(d){
        if (d.ok) {
          status.textContent = '✓ Đã upload';
          showToast('Upload thành công','success');
          setTimeout(function(){ location.reload(); }, 800);
        } else {
          status.textContent = '';
          showToast(d.error || 'Upload thất bại','error');
        }
      })
      .catch(function(e){
        status.textContent = '';
        showToast('Lỗi: '+e.message,'error');
      });
  });

  saveBtn && saveBtn.addEventListener('click', function(){
    var link = document.getElementById('linkInput').value.trim();
    var alt = document.getElementById('altInput').value.trim();
    fetch('/admin/api/header-banner/update', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      credentials:'same-origin',
      body: JSON.stringify({ link: link, alt: alt })
    }).then(function(r){ return r.json(); }).then(function(d){
      if (d.ok) { showToast('Đã lưu','success'); }
      else { showToast(d.error || 'Lưu thất bại','error'); }
    });
  });

  removeBtn && removeBtn.addEventListener('click', function(){
    if (!confirm('Xoá ảnh banner? (text mặc định sẽ hiện thay)')) return;
    fetch('/admin/api/header-banner/remove', { method:'POST', credentials:'same-origin' })
      .then(function(r){ return r.json(); })
      .then(function(d){
        if (d.ok) { showToast('Đã xoá','success'); setTimeout(function(){ location.reload(); }, 600); }
      });
  });

  toggleBtn && toggleBtn.addEventListener('click', function(){
    var newState = !<%= cfg.enabled %>;
    fetch('/admin/api/header-banner/toggle', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      credentials:'same-origin',
      body: JSON.stringify({ enabled: newState })
    }).then(function(r){ return r.json(); }).then(function(d){
      if (d.ok) { location.reload(); }
    });
  });
})();
</script>

<%- include('partials/layout-end') %>
