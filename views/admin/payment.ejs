<%- include('partials/layout-start', { title:'Tiền công Idol/BLV', active:'payment', obsPending: 0, adminUser: typeof adminUser !== 'undefined' ? adminUser : {} }) %>

<div class="bg-bg-card border border-line rounded-xl p-5 mb-5">
  <div class="flex items-start gap-3">
    <div class="text-3xl">💰</div>
    <div class="flex-1">
      <h2 class="text-base font-extrabold text-white">Quản Lý Phiên Live & Tiền Công</h2>
      <p class="text-muted text-xs mt-1">Xem chi tiết mỗi phiên live (giờ bắt đầu/kết thúc, viewers, payment). Set rate per giờ hoặc per trận cho từng Idol/BLV.</p>
    </div>
  </div>
</div>

<!-- Tabs -->
<nav class="flex gap-2 mb-4 bg-bg-card border border-line rounded-xl p-2 overflow-x-auto">
  <button data-tab="sessions" class="pay-tab is-active flex items-center gap-2 px-4 py-2 rounded-lg font-bold text-[13px] whitespace-nowrap">📊 Phiên Live</button>
  <button data-tab="rates"    class="pay-tab flex items-center gap-2 px-4 py-2 rounded-lg font-bold text-[13px] whitespace-nowrap">💰 Set Tiền Công</button>
  <button data-tab="payable"  class="pay-tab flex items-center gap-2 px-4 py-2 rounded-lg font-bold text-[13px] whitespace-nowrap">💳 Chưa Trả</button>
  <button data-tab="withdraw" class="pay-tab flex items-center gap-2 px-4 py-2 rounded-lg font-bold text-[13px] whitespace-nowrap relative">💸 Yêu Cầu Rút Tiền <span id="payWdBadge" class="hidden bg-red-500 text-white text-[9px] font-extrabold px-1.5 py-0.5 rounded-full">0</span></button>
</nav>

<!-- ════════════ TAB 1: PHIÊN LIVE ════════════ -->
<div id="payPanelSessions" class="pay-panel">
  <!-- Filter -->
  <div class="bg-bg-card border border-line rounded-xl p-3 mb-3 flex flex-wrap items-center gap-2">
    <select id="paySessFilterType" class="bg-bg-deep border border-line text-white text-xs px-3 py-1.5 rounded">
      <option value="">Tất cả (Idol + BLV)</option>
      <option value="idol">Chỉ Idol</option>
      <option value="blv">Chỉ BLV</option>
    </select>
    <input id="paySessFilterUser" type="text" placeholder="Username..." class="bg-bg-deep border border-line text-white text-xs px-3 py-1.5 rounded flex-1 max-w-[200px]">
    <select id="paySessFilterPaid" class="bg-bg-deep border border-line text-white text-xs px-3 py-1.5 rounded">
      <option value="">Tất cả status</option>
      <option value="paid">Đã trả</option>
      <option value="unpaid">Chưa trả</option>
    </select>
    <button onclick="paySessLoad()" class="bg-pri text-white text-xs font-bold px-4 py-1.5 rounded">Lọc</button>
  </div>

  <!-- Stats -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-4">
    <div class="bg-bg-deep border border-line rounded-lg p-3"><div class="text-[10px] text-muted uppercase font-bold">Tổng Session</div><div class="text-xl font-black text-white" id="paySessTotal">—</div></div>
    <div class="bg-bg-deep border border-line rounded-lg p-3"><div class="text-[10px] text-muted uppercase font-bold">Tổng Giờ</div><div class="text-xl font-black text-pri-light" id="paySessHours">—</div></div>
    <div class="bg-bg-deep border border-line rounded-lg p-3"><div class="text-[10px] text-muted uppercase font-bold">Tổng Tiền</div><div class="text-xl font-black text-emerald-400 tabular-nums" id="paySessEarn">—</div></div>
    <div class="bg-bg-deep border border-line rounded-lg p-3"><div class="text-[10px] text-muted uppercase font-bold">Chưa Trả</div><div class="text-xl font-black text-yellow-400 tabular-nums" id="paySessUnpaid">—</div></div>
  </div>

  <!-- Table -->
  <div class="bg-bg-card border border-line rounded-xl overflow-x-auto">
    <table class="w-full text-[12px]">
      <thead class="bg-bg-soft border-b border-line text-muted text-[10px] uppercase tracking-wider">
        <tr>
          <th class="px-2 py-2 text-left">User</th>
          <th class="px-2 py-2 text-left">Lịch / Trận</th>
          <th class="px-2 py-2 text-left">Start</th>
          <th class="px-2 py-2 text-left">End</th>
          <th class="px-2 py-2 text-center">Duration</th>
          <th class="px-2 py-2 text-center">Method</th>
          <th class="px-2 py-2 text-right">Tiền</th>
          <th class="px-2 py-2 text-center">Status</th>
          <th class="px-2 py-2 text-center">Action</th>
        </tr>
      </thead>
      <tbody id="paySessTbody" class="text-white">
        <tr><td colspan="9" class="text-center text-muted py-8">Đang tải...</td></tr>
      </tbody>
    </table>
  </div>
</div>

<!-- ════════════ TAB 2: SET RATE ════════════ -->
<div id="payPanelRates" class="pay-panel hidden">
  <div class="bg-bg-card border border-line rounded-xl p-4 mb-3">
    <h3 class="text-white font-bold mb-3 flex items-center gap-2"><span>💰</span> Set tiền công cho Idol</h3>
    <div class="grid md:grid-cols-2 gap-3">
      <% (idols || []).forEach(function(i){ %>
        <div class="bg-bg-deep border border-line rounded-lg p-3" data-user-rate="idol-<%= i.id %>">
          <div class="flex items-center gap-2 mb-2.5">
            <div class="w-9 h-9 rounded-full bg-gradient-to-br from-pink-500 to-rose-600 grid place-items-center text-base">👑</div>
            <div class="flex-1 min-w-0">
              <div class="font-bold text-white text-sm truncate"><%= i.name %></div>
              <div class="text-[10px] text-muted truncate">@<%= i.userId || i.username || i.id %></div>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-2 mb-2">
            <div>
              <label class="text-[9px] text-muted uppercase">Per Giờ (VND)</label>
              <input type="number" min="0" step="10000" class="rate-per-hour w-full bg-bg-card border border-line text-white text-xs px-2 py-1.5 rounded mt-0.5" value="<%= (i.paymentRate && i.paymentRate.perHour) || 50000 %>">
            </div>
            <div>
              <label class="text-[9px] text-muted uppercase">Per Trận (VND)</label>
              <input type="number" min="0" step="50000" class="rate-per-match w-full bg-bg-card border border-line text-white text-xs px-2 py-1.5 rounded mt-0.5" value="<%= (i.paymentRate && i.paymentRate.perMatch) || 200000 %>">
            </div>
          </div>
          <label class="flex items-center gap-2 text-[11px] text-gray-200 mb-2">
            <input type="checkbox" class="rate-use-match" <%= (i.paymentRate && i.paymentRate.useMatchRate) ? 'checked' : '' %>>
            <span>Khi BLV bind trận: tính theo trận thay vì giờ</span>
          </label>
          <button onclick="paySetRate(this, 'idol', '<%= i.id %>')" class="w-full bg-emerald-600 hover:bg-emerald-700 text-white text-xs font-bold py-1.5 rounded">💾 Lưu</button>
        </div>
      <% }); %>
    </div>
  </div>

  <div class="bg-bg-card border border-line rounded-xl p-4">
    <h3 class="text-white font-bold mb-3 flex items-center gap-2"><span>🎙️</span> Set tiền công cho BLV</h3>
    <div class="grid md:grid-cols-2 gap-3">
      <% if (!blvs || blvs.length === 0) { %>
        <div class="col-span-2 text-center text-muted text-sm py-6">Chưa có BLV nào active</div>
      <% } %>
      <% (blvs || []).forEach(function(b){ %>
        <div class="bg-bg-deep border border-line rounded-lg p-3" data-user-rate="blv-<%= b.id %>">
          <div class="flex items-center gap-2 mb-2.5">
            <div class="w-9 h-9 rounded-full bg-gradient-to-br from-blue-500 to-indigo-600 grid place-items-center text-base">🎙️</div>
            <div class="flex-1 min-w-0">
              <div class="font-bold text-white text-sm truncate"><%= b.name %></div>
              <div class="text-[10px] text-muted truncate">@<%= b.userId || b.username || b.id %></div>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-2 mb-2">
            <div>
              <label class="text-[9px] text-muted uppercase">Per Giờ (VND)</label>
              <input type="number" min="0" step="10000" class="rate-per-hour w-full bg-bg-card border border-line text-white text-xs px-2 py-1.5 rounded mt-0.5" value="<%= (b.paymentRate && b.paymentRate.perHour) || 100000 %>">
            </div>
            <div>
              <label class="text-[9px] text-muted uppercase">Per Trận (VND)</label>
              <input type="number" min="0" step="50000" class="rate-per-match w-full bg-bg-card border border-line text-white text-xs px-2 py-1.5 rounded mt-0.5" value="<%= (b.paymentRate && b.paymentRate.perMatch) || 300000 %>">
            </div>
          </div>
          <label class="flex items-center gap-2 text-[11px] text-gray-200 mb-2">
            <input type="checkbox" class="rate-use-match" <%= (b.paymentRate && b.paymentRate.useMatchRate) ? 'checked' : '' %>>
            <span>Tính theo trận thay vì giờ (mặc định cho BLV)</span>
          </label>
          <button onclick="paySetRate(this, 'blv', '<%= b.id %>')" class="w-full bg-emerald-600 hover:bg-emerald-700 text-white text-xs font-bold py-1.5 rounded">💾 Lưu</button>
        </div>
      <% }); %>
    </div>
  </div>
</div>

<!-- ════════════ TAB 3: CHƯA TRẢ ════════════ -->
<div id="payPanelPayable" class="pay-panel hidden">
  <div class="bg-bg-card border border-line rounded-xl p-4">
    <div class="flex items-center justify-between mb-3">
      <h3 class="text-white font-bold flex items-center gap-2"><span>💳</span> Tổng kết chưa trả - theo user</h3>
      <button onclick="payLoadPayable()" class="text-pri-light text-xs hover:underline">🔄 Refresh</button>
    </div>
    <div id="payPayableList" class="space-y-2">
      <div class="text-center text-muted text-sm py-6">Đang tải...</div>
    </div>
  </div>
</div>

<!-- ════════════ TAB 4: YÊU CẦU RÚT TIỀN ════════════ -->
<div id="payPanelWithdraw" class="pay-panel hidden">
  <!-- Stats -->
  <div class="grid grid-cols-2 md:grid-cols-5 gap-2 mb-3">
    <div class="bg-bg-deep border border-line rounded-lg p-3"><div class="text-[10px] text-muted uppercase font-bold">Tổng YC</div><div class="text-xl font-black text-white" id="payWdTotal">—</div></div>
    <div class="bg-yellow-500/10 border border-yellow-500/30 rounded-lg p-3"><div class="text-[10px] text-yellow-300 uppercase font-bold">Pending</div><div class="text-xl font-black text-yellow-300" id="payWdPending">—</div></div>
    <div class="bg-blue-500/10 border border-blue-500/30 rounded-lg p-3"><div class="text-[10px] text-blue-300 uppercase font-bold">Đang xử lý</div><div class="text-xl font-black text-blue-300" id="payWdApproved">—</div></div>
    <div class="bg-emerald-500/10 border border-emerald-500/30 rounded-lg p-3"><div class="text-[10px] text-emerald-300 uppercase font-bold">Đã trả</div><div class="text-xl font-black text-emerald-300 tabular-nums" id="payWdPaidAmt">—</div></div>
    <div class="bg-red-500/10 border border-red-500/30 rounded-lg p-3"><div class="text-[10px] text-red-300 uppercase font-bold">Từ chối</div><div class="text-xl font-black text-red-300" id="payWdRejected">—</div></div>
  </div>

  <!-- Filter -->
  <div class="bg-bg-card border border-line rounded-xl p-3 mb-3 flex flex-wrap items-center gap-2">
    <select id="payWdFilterStatus" class="bg-bg-deep border border-line text-white text-xs px-3 py-1.5 rounded">
      <option value="">Tất cả status</option>
      <option value="pending" selected>⏳ Chờ duyệt</option>
      <option value="approved">🔵 Đang xử lý</option>
      <option value="paid">✅ Đã trả</option>
      <option value="rejected">❌ Từ chối</option>
      <option value="cancelled">⊘ User hủy</option>
    </select>
    <select id="payWdFilterMethod" class="bg-bg-deep border border-line text-white text-xs px-3 py-1.5 rounded">
      <option value="">Tất cả phương thức</option>
      <option value="bank">🏦 Ngân hàng</option>
      <option value="usdt">₮ USDT</option>
    </select>
    <input id="payWdFilterUser" type="text" placeholder="Username..." class="bg-bg-deep border border-line text-white text-xs px-3 py-1.5 rounded flex-1 max-w-[200px]">
    <button onclick="payWdLoad()" class="bg-pri text-white text-xs font-bold px-4 py-1.5 rounded">Lọc</button>
    <button onclick="payWdLoad()" class="text-pri-light text-xs hover:underline ml-auto">🔄 Refresh</button>
  </div>

  <!-- List -->
  <div id="payWdList" class="space-y-2">
    <div class="text-center text-muted text-sm py-6">Đang tải...</div>
  </div>
</div>

<style>
.pay-tab { background:transparent; color:#cbd5e1; border:none; cursor:pointer; }
.pay-tab.is-active { background:linear-gradient(135deg,#f97316,#ef4444); color:#fff; }
</style>

<script>
(function(){
  function $(id){ return document.getElementById(id); }
  function escHtml(s){ return String(s||'').replace(/[<>&"]/g,function(c){return ({'<':'&lt;','>':'&gt;','&':'&amp;','"':'&quot;'})[c];}); }
  function fmt(ts){ return ts ? new Date(ts).toLocaleString('vi-VN',{day:'2-digit',month:'2-digit',hour:'2-digit',minute:'2-digit'}) : '—'; }
  function dur(ms){
    if (!ms || ms < 0) return '—';
    var s = Math.floor(ms/1000);
    var h = Math.floor(s/3600), m = Math.floor((s%3600)/60);
    return h + 'h ' + String(m).padStart(2,'0') + 'm';
  }
  function vnd(n){ return (n||0).toLocaleString('vi-VN') + 'đ'; }

  // ===== TAB SWITCHING =====
  document.querySelectorAll('.pay-tab').forEach(function(b){
    b.addEventListener('click', function(){
      document.querySelectorAll('.pay-tab').forEach(function(x){ x.classList.remove('is-active'); });
      b.classList.add('is-active');
      var tab = b.getAttribute('data-tab');
      document.querySelectorAll('.pay-panel').forEach(function(p){ p.classList.add('hidden'); });
      var panel = $('payPanel' + tab.charAt(0).toUpperCase() + tab.slice(1));
      if (panel) panel.classList.remove('hidden');
      if (tab === 'sessions') paySessLoad();
      if (tab === 'payable') payLoadPayable();
      if (tab === 'withdraw') payWdLoad();
    });
  });

  // ===== WITHDRAW =====
  var __wdBankMap = {
    VCB:'Vietcombank', TCB:'Techcombank', MBB:'MB Bank', BIDV:'BIDV',
    VTB:'VietinBank', ACB:'ACB', VPB:'VPBank', TPB:'TPBank',
    STB:'Sacombank', SHB:'SHB', HDB:'HDBank', OCB:'OCB',
    EIB:'Eximbank', NAB:'NamABank', SEAB:'SeABank', MSB:'MSB',
    VIB:'VIB', AGRI:'Agribank'
  };
  function bankLabel(code){ return __wdBankMap[code] || code; }

  function statusBadgeWd(st){
    var map = {
      pending:   ['⏳ Chờ duyệt', 'bg-yellow-500/20 text-yellow-300'],
      approved:  ['🔵 Đang xử lý', 'bg-blue-500/20 text-blue-300'],
      paid:      ['✅ Đã trả',     'bg-emerald-500/20 text-emerald-300'],
      rejected:  ['❌ Từ chối',    'bg-red-500/20 text-red-300'],
      cancelled: ['⊘ User hủy',   'bg-gray-500/20 text-gray-300']
    };
    var m = map[st] || ['—','bg-gray-500/20 text-gray-300'];
    return '<span class="text-[10px] font-bold px-2 py-0.5 rounded ' + m[1] + '">' + m[0] + '</span>';
  }

  window.payWdLoad = function(){
    var params = new URLSearchParams();
    var st = $('payWdFilterStatus').value; if (st) params.set('status', st);
    var me = $('payWdFilterMethod').value; if (me) params.set('method', me);
    var us = $('payWdFilterUser').value.trim(); if (us) params.set('username', us);
    fetch('/api/admin/withdraw/list?' + params.toString(), { credentials:'same-origin' })
      .then(function(r){ return r.json(); })
      .then(function(d){
        if (!d.ok) { $('payWdList').innerHTML = '<div class="text-red-400 text-center py-6">Lỗi tải dữ liệu</div>'; return; }
        var s = d.stats || {};
        $('payWdTotal').textContent    = s.total || 0;
        $('payWdPending').textContent  = s.pending || 0;
        $('payWdApproved').textContent = s.approved || 0;
        $('payWdPaidAmt').textContent  = vnd(s.paidAmount || 0);
        $('payWdRejected').textContent = s.rejected || 0;

        // Badge pending count cho tab
        var badge = $('payWdBadge');
        if (s.pending > 0) { badge.textContent = s.pending; badge.classList.remove('hidden'); }
        else { badge.classList.add('hidden'); }

        var list = d.list || [];
        if (list.length === 0) {
          $('payWdList').innerHTML = '<div class="text-center text-muted py-10 bg-bg-card border border-line rounded-xl">Không có yêu cầu nào.</div>';
          return;
        }
        $('payWdList').innerHTML = list.map(function(w){
          var icon = w.userType === 'blv' ? '🎙️' : (w.userType === 'idol' ? '👑' : '👤');
          var methodBox = '';
          if (w.method === 'bank') {
            methodBox = ''
              + '<div class="bg-bg-deep border border-line rounded-lg p-2.5 text-[12px]">'
              +   '<div class="flex items-center gap-1.5 text-blue-300 font-bold mb-1.5">🏦 ' + escHtml(bankLabel(w.bankName)) + '</div>'
              +   '<div class="grid grid-cols-1 sm:grid-cols-2 gap-1">'
              +     '<div><span class="text-muted text-[10px]">STK:</span> <button onclick="payWdCopy(this,\''+escHtml(w.bankAccount)+'\')" class="text-white font-mono font-bold hover:text-pri-light">'+escHtml(w.bankAccount)+'</button></div>'
              +     '<div><span class="text-muted text-[10px]">Chủ TK:</span> <span class="text-white font-bold uppercase">'+escHtml(w.bankHolder)+'</span></div>'
              +   '</div>'
              + '</div>';
          } else {
            methodBox = ''
              + '<div class="bg-bg-deep border border-line rounded-lg p-2.5 text-[12px]">'
              +   '<div class="flex items-center gap-1.5 text-emerald-300 font-bold mb-1.5">₮ USDT - ' + escHtml(w.usdtNetwork) + '</div>'
              +   '<div><span class="text-muted text-[10px]">Địa chỉ ví:</span> <button onclick="payWdCopy(this,\''+escHtml(w.usdtAddress)+'\')" class="text-white font-mono text-[11px] break-all hover:text-pri-light">'+escHtml(w.usdtAddress)+'</button></div>'
              + '</div>';
          }
          var actions = '';
          if (w.status === 'pending') {
            actions = ''
              + '<button onclick="payWdApprove(\''+w.id+'\')" class="bg-blue-600 hover:bg-blue-700 text-white text-[11px] font-bold px-3 py-1.5 rounded">✓ Duyệt</button>'
              + '<button onclick="payWdPaid(\''+w.id+'\')" class="bg-emerald-600 hover:bg-emerald-700 text-white text-[11px] font-bold px-3 py-1.5 rounded">💰 Đã trả</button>'
              + '<button onclick="payWdReject(\''+w.id+'\')" class="bg-red-600 hover:bg-red-700 text-white text-[11px] font-bold px-3 py-1.5 rounded">✗ Từ chối</button>';
          } else if (w.status === 'approved') {
            actions = ''
              + '<button onclick="payWdPaid(\''+w.id+'\')" class="bg-emerald-600 hover:bg-emerald-700 text-white text-[11px] font-bold px-3 py-1.5 rounded">💰 Đã chuyển tiền</button>'
              + '<button onclick="payWdReject(\''+w.id+'\')" class="bg-red-600 hover:bg-red-700 text-white text-[11px] font-bold px-3 py-1.5 rounded">✗ Từ chối</button>';
          }
          var meta = '<div class="text-[10px] text-muted">Tạo: ' + fmt(w.createdAt);
          if (w.reviewedAt) meta += ' • Xử lý: ' + fmt(w.reviewedAt) + (w.reviewedBy ? ' bởi @' + escHtml(w.reviewedBy) : '');
          if (w.paidAt)     meta += ' • Trả: ' + fmt(w.paidAt);
          if (w.paidTxId)   meta += ' • TX: ' + escHtml(w.paidTxId);
          meta += '</div>';
          var rejectInfo = w.rejectReason ? '<div class="text-[11px] text-red-300 mt-1">Lý do từ chối: '+escHtml(w.rejectReason)+'</div>' : '';
          var noteInfo   = w.note ? '<div class="text-[11px] text-gray-300 mt-1 italic">📝 '+escHtml(w.note)+'</div>' : '';

          return ''
            + '<div class="bg-bg-card border border-line rounded-xl p-3.5">'
            +   '<div class="flex flex-wrap items-start gap-3 mb-2.5">'
            +     '<div class="flex items-center gap-2 flex-1 min-w-[180px]">'
            +       '<span class="text-2xl">'+icon+'</span>'
            +       '<div>'
            +         '<div class="font-extrabold text-white">@'+escHtml(w.username)+' <span class="text-[10px] text-muted uppercase">'+escHtml(w.userType)+'</span></div>'
            +         '<div class="text-[10px] text-muted">ID: '+escHtml(w.id)+'</div>'
            +       '</div>'
            +     '</div>'
            +     '<div class="text-right">'
            +       '<div class="text-2xl font-black text-gold tabular-nums">'+vnd(w.amount)+'</div>'
            +       statusBadgeWd(w.status)
            +     '</div>'
            +   '</div>'
            +   methodBox
            +   noteInfo
            +   rejectInfo
            +   '<div class="flex items-center justify-between flex-wrap gap-2 mt-2.5 pt-2.5 border-t border-line/40">'
            +     meta
            +     '<div class="flex gap-1.5">' + actions + '</div>'
            +   '</div>'
            + '</div>';
        }).join('');
      });
  };

  window.payWdCopy = function(btn, txt){
    try {
      navigator.clipboard.writeText(txt);
      var old = btn.textContent;
      btn.textContent = '✓ Đã copy';
      setTimeout(function(){ btn.textContent = old; }, 1200);
    } catch(e){ alert(txt); }
  };

  window.payWdApprove = function(id){
    if (!confirm('Xác nhận DUYỆT yêu cầu này?\n(Cần chuyển tiền thủ công sau đó bấm "Đã trả")')) return;
    fetch('/api/admin/withdraw/'+id+'/approve', { method:'POST', credentials:'same-origin' })
      .then(function(r){ return r.json(); }).then(function(d){
        if (d.ok) payWdLoad(); else alert(d.error || 'Lỗi');
      });
  };

  window.payWdPaid = function(id){
    var txId = prompt('Nhập mã GD ngân hàng / Tx hash USDT (tùy chọn):', '');
    if (txId === null) return;
    fetch('/api/admin/withdraw/'+id+'/paid', {
      method:'POST', credentials:'same-origin',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ txId: txId })
    }).then(function(r){ return r.json(); }).then(function(d){
      if (d.ok) payWdLoad(); else alert(d.error || 'Lỗi');
    });
  };

  window.payWdReject = function(id){
    var reason = prompt('Lý do từ chối:', 'Thông tin TK không đúng');
    if (!reason) return;
    fetch('/api/admin/withdraw/'+id+'/reject', {
      method:'POST', credentials:'same-origin',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ reason: reason })
    }).then(function(r){ return r.json(); }).then(function(d){
      if (d.ok) payWdLoad(); else alert(d.error || 'Lỗi');
    });
  };

  // Pre-load withdraw stats để hiện badge ngay khi load page
  fetch('/api/admin/withdraw/list?status=pending&limit=1', { credentials:'same-origin' })
    .then(function(r){ return r.json(); })
    .then(function(d){
      if (d.ok && d.stats && d.stats.pending > 0) {
        var b = $('payWdBadge');
        b.textContent = d.stats.pending;
        b.classList.remove('hidden');
      }
    }).catch(function(){});

  // Auto-open tab withdraw nếu URL có ?tab=withdraw
  try {
    var qs = new URLSearchParams(location.search);
    if (qs.get('tab') === 'withdraw') {
      var t = document.querySelector('.pay-tab[data-tab="withdraw"]');
      if (t) t.click();
    }
  } catch(e){}

  // ===== SESSIONS =====
  window.paySessLoad = function(){
    var params = new URLSearchParams();
    var t = $('paySessFilterType').value; if (t) params.set('userType', t);
    var u = $('paySessFilterUser').value.trim(); if (u) params.set('username', u);
    var p = $('paySessFilterPaid').value; if (p) params.set('paid', p);
    fetch('/api/admin/sessions/list?' + params.toString(), { credentials:'same-origin' })
      .then(function(r){ return r.json(); })
      .then(function(d){
        if (!d.ok) { $('paySessTbody').innerHTML = '<tr><td colspan="9" class="text-center text-red-400 py-8">Lỗi tải</td></tr>'; return; }
        // Stats
        var list = d.list || [];
        var totalDur = 0, totalEarn = 0, unpaid = 0;
        list.forEach(function(s){
          totalDur += s.duration || 0;
          totalEarn += s.paymentAmount || 0;
          if (!s.paid && s.endTime) unpaid += s.paymentAmount || 0;
        });
        $('paySessTotal').textContent = list.length;
        $('paySessHours').textContent = (totalDur/3600000).toFixed(1) + 'h';
        $('paySessEarn').textContent = vnd(totalEarn);
        $('paySessUnpaid').textContent = vnd(unpaid);

        if (list.length === 0) {
          $('paySessTbody').innerHTML = '<tr><td colspan="9" class="text-center text-muted py-8">Không có session nào.</td></tr>';
          return;
        }
        $('paySessTbody').innerHTML = list.map(function(s){
          var statusBadge = s.endTime
            ? (s.paid
              ? '<span class="bg-emerald-500/20 text-emerald-300 text-[9px] font-bold px-1.5 py-0.5 rounded">✓ ĐÃ TRẢ</span>'
              : '<span class="bg-yellow-500/20 text-yellow-300 text-[9px] font-bold px-1.5 py-0.5 rounded">⏳ CHỜ TRẢ</span>')
            : '<span class="bg-emerald-500/20 text-emerald-300 text-[9px] font-bold px-1.5 py-0.5 rounded animate-pulse">🔴 LIVE</span>';
          var actionBtn = !s.endTime ? '<span class="text-muted text-[10px]">Đang live</span>'
            : (s.paid
              ? '<button onclick="payUnmarkPaid(\''+s.id+'\')" class="text-[10px] text-red-400 hover:underline">Hủy</button>'
              : '<button onclick="payMarkPaid(\''+s.id+'\')" class="bg-emerald-600 hover:bg-emerald-700 text-white text-[10px] font-bold px-2 py-0.5 rounded">✓ Trả</button>');
          var userTypeBadge = s.userType === 'blv' ? '🎙️' : '👑';
          var matchInfo = s.matchTitle ? '<div class="text-[9px] text-pri-light truncate max-w-[180px]">⚽ '+escHtml(s.matchTitle)+'</div>' : '<span class="text-[9px] text-muted">Tự do</span>';
          return ''
            + '<tr class="border-b border-line/40 hover:bg-bg-soft/40">'
            +   '<td class="px-2 py-1.5 font-bold"><span class="mr-1">'+userTypeBadge+'</span>'+escHtml(s.username)+'</td>'
            +   '<td class="px-2 py-1.5">'+matchInfo+'</td>'
            +   '<td class="px-2 py-1.5 text-[11px] tabular-nums">'+fmt(s.startTime)+'</td>'
            +   '<td class="px-2 py-1.5 text-[11px] tabular-nums">'+fmt(s.endTime)+'</td>'
            +   '<td class="px-2 py-1.5 text-center text-pri-light font-bold">'+dur(s.duration)+'</td>'
            +   '<td class="px-2 py-1.5 text-center text-[10px]">'+(s.paymentMethod==='match'?'⚽ Trận':'⏰ Giờ')+'</td>'
            +   '<td class="px-2 py-1.5 text-right font-extrabold text-gold tabular-nums">'+vnd(s.paymentAmount)+'</td>'
            +   '<td class="px-2 py-1.5 text-center">'+statusBadge+'</td>'
            +   '<td class="px-2 py-1.5 text-center">'+actionBtn+'</td>'
            + '</tr>';
        }).join('');
      });
  };

  window.payMarkPaid = function(id){
    if (!confirm('Đánh dấu đã trả?')) return;
    fetch('/api/admin/sessions/'+id+'/mark-paid', { method:'POST', credentials:'same-origin' })
      .then(function(r){return r.json();}).then(function(d){ if (d.ok) paySessLoad(); else alert(d.error); });
  };

  window.payUnmarkPaid = function(id){
    if (!confirm('Hủy đánh dấu đã trả?')) return;
    fetch('/api/admin/sessions/'+id+'/unmark-paid', { method:'POST', credentials:'same-origin' })
      .then(function(r){return r.json();}).then(function(d){ if (d.ok) paySessLoad(); else alert(d.error); });
  };

  // ===== SET RATE =====
  window.paySetRate = function(btn, userType, idOrUsername){
    var card = btn.closest('[data-user-rate]');
    var body = {
      userType: userType,
      idOrUsername: idOrUsername,
      perHour: card.querySelector('.rate-per-hour').value,
      perMatch: card.querySelector('.rate-per-match').value,
      useMatchRate: card.querySelector('.rate-use-match').checked
    };
    btn.disabled = true; btn.textContent = '⏳ Đang lưu...';
    fetch('/api/admin/payment-rate', {
      method:'POST', credentials:'same-origin',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify(body)
    }).then(function(r){return r.json();}).then(function(d){
      btn.disabled = false; btn.textContent = '💾 Lưu';
      if (d.ok) { btn.textContent = '✓ Đã lưu'; setTimeout(function(){ btn.textContent = '💾 Lưu'; }, 1500); }
      else alert(d.error);
    });
  };

  // ===== PAYABLE - tổng kết chưa trả per user =====
  window.payLoadPayable = function(){
    fetch('/api/admin/sessions/list?paid=unpaid&limit=500', { credentials:'same-origin' })
      .then(function(r){ return r.json(); })
      .then(function(d){
        if (!d.ok) { $('payPayableList').innerHTML = '<div class="text-red-400 text-sm">Lỗi tải</div>'; return; }
        var byUser = {};
        (d.list || []).forEach(function(s){
          if (!byUser[s.username]) byUser[s.username] = { count:0, total:0, type:s.userType };
          byUser[s.username].count++;
          byUser[s.username].total += s.paymentAmount || 0;
        });
        var keys = Object.keys(byUser).sort(function(a,b){ return byUser[b].total - byUser[a].total; });
        if (keys.length === 0) {
          $('payPayableList').innerHTML = '<div class="text-center text-muted py-6">🎉 Không còn ai chưa trả!</div>';
          return;
        }
        $('payPayableList').innerHTML = keys.map(function(u){
          var info = byUser[u];
          var icon = info.type === 'blv' ? '🎙️' : '👑';
          return ''
            + '<div class="flex items-center justify-between bg-bg-deep border border-line rounded-lg p-3">'
            +   '<div class="flex items-center gap-2.5">'
            +     '<span class="text-xl">'+icon+'</span>'
            +     '<div><div class="font-bold text-white">@'+escHtml(u)+'</div>'
            +     '<div class="text-[11px] text-muted">'+info.count+' session chưa trả</div></div>'
            +   '</div>'
            +   '<div class="text-right">'
            +     '<div class="text-xl font-black text-yellow-400 tabular-nums">'+vnd(info.total)+'</div>'
            +     '<button onclick="paySessFilterByUser(\''+u+'\')" class="text-[10px] text-pri-light hover:underline mt-0.5">Xem chi tiết →</button>'
            +   '</div>'
            + '</div>';
        }).join('');
      });
  };

  window.paySessFilterByUser = function(u){
    $('paySessFilterUser').value = u;
    document.querySelector('.pay-tab[data-tab="sessions"]').click();
  };

  // Initial
  paySessLoad();
})();
</script>

<%- include('partials/layout-end') %>
