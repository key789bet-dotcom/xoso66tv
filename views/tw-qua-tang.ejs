<%- include('partials/tw-seo-bottom', { seoContent: {
  h2:'Hệ thống quà tặng & X COIN của '+brand.name,
  intro:'Càng tích cực hoạt động trên '+brand.name+', bạn càng nhận được nhiều quà. Hệ thống tự động ghi nhận điểm danh, streak, mời bạn.',
  sections: [
    { h3:'Quà miễn phí hàng ngày', p:'8 phần quà tích hợp: chào mừng, login, streak 3/7 ngày, sinh nhật, mời bạn, share Facebook, VIP. Hoàn toàn miễn phí.' },
    { h3:'Đổi X COIN lấy quà vật lý XOSO66', p:'11 món quà vật lý chính hãng từ phụ kiện XOSO66 (mũ, áo thun, hoodie, balo) đến công nghệ cao cấp (sạc dự phòng, JBL, AirPods, Apple Watch, iPad, iPhone, SH 150i).' }
  ],
  faqs: [
    { q:'Quay vòng quay có mất phí không?', a:'1 lượt miễn phí mỗi ngày. Lượt sau 10 X COIN/lượt.' },
    { q:'X COIN dùng để làm gì?', a:'Có. Đổi được quà vật lý chính hãng XOSO66, giao tận nơi miễn phí toàn quốc.' },
    { q:'Quà có giao tận nhà không?', a:'Có. Sau khi đổi, CSKH liên hệ trong 24h xác nhận địa chỉ giao hàng.' }
  ]
}}) %>

<script>
(function(){
  // ===== Toast fallback =====
  if (typeof window.showToast !== 'function') {
    window.showToast = function(msg, kind){
      var t = document.createElement('div');
      var col = kind==='error' ? '#ff3b3b' : kind==='success' ? '#27ae60' : '#ff7a18';
      t.style.cssText = 'position:fixed;bottom:20px;right:20px;background:#161a22;color:#fff;padding:12px 18px;border-radius:8px;border-left:4px solid '+col+';z-index:9999;font-size:13px;font-weight:600;box-shadow:0 8px 24px rgba(0,0,0,.4);max-width:320px;';
      t.textContent = msg;
      document.body.appendChild(t);
      setTimeout(function(){ t.style.opacity='0'; t.style.transition='opacity .3s'; }, 2500);
      setTimeout(function(){ t.remove(); }, 3000);
    };
  }

  // ===== Helpers =====
  function getUser(){ try { return JSON.parse(localStorage.getItem('x66_user')||'{}'); } catch(e){ return {}; } }
  function setUser(u){ try { localStorage.setItem('x66_user', JSON.stringify(u)); } catch(e){} }
  function getCoin(){ var u = getUser(); return typeof u.coin==='number'?u.coin:79; }
  function setCoin(c){ var u = getUser(); u.coin = c; setUser(u); refreshBal(); }
  function refreshBal(){ var el = document.getElementById('qtBalance'); if (el) el.textContent = getCoin().toLocaleString('vi-VN') + ' 🪙'; }
  function isLoggedIn(){ var u = getUser(); return !!u.username; }
  function getStreak(){
    try { var ck = JSON.parse(localStorage.getItem('x66_checkin')||'{}'); return (ck.done||[]).length; }
    catch(e){ return 0; }
  }
  function today(){ return new Date().toDateString(); }

  // ===== Claim state =====
  function getClaimed(){
    try { return JSON.parse(localStorage.getItem('x66_gifts_claimed')||'{}'); } catch(e){ return {}; }
  }
  function setClaimed(obj){ try { localStorage.setItem('x66_gifts_claimed', JSON.stringify(obj)); } catch(e){} }
  function isDailyClaimed(id){
    var c = getClaimed();
    return c[id] && c[id].date === today();
  }
  function isOnceClaimed(id){
    var c = getClaimed();
    return !!c[id];
  }

  // ===== History =====
  function pushHistory(label, amount, type){
    var hist = [];
    try { hist = JSON.parse(localStorage.getItem('x66_gifts_history')||'[]'); } catch(e){}
    hist.unshift({ label: label, amount: amount, type: type||'gift', t: Date.now() });
    try { localStorage.setItem('x66_gifts_history', JSON.stringify(hist.slice(0,30))); } catch(e){}
    renderHistory();
  }
  function renderHistory(){
    var hist = [];
    try { hist = JSON.parse(localStorage.getItem('x66_gifts_history')||'[]'); } catch(e){}
    var el = document.getElementById('qtHistory');
    if (!hist.length) { el.innerHTML = '<div class="text-muted text-sm text-center py-6">Chưa nhận quà nào. Bắt đầu nào!</div>'; return; }
    el.innerHTML = hist.slice(0,15).map(function(h){
      var d = new Date(h.t);
      var time = String(d.getHours()).padStart(2,'0')+':'+String(d.getMinutes()).padStart(2,'0')+' '+d.getDate()+'/'+(d.getMonth()+1);
      var clr = h.amount > 0 ? 'text-emerald-400' : 'text-live';
      var icon = h.type==='shop' ? '🛍' : h.type==='spend' ? '💸' : '🎁';
      var sign = h.amount > 0 ? '+' : '';
      return '<div class="flex items-center gap-2 bg-bg-soft border border-line/40 rounded px-3 py-2 text-sm"><span class="text-lg">'+icon+'</span><span class="flex-1 text-white">'+h.label+'</span><span class="'+clr+' font-bold tabular-nums">'+sign+h.amount.toLocaleString('vi-VN')+' 🪙</span><span class="text-dim text-[10px] tabular-nums hidden sm:inline">'+time+'</span></div>';
    }).join('');
  }

  // ===== CLAIM DAILY GIFT =====
  window.claimGift = function(id, cond, reward, condText){
    if (!isLoggedIn()) { if (confirm('Bạn cần đăng nhập. Đăng nhập ngay?')) location.href='/dang-nhap'; return; }
    var u = getUser();

    // Check conditions
    if (cond === 'register') {
      // Quà 1 lần duy nhất
      if (isOnceClaimed(id)) { showToast('Quà này chỉ nhận 1 lần, bạn đã nhận rồi!','error'); markDone(id); return; }
    } else if (cond === 'daily') {
      if (isDailyClaimed(id)) { showToast('Hôm nay bạn đã nhận quà này rồi, ngày mai quay lại nhé!','error'); markDone(id); return; }
    } else if (cond === 'streak3') {
      var s = getStreak();
      if (s < 3) { showToast('Cần điểm danh ít nhất 3 ngày liên tiếp (hiện: '+s+' ngày). Vào /profile?tab=checkin','error'); return; }
      if (isOnceClaimed(id)) { showToast('Đã nhận quà streak 3 trong tháng này. Đợi tháng sau!','error'); markDone(id); return; }
    } else if (cond === 'streak7') {
      var s = getStreak();
      if (s < 7) { showToast('Cần điểm danh ít nhất 7 ngày liên tiếp (hiện: '+s+' ngày)','error'); return; }
      if (isOnceClaimed(id)) { showToast('Đã nhận quà streak 7 trong tháng này.','error'); markDone(id); return; }
    } else if (cond === 'birthday') {
      if (!u.birthday) { if (confirm('Bạn chưa cập nhật ngày sinh. Đi cập nhật ngay?')) location.href='/profile?tab=info'; return; }
      var bd = new Date(u.birthday), today = new Date();
      if (bd.getMonth() !== today.getMonth()) { showToast('Quà chỉ tặng trong tháng sinh nhật bạn (tháng '+(bd.getMonth()+1)+')','error'); return; }
      if (isOnceClaimed(id)) { showToast('Đã nhận quà sinh nhật năm nay rồi!','error'); markDone(id); return; }
    } else if (cond === 'invite') {
      var link = location.origin + '/dang-ky?ref=' + (u.username || 'X66');
      prompt('Copy link mời bạn của bạn (chia sẻ trên FB/Zalo, mỗi bạn đăng ký = +200 xu):', link);
      // Demo: cộng luôn 200 xu mỗi lần share
      if (isDailyClaimed(id)) { showToast('Hôm nay đã chia sẻ link rồi, mai quay lại nhé','error'); return; }
    } else if (cond === 'vip') {
      var vip = u.vip || 1;
      if (vip < 2) { showToast('Cần VIP >= 2 (nạp tích lũy >= 10tr). Hiện tại VIP '+vip,'error'); return; }
      if (isDailyClaimed(id)) { showToast('Đã nhận quà VIP hôm nay','error'); markDone(id); return; }
    }

    // Pass all checks → cộng coin
    setCoin(getCoin() + reward);
    var c = getClaimed(); c[id] = { date: today(), t: Date.now() }; setClaimed(c);
    pushHistory('Nhận: ' + getGiftName(id), reward, 'gift');
    showToast('🎉 Đã nhận +' + reward + ' X COIN!', 'success');
    markDone(id);
  };

  function getGiftName(id){
    var btn = document.querySelector('#card-'+id+' h3');
    return btn ? btn.textContent : 'Quà';
  }
  function markDone(id){
    var card = document.getElementById('card-'+id);
    if (!card) return;
    var btn = card.querySelector('button');
    if (btn) {
      btn.textContent = '✓ Đã nhận hôm nay';
      btn.className = 'inline-block bg-bg-deep text-muted px-4 py-1.5 rounded-md font-bold text-xs cursor-not-allowed';
      btn.disabled = true;
    }
  }

  // Init UI: mark đã claim
  ['g_login','g_register','g_streak3','g_streak7','g_birthday','g_invite','g_share','g_vip'].forEach(function(id){
    if (id === 'g_register' || id.indexOf('streak') === 0 || id === 'g_birthday') {
      if (isOnceClaimed(id)) markDone(id);
    } else {
      if (isDailyClaimed(id)) markDone(id);
    }
  });

  // ===== REDEEM SHOP ITEM =====
  window.redeemItem = function(id, name, cost){
    if (!isLoggedIn()) { if (confirm('Bạn cần đăng nhập. Đăng nhập ngay?')) location.href='/dang-nhap'; return; }
    var coin = getCoin();
    if (coin < cost) { showToast('X COIN không đủ! Cần '+cost+', còn '+coin+'. Kiếm thêm nhé!','error'); return; }
    if (!confirm('Đổi "'+name+'" với giá '+cost+' X COIN?\nSố dư hiện tại: '+coin+'\nSau khi đổi: '+(coin-cost))) return;
    setCoin(coin - cost);
    pushHistory('Đổi: ' + name, -cost, 'shop');
    showToast('🎉 Đã đổi "'+name+'"! CSKH sẽ liên hệ trong 24h.','success');
  };

  // Init
  refreshBal();
  renderHistory();
  // Sync balance pill mobile
  function _syncMobileBal(){
    var el = document.getElementById('qtBalanceMobile');
    var src = document.getElementById('qtBalance');
    if (el && src) el.textContent = src.textContent.replace(/[^\d.,]/g, '') || '0';
  }
  _syncMobileBal();
  setInterval(_syncMobileBal, 1500);
})();
</script>

</div><!-- /px-3 mobile wrapper -->

<%- include('partials/tw-footer') %>
