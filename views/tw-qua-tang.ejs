        { id:'g_invite',    ico:'&#127942;', n:'Mời bạn nhận xu',    d:'Mỗi bạn = +200 xu',     reward:200,  cond:'invite',   condText:'Chia sẻ link mời' },
        { id:'g_share',     ico:'&#128279;', n:'Chia sẻ Facebook',   d:'1 lần / ngày',          reward:20,   cond:'daily',    condText:'Click share Facebook' },
