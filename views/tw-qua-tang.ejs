<!-- LỊCH SỬ ĐÃ NHẬN -->
<section class="mb-6 bg-bg-card border border-line rounded-xl p-5">
  <h2 class="text-base font-extrabold text-white mb-3 flex items-center gap-2">
    <span class="w-1 h-5 bg-pri rounded-sm"></span> &#128221; Lịch sử nhận quà
    <a href="/profile?tab=history" class="ml-auto text-xs text-pri-light font-semibold">Xem đầy đủ →</a>
