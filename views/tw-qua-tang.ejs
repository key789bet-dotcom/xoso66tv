          <span class="tabular-nums">+<%= g.reward.toLocaleString('vi-VN') %></span>
        </div>
        <button onclick="claimGift('<%= g.id %>', '<%= g.cond %>', <%= g.reward %>, '<%= g.condText %>')" class="qt-btn inline-block bg-pri hover:bg-pri-dark text-white px-3 md:px-4 py-1 md:py-1.5 rounded-md font-bold text-[11px] md:text-xs transition-colors">Nhận quà</button>
