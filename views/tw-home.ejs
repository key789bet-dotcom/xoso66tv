<%
var _today = new Date();
var _todayVi = _today.getDate()+'/'+(_today.getMonth()+1)+'/'+_today.getFullYear();
var _liveCount = (live && live.length) ? live.length : '50+';
var _upCount   = (upcoming && upcoming.length) ? upcoming.length : '100+';
seo = {
  title: 'XOSO66 TV - Xem Trực Tiếp Bóng Đá Full HD, Idol Live 24/7 (' + _todayVi + ')',
  description: 'XOSO66 (xổ số 66) - Xem trực tiếp bóng đá Full HD miễn phí Ngoại Hạng Anh, La Liga, Champions League cùng nhận định bóng đá, dự đoán tỉ số chính xác và idol live show 24/7. ' + _liveCount + ' trận đang live hôm nay ' + _todayVi + ' tại XOSO66 TV.',
  keywords: 'xoso66, xổ số 66, xoso66 tv, xem trực tiếp bóng đá, nhận định bóng đá, dự đoán bóng đá, idol live, xem bóng đá Ngoại Hạng Anh, La Liga, Champions League, V-League, livescore, soi kèo bóng đá',
  canonical: '/',
  ogType: 'website',
  ogImage: (typeof siteUrl !== 'undefined' ? siteUrl : '') + '/static/img/logoxoso66tv.webp',
  publishedAt: '2026-01-01',
  modifiedAt: new Date().toISOString().slice(0,10)
};
// Cho phep render AggregateRating schema
var aggregateRating = true;
// Featured stream = live[0] hoặc upcoming[0] hoặc placeholder
var featured = (live && live[0]) || (upcoming && upcoming[0]) || null;
// Phân loại danh sách theo nhóm để hiển thị bên cạnh
function _bySport(arr, sport) {
  if (!arr) return [];
  return arr.filter(function(x){ return (x.sport||'')===sport; });
}
var roomsTheThao   = (live||[]).concat(upcoming||[]).filter(function(x){ return ['Soccer','Basketball','Tennis','Volleyball'].indexOf(x.sport)>=0; }).slice(0, 8);

// Idol thật từ DB, có CATEGORY để lọc tab
var _allIdolRooms = (typeof dbIdols !== 'undefined' && dbIdols && dbIdols.length) ? dbIdols
  .filter(function(i){ return i.status === 'active'; })
  .map(function(i){
    return {
      id: i.id,
      home: i.name,
      away: i.room || 'Phòng',
      league: i.category === 'casino' ? 'Live Sòng Bài' :
              i.category === 'bongda' ? 'BLV Bóng Đá' :
              i.category === 'esport' ? 'BLV Esports' : 'Idol Live Show',
      sport: 'Idol',
      category: i.category || 'idol',  // chuyên mục stream
      status: i.liveNow ? 'live' : 'offline',
      time: '21:00',
      poster: i.cardImage || i.avatar || '',
      lock: i.lock || 0,
      emoji: i.emoji || '👑',
      isIdolRoom: true
    };
  }) : [];

// Tab HOT: TẤT CẢ phòng đang LIVE (sports + idol mọi category)
var roomsHot = (live||[])
  .concat(_allIdolRooms.filter(function(r){ return r.status === 'live'; }))
  .sort(function(a, b){
    // Live trước, offline sau; trong cùng nhóm sắp theo viewers nếu có
    var aLive = (a.status === 'live') ? 1 : 0;
    var bLive = (b.status === 'live') ? 1 : 0;
    if (aLive !== bLive) return bLive - aLive;
    return (b.viewers || 0) - (a.viewers || 0);
  })
  .slice(0, 12);
// Nếu không có ai live → fallback hiện sports trên trang chủ
if (roomsHot.length === 0) roomsHot = (live||[]).slice(0, 8);

// Tab Idol Live: chỉ idol có category='idol' (idol show thuần)
var roomsIdol = _allIdolRooms.filter(function(r){ return r.category === 'idol'; });
// Tab Casino: idol có category='casino' (live sòng bài)
var roomsCasino = _allIdolRooms.filter(function(r){ return r.category === 'casino'; });
// Tab Esports: idol có category='esport' + match esport thật
var roomsEsport = _allIdolRooms.filter(function(r){ return r.category === 'esport'; })
  .concat((live||[]).filter(function(x){ return x.sport === 'Esports'; }))
  .slice(0, 8);
// Tab Bóng đá: idol category='bongda' + roomsTheThao (đã có)
var roomsBongdaIdol = _allIdolRooms.filter(function(r){ return r.category === 'bongda'; });
%>
<%- include('partials/tw-layout-start') %>

<!-- ===== MOBILE HOME (OkwinTV style) ===== -->
<%- include('partials/tw-mobile-home') %>

<!-- ===== DESKTOP HOME (giữ nguyên, ẩn trên mobile) ===== -->
<div class="hidden md:block">

<!-- H1 SEO — ẨN visual nhưng giữ trong DOM cho Google index (sr-only) -->
<header class="sr-only"><div class="hero-sparkles hidden" aria-hidden="true"><span></span><span></span><span></span><span></span><span></span></div>
  <h1 class="text-xl md:text-2xl font-black text-white mb-2 leading-tight flex items-center gap-2.5">
    <span class="text-2xl">📺</span>
    <span class="text-shimmer"><%= brand.name %> - Xem Trực Tiếp Bóng Đá HD Miễn Phí Hôm Nay <%= _todayVi %></span>
  </h1>
  <p class="text-muted text-sm leading-relaxed">
    Kênh livestream <strong class="text-white"><%= brand.name %></strong> phủ sóng
    <a href="/lich-phat-song?mon=bong-da" class="text-pri-light font-semibold hover:underline">bóng đá trực tiếp</a>
    Ngoại Hạng Anh, La Liga, Champions League, V-League, World Cup chất lượng <strong class="text-white">Full HD 1080p</strong>,
    bình luận tiếng Việt 24/7, không quảng cáo gián đoạn. Ngoài ra còn có
    <a href="/the-thao/bong-ro" class="text-pri-light font-semibold hover:underline">NBA bóng rổ</a>,
    <a href="/the-thao/tennis" class="text-pri-light font-semibold hover:underline">Grand Slam tennis</a>,
    <a href="/esports" class="text-pri-light font-semibold hover:underline">esports LCK/Valorant</a>,
    <a href="/casino" class="text-pri-light font-semibold hover:underline">casino trực tuyến</a> và
    <a href="/idol-live" class="text-pri-light font-semibold hover:underline">idol live show</a> 24/7.
  </p>
</header>

<!-- Banner promo strip (slider) - dung opacity + GPU compositing -->
<div class="relative rounded-xl overflow-hidden mb-3.5 h-[70px] md:h-[140px] bg-bg-card" id="heroBanner" style="contain:layout paint;will-change:contents">
  <% banners.forEach(function(b, i){ %>
    <% var _bgStyle = 'background:'+b.bg+';' + (b.image ? 'background-image:url('+b.image+');background-size:contain;background-position:center;background-repeat:no-repeat;' : ''); %>
    <div class="hero-slide absolute inset-0 flex items-center px-5 md:px-8 py-5 md:py-7 text-white" style="<%= _bgStyle %>opacity:<%= i===0?1:0 %>;transition:opacity 1s ease-in-out;pointer-events:<%= i===0?'auto':'none' %>;will-change:opacity;transform:translateZ(0)">
      <% if (!b.image) { %>
        <!-- Khong co anh: hien text + radial spotlight + CTA -->
        <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(circle at 75% 50%,rgba(255,255,255,.18),transparent 60%);"></div>
        <div class="relative z-[1] flex-1 min-w-0">
          <div class="text-base md:text-2xl font-extrabold drop-shadow-lg mb-1 md:mb-1.5 leading-tight truncate"><%= b.title %></div>
          <div class="text-xs md:text-sm opacity-95 mb-2 md:mb-3 line-clamp-2"><%= b.desc %></div>
          <a href="<%= b.url %>" target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-white text-red-700 px-5 md:px-7 py-1.5 md:py-2.5 rounded-lg font-extrabold shadow-lg hover:scale-105 transition-transform text-xs md:text-sm"><%= b.cta %> &rarr;</a>
        </div>
      <% } else { %>
        <!-- Co anh: KHONG do lop phu, anh hien thi 100% ro net + chi co link an len toan banner -->
        <a href="<%= b.url %>" target="_blank" rel="noopener" class="absolute inset-0 z-[1]" aria-label="<%= b.title %>"></a>
      <% } %>
    </div>
  <% }); %>
  <div class="absolute bottom-2 left-1/2 -translate-x-1/2 flex gap-1.5 z-[2]" id="heroDots">
    <% banners.forEach(function(b, i){ %><span class="w-1.5 h-1.5 rounded-full bg-white/40 cursor-pointer transition-all duration-500 <%= i===0?'!w-5 !bg-white':'' %>"></span><% }); %>
  </div>
</div>

<!-- MAIN PLAYER + ROOM LIST -->
<section class="grid lg:grid-cols-[1fr_320px] xl:grid-cols-[1fr_360px] gap-3.5 mb-4 items-stretch" aria-label="Player">

  <!-- Video player frame (always present) -->
  <article class="bg-black rounded-xl relative overflow-hidden flex flex-col">
    <div class="aspect-video bg-gradient-to-br from-[#1a2030] via-[#11151c] to-bg relative grid place-items-center overflow-hidden">
      <%
        // 🏆 Ưu tiên ảnh nền giải đấu (admin upload) cho card video featured
        var _featBgs = (typeof leagueBgs !== 'undefined' && leagueBgs) ? leagueBgs : {};
        function _featNormLg(s){ return String(s||'').toLowerCase().replace(/\./g,'').replace(/\s+/g,' ').trim(); }
        var featuredBg = '';
        if (featured && featured.league) {
          if (_featBgs[featured.league]) featuredBg = _featBgs[featured.league];
          else {
            var _ft = _featNormLg(featured.league);
            for (var _fk in _featBgs) {
              if (_fk === '__default__') continue;
              if (_featNormLg(_fk) === _ft) { featuredBg = _featBgs[_fk]; break; }
            }
          }
        }
        if (!featuredBg && _featBgs['__default__']) featuredBg = _featBgs['__default__'];
        if (!featuredBg && featured && featured.poster) featuredBg = featured.poster;
      %>
      <% if (featuredBg) { %>
        <img src="<%= featuredBg %>" alt="" class="absolute inset-0 w-full h-full object-cover opacity-55" onerror="this.style.display='none'">
        <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-black/50"></div>
      <% } %>
      <!-- decorative football pattern -->
      <div class="absolute inset-0 opacity-20 pointer-events-none" style="background:radial-gradient(ellipse at center,#ff7a18 0%,transparent 60%)"></div>

      <% if (featured) { %>
        <!-- LIVE / status badges -->
        <% if (featured.status === 'live') { %>
          <span class="absolute top-3 left-3 z-[2] bg-live text-white px-2.5 py-1 rounded-md font-extrabold text-[11px] flex items-center gap-1.5 shadow-live"><span class="w-1.5 h-1.5 bg-white rounded-full animate-pulse-live"></span>LIVE</span>
        <% } else { %>
          <span class="absolute top-3 left-3 z-[2] bg-gradient-to-r from-pri to-pri-dark text-white px-2.5 py-1 rounded-md font-extrabold text-[11px]">&#9200; SẮP DIỄN RA</span>
        <% } %>
        <span class="absolute top-3 right-3 z-[2] bg-black/70 text-gold px-2 py-0.5 rounded text-[10px] font-bold">HD 1080p</span>

        <!-- match info center -->
        <div class="relative z-[1] text-center px-6 py-4 text-white max-w-[90%]">
          <div class="text-[11px] md:text-xs text-gray-300 mb-1.5 font-bold tracking-widest uppercase line-clamp-1"><%= featured.league %></div>
          <h2 class="text-base md:text-xl font-extrabold mb-2 leading-tight line-clamp-2"><%= featured.home %> vs <%= featured.away %></h2>
          <% if (featured.score) { %>
            <div class="text-4xl md:text-5xl font-black text-gold my-2 drop-shadow-lg tabular-nums"><%= featured.score[0] %> : <%= featured.score[1] %></div>
          <% } else { %>
            <div class="text-2xl md:text-3xl font-black text-gold/80 my-2"><%= featured.time || 'VS' %></div>
          <% } %>
          <a href="/live/<%= featured.slug || featured.id %>" class="inline-flex items-center gap-2 px-6 md:px-9 py-2.5 md:py-3.5 bg-pri hover:bg-pri-dark text-white rounded-lg md:rounded-full font-extrabold text-xs md:text-sm shadow-pri hover:scale-105 transition-all">
            &#9654; VÀO PHÒNG
          </a>
        </div>
      <% } else { %>
        <!-- Empty player placeholder -->
        <div class="relative z-[1] text-center text-white px-6">
          <div class="w-20 h-20 mx-auto mb-3 rounded-full bg-gradient-to-br from-pri to-live grid place-items-center text-3xl shadow-live">&#9654;</div>
          <div class="font-bold text-base md:text-lg mb-1"><%= brand.name %></div>
          <div class="text-muted text-xs md:text-sm">Hôm nay chưa có trận live. Xem <a href="/lich-phat-song" class="text-pri-light underline">lịch phát sóng</a>.</div>
        </div>
      <% } %>
    </div>

    <!-- Player controls bar -->
    <div class="bg-[#0a0d12] border-t border-line/50 flex items-center gap-3 px-3 py-2 text-white">
      <button class="w-8 h-8 grid place-items-center hover:text-pri transition-colors" aria-label="Phát/Tạm dừng">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="5" width="4" height="14" rx="1"/><rect x="14" y="5" width="4" height="14" rx="1"/></svg>
      </button>
      <button class="w-8 h-8 grid place-items-center hover:text-pri transition-colors" aria-label="Bật/Tắt tiếng">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/></svg>
      </button>
      <% if (featured && featured.status === 'live') { %>
        <span class="text-xs flex items-center gap-1.5 text-live font-bold ml-1"><span class="w-1.5 h-1.5 bg-live rounded-full animate-pulse-live"></span>LIVE</span>
      <% } else { %>
        <span class="text-xs text-muted ml-1">Preview</span>
      <% } %>
      <div class="flex-1"></div>
      <button class="w-8 h-8 grid place-items-center hover:text-pri transition-colors hidden md:grid" aria-label="HD">
        <span class="text-[10px] font-bold bg-pri text-white px-1.5 py-0.5 rounded">HD</span>
      </button>
      <button class="w-8 h-8 grid place-items-center hover:text-pri transition-colors" aria-label="Toàn màn hình">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/></svg>
      </button>
    </div>
  </article>

  <!-- Right sidebar: Tab list of rooms - CỐ ĐỊNH max-height, scroll bên trong -->
  <aside class="bg-bg-card border border-line rounded-xl overflow-hidden flex flex-col" style="max-height:560px;min-height:0;">
    <!-- Tabs - LOC IDOL THEO CATEGORY -->
    <%
      var _ti = (typeof tabIcons !== 'undefined' && tabIcons) ? tabIcons : {};
      /**
       * Render 1 tab button:
       *   - Có ảnh upload: render <img> chiếm nguyên button, KHÔNG hiện text (ảnh tự chứa label)
       *   - Không ảnh: render emoji + text như mặc định
       */
      function _renderTab(key, fallbackEmoji, label, isActive) {
        var baseCls = 'room-tab flex items-center justify-center whitespace-nowrap transition-all rounded-md shrink-0';
        var activeCls = isActive ? 'bg-pri text-white shadow-pri' : 'text-gray-200 hover:bg-bg-soft';
        if (_ti[key]) {
          // 🎯 Kích thước gọn: h-10 (40px) cao, ảnh w-auto theo tỉ lệ, max 140px
          return '<button data-tab="' + key + '" class="' + baseCls + ' ' + activeCls + ' p-1 h-10" role="tab" aria-label="' + label + '">' +
                   '<img src="' + _ti[key] + '" alt="' + label + '" class="h-8 w-auto object-contain max-w-[140px]">' +
                 '</button>';
        }
        // Fallback emoji + text: cùng h-10
        return '<button data-tab="' + key + '" class="' + baseCls + ' ' + activeCls + ' gap-1.5 px-3 h-10 text-[12px] font-bold" role="tab">' +
                 fallbackEmoji + ' ' + label +
               '</button>';
      }
    %>
    <!-- Khung tab: scroll ngang khi tràn -->
    <nav class="flex gap-1 p-2 border-b border-line overflow-x-auto scroll-smooth" role="tablist" id="roomTabs" style="scrollbar-width:thin;-webkit-overflow-scrolling:touch;">
      <%- _renderTab('hot',     '&#128293;', 'Hot',       true)  %>
      <%- _renderTab('thethao', '&#9917;',   'Thể thao',  false) %>
      <%- _renderTab('idol',    '&#128081;', 'Idol Live', false) %>
      <%- _renderTab('casino',  '&#127920;', 'Casino',    false) %>
      <%- _renderTab('esport',  '&#127918;', 'Esports',   false) %>
    </nav>
    <style>
      #roomTabs::-webkit-scrollbar { height: 6px; }
      #roomTabs::-webkit-scrollbar-track { background: transparent; }
      #roomTabs::-webkit-scrollbar-thumb { background: rgba(249,115,22,.5); border-radius: 3px; }
      #roomTabs::-webkit-scrollbar-thumb:hover { background: rgba(249,115,22,.8); }
    </style>

    <!-- Room panels -->
    <div class="flex-1 overflow-y-auto scrollbar-thin">

      <!-- Tab: HOT -->
      <div class="room-panel" data-panel="hot">
        <% if (roomsHot.length === 0) { %>
          <div class="p-10 text-center text-muted text-sm">
            <div class="text-4xl mb-2 opacity-50">&#128229;</div>
            Chưa có phòng live.
            <div class="mt-3"><a href="/lich-phat-song" class="text-pri-light text-xs font-semibold">&rarr; Xem lịch phát sóng</a></div>
          </div>
        <% } else { %>
          <% roomsHot.forEach(function(m){ %>
            <%- include('partials/tw-room-row', { m: m }) %>
          <% }); %>
        <% } %>
      </div>

      <!-- Tab: THỂ THAO -->
      <div class="room-panel hidden" data-panel="thethao">
        <% if (roomsTheThao.length === 0) { %>
          <div class="p-10 text-center text-muted text-sm"><div class="text-4xl mb-2 opacity-50">&#9917;</div>Chưa có phòng thể thao live.</div>
        <% } else { %>
          <% roomsTheThao.forEach(function(m){ %>
            <%- include('partials/tw-room-row', { m: m }) %>
          <% }); %>
        <% } %>
      </div>

      <!-- Tab: IDOL LIVE (chỉ idol category='idol') -->
      <div class="room-panel hidden" data-panel="idol">
        <% if (roomsIdol.length === 0) { %>
          <div class="p-10 text-center text-muted text-sm"><div class="text-4xl mb-2 opacity-50">&#128081;</div>Chưa có phòng idol live.</div>
        <% } else { %>
          <% roomsIdol.forEach(function(m){ %>
            <%- include('partials/tw-room-row', { m: m }) %>
          <% }); %>
        <% } %>
      </div>

      <!-- Tab: CASINO (idol category='casino' - live sòng bài) -->
      <div class="room-panel hidden" data-panel="casino">
        <% if (roomsCasino.length === 0) { %>
          <div class="p-10 text-center text-muted text-sm">
            <div class="text-4xl mb-2 opacity-50">&#127920;</div>
            Chưa có idol live sòng bài
            <div class="mt-2 text-[11px] text-dim">Admin có thể chuyển chuyên mục idol sang Sòng Bài trong /admin/idol</div>
          </div>
        <% } else { %>
          <% roomsCasino.forEach(function(m){ %>
            <%- include('partials/tw-room-row', { m: m }) %>
          <% }); %>
        <% } %>
      </div>

      <!-- Tab: ESPORT (idol category='esport' + match esport) -->
      <div class="room-panel hidden" data-panel="esport">
        <% if (roomsEsport.length === 0) { %>
          <div class="p-10 text-center text-muted text-sm">
            <div class="text-4xl mb-2 opacity-50">&#127918;</div>
            Chưa có phòng esports live
          </div>
        <% } else { %>
          <% roomsEsport.forEach(function(m){ %>
            <%- include('partials/tw-room-row', { m: m }) %>
          <% }); %>
        <% } %>
      </div>

    </div>
  </aside>
</section>

<!-- Top Streamer carousel -->
<%- include('partials/tw-top-streamer') %>

<!-- Quick category filter chips: ĐÃ XÓA (trùng với tabs Hot/Thể thao/Idol/Casino/Esports ở sidebar phải) -->

<!-- Live rooms grid -->
<section class="mb-6" aria-label="Đang trực tiếp">
  <div class="flex items-center gap-2.5 mb-3.5">
    <span class="w-1 h-5 bg-pri rounded-sm"></span>
    <h2 class="text-lg font-extrabold text-white flex items-center gap-2">Đang trực tiếp <span class="bg-live text-white text-[11px] px-2 py-0.5 rounded font-extrabold flex items-center gap-1"><span class="w-1.5 h-1.5 bg-white rounded-full animate-pulse-live"></span>LIVE &middot; <%= live.length %></span></h2>
    <a href="/lich-phat-song" class="ml-auto text-sm text-pri-light font-semibold">Xem tất cả &rarr;</a>
  </div>
  <% if (!live || live.length === 0) { %>
    <div class="p-12 text-center bg-bg-card border border-dashed border-line rounded-xl text-muted"><div class="text-5xl mb-2 opacity-60">&#128229;</div>Hiện không có trận trực tiếp. Xem <a href="/lich-phat-song" class="text-pri-light">lịch phát sóng</a>.</div>
  <% } else { %>
    <div class="grid gap-3.5 grid-cols-[repeat(auto-fill,minmax(260px,1fr))]"><%- include('partials/tw-stream-card', { list: live.slice(0,12) }) %></div>
  <% } %>
</section>

<section class="mb-6" aria-label="Sắp diễn ra">
  <div class="flex items-center gap-2.5 mb-3.5"><span class="w-1 h-5 bg-pri rounded-sm"></span><h2 class="text-lg font-extrabold text-white">&#9200; Sắp diễn ra</h2><a href="/lich-phat-song" class="ml-auto text-sm text-pri-light font-semibold">Lịch đầy đủ &rarr;</a></div>
  <% if (upcoming.length === 0) { %>
    <div class="p-12 text-center bg-bg-card border border-dashed border-line rounded-xl text-muted"><div class="text-5xl mb-2 opacity-60">&#128197;</div>Chưa có trận sắp diễn ra.</div>
  <% } else { %>
    <div class="grid gap-3.5 grid-cols-[repeat(auto-fill,minmax(260px,1fr))]"><%- include('partials/tw-stream-card', { list: upcoming }) %></div>
  <% } %>
</section>

<% if (finished && finished.length) { %>
