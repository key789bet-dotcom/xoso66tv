<script>
// Tab switcher for room list sidebar
(function(){
  var tabs = document.querySelectorAll('.room-tab');
  var panels = document.querySelectorAll('.room-panel');
  tabs.forEach(function(t){
    t.addEventListener('click', function(){
      tabs.forEach(function(x){ x.className = x.className.replace('bg-pri text-white shadow-pri','').trim() + ' text-gray-200 hover:bg-bg-soft'; });
      this.className = this.className.replace('text-gray-200 hover:bg-bg-soft','').trim() + ' bg-pri text-white shadow-pri';
      var name = this.getAttribute('data-tab');
      panels.forEach(function(p){ p.classList.toggle('hidden', p.getAttribute('data-panel') !== name); });
    });
  });
  // Hero slider - fade chuyen dong muot khong gay reflow (khong anh huong video)
  var slides = document.querySelectorAll('#heroBanner .hero-slide');
  var dots   = document.querySelectorAll('#heroDots span');
  if (slides.length > 1) {
    var idx = 0;
    var paused = false;
    var heroEl = document.getElementById('heroBanner');
    // Pause khi tab khong active (tiet kiem CPU)
    document.addEventListener('visibilitychange', function(){ paused = document.hidden; });
    // Pause khi hover vao banner
    heroEl.addEventListener('mouseenter', function(){ paused = true; });
    heroEl.addEventListener('mouseleave', function(){ paused = false; });
    function nextSlide(){
      if (paused) return;
      // Chi thay doi style inline -> GPU composite, KHONG trigger reflow toan trang
      slides[idx].style.opacity = '0';
      slides[idx].style.pointerEvents = 'none';
      dots[idx].classList.remove('!w-5','!bg-white');
      idx = (idx + 1) % slides.length;
      slides[idx].style.opacity = '1';
      slides[idx].style.pointerEvents = 'auto';
      dots[idx].classList.add('!w-5','!bg-white');
    }
    setInterval(nextSlide, 5000);
    // Click dot de chuyen slide
    dots.forEach(function(d, i){
      d.addEventListener('click', function(){
        if (i === idx) return;
        slides[idx].style.opacity = '0'; slides[idx].style.pointerEvents = 'none';
        dots[idx].classList.remove('!w-5','!bg-white');
        idx = i;
        slides[idx].style.opacity = '1'; slides[idx].style.pointerEvents = 'auto';
        dots[idx].classList.add('!w-5','!bg-white');
      });
    });
  }
})();
</script>


<script>
// Idol row click handler (cho sidebar tab Idol Live tren home)
function tryEnterIdolRow(el, ev){
  if (ev) ev.preventDefault();
  var id = el.getAttribute('data-id');
  openUnlockDialog({
    id:     id,
    name:   el.getAttribute('data-name'),
    room:   el.getAttribute('data-room'),
    price:  parseInt(el.getAttribute('data-lock'),10) || 0,
    avatar: el.getAttribute('data-emoji') || '👑',
    duration: 30,
    redirectUrl: '/idol/' + id
  });
}
</script>

