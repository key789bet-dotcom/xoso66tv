  bongro:     '<svg viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5"><path d="M11.95 2.04c-2.32.21-4.43 1.15-6.1 2.58l3.95 3.95c.86-1.92 1.6-4.16 2.15-6.53zM4.04 11.95c.21-2.32 1.15-4.43 2.58-6.1l3.95 3.95c-1.92.86-4.16 1.6-6.53 2.15zm0 .1c2.37.55 4.61 1.29 6.53 2.15L6.62 18.15c-1.43-1.67-2.37-3.78-2.58-6.1zm7.91 9.91c-2.32-.21-4.43-1.15-6.1-2.58l3.95-3.95c.86 1.92 1.6 4.16 2.15 6.53zm.1 0c.55-2.37 1.29-4.61 2.15-6.53l3.95 3.95c-1.67 1.43-3.78 2.37-6.1 2.58zm9.91-9.91c-.21 2.32-1.15 4.43-2.58 6.1l-3.95-3.95c1.92-.86 4.16-1.6 6.53-2.15zm0-.1c-2.37-.55-4.61-1.29-6.53-2.15l3.95-3.95c1.43 1.67 2.37 3.78 2.58 6.1zm-9.91-9.91c2.32.21 4.43 1.15 6.1 2.58l-3.95 3.95c-.86-1.92-1.6-4.16-2.15-6.53z"/></svg>',
  tennis:     '<svg viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5"><path d="M6.27 17.05c.43.58.94 1.11 1.52 1.56l1.61-1.61L6.65 14.5C6.6 15.42 6.45 16.27 6.27 17.05zM7.79 5.39c-.58.45-1.09.97-1.52 1.55.18.79.33 1.64.38 2.55l2.74-2.49L7.79 5.39zM17.05 6.94c-.43-.58-.94-1.1-1.52-1.55l-1.61 1.61 2.74 2.49c.05-.91.21-1.76.39-2.55zM18.61 6.95c1.07-2.06.78-3.93-.07-4.79-.85-.86-2.72-1.16-4.79-.07-.86.45-1.83 1.16-2.83 2.16l-.4.4 5.52 5.52.4-.4c1-1 1.71-1.97 2.17-2.82zM2.16 13.91c-1.07 2.06-.78 3.93.07 4.79.85.85 2.72 1.15 4.79.07.85-.45 1.82-1.16 2.82-2.16l.4-.4-5.52-5.52-.4.4c-1 1-1.71 1.96-2.16 2.82zM15.53 18.61l1.61-1.61c-.45.58-.97 1.1-1.55 1.55l-.06.06zM5.39 7.79l1.61 1.61c.45-.58.97-1.1 1.55-1.55l-.06-.06z"/></svg>',
  bongchuyen: '<svg viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 2c1.93 0 3.68.69 5.05 1.83C15.5 6.34 12.42 8.85 11 11c-1.7-2.06-3.06-5.5-3.92-7.27C8.45 4.27 10.16 4 12 4zm-7.93 6.97C5.07 12.36 6.4 14.92 8 17c-2.04.16-4.7 0-5.93-.66-.5-1.05-.07-3.31 0-4.37zm4.93 9.39c-1.5-.84-3.16-2.06-4.16-3.36-.07-.61 0-1.32.13-2.04.85.07 2.65.31 5.41 0 1.05 1.32 2.81 3.13 5 4.5-2.06.66-4.41.92-6.38.9zM12 20c-.42 0-.83-.04-1.23-.09 1.32-1.18 3.81-3.51 4.83-5.45.97 1.16 2.13 2.94 3.06 5.04C17.16 19.46 14.65 20 12 20zm7.74-1.71c-.93-1.97-2.21-3.83-3.41-5.39 2.42-.31 4.61-.13 5.93.13.13.71.32 1.45-.13 2.06-.66.96-1.6 2.16-2.39 3.2zM19 12c-1.18-.07-3.74-.31-6.13.93-.59-2.16-1.43-4.74-2.06-6.93 1.06.27 5.13 1.45 7.45 4.16.4.6.6 1.2.74 1.84z"/></svg>',
  bongban:    '<svg viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5"><path d="M21 3c-1.11-1.11-3.27-1.32-5.79-.62-2.6.71-5.32 2.34-7.55 4.57-1.7 1.7-3.13 3.76-3.95 5.86l1.92-.5c.78-1.65 1.95-3.27 3.45-4.77 1.97-1.97 4.34-3.4 6.66-4.04 1.96-.55 3.62-.45 4.55.47 1.5 1.5.93 4.95-1.42 8.41C13 16.5 11.32 17.78 9.59 18.45L9 21l4.13-1.09c2.32-1.04 4.66-2.94 6.5-5.41C22.5 10.18 23.13 5.13 21 3zM6.55 15.74C4.65 13.84 4.85 10.94 7 8.79c1.42-1.42 3.17-1.97 4.92-1.58l-2.74 2.75 1.41 1.42 2.92-2.93c1.13.65 1.99 1.66 2.42 2.88l-3.05 3.05 1.41 1.41 2.7-2.7C16.69 16.94 13.42 19.36 11 19.36c-.83 0-1.59-.27-2.2-.78l3-3-1.41-1.41-3.05 3.05c-.42-.42-.74-.93-.97-1.48z"/></svg>',
  esports:    '<svg viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5"><path d="M21.58 16.09l-1.09-7.66C20.21 6.46 18.52 5 16.53 5H7.47C5.48 5 3.79 6.46 3.51 8.43l-1.09 7.66C2.2 17.63 3.39 19 4.94 19c.68 0 1.32-.27 1.8-.75L9 16h6l2.25 2.25c.48.48 1.13.75 1.8.75 1.56 0 2.75-1.37 2.53-2.91zM11 11H9v2H8v-2H6v-1h2V8h1v2h2v1zm4-1c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm3 3c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1z"/></svg>',
  idol:       '<svg viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5"><path d="M5 16L3 5l5.5 5L12 4l3.5 6L21 5l-2 11H5zm0 2h14v2H5v-2z"/></svg>',
  casino:     '<svg viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5"><path d="M16 7V3H2v18h20V7H16zM6 19H4v-2h2v2zm0-4H4v-2h2v2zm0-4H4V9h2v2zm0-4H4V5h2v2zm4 12H8v-2h2v2zm0-4H8v-2h2v2zm0-4H8V9h2v2zm0-4H8V5h2v2zm4 12h-2v-2h2v2zm0-4h-2v-2h2v2zm0-4h-2V9h2v2zm0-4h-2V5h2v2zm6 12h-4V9h4v10z"/></svg>',
  hot:        '<svg viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5"><path d="M13.5.67s.74 2.65.74 4.8c0 2.06-1.35 3.73-3.41 3.73-2.07 0-3.63-1.67-3.63-3.73l.03-.36C5.21 7.51 4 10.62 4 14c0 4.42 3.58 8 8 8s8-3.58 8-8C20 8.61 17.41 3.8 13.5.67zM11.71 19c-1.78 0-3.22-1.4-3.22-3.14 0-1.62 1.05-2.76 2.81-3.12 1.77-.36 3.6-1.21 4.62-2.58.39 1.29.59 2.65.59 4.04 0 2.65-2.15 4.8-4.8 4.8z"/></svg>',
  trophy:     '<svg viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5"><path d="M19 5h-2V3H7v2H5c-1.1 0-2 .9-2 2v1c0 2.55 1.92 4.63 4.39 4.94.63 1.5 1.98 2.63 3.61 2.96V19H7v2h10v-2h-4v-3.1c1.63-.33 2.98-1.46 3.61-2.96C19.08 12.63 21 10.55 21 8V7c0-1.1-.9-2-2-2zM5 8V7h2v3.82C5.84 10.4 5 9.3 5 8zm14 0c0 1.3-.84 2.4-2 2.82V7h2v1z"/></svg>'
};
// Map sport name (m.sport English) → key trong _svgIco (cho fallback league icon)
var _sportToIcoKey = { 'Soccer':'bongda', 'Basketball':'bongro', 'Tennis':'tennis', 'Volleyball':'bongchuyen', 'TableTennis':'bongban', 'Esports':'esports' };

// ===== Mobile day picker - sinh 6 ngày liên tiếp =====
var _vnDays = ['Chủ nhật','Thứ 2','Thứ 3','Thứ 4','Thứ 5','Thứ 6','Thứ 7'];
var _dayPicker = [];
for (var _di=0; _di<6; _di++) {
  var _d = new Date(); _d.setDate(_d.getDate() + _di);
  var _dd = String(_d.getDate()).padStart(2,'0');
  var _mm = String(_d.getMonth()+1).padStart(2,'0');
  var _label = _di===0 ? 'Hôm nay' : _di===1 ? 'Ngày mai' : _vnDays[_d.getDay()];
  _dayPicker.push({ label: _label, date: _dd+'-'+_mm, key: _dd+_mm, iso: _d.toISOString().slice(0,10) });
}

// ===== DATA THẬT =====
var _blvList = (typeof blvs !== 'undefined' && blvs) ? blvs : [];
var _idolList = (typeof idols !== 'undefined' && idols) ? idols : [];

// Helper: assign 2 BLV deterministic cho mỗi match (dựa trên match.id)
function _pickBlvs(matchId){
  if (_blvList.length === 0) return [];
  // Hash đơn giản từ ID để pick stable
  var h = 0; var s = String(matchId || '');
  for (var i=0; i<s.length; i++) h = (h*31 + s.charCodeAt(i)) & 0xfff;
  var a = _blvList[h % _blvList.length];
  var b = _blvList.length > 1 ? _blvList[(h*7) % _blvList.length] : null;
  if (b && b.id === a.id) b = _blvList[(h*7+1) % _blvList.length];
  return b ? [a, b] : [a];
}

// Build allCards: matches + idol cards (cat=idol)
var _allCards = [];
// 1. Sports matches
(list || []).forEach(function(m){
  var _isoDate = '';
  try { if (m.date) _isoDate = new Date(m.date).toISOString().slice(0,10); } catch(e){}
  var _cat = m.sport==='Soccer' ? 'bong-da'
           : m.sport==='Basketball' ? 'bong-ro'
           : m.sport==='Tennis' ? 'tennis'
           : m.sport==='Volleyball' ? 'bong-chuyen'
           : m.sport==='Esports' ? 'esports' : 'khac';
  _allCards.push({
    type: 'match',
    cat: _cat,
    isoDate: _isoDate || _dayPicker[0].iso,
    data: m,
    blvs: _pickBlvs(m.id || m.slug)
  });
});
// 2. Idol cards (cat=idol) - mỗi idol là 1 "lịch" stream
_idolList.forEach(function(i){
  if (i.category && i.category !== 'idol') return; // skip casino/bongda idols (đã thuộc cat khác)
  _allCards.push({
    type: 'idol',
    cat: 'idol',
    isoDate: _dayPicker[0].iso, // idol live mặc định hôm nay
    data: i,
    blvs: []
  });
});
%>
<%- include('partials/tw-layout-start') %>

<!-- ═══════════════════════════════════════════════════════════════ -->
<!-- DESKTOP layout - REDESIGN: list grouped by league + action buttons -->
<!-- ═══════════════════════════════════════════════════════════════ -->
<%
// ===== Group matches by league (desktop) =====
var _blvSet = (typeof blvMatchIds !== 'undefined' && blvMatchIds) ? blvMatchIds : new Set();
var _artMap = (typeof articleByMatch !== 'undefined' && articleByMatch) ? articleByMatch : {};
var _leagueGroups = {}; // { leagueName: { league, country, logo, matches: [] } }
var _leagueSet = {}; // unique league names cho filter chips
(list || []).forEach(function(m){
  var lname = m.league || m.sport || 'Khác';
  if (!_leagueGroups[lname]) {
    _leagueGroups[lname] = {
      name: lname, country: m.country || '', logo: m.leagueLogo || '',
      flag: m.leagueFlag || '', matches: []
    };
  }
  _leagueGroups[lname].matches.push(m);
  _leagueSet[lname] = (_leagueSet[lname] || 0) + 1;
});
// Sort league theo số match desc, league lớn hiện trước
var _leagueArr = Object.keys(_leagueGroups).sort(function(a,b){
  return _leagueGroups[b].matches.length - _leagueGroups[a].matches.length;
}).map(function(k){ return _leagueGroups[k]; });
%>
<div class="hidden md:block">
<%- include('partials/tw-breadcrumb') %>

<!-- Title H1 -->
<header class="mb-4">
  <h1 class="text-xl md:text-2xl font-black text-white leading-tight uppercase tracking-wide">
    Lịch Thi Đấu <%= _catName||'Bóng Đá' %> Chuẩn Xác Nhất Hôm Nay - LTĐ Sắp Diễn Ra
  </h1>
</header>

<!-- Tabs môn thể thao (pill style teal) -->
<nav class="flex gap-2 flex-wrap mb-4" aria-label="Lọc môn">
  <% Object.entries(cats).forEach(function(pair){ var k=pair[0], c=pair[1]; if (c.partnerOnly || c.sport===null) return;
       var _icoKey = (k==='bong-da'?'bongda':k==='bong-ro'?'bongro':k==='bong-chuyen'?'bongchuyen':k==='bong-ban'?'bongban':k);
       var _isAct = (sport===k) || (!sport && k==='bong-da');
  %>
    <a href="/lich-phat-song?mon=<%= k %>" class="lps-sport-tab <%= _isAct ? 'is-active' : '' %>">
      <span class="lps-sport-ico"><%- _svgIco[_icoKey] || ('<span>'+(c.icon||'🏆')+'</span>') %></span>
      <span class="uppercase tracking-wide"><%= c.name %></span>
    </a>
  <% }); %>
</nav>

<!-- Filter bar: Hôm nay + Date picker + Sắp xếp -->
<div class="flex items-center gap-3 flex-wrap bg-bg-card border border-line rounded-lg px-4 py-2.5 mb-3">
  <button type="button" class="lps-day-btn is-active" data-mode="today">
    <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M19 4h-1V2h-2v2H8V2H6v2H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V10h14v10zM9 14H7v-2h2v2zm4 0h-2v-2h2v2zm4 0h-2v-2h2v2z"/></svg>
    HÔM NAY
  </button>
  <span class="text-muted text-[13px]">Cụ thể</span>
  <input type="date" id="lpsDate" value="<%= new Date().toISOString().slice(0,10) %>" class="bg-bg-soft border border-line text-white text-[13px] px-2.5 py-1 rounded font-semibold cursor-pointer">
  <div class="ml-auto flex items-center gap-2">
    <span class="text-muted text-[13px]">Sắp xếp:</span>
    <button type="button" id="lpsSortBtn" class="text-pri-light text-[13px] font-bold flex items-center gap-1">
      Theo thời gian
      <svg viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5"><path d="M7 10l5 5 5-5z"/></svg>
    </button>
  </div>
</div>

<!-- Filter chips theo giải đấu (auto-gen từ list) -->
<% if (_leagueArr.length > 1) { %>
<div class="bg-bg-card border border-line rounded-lg px-3 py-2.5 mb-4 max-h-[112px] overflow-y-auto">
  <div class="flex gap-1.5 flex-wrap" id="lpsLeagueChips">
    <button type="button" class="lps-lg-chip is-active" data-lg="__all__">TẤT CẢ</button>
    <% _leagueArr.forEach(function(lg){ %>
      <button type="button" class="lps-lg-chip" data-lg="<%= lg.name %>" title="<%= lg.matches.length %> trận"><%= lg.name.toUpperCase() %></button>
    <% }); %>
  </div>
</div>
<% } %>

<!-- Match list - GROUPED BY LEAGUE -->
<section id="lpsList">
  <% if (!list || list.length === 0) { %>
    <div class="p-12 text-center bg-bg-card border border-dashed border-line rounded-xl text-muted">
      <div class="text-5xl mb-2 opacity-60">&#128229;</div>
      Không có trận sắp diễn ra.
    </div>
  <% } else { %>
    <% _leagueArr.forEach(function(lg){ %>
      <div class="lps-lg-group mb-4" data-lg="<%= lg.name %>">
        <!-- League header -->
        <div class="lps-lg-header">
          <span class="lps-lg-logo">
            <% if (lg.logo) { %>
              <img src="<%= lg.logo %>" alt="<%= lg.name %>" class="w-full h-full object-contain" loading="lazy" onerror="this.outerHTML='<svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; class=&quot;w-4 h-4&quot;><path d=&quot;M19 5h-2V3H7v2H5c-1.1 0-2 .9-2 2v1c0 2.55 1.92 4.63 4.39 4.94.63 1.5 1.98 2.63 3.61 2.96V19H7v2h10v-2h-4v-3.1c1.63-.33 2.98-1.46 3.61-2.96C19.08 12.63 21 10.55 21 8V7c0-1.1-.9-2-2-2z&quot;/></svg>'">
            <% } else { %>
              <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M19 5h-2V3H7v2H5c-1.1 0-2 .9-2 2v1c0 2.55 1.92 4.63 4.39 4.94.63 1.5 1.98 2.63 3.61 2.96V19H7v2h10v-2h-4v-3.1c1.63-.33 2.98-1.46 3.61-2.96C19.08 12.63 21 10.55 21 8V7c0-1.1-.9-2-2-2z"/></svg>
            <% } %>
          </span>
          <span class="text-white font-bold text-[14px]"><%= lg.name %></span>
          <% if (lg.country) { %><span class="text-muted text-[11px] ml-1">· <%= lg.country %></span><% } %>
          <span class="ml-auto text-muted text-[11px]"><%= lg.matches.length %> trận</span>
        </div>

        <!-- Matches in this league -->
        <% lg.matches.forEach(function(m){
          var _matchKey = String(m.id || '');
          var _hasBlv  = _blvSet.has(_matchKey);
          var _articleSlug = _artMap[_matchKey] || null;
          var _isLive  = m.status === 'live';
          var _ddmm = ''; var _hhmm = m.time || '--:--';
          try {
            if (m.matchTs) {
              var _d = new Date(m.matchTs);
              _ddmm = String((_d.getUTCDate()+(_d.getUTCHours()>=17?1:0))).padStart(2,'0');
              var _vn = new Date(m.matchTs + 7*3600*1000);
              _ddmm = String(_vn.getUTCDate()).padStart(2,'0') + '/' + String(_vn.getUTCMonth()+1).padStart(2,'0');
              _hhmm = String(_vn.getUTCHours()).padStart(2,'0')+':'+String(_vn.getUTCMinutes()).padStart(2,'0');
            }
          } catch(e){}
        %>
          <div class="lps-match-row" data-time="<%= m.matchTs || 0 %>">
            <!-- Cột 1: Time -->
            <div class="lps-col-time">
              <span class="lps-time-box"><%= _hhmm %> <%= _ddmm %></span>
            </div>
            <!-- Cột 2: Home team (name + logo, align right) -->
            <div class="lps-col-home">
              <span class="lps-team-name truncate"><%= m.home || '?' %></span>
              <span class="lps-team-logo">
                <% if (m.homeBadge) { %>
                  <img src="<%= m.homeBadge %>" alt="<%= m.home %>" loading="lazy" onerror="this.outerHTML='<span class=&quot;lps-team-letter&quot;>'+'<%= (m.home||'?').replace(/&apos;/g,'&apos;')[0] %>'+'</span>'">
                <% } else { %>
                  <span class="lps-team-letter"><%= (m.home||'?')[0] %></span>
                <% } %>
              </span>
            </div>
            <!-- Cột 3: VS / Score -->
            <div class="lps-col-vs">
              <% if (m.score && _isLive) { %>
                <span class="text-live font-black"><%= m.score[0] %> - <%= m.score[1] %></span>
              <% } else { %>
                <span class="text-muted font-bold">VS</span>
              <% } %>
            </div>
            <!-- Cột 4: Away team (logo + name, align left) -->
            <div class="lps-col-away">
              <span class="lps-team-logo">
                <% if (m.awayBadge) { %>
                  <img src="<%= m.awayBadge %>" alt="<%= m.away %>" loading="lazy" onerror="this.outerHTML='<span class=&quot;lps-team-letter&quot;>'+'<%= (m.away||'?').replace(/&apos;/g,'&apos;')[0] %>'+'</span>'">
                <% } else { %>
                  <span class="lps-team-letter"><%= (m.away||'?')[0] %></span>
                <% } %>
              </span>
              <span class="lps-team-name truncate"><%= m.away || '?' %></span>
            </div>
            <!-- Cột 5: Action buttons -->
            <div class="lps-col-actions">
              <% if (_hasBlv || _isLive) { %>
                <a href="/live/<%= m.slug || m.id %>" class="lps-btn-live" title="BLV đang tường thuật trận này">
                  <% if (_isLive) { %><span class="lps-live-dot"></span><% } %>
                  Xem trực tiếp
                </a>
              <% } %>
              <% if (_articleSlug) { %>
                <a href="/tin-tuc/<%= _articleSlug %>" class="lps-btn-predict" title="Bài nhận định &amp; soi kèo">
                  <svg viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5"><path d="M9 21c0 .55.45 1 1 1h4c.55 0 1-.45 1-1v-1H9v1zm3-19C8.14 2 5 5.14 5 9c0 2.38 1.19 4.47 3 5.74V17c0 .55.45 1 1 1h6c.55 0 1-.45 1-1v-2.26c1.81-1.27 3-3.36 3-5.74 0-3.86-3.14-7-7-7z"/></svg>
                  Xem nhận định
                </a>
              <% } %>
              <% if (!_hasBlv && !_isLive && !_articleSlug) { %>
                <a href="/live/<%= m.slug || m.id %>" class="lps-btn-detail">Chi tiết</a>
              <% } %>
            </div>
            <!-- Cột 6: Round/Stage tag -->
            <div class="lps-col-round">
              <% if (m.round) { %>
                <span class="lps-round-tag"><%= m.round %></span>
              <% } %>
            </div>
          </div>
        <% }); %>
      </div>
    <% }); %>
  <% } %>
</section>

<style>
/* ===== DESKTOP LICH PHAT SONG REDESIGN ===== */
.lps-sport-tab {
  display: inline-flex; align-items: center; gap: 8px;
  background: #1a1f29; border: 1px solid #2a3344;
  color: #cbd5e1; padding: 9px 18px; border-radius: 999px;
  font-weight: 700; font-size: 12px;
  transition: all .22s ease; cursor: pointer; text-decoration: none;
}
.lps-sport-tab:hover { background: #232a36; color: #fff; transform: translateY(-1px); }
.lps-sport-tab.is-active {
  background: linear-gradient(135deg, #14b8a6, #0d9488);
  border-color: #14b8a6; color: #fff;
  box-shadow: 0 6px 16px -4px rgba(20,184,166,.45);
}
.lps-sport-ico {
  width: 26px; height: 26px; border-radius: 50%;
  background: rgba(255,255,255,.1);
  display: grid; place-items: center;
}
.lps-sport-tab.is-active .lps-sport-ico { background: rgba(255,255,255,.22); }

.lps-day-btn {
  display: inline-flex; align-items: center; gap: 6px;
  background: transparent; border: 1px solid #2a3344;
  color: #cbd5e1; padding: 5px 12px; border-radius: 6px;
  font-weight: 700; font-size: 12px;
  transition: all .2s; cursor: pointer;
}
.lps-day-btn:hover { color: #fff; border-color: #14b8a6; }
.lps-day-btn.is-active {
  background: rgba(20,184,166,.15); border-color: #14b8a6; color: #14b8a6;
}

.lps-lg-chip {
  background: #1a1f29; border: 1px solid #2a3344;
  color: #cbd5e1; padding: 4px 10px; border-radius: 4px;
  font-weight: 700; font-size: 11px; cursor: pointer;
  transition: all .18s; white-space: nowrap;
}
.lps-lg-chip:hover { background: #232a36; color: #fff; border-color: #ff9a3a; }
.lps-lg-chip.is-active {
  background: linear-gradient(135deg, #ff7a18, #ea580c);
  border-color: #ff7a18; color: #fff;
}

/* League group */
.lps-lg-group { background: transparent; }
.lps-lg-header {
  display: flex; align-items: center; gap: 10px;
  background: linear-gradient(90deg, #1a2230 0%, #141a26 100%);
  border: 1px solid #2a3344; border-bottom: none;
  padding: 9px 14px; border-radius: 6px 6px 0 0;
}
.lps-lg-logo {
  width: 22px; height: 22px; border-radius: 50%;
  background: rgba(255,255,255,.95); color: #1a1f29;
  display: grid; place-items: center; padding: 2px;
  flex-shrink: 0;
}
.lps-lg-logo img { width: 100%; height: 100%; object-fit: contain; }

/* Match row - grid layout */
.lps-match-row {
  display: grid;
  grid-template-columns: 110px 1fr 60px 1fr 200px 110px;
  align-items: center;
  gap: 8px;
  background: #11151c; border: 1px solid #1a2230;
  border-top: none;
  padding: 10px 14px;
  transition: background .15s;
}
.lps-match-row:hover { background: #161b24; }
.lps-match-row:last-child { border-radius: 0 0 6px 6px; }

.lps-col-time { display: flex; }
.lps-time-box {
  background: #1a1f29; border: 1px solid #2a3344;
  color: #fbbf24; padding: 4px 10px; border-radius: 4px;
  font-weight: 800; font-size: 12px; font-family: 'Roboto Mono', monospace;
  white-space: nowrap;
}

.lps-col-home, .lps-col-away {
  display: flex; align-items: center; gap: 10px; min-width: 0;
}
.lps-col-home { justify-content: flex-end; }
.lps-col-away { justify-content: flex-start; }
.lps-team-name {
  color: #e2e8f0; font-weight: 600; font-size: 13px;
  max-width: 180px;
}
.lps-team-logo {
  width: 28px; height: 28px; border-radius: 50%;
  background: #fff; display: grid; place-items: center;
  padding: 2px; flex-shrink: 0;
  overflow: hidden;
}
.lps-team-logo img { width: 100%; height: 100%; object-fit: contain; }
.lps-team-letter {
  color: #1a1f29; font-weight: 800; font-size: 11px;
}

.lps-col-vs {
  text-align: center; font-size: 13px;
}

.lps-col-actions {
  display: flex; gap: 6px; justify-content: center;
}

.lps-btn-live, .lps-btn-predict, .lps-btn-detail {
  display: inline-flex; align-items: center; gap: 5px;
  padding: 6px 14px; border-radius: 4px;
  font-weight: 700; font-size: 11px;
  text-decoration: none; white-space: nowrap;
  transition: all .2s;
}
.lps-btn-live {
  background: #dc2626; color: #fff;
  box-shadow: 0 2px 8px -2px rgba(220,38,38,.55);
}
.lps-btn-live:hover { background: #ef4444; transform: translateY(-1px); box-shadow: 0 4px 12px -2px rgba(220,38,38,.7); }
.lps-live-dot {
  width: 7px; height: 7px; border-radius: 50%; background: #fff;
  animation: lpsLivePulse 1.2s infinite;
}
@keyframes lpsLivePulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: .5; transform: scale(.8); }
}
.lps-btn-predict {
  background: linear-gradient(135deg, #f59e0b, #d97706); color: #fff;
  box-shadow: 0 2px 8px -2px rgba(245,158,11,.55);
}
.lps-btn-predict:hover { filter: brightness(1.1); transform: translateY(-1px); }
.lps-btn-detail {
  background: transparent; border: 1px solid #2a3344; color: #94a3b8;
}
.lps-btn-detail:hover { border-color: #14b8a6; color: #14b8a6; }

.lps-col-round { text-align: right; }
.lps-round-tag {
  display: inline-block;
  background: #1a1f29; border: 1px solid #2a3344;
  color: #94a3b8; padding: 3px 8px; border-radius: 4px;
  font-size: 11px; font-weight: 600;
}

/* Responsive: thu nhỏ cột round trên 1200px */
@media (max-width: 1280px) {
  .lps-match-row {
    grid-template-columns: 100px 1fr 50px 1fr 180px 90px;
    gap: 6px;
  }
  .lps-team-name { max-width: 140px; font-size: 12px; }
}
</style>

<script>
(function(){
  // ===== League filter chips =====
  var chips = document.querySelectorAll('#lpsLeagueChips .lps-lg-chip');
  var groups = document.querySelectorAll('.lps-lg-group');
  chips.forEach(function(c){
    c.addEventListener('click', function(){
      chips.forEach(function(x){ x.classList.remove('is-active'); });
      c.classList.add('is-active');
      var lg = c.getAttribute('data-lg');
      groups.forEach(function(g){
        if (lg === '__all__' || g.getAttribute('data-lg') === lg) {
          g.style.display = '';
        } else {
          g.style.display = 'none';
        }
      });
    });
  });

  // ===== Date picker - chuyển ngày (reload với query) =====
  var dateInput = document.getElementById('lpsDate');
  var todayBtn = document.querySelector('.lps-day-btn[data-mode="today"]');
  if (dateInput) {
    dateInput.addEventListener('change', function(){
      // Tạm thời chỉ scroll lên đầu (API chưa hỗ trợ ?date= ở route này)
      // TODO: nâng cấp route /lich-phat-song?date=YYYY-MM-DD
      var d = dateInput.value;
      var todayIso = new Date().toISOString().slice(0,10);
      if (d !== todayIso) {
        alert('Tính năng chọn ngày khác hôm nay sẽ sớm có. Hiện tại đang hiển thị lịch 3 ngày tới.');
        dateInput.value = todayIso;
      }
    });
  }
  if (todayBtn) {
    todayBtn.addEventListener('click', function(){
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }
})();
</script>

