<!-- 📱 MOBILE layout - redesign theo style OkwinTV -->
<!-- ═══════════════════════════════════════════════════════════════ -->
<div class="md:hidden px-3" id="mobileLich">

  <!-- Title bar: ‹ Lịch Phát Sóng -->
  <div class="flex items-center gap-2 mb-3 mt-1">
    <a href="/" class="text-pri-light text-2xl leading-none" aria-label="Back">‹</a>
    <h2 class="text-pri-light font-extrabold text-xl">Lịch Phát Sóng</h2>
  </div>

  <!-- Day picker - horizontal scroll, 6 ngày -->
  <div class="flex gap-2 overflow-x-auto scrollbar-hide pb-1 mb-3 -mx-3 px-3" id="mLichDays">
    <% _dayPicker.forEach(function(d, i){ %>
      <button class="m-day-pill shrink-0 flex flex-col items-center justify-center min-w-[68px] px-2 py-2 rounded-lg border <%= i===0 ? 'is-active' : '' %>" data-day="<%= d.iso %>" type="button">
        <span class="text-[11px] font-semibold opacity-80 truncate w-full text-center"><%= d.label %></span>
        <span class="text-sm font-extrabold mt-0.5"><%= d.date %></span>
      </button>
    <% }); %>
  </div>

  <!-- Filter chips: 5 cat giống trang chủ - horizontal scroll -->
  <div class="flex gap-2 overflow-x-auto scrollbar-hide pb-1 mb-3 -mx-3 px-3" id="mLichCats">
    <button class="m-cat-pill is-active shrink-0" data-cat="all" type="button">
      <span class="m-cat-ico bg-pri/20 text-pri-light"><%- _svgIco.all %></span>
      <span>Tất cả</span>
    </button>
    <button class="m-cat-pill shrink-0" data-cat="bong-da" type="button">
      <span class="m-cat-ico bg-emerald-500/20 text-emerald-400"><%- _svgIco.bongda %></span>
      <span>Bóng đá</span>
    </button>
    <button class="m-cat-pill shrink-0" data-cat="idol" type="button">
      <span class="m-cat-ico bg-pink-500/20 text-pink-400"><%- _svgIco.idol %></span>
      <span>Idol</span>
    </button>
    <button class="m-cat-pill shrink-0" data-cat="casino" type="button">
      <span class="m-cat-ico bg-amber-500/20 text-amber-400"><%- _svgIco.casino %></span>
      <span>Sòng Bài</span>
    </button>
    <button class="m-cat-pill shrink-0" data-cat="esports" type="button">
      <span class="m-cat-ico bg-violet-500/20 text-violet-400"><%- _svgIco.esports %></span>
      <span>Esport</span>
    </button>
  </div>

  <!-- Match cards list - data thật từ server -->
  <div class="space-y-3" id="mLichList">
    <% if (_allCards.length === 0) { %>
      <div class="p-10 text-center bg-bg-card border border-dashed border-line rounded-xl text-muted">
        <div class="text-4xl mb-2 opacity-60">📥</div>
        <div class="text-sm">Không có trận sắp diễn ra.</div>
      </div>
    <% } else { %>
      <% _allCards.slice(0, 40).forEach(function(card){
        if (card.type === 'idol') {
          // ===== IDOL CARD =====
          var i = card.data;
      %>
        <article class="m-match-card bg-bg-card border border-line rounded-xl overflow-hidden" data-cat="idol" data-date="<%= card.isoDate %>" data-status="<%= i.liveNow ? 'live' : 'upcoming' %>">
          <header class="flex items-center justify-between px-3 py-2 bg-bg-soft/40 border-b border-line">
            <div class="flex items-center gap-1.5 min-w-0">
              <span class="bg-pink-500/20 text-pink-400 w-5 h-5 rounded grid place-items-center text-[11px] shrink-0">👑</span>
              <span class="text-white text-[12px] font-bold truncate">Idol Live Show</span>
            </div>
            <% if (i.liveNow) { %>
              <span class="bg-live text-white text-[10px] font-extrabold px-2 py-0.5 rounded flex items-center gap-1"><span class="w-1.5 h-1.5 bg-white rounded-full animate-pulse-live"></span>LIVE</span>
            <% } else { %>
              <span class="bg-pri/20 text-pri-light text-[10px] font-extrabold px-2 py-0.5 rounded">SẮP LÊN SÓNG</span>
            <% } %>
          </header>
          <a href="/idol/<%= i.id %>" class="flex items-center px-3 py-4 hover:bg-bg-soft/30 active:scale-[.98] transition-all">
            <div class="w-16 h-16 rounded-full overflow-hidden border-2 border-pink-500 shrink-0">
              <img src="<%= i.avatar || ('https://i.pravatar.cc/100?u='+i.id) %>" alt="<%= i.name %>" class="w-full h-full object-cover" onerror="this.outerHTML='<div class=&quot;w-full h-full grid place-items-center text-2xl bg-gradient-to-br from-pink-500 to-purple-600 text-white&quot;>'+'<%= (i.name||'?')[0] %>'+'</div>'">
            </div>
            <div class="flex-1 min-w-0 ml-3">
              <div class="text-white font-extrabold text-base truncate"><%= i.name %></div>
              <div class="text-pri-light text-[11px] font-semibold mt-0.5"><%= i.room || ('Phòng riêng ' + i.name) %></div>
              <% if (i.viewers) { %>
                <div class="text-muted text-[10px] mt-1">👁 <%= i.viewers.toLocaleString('vi-VN') %> đang xem</div>
              <% } %>
            </div>
            <div class="shrink-0">
              <% if (i.lock > 0) { %>
                <span class="bg-yellow-500/20 text-yellow-300 text-[10px] font-bold px-2 py-1 rounded">🔒 <%= i.lock %></span>
              <% } else { %>
                <span class="bg-emerald-500/20 text-emerald-400 text-[10px] font-bold px-2 py-1 rounded">FREE</span>
              <% } %>
            </div>
          </a>
        </article>
      <% } else {
          // ===== MATCH CARD =====
          var m = card.data;
          var _dateStr=''; try { _dateStr = m.date ? new Date(m.date).toLocaleDateString('vi-VN',{day:'2-digit',month:'2-digit',year:'numeric'}) : ''; } catch(e){}
          var _leagueIconKey = _sportToIcoKey[m.sport] || 'trophy';
          var _leagueIconSvg = _svgIco[_leagueIconKey] || _svgIco.trophy;
      %>
        <article class="m-match-card bg-bg-card border border-line rounded-xl overflow-hidden" data-cat="<%= card.cat %>" data-date="<%= card.isoDate %>" data-status="<%= m.status %>">
          <header class="flex items-center justify-between px-3 py-2 bg-bg-soft/40 border-b border-line">
            <div class="flex items-center gap-1.5 min-w-0">
              <% if (m.leagueLogo) { %>
                <span class="inline-flex items-center justify-center bg-white rounded-full shadow-sm shrink-0" style="width:24px;height:24px;padding:2px;">
                  <img src="<%= m.leagueLogo %>" alt="<%= m.league || '' %>" class="w-full h-full object-contain" loading="lazy" decoding="async" onerror="this.parentNode.style.display='none'">
                </span>
              <% } else { %>
                <span class="bg-pri/20 text-pri-light w-5 h-5 rounded grid place-items-center shrink-0"><%- _leagueIconSvg %></span>
              <% } %>
              <span class="text-white text-[12px] font-bold truncate"><%= m.league || m.sport %></span>
            </div>
            <% if (m.status==='live') { %>
              <span class="bg-live text-white text-[10px] font-extrabold px-2 py-0.5 rounded flex items-center gap-1"><span class="w-1.5 h-1.5 bg-white rounded-full animate-pulse-live"></span>LIVE</span>
            <% } else if (m.status==='finished') { %>
              <span class="bg-black/60 text-white text-[10px] font-extrabold px-2 py-0.5 rounded">FT</span>
            <% } else { %>
              <span class="bg-pri/20 text-pri-light text-[10px] font-extrabold px-2 py-0.5 rounded">SẮP DIỄN RA</span>
            <% } %>
          </header>
          <a href="/live/<%= m.slug || m.id %>" class="flex items-center px-3 py-3 hover:bg-bg-soft/30 active:scale-[.98] transition-all">
            <div class="flex-1 flex flex-col items-center gap-1.5 min-w-0">
              <% if (m.homeBadge) { %>
                <div class="w-12 h-12 bg-white rounded-full p-1 shadow shrink-0 grid place-items-center"><img src="<%= m.homeBadge %>" alt="<%= m.home %>" class="w-full h-full object-contain" onerror="this.outerHTML='<span class=&quot;text-xl&quot;>&#9917;</span>'"></div>
              <% } else { %>
                <div class="w-12 h-12 rounded-full bg-bg-deep grid place-items-center text-white font-bold text-base"><%= (m.home||'?')[0] %></div>
              <% } %>
              <div class="text-[11px] text-gray-300 font-semibold text-center truncate w-full px-1"><%= m.home || '?' %></div>
            </div>
            <div class="px-3 text-center shrink-0">
              <% if (m.score) { %>
                <div class="text-xl font-black text-white"><%= m.score[0] %> : <%= m.score[1] %></div>
              <% } else { %>
                <div class="text-xl font-black text-white"><%= m.time || 'VS' %></div>
              <% } %>
              <% if (_dateStr) { %>
                <div class="inline-block bg-pri text-white text-[10px] font-bold px-2 py-0.5 rounded mt-1"><%= _dateStr %></div>
              <% } %>
            </div>
            <div class="flex-1 flex flex-col items-center gap-1.5 min-w-0">
              <% if (m.awayBadge) { %>
                <div class="w-12 h-12 bg-white rounded-full p-1 shadow shrink-0 grid place-items-center"><img src="<%= m.awayBadge %>" alt="<%= m.away %>" class="w-full h-full object-contain" onerror="this.outerHTML='<span class=&quot;text-xl&quot;>&#9917;</span>'"></div>
              <% } else { %>
                <div class="w-12 h-12 rounded-full bg-bg-deep grid place-items-center text-white font-bold text-base"><%= (m.away||'?')[0] %></div>
              <% } %>
              <div class="text-[11px] text-gray-300 font-semibold text-center truncate w-full px-1"><%= m.away || '?' %></div>
            </div>
          </a>
          <% if (card.blvs && card.blvs.length > 0) { %>
          <footer class="flex items-center gap-2 px-3 py-2 border-t border-line bg-bg-deep/40">
            <div class="flex-1 flex items-center gap-3 overflow-x-auto scrollbar-hide">
              <% card.blvs.forEach(function(blv, _bi){
                var _colors = ['from-pri to-live','from-emerald-500 to-emerald-700','from-violet-500 to-purple-700','from-sky-500 to-blue-700'];
                var _color = _colors[_bi % _colors.length];
              %>
                <a href="/live/<%= m.slug || m.id %>" class="flex items-center gap-1.5 shrink-0">
                  <% if (blv.avatar) { %>
                    <img src="<%= blv.avatar %>" class="w-6 h-6 rounded-full object-cover border border-line" alt="<%= blv.name %>" onerror="this.outerHTML='<div class=&quot;w-6 h-6 rounded-full bg-gradient-to-br <%= _color %> grid place-items-center text-white text-[10px] font-bold&quot;>'+'<%= (blv.name||'?')[0] %>'+'</div>'">
                  <% } else { %>
                    <div class="w-6 h-6 rounded-full bg-gradient-to-br <%= _color %> grid place-items-center text-white text-[10px] font-bold"><%= (blv.name||'?')[0] %></div>
                  <% } %>
                  <span class="text-gray-200 text-[11px] font-semibold truncate max-w-[100px]"><%= blv.name %></span>
                  <% if (blv.liveNow) { %><span class="bg-live text-white text-[8px] font-extrabold px-1 rounded">LIVE</span><% } %>
                </a>
              <% }); %>
            </div>
          </footer>
          <% } %>
        </article>
      <% } }); %>
    <% } %>
  </div>
</div>

<style>
/* ===== MOBILE LICH PHAT SONG ===== */
/* Day picker pills */
.m-day-pill {
  background: #1a1f29; border-color: #2a3344; color: #94a3b8;
  transition: all .15s;
}
.m-day-pill.is-active {
  background: linear-gradient(135deg, #ff7a18, #ea580c);
  border-color: #ff7a18; color: #fff;
  box-shadow: 0 4px 12px rgba(255, 122, 24, .35);
}
.m-day-pill:active { transform: scale(.96); }

/* Cat pill - horizontal scroll giống trang chủ */
.m-cat-pill {
  display: flex; align-items: center; gap: 6px;
  padding: 6px 12px 6px 6px; border-radius: 999px;
  background: #1a1f29; border: 1px solid #2a3344;
  color: #cbd5e1; font-size: 12px; font-weight: 700;
  transition: all .15s; white-space: nowrap;
}
.m-cat-pill:active { transform: scale(.95); }
.m-cat-pill.is-active {
  background: linear-gradient(135deg, #ff7a18, #ea580c);
  border-color: #ff7a18; color: #fff;
  box-shadow: 0 4px 12px rgba(255, 122, 24, .35);
}
.m-cat-pill.is-active .m-cat-ico {
  background: rgba(255,255,255,.18) !important;
  color: #fff !important;
}
.m-cat-ico {
  width: 26px; height: 26px; border-radius: 50%;
  display: grid; place-items: center;
  font-size: 13px;
}
</style>

<script>
(function(){
  // Day picker click
  document.querySelectorAll('#mLichDays .m-day-pill').forEach(function(b){
    b.addEventListener('click', function(){
      document.querySelectorAll('#mLichDays .m-day-pill').forEach(function(x){ x.classList.remove('is-active'); });
      b.classList.add('is-active');
      applyFilter();
    });
  });
  // Cat pill click - single select
  document.querySelectorAll('#mLichCats .m-cat-pill').forEach(function(c){
    c.addEventListener('click', function(){
      document.querySelectorAll('#mLichCats .m-cat-pill').forEach(function(x){ x.classList.remove('is-active'); });
      c.classList.add('is-active');
      applyFilter();
    });
  });

  function applyFilter(){
    var activeCat = document.querySelector('#mLichCats .m-cat-pill.is-active');
    var catFilter = activeCat ? activeCat.getAttribute('data-cat') : 'all';
    if (catFilter === 'all') catFilter = null;

    var activeDay = document.querySelector('#mLichDays .m-day-pill.is-active');
    var dayFilter = activeDay ? activeDay.getAttribute('data-day') : null;

    var cards = document.querySelectorAll('#mLichList .m-match-card');
    var shown = 0;
    cards.forEach(function(card){
      var cat = card.getAttribute('data-cat');
      var date = card.getAttribute('data-date');
      var match = true;
      if (catFilter && cat !== catFilter) match = false;
      if (dayFilter && date !== dayFilter) match = false;
      card.style.display = match ? '' : 'none';
      if (match) shown++;
    });

    // Show empty state nếu không có card nào
    var emptyId = 'mLichEmpty';
    var emptyEl = document.getElementById(emptyId);
    if (shown === 0) {
      if (!emptyEl) {
        emptyEl = document.createElement('div');
        emptyEl.id = emptyId;
        emptyEl.className = 'p-10 text-center bg-bg-card border border-dashed border-line rounded-xl text-muted';
        emptyEl.innerHTML = '<div class="text-4xl mb-2 opacity-60">📥</div><div class="text-sm">Không có trận khớp bộ lọc.</div>';
        document.getElementById('mLichList').appendChild(emptyEl);
      }
    } else {
      if (emptyEl) emptyEl.remove();
    }
  }
})();
</script>

<%- include('partials/tw-footer') %>
