<%
var _today = new Date(); var _todayVi = _today.getDate()+'/'+(_today.getMonth()+1)+'/'+_today.getFullYear();
var _catName = sport ? (cats[sport] && cats[sport].name || '') : '';
seo = {
  title: 'Lịch Phát Sóng Bóng Đá '+_todayVi+' | XOSO66 TV',
  description: 'Lịch phát sóng bóng đá '+_todayVi+' & ngày mai. Xem trực tiếp Full HD '+list.length+' trận NHA, La Liga, V-League cùng BLV tiếng Việt tại XOSO66.',
  keywords: 'lịch phát sóng bóng đá, lịch thi đấu bóng đá hôm nay, xem trực tiếp bóng đá, xoso66, xổ số 66, xoso66 tv',
  canonical: '/lich-phat-song'+(sport?'?mon='+sport:''),
  breadcrumb: [{ name:'Lịch phát sóng bóng đá', url:'/lich-phat-song' }].concat(sport?[{ name:_catName, url:'/lich-phat-song?mon='+sport }]:[])
};

// ===== Mobile day picker - sinh 6 ngày liên tiếp =====
var _vnDays = ['Chủ nhật','Thứ 2','Thứ 3','Thứ 4','Thứ 5','Thứ 6','Thứ 7'];
var _dayPicker = [];
for (var _di=0; _di<6; _di++) {
  var _d = new Date(); _d.setDate(_d.getDate() + _di);
  var _dd = String(_d.getDate()).padStart(2,'0');
  var _mm = String(_d.getMonth()+1).padStart(2,'0');
  var _label = _di===0 ? 'Hôm nay' : _di===1 ? 'Ngày mai' : _vnDays[_d.getDay()];
  _dayPicker.push({ label: _label, date: _dd+'-'+_mm, key: _dd+_mm, iso: _d.toISOString().slice(0,10) });
}

// ===== DATA THẬT =====
var _blvList = (typeof blvs !== 'undefined' && blvs) ? blvs : [];
var _idolList = (typeof idols !== 'undefined' && idols) ? idols : [];

// Helper: assign 2 BLV deterministic cho mỗi match (dựa trên match.id)
function _pickBlvs(matchId){
  if (_blvList.length === 0) return [];
  // Hash đơn giản từ ID để pick stable
  var h = 0; var s = String(matchId || '');
  for (var i=0; i<s.length; i++) h = (h*31 + s.charCodeAt(i)) & 0xfff;
  var a = _blvList[h % _blvList.length];
  var b = _blvList.length > 1 ? _blvList[(h*7) % _blvList.length] : null;
  if (b && b.id === a.id) b = _blvList[(h*7+1) % _blvList.length];
  return b ? [a, b] : [a];
}

// Build allCards: matches + idol cards (cat=idol)
var _allCards = [];
// 1. Sports matches
(list || []).forEach(function(m){
  var _isoDate = '';
  try { if (m.date) _isoDate = new Date(m.date).toISOString().slice(0,10); } catch(e){}
  var _cat = m.sport==='Soccer' ? 'bong-da'
           : m.sport==='Basketball' ? 'bong-ro'
           : m.sport==='Tennis' ? 'tennis'
           : m.sport==='Volleyball' ? 'bong-chuyen'
           : m.sport==='Esports' ? 'esports' : 'khac';
  _allCards.push({
    type: 'match',
    cat: _cat,
    isoDate: _isoDate || _dayPicker[0].iso,
    data: m,
    blvs: _pickBlvs(m.id || m.slug)
  });
});
// 2. Idol cards (cat=idol) - mỗi idol là 1 "lịch" stream
_idolList.forEach(function(i){
  if (i.category && i.category !== 'idol') return; // skip casino/bongda idols (đã thuộc cat khác)
  _allCards.push({
    type: 'idol',
    cat: 'idol',
    isoDate: _dayPicker[0].iso, // idol live mặc định hôm nay
    data: i,
    blvs: []
  });
});
%>
