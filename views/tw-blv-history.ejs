<%
seo = { title: 'Lịch Sử BLV - ' + brand.name, description: 'Lịch sử đăng ký trận BLV', canonical: '/blv-history', noindex: true };
var _blvName = (typeof myBlvName !== 'undefined') ? myBlvName : 'BLV';
var _schedules = (typeof schedules !== 'undefined' && Array.isArray(schedules)) ? schedules : [];
function _statusBadge(s){
  if (s === 'approved') return '<span class="px-2 py-0.5 bg-emerald-600 text-white text-[10px] font-extrabold rounded">ĐÃ DUYỆT</span>';
  if (s === 'rejected') return '<span class="px-2 py-0.5 bg-red-600 text-white text-[10px] font-extrabold rounded">TỪ CHỐI</span>';
  return '<span class="px-2 py-0.5 bg-amber-600 text-white text-[10px] font-extrabold rounded animate-pulse">CHỜ DUYỆT</span>';
}
function _fmt(ts){
  if (!ts) return '-';
  var d = new Date(ts);
  return ('0'+d.getDate()).slice(-2)+'/'+('0'+(d.getMonth()+1)).slice(-2)+'/'+d.getFullYear()+' '+('0'+d.getHours()).slice(-2)+':'+('0'+d.getMinutes()).slice(-2);
}
%>
<%- include('partials/tw-layout-start') %>

<section class="max-w-6xl mx-auto mb-6 px-2 md:px-4">
  <div class="flex items-center gap-3 mb-3 bg-bg-card border border-line rounded-xl p-3">
    <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-pri to-rose-500 grid place-items-center text-xl">🎙️</div>
    <div class="flex-1 min-w-0"><div class="text-sm font-bold text-white truncate"><%= _blvName %></div><div class="text-[10.5px] text-muted">Bình luận viên</div></div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-[220px_minmax(0,1fr)] gap-4">
    <%- include('partials/tw-blv-sidebar', { activeBlv: 'history', myBlvName: _blvName }) %>

    <main class="space-y-4 min-w-0">
      <div class="bg-bg-card border border-line rounded-xl p-4">
        <h2 class="text-white font-extrabold text-lg flex items-center gap-2 mb-2">
          <span class="text-2xl">📜</span> Lịch Sử Đăng Ký BLV
        </h2>
        <p class="text-[12px] text-muted">Tất cả yêu cầu đăng ký BLV của bạn — đang chờ duyệt, đã duyệt, hoặc bị từ chối.</p>
        <!-- Filter -->
        <div class="flex gap-2 mt-3 flex-wrap">
          <button onclick="filterStatus('')" class="filter-btn bg-pri text-white text-xs font-bold px-3 py-1.5 rounded-lg" data-st="">Tất cả (<%= _schedules.length %>)</button>
          <button onclick="filterStatus('pending')" class="filter-btn bg-bg-deep border border-line text-gray-200 text-xs font-bold px-3 py-1.5 rounded-lg" data-st="pending">⏳ Chờ duyệt</button>
          <button onclick="filterStatus('approved')" class="filter-btn bg-bg-deep border border-line text-gray-200 text-xs font-bold px-3 py-1.5 rounded-lg" data-st="approved">✅ Đã duyệt</button>
          <button onclick="filterStatus('rejected')" class="filter-btn bg-bg-deep border border-line text-gray-200 text-xs font-bold px-3 py-1.5 rounded-lg" data-st="rejected">❌ Từ chối</button>
        </div>
      </div>

      <div class="bg-bg-card border border-line rounded-xl p-4">
        <% if (_schedules.length === 0) { %>
          <div class="text-center py-10 text-muted">
            <div class="text-5xl mb-2 opacity-60">📭</div>
            <div class="text-sm font-bold mb-1">Chưa có yêu cầu nào</div>
            <div class="text-xs">Vào <a href="/blv-register" class="text-pri-light underline">📝 Đăng Ký BLV</a> để chọn trận đầu tiên.</div>
          </div>
        <% } else { %>
          <div class="space-y-2.5" id="schList">
            <% _schedules.forEach(function(s){ %>
              <div class="bg-bg-deep border border-line rounded-xl p-3 sch-item" data-status="<%= s.status %>">
                <div class="flex items-start justify-between gap-3 flex-wrap">
                  <div class="flex-1 min-w-0">
                    <div class="text-sm font-extrabold text-white truncate"><%= s.title || (s.matchTitle || 'Buổi live') %></div>
                    <div class="text-[11px] text-muted mt-0.5 flex items-center gap-2 flex-wrap">
                      <span>📅 <%= _fmt(s.startTime) %></span>
                      <span>→ <%= _fmt(s.endTime) %></span>
                      <% if (s.matchTitle && s.title !== s.matchTitle) { %><span>· ⚽ <%= s.matchTitle %></span><% } %>
                      <% if (s.description) { %><span>· 🏆 <%= s.description %></span><% } %>
                    </div>
                    <% if (s.rejectReason) { %>
                      <div class="text-[11px] text-red-300 mt-1 bg-red-900/20 border border-red-500/30 rounded px-2 py-1">💬 Lý do: <%= s.rejectReason %></div>
                    <% } %>
                  </div>
                  <div class="flex items-center gap-2 shrink-0">
                    <%- _statusBadge(s.status) %>
                    <% if (s.status === 'pending') { %>
                      <button onclick="cancelSch('<%= s.id %>')" class="bg-bg-soft border border-line hover:border-red-500 text-gray-200 hover:text-red-300 text-xs font-bold px-3 py-1 rounded-lg">🗑 Hủy</button>
                    <% } else if (s.status === 'approved') { %>
                      <a href="/blv-obs" class="bg-emerald-600 hover:bg-emerald-500 text-white text-xs font-bold px-3 py-1 rounded-lg">📡 Kết nối OBS</a>
                    <% } %>
                  </div>
                </div>
              </div>
            <% }); %>
          </div>
        <% } %>
      </div>
    </main>
  </div>
</section>

<script>
window.filterStatus = function(st){
  document.querySelectorAll('.filter-btn').forEach(function(b){
    if (b.dataset.st === st) { b.classList.remove('bg-bg-deep','border','border-line','text-gray-200'); b.classList.add('bg-pri','text-white'); }
    else { b.classList.add('bg-bg-deep','border','border-line','text-gray-200'); b.classList.remove('bg-pri','text-white'); }
  });
  document.querySelectorAll('.sch-item').forEach(function(it){
    it.style.display = (!st || it.dataset.status === st) ? '' : 'none';
  });
};
window.cancelSch = function(id){
  if (!confirm('Hủy yêu cầu này?')) return;
  fetch('/api/schedule/' + encodeURIComponent(id), { method:'DELETE', credentials:'include' })
    .then(function(r){ return r.json(); })
    .then(function(j){ if (j.ok) location.reload(); else alert('Lỗi: ' + (j.error||'fail')); });
};
</script>
