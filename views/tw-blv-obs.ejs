<%
seo = {
  title: 'Kết nối OBS - BLV - ' + brand.name,
  description: 'Quản lý kết nối OBS cho BLV - tạo stream key theo từng trận đấu',
  canonical: '/blv-obs',
  noindex: true
};
var _user = (typeof publicUser !== 'undefined' && publicUser) ? publicUser : null;
var _blvName = (typeof myBlvName !== 'undefined') ? myBlvName : (_user ? _user.username : 'BLV');
var _selectedDate = (typeof selectedDate !== 'undefined' && selectedDate) ? selectedDate : (new Date().toISOString().slice(0,10));
var _matches = (typeof matches !== 'undefined' && Array.isArray(matches)) ? matches : [];
var _maxConcurrent = (typeof maxConcurrent !== 'undefined') ? maxConcurrent : 3;
%>
<%- include('partials/tw-layout-start') %>

<section class="max-w-6xl mx-auto mb-6 px-2 md:px-4">

  <!-- HEADER NHỎ -->
  <div class="flex items-center gap-3 mb-3 bg-bg-card border border-line rounded-xl p-3">
    <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-pri to-rose-500 grid place-items-center text-xl shrink-0">🎙️</div>
    <div class="flex-1 min-w-0">
      <div class="text-sm font-bold text-white truncate"><%= _blvName %></div>
      <div class="text-[10.5px] text-muted">Bình luận viên</div>
    </div>
    <span class="inline-flex items-center gap-1 bg-bg-deep text-emerald-400 text-[10px] font-bold px-2 py-1 rounded-full border border-line">
      <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span> READY
    </span>
  </div>

  <!-- LAYOUT 2 CỘT -->
  <div class="grid grid-cols-1 md:grid-cols-[220px_minmax(0,1fr)] gap-4">

    <!-- ═══════════ SIDEBAR ═══════════ -->
    <%- include('partials/tw-blv-sidebar', { activeBlv: 'obs', myBlvName: _blvName }) %>

    <!-- ═══════════ MAIN ═══════════ -->
    <main class="space-y-4 min-w-0">

      <!-- HEADER + DATE PICKER -->
      <div class="bg-bg-card border border-line rounded-xl p-4">
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-3 mb-2">
          <h2 class="text-white font-extrabold text-lg flex items-center gap-2">
            <span class="text-2xl">📡</span>
            Kết Nối OBS Với Trận Đấu
          </h2>
          <form action="/blv-obs" method="get" class="flex items-center gap-2">
            <label class="text-xs text-muted font-bold">Chọn ngày:</label>
            <input type="date" name="date" value="<%= _selectedDate %>"
                   class="bg-bg-deep border border-line text-white text-sm px-2 py-1.5 rounded-lg outline-none focus:border-pri">
            <button type="submit" class="bg-emerald-600 hover:bg-emerald-500 text-white text-xs font-bold px-3 py-1.5 rounded-lg">🔍 Lọc</button>
          </form>
        </div>
        <p class="text-[12px] text-muted leading-relaxed">
          Tạo stream key cho 1 trận → copy <b>RTMP URL</b> + <b>Stream Key</b> vào OBS → bắt đầu phát.
          Mỗi trận tối đa <b class="text-pri-light"><%= _maxConcurrent %> BLV</b> live song song.
        </p>
        <div class="mt-2 text-[11px] text-amber-300 bg-amber-900/20 border border-amber-500/30 rounded-lg px-2.5 py-2 flex items-center gap-2">
          <span>⚠️</span>
          <span>Bạn là BLV: chỉ thấy + tạo stream cho các trận đã được <b>Admin duyệt qua</b>
            <a href="/dang-ky-blv" class="text-amber-200 underline font-bold ml-1">Đăng ký BLV</a></span>
        </div>
      </div>

      <!-- LIST TRẬN ĐƯỢC DUYỆT -->
      <div class="bg-bg-card border border-line rounded-xl p-4" id="matches">
        <div class="flex items-center justify-between mb-3 flex-wrap gap-2">
          <h3 class="text-white font-bold text-base flex items-center gap-2">
            <span>🌐</span>
            Trận bạn được duyệt làm BLV
            <span class="text-pri-light text-sm">(<span id="matchCount"><%= _matches.length %></span>)</span>
          </h3>
          <input type="text" id="matchSearch" placeholder="🔍 Tìm theo tên đội, giải, giờ..."
                 class="flex-1 max-w-xs bg-bg-deep border border-line text-white text-xs px-3 py-1.5 rounded-lg outline-none focus:border-pri">
        </div>

        <div id="matchList" class="space-y-3">
          <% if (_matches.length === 0) { %>
            <div class="text-center py-10 text-muted">
              <div class="text-5xl mb-2 opacity-60">📭</div>
              <div class="text-sm font-bold mb-1">Chưa có trận nào được duyệt cho ngày này</div>
              <div class="text-xs">
                Gửi yêu cầu duyệt trận đấu với admin trước.
                <a href="#" id="schSubmitFromList" onclick="alert('Tính năng đang cập nhật. Liên hệ admin để được duyệt trận.'); return false;"
                   class="text-pri-light underline">Liên hệ admin</a>
              </div>
            </div>
          <% } else { %>
            <% _matches.forEach(function(m){ %>
              <%
                var matchTitle = (m.home || '?') + ' vs ' + (m.away || '?');
                var hasKey = !!(m.streamKey);
                var isLive = !!m.isLive;
                var isEnded = !!m.isEnded;
              %>
              <div class="bg-bg-deep border border-line rounded-xl p-4 hover:border-pri/40 transition-colors match-card" data-search="<%= (m.home + ' ' + m.away + ' ' + (m.league || '')).toLowerCase() %>">
                <!-- Title row -->
                <div class="flex items-start justify-between gap-3 mb-2 flex-wrap">
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 flex-wrap">
                      <span class="text-base font-extrabold text-white"><%= m.home || '?' %></span>
                      <span class="text-muted text-xs">vs</span>
                      <span class="text-base font-extrabold text-white"><%= m.away || '?' %></span>
                      <% if (m.score) { %>
                        <span class="ml-1 px-2 py-0.5 bg-emerald-600/20 border border-emerald-500/40 text-emerald-300 font-bold rounded text-xs"><%= m.score %></span>
                      <% } %>
                    </div>
                    <div class="text-[11.5px] text-muted mt-1 flex items-center gap-2 flex-wrap">
                      <% if (m.league) { %><span>🏆 <%= m.league %></span><% } %>
                      <% if (m.time) { %><span>· ⏰ <%= m.time %></span><% } %>
                      <% if (m.dateStr) { %><span>· 📅 <%= m.dateStr %></span><% } %>
                    </div>
                  </div>
                  <div class="flex items-center gap-2 shrink-0">
                    <% if (isEnded) { %>
                      <span class="px-2.5 py-1 bg-gray-700 text-gray-300 text-[10px] font-extrabold rounded">ĐÃ KẾT THÚC</span>
                    <% } else if (isLive) { %>
                      <span class="px-2.5 py-1 bg-red-600 text-white text-[10px] font-extrabold rounded animate-pulse">🔴 LIVE</span>
                    <% } %>
                    <% if (!hasKey && !isEnded) { %>
                      <button onclick="blvCreateStream('<%= m.scheduleId %>', '<%= m.id %>')" class="bg-emerald-600 hover:bg-emerald-500 text-white text-xs font-bold px-3 py-1.5 rounded-lg flex items-center gap-1.5">
                        <span>📡</span> Tạo Stream OBS
                      </button>
                    <% } %>
                    <button class="bg-purple-600 hover:bg-purple-500 text-white text-xs font-bold px-3 py-1.5 rounded-lg flex items-center gap-1.5">
                      <span>⚙️</span> Cấu hình share
                    </button>
                  </div>
                </div>

                <!-- OBS Config block (chỉ hiện khi đã có key) -->
                <% if (hasKey) { %>
                <div class="mt-3 bg-bg-card border border-line rounded-lg p-3 space-y-2">
                  <div class="flex items-center gap-2 mb-1">
                    <span class="text-pri-light font-bold text-xs flex items-center gap-1.5">📺 CẤU HÌNH OBS</span>
                    <span class="px-2 py-0.5 bg-emerald-600 text-white text-[9px] font-extrabold rounded">SRS LIVE</span>
                  </div>
                  <!-- RTMP -->
                  <div>
                    <div class="text-[10px] text-muted uppercase font-bold mb-1">Server (RTMP):</div>
                    <div class="flex gap-2">
                      <input readonly value="<%= m.rtmpUrl || 'rtmp://stream.xoso66tv.com:1936/live' %>"
                             class="flex-1 bg-bg-deep border border-line text-emerald-300 text-xs px-2.5 py-1.5 rounded-lg font-mono">
                      <button onclick="blvCopy('<%= m.rtmpUrl || 'rtmp://stream.xoso66tv.com:1936/live' %>', this)"
                              class="bg-blue-600 hover:bg-blue-500 text-white text-xs font-bold px-3 py-1.5 rounded-lg flex items-center gap-1">📋 Copy</button>
                    </div>
                  </div>
                  <!-- Stream Key -->
                  <div>
                    <div class="text-[10px] text-muted uppercase font-bold mb-1">Stream Key:</div>
                    <div class="flex gap-2">
                      <input readonly value="<%= m.streamKey %>"
                             class="flex-1 bg-orange-900/30 border border-orange-500/40 text-orange-200 text-xs px-2.5 py-1.5 rounded-lg font-mono">
                      <button onclick="blvCopy('<%= m.streamKey %>', this)"
                              class="bg-orange-600 hover:bg-orange-500 text-white text-xs font-bold px-3 py-1.5 rounded-lg flex items-center gap-1">📋 Copy</button>
                    </div>
                  </div>
                  <!-- HLS Public -->
                  <% if (m.hlsUrl) { %>
                  <div>
                    <div class="text-[10px] text-muted uppercase font-bold mb-1">HLS Public:</div>
                    <div class="flex gap-2">
                      <input readonly value="<%= m.hlsUrl %>"
                             class="flex-1 bg-bg-deep border border-line text-blue-300 text-xs px-2.5 py-1.5 rounded-lg font-mono">
                      <button onclick="blvCopy('<%= m.hlsUrl %>', this)"
                              class="bg-blue-600 hover:bg-blue-500 text-white text-xs font-bold px-3 py-1.5 rounded-lg flex items-center gap-1">📋 Copy</button>
                    </div>
                  </div>
                  <% } %>

                  <div class="bg-emerald-900/20 border border-emerald-500/30 rounded-lg px-2.5 py-1.5 text-[11px] text-emerald-300 flex items-center gap-1.5 mt-1">
                    <span>⚡</span>
                    <span>Stream phát qua VPS SRS · bypass Cloudflare timeout. Có thể scale <b>~5-10K viewers</b>.</span>
                  </div>

                  <!-- Action buttons -->
                  <div class="flex flex-wrap gap-2 mt-2">
                    <button class="bg-bg-deep border border-line text-gray-200 hover:border-pri text-xs font-bold px-3 py-1.5 rounded-lg flex items-center gap-1.5">📖 Hướng dẫn OBS</button>
                    <button onclick="blvGoLive('<%= m.scheduleId %>')" class="bg-gradient-to-r from-red-600 to-rose-600 hover:brightness-110 text-white text-xs font-bold px-3 py-1.5 rounded-lg flex items-center gap-1.5">
                      <span>🔴</span> Bắt đầu LIVE
                    </button>
                    <button class="bg-purple-600 hover:bg-purple-500 text-white text-xs font-bold px-3 py-1.5 rounded-lg flex items-center gap-1.5">⚙️ Cấu hình share RIÊNG (BLV)</button>
                    <button onclick="blvRegenKey('<%= m.scheduleId %>')" class="bg-amber-600 hover:bg-amber-500 text-white text-xs font-bold px-3 py-1.5 rounded-lg flex items-center gap-1.5">🔑 Sinh lại Key</button>
                    <button onclick="blvDeleteStream('<%= m.scheduleId %>')" class="ml-auto bg-red-600 hover:bg-red-500 text-white text-xs font-bold px-3 py-1.5 rounded-lg flex items-center gap-1.5">🗑 Xóa</button>
                  </div>
                </div>
                <% } %>
              </div>
            <% }); %>
          <% } %>
        </div>
      </div>
    </main>
  </div>
</section>

<script>
(function(){
  // Search filter
  var searchInput = document.getElementById('matchSearch');
  if (searchInput) {
    searchInput.addEventListener('input', function(){
      var q = this.value.toLowerCase().trim();
      document.querySelectorAll('.match-card').forEach(function(card){
        var data = card.getAttribute('data-search') || '';
        card.style.display = data.indexOf(q) >= 0 ? '' : 'none';
      });
    });
  }

  window.blvCopy = function(text, btn){
    if (navigator.clipboard) {
      navigator.clipboard.writeText(text).then(function(){
        var orig = btn.innerHTML; btn.innerHTML = '✓ Copied!';
        setTimeout(function(){ btn.innerHTML = orig; }, 1500);
      });
    } else {
      var ta = document.createElement('textarea'); ta.value = text; document.body.appendChild(ta);
      ta.select(); document.execCommand('copy'); document.body.removeChild(ta);
      alert('Đã copy: ' + text);
    }
  };

  window.blvCreateStream = function(scheduleId, matchId){
    if (!confirm('Tạo Stream Key cho trận này?')) return;
    fetch('/api/blv/match/' + encodeURIComponent(scheduleId) + '/stream-key', {
      method: 'POST', credentials: 'include',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ matchId: matchId })
    })
    .then(function(r){ return r.json(); })
    .then(function(j){
      if (j.ok) { location.reload(); }
      else alert('Lỗi: ' + (j.error || 'Không tạo được'));
    })
    .catch(function(e){ alert('Lỗi mạng: ' + e.message); });
  };

  window.blvRegenKey = function(scheduleId){
    if (!confirm('Sinh lại Stream Key mới? Key cũ sẽ ngưng hoạt động.')) return;
    fetch('/api/blv/match/' + encodeURIComponent(scheduleId) + '/regen-key', {
      method: 'POST', credentials: 'include'
    })
    .then(function(r){ return r.json(); })
    .then(function(j){
      if (j.ok) { location.reload(); } else alert('Lỗi: ' + (j.error || 'Fail'));
    });
  };

  window.blvDeleteStream = function(scheduleId){
    if (!confirm('Xóa stream + ngưng phát?')) return;
    fetch('/api/blv/match/' + encodeURIComponent(scheduleId) + '/delete', {
      method: 'POST', credentials: 'include'
    })
    .then(function(r){ return r.json(); })
    .then(function(j){
      if (j.ok) { location.reload(); } else alert('Lỗi: ' + (j.error || 'Fail'));
    });
  };

  window.blvGoLive = function(scheduleId){
    var msg = '📡 HƯỚNG DẪN BẮT ĐẦU LIVE:\n\n' +
              '1️⃣ Mở OBS Studio trên máy tính\n' +
              '2️⃣ Settings → Stream\n' +
              '   • Service: Custom\n' +
              '   • Server: dán RTMP URL ở trên\n' +
              '   • Stream Key: dán Stream Key ở trên\n' +
              '3️⃣ OK → Start Streaming (góc dưới phải)\n\n' +
              '⚠️ Lưu ý:\n' +
              '• Server tự động phát hiện khi OBS publish\n' +
              '• Phòng sẽ hiện trên trang chủ sau ~3 giây\n' +
              '• Nếu OBS báo "Failed to connect" → kiểm tra Stream Key copy đúng chưa';
    alert(msg);
  };
})();
</script>
