<%
seo = {
  title: 'Idol Live Show 24/7 - Trò Chuyện Cùng Hotgirl - '+brand.name,
  description: 'Hàng trăm idol Việt xinh đẹp live show 24/7 tại '+brand.name+'. Phòng chat riêng, dance show, karaoke. Đối tác '+brand.domain+'.',
  keywords: 'idol live, hotgirl live show, live stream idol, '+brand.short,
  canonical: '/idol-live',
  breadcrumb: [{ name:'Idol Live', url:'/idol-live' }],
};
%>
<%- include('partials/layout-start', { title: seo.title, seo }) %>
<%- include('partials/breadcrumb') %>

<header class="partner-hero" style="background:linear-gradient(135deg,#8e44ad,#e91e63,#f39c12)">
  <div style="font-size:64px;margin-bottom:14px">👑</div>
  <h1>Idol Live Show 24/7</h1>
  <p>Hàng trăm idol xinh đẹp - Live show riêng tư - Trò chuyện cùng hotgirl yêu thích</p>
  <a href="<%= partner.idol %>" target="_blank" rel="noopener" class="btn" style="color:#8e44ad">💖 Vào sảnh Idol</a>
</header>

<section class="sec" aria-label="Idol đang live">
  <div class="sec-head">
    <h2 class="ttl">🔥 Top idol đang LIVE</h2>
    <span style="margin-left:auto;color:var(--muted);font-size:13px">Cập nhật realtime từ <%= brand.domain %></span>
  </div>

  <%
    const IDOL_NAMES = ['Linh Trang','Mai Chi','Thảo Vy','Bảo Châu','Khánh Linh','Hồng Nhung','Quỳnh Anh','Phương Mai','Diễm My','Hà My','Bích Phương','Tú Anh','Ngọc Anh','Mỹ Tâm','Hoài Linh','Phạm Quỳnh'];
    const ROOMS = ['Phòng VIP','Phòng riêng','Show riêng','Karaoke','Chat 1-1','Dance show'];
  %>

  <div class="idol-grid">
    <% IDOL_NAMES.forEach((name, i) => {
       const viewers = ((name.charCodeAt(0)+i) * 37) % 9000 + 500;
       const emoji = ['💃','👩','💄','💋','👸','🎤','💖','🌹'][i % 8];
    %>
      <a href="<%= partner.idol %>" target="_blank" rel="noopener" class="idol-card" aria-label="<%= name %> đang live">
        <div class="img" style="background:linear-gradient(135deg, hsl(<%= i*30 %>,70%,40%), hsl(<%= i*30+60 %>,70%,50%))">
          <span class="live">LIVE</span>
          <span class="viewers">👁 <%= viewers.toLocaleString('vi-VN') %></span>
          <%= emoji %>
          <div class="meta">
            <div class="name"><%= name %></div>
            <div class="room"><%= ROOMS[i % ROOMS.length] %> • #<%= 1000 + i %></div>
          </div>
        </div>
      </a>
    <% }); %>
  </div>

  <aside style="margin-top:28px;background:linear-gradient(135deg,#e91e63,#8e44ad);padding:24px;border-radius:12px;color:#fff;text-align:center">
    <h2 style="font-size:20px;font-weight:900;margin-bottom:8px">💎 Trở thành VIP để xem show riêng</h2>
    <p style="opacity:.95;margin-bottom:14px">Nạp tối thiểu 500K nhận ngay 100K voucher idol + đặc quyền show riêng</p>
    <a href="<%= partner.register %>" target="_blank" rel="noopener" style="background:#fff;color:#e91e63;padding:12px 28px;border-radius:8px;font-weight:800;display:inline-block">💖 Đăng ký VIP</a>
  </aside>
</section>

<%- include('partials/seo-bottom', { seoContent: {
  h2:'Idol Live - giải trí đỉnh cao 24/7',
  intro:'<strong>'+brand.name+'</strong> liên kết với các <strong>idol Việt Nam chính chủ</strong>, live show trực tiếp từ studio chuyên nghiệp.',
  sections: [
    { h3:'Phòng phổ thông &amp; phòng riêng', p:'Phòng phổ thông miễn phí, tất cả khách xem được. Phòng riêng VIP cần nạp xu để vào, được tương tác 1-1 với idol.' },
    { h3:'Quà tặng &amp; xếp hạng', p:'Tặng quà cho idol yêu thích, leo top ranking, nhận badge VIP đặc biệt và đặc quyền truy cập sớm phòng độc quyền.' },
  ],
  faqs: [
    { q:'Idol có thật không hay AI?', a:'100% idol thật, live trực tiếp. '+brand.name+' không chấp nhận deepfake hoặc AI generated.' },
    { q:'18+? Có kiểm duyệt nội dung không?', a:'Bắt buộc 18+. Mọi nội dung tuân thủ pháp luật Việt Nam, không có nội dung khiêu dâm.' },
  ]
} }) %>

<%- include('partials/footer') %>
