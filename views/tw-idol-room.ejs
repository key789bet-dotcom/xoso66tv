<%# 🎨 Album coverflow CSS — PHẢI render UNCONDITIONAL (idol không có PIN vẫn cần) %>
<style>
/* ╔══════ ALBUM COVERFLOW (center-stage chuyên nghiệp) ══════╗ */
:root {
  --alb-ease: cubic-bezier(.45,.05,.15,1);
  --alb-dur: .75s;
}
.alb-slider { position: relative; }
.alb-stage {
  position: relative;
  width: 100%;
  height: 460px;
  border-radius: 16px;
  overflow: hidden;
  background: radial-gradient(60% 80% at 50% 30%, #16202e, #06090f 90%);
  box-shadow: 0 18px 50px rgba(0,0,0,.55), inset 0 0 0 1px rgba(255,255,255,.04);
}
.alb-track {
  display: flex;
  gap: 10px;
  height: 100%;
  align-items: stretch;
  padding: 14px;
  box-sizing: border-box;
  width: 100%;
  will-change: transform;
  transition: transform var(--alb-dur) var(--alb-ease);
}
.alb-slide {
  flex: 0 0 88px;
  height: 100%;
  border: 0; padding: 0; margin: 0;
  position: relative; overflow: hidden;
  border-radius: 14px;
  cursor: pointer;
  background-size: cover; background-position: center;
  opacity: .72;
  filter: brightness(.78) saturate(.9);
  transform: scale(.96);
  transition:
    flex-basis var(--alb-dur) var(--alb-ease),
    opacity .55s ease,
    filter .55s ease,
    transform .55s ease,
    box-shadow .55s ease;
  box-shadow: 0 6px 16px rgba(0,0,0,.4);
  outline: 0;
}
.alb-slide:hover { opacity: .92; filter: brightness(.95); }
.alb-slide.is-active {
  flex-basis: min(640px, 70%);
  opacity: 1;
  filter: brightness(1) saturate(1);
  transform: scale(1);
  box-shadow: 0 25px 60px rgba(0,0,0,.75), 0 0 0 2px rgba(255,122,24,.45);
  z-index: 2;
}
.alb-glow {
  position: absolute; inset: 0;
  background:
    radial-gradient(60% 80% at 50% 35%, rgba(255,255,255,.16), transparent 70%),
    linear-gradient(180deg, rgba(0,0,0,0) 45%, rgba(0,0,0,.82) 100%);
  pointer-events: none;
}
.alb-emoji {
  position: absolute; inset: 0;
  display: grid; place-items: center;
  font-size: clamp(40px, 9vw, 130px);
  filter: drop-shadow(0 8px 22px rgba(0,0,0,.55));
  opacity: .85;
  transition: opacity .5s, transform .8s ease-out;
}
.alb-slide.is-active .alb-emoji {
  animation: albFloat 4.5s ease-in-out infinite;
}
@keyframes albFloat { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-10px)} }

.alb-caption {
  position: absolute; left: 18px; bottom: 16px; right: 18px;
  display: flex; align-items: baseline; gap: 12px;
  color: #fff; text-align: left; pointer-events: none;
  opacity: 0; transform: translateY(8px);
  transition: opacity .5s .15s, transform .5s .15s;
}
.alb-slide.is-active .alb-caption { opacity: 1; transform: translateY(0); }
.alb-num {
  font: 800 22px/1 ui-monospace,Menlo,monospace;
  background: linear-gradient(135deg, #ff7a18, #ffd166);
  -webkit-background-clip: text; background-clip: text; color: transparent;
  text-shadow: 0 2px 12px rgba(255,122,24,.4);
  white-space: nowrap;
}
.alb-title {
  font-size: 18px; font-weight: 800;
  text-shadow: 0 2px 12px rgba(0,0,0,.75);
  letter-spacing: .2px;
}
.alb-badge {
  position: absolute; top: 14px; left: 14px;
  background: linear-gradient(135deg, #ff3b3b, #ff7a18);
  color: #fff; font-size: 11px; font-weight: 900;
  padding: 5px 10px; border-radius: 6px;
  box-shadow: 0 6px 16px rgba(255,59,59,.5);
  letter-spacing: .5px;
  opacity: 0; transform: translateY(-4px);
  transition: opacity .4s .2s, transform .4s .2s;
}
.alb-slide.is-active .alb-badge { opacity: 1; transform: translateY(0); }
.alb-zoom {
  position: absolute; top: 14px; right: 14px;
  width: 34px; height: 34px;
  background: rgba(0,0,0,.55); backdrop-filter: blur(8px);
  border-radius: 8px; display: grid; place-items: center;
  color: #fff; font-size: 16px;
  opacity: 0; transform: translateY(-4px);
  transition: opacity .25s, transform .25s, background .2s;
}
.alb-slide.is-active:hover .alb-zoom { opacity: 1; transform: translateY(0); }
.alb-slide.is-active .alb-zoom:hover { background: rgba(255,122,24,.85); }

.alb-arrow {
  position: absolute; top: 50%; transform: translateY(-50%);
  width: 48px; height: 48px;
  background: rgba(0,0,0,.6); backdrop-filter: blur(10px);
  border: 1px solid rgba(255,255,255,.18);
  color: #fff; font-size: 30px; line-height: 1;
  border-radius: 999px;
  display: grid; place-items: center; cursor: pointer;
  transition: background .25s, transform .25s, box-shadow .25s;
  z-index: 10;
  box-shadow: 0 6px 20px rgba(0,0,0,.5);
}
.alb-arrow:hover {
  background: linear-gradient(135deg, #ff7a18, #ff3b3b);
  transform: translateY(-50%) scale(1.1);
  box-shadow: 0 10px 28px rgba(255,122,24,.5);
}
.alb-prev { left: 14px; }
.alb-next { right: 14px; }

.alb-counter {
  position: absolute; top: 14px; left: 50%; transform: translateX(-50%);
  display: inline-flex; align-items: center; gap: 8px;
  background: rgba(0,0,0,.6); backdrop-filter: blur(10px);
  color: #fff; font: 700 12px/1 ui-monospace,Menlo,monospace;
  padding: 7px 12px; border-radius: 999px;
  z-index: 10;
  border: 1px solid rgba(255,255,255,.1);
}
.alb-play {
  background: transparent; border: 0; color: #fff;
  cursor: pointer; font-size: 12px; line-height: 1;
  padding: 0 0 0 8px; border-left: 1px solid rgba(255,255,255,.22);
}

.alb-progress {
  position: absolute; left: 0; right: 0; bottom: 0;
  height: 3px; background: rgba(255,255,255,.06);
  z-index: 10;
}
.alb-progress > span {
  display: block; height: 100%; width: 0%;
  background: linear-gradient(90deg, #ff7a18, #ffd166);
  transition: width .1s linear;
  box-shadow: 0 0 12px rgba(255,122,24,.75);
}

.alb-dots {
  display: flex; justify-content: center; gap: 6px; margin-top: 12px;
}
.alb-dot {
  width: 6px; height: 6px; border-radius: 999px;
  background: rgba(255,255,255,.22); border: 0; cursor: pointer;
  padding: 0; transition: width .3s var(--alb-ease), background .3s;
}
.alb-dot:hover { background: rgba(255,255,255,.4); }
.alb-dot.is-active { width: 26px; background: linear-gradient(90deg, #ff7a18, #ffd166); }

@media (max-width: 768px) {
  .alb-stage { height: 360px; border-radius: 14px; }
  .alb-track { padding: 10px; gap: 6px; }
  .alb-slide { flex-basis: 56px; border-radius: 10px; }
  .alb-slide.is-active { flex-basis: 72%; }
  .alb-arrow { width: 38px; height: 38px; font-size: 24px; }
  .alb-title { font-size: 14px; }
  .alb-num { font-size: 18px; }
  .alb-counter { top: 10px; font-size: 11px; padding: 5px 10px; }
  .alb-badge { font-size: 10px; padding: 4px 8px; top: 10px; left: 10px; }
}
@media (max-width: 480px) {
  .alb-stage { height: 300px; }
  .alb-slide { flex-basis: 44px; }
  .alb-slide.is-active { flex-basis: 78%; }
}
/* ╚══════ END ALBUM COVERFLOW ══════╝ */
</style>
<% if (typeof pinRequired !== 'undefined' && pinRequired) { %>
<script>
(function(){
  var idolId = '<%= idolId %>';
  var storageKey = 'x66_pin_ok_' + idolId;
  var overlay = document.getElementById('pinOverlay');

  // ===== ADMIN BYPASS: skip PIN modal =====
  if (typeof window.isUserAdmin === 'function' && window.isUserAdmin()) {
    if (window.x66ShowAdminBadge) window.x66ShowAdminBadge();
    return;
  }
  // Check localStorage: nếu đã verify trước rồi thì không hỏi nữa
  try {
    var ok = localStorage.getItem(storageKey);
    if (!ok) {
      overlay.classList.remove('hidden');
      setTimeout(function(){ var f = document.querySelector('.pin-digit'); if (f) f.focus(); }, 200);
    }
  } catch(e) {
    overlay.classList.remove('hidden');
  }

  // PIN inputs interaction
  var inputs = document.querySelectorAll('.pin-digit');
  inputs.forEach(function(inp, idx){
    inp.addEventListener('input', function(){
      this.value = this.value.replace(/[^0-9]/g, '');
      if (this.value && idx < inputs.length - 1) inputs[idx+1].focus();
      // Auto-submit khi nhập đủ 4
      if (idx === inputs.length - 1 && this.value) {
        var pin = ''; inputs.forEach(function(i){ pin += i.value; });
        if (pin.length === 4) pinSubmit();
      }
    });
    inp.addEventListener('keydown', function(e){
      if (e.key === 'Backspace' && !this.value && idx > 0) inputs[idx-1].focus();
      if (e.key === 'Enter') pinSubmit();
    });
    inp.addEventListener('paste', function(e){
      e.preventDefault();
      var paste = (e.clipboardData || window.clipboardData).getData('text');
      var digits = (paste||'').replace(/[^0-9]/g,'').slice(0,4).split('');
      digits.forEach(function(d, i){ if (inputs[i]) inputs[i].value = d; });
      if (digits.length >= 4) pinSubmit();
    });
  });

  window.pinSubmit = function(){
    var pin = '';
    inputs.forEach(function(i){ pin += i.value; });
    if (pin.length !== 4) {
      showPinErr('Nhập đủ 4 chữ số');
      return;
    }
    var btn = document.getElementById('pinSubmitBtn');
    btn.disabled = true;
    btn.textContent = '⏳ Đang kiểm tra...';
    fetch('/api/idol/verify-pin', {
      method: 'POST', headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ idolId: idolId, pin: pin })
    }).then(function(r){ return r.json(); }).then(function(j){
      btn.disabled = false;
      btn.textContent = '🔓 Mở khóa phòng';
      if (j.ok) {
        try { localStorage.setItem(storageKey, '1'); } catch(e){}
        overlay.style.transition = 'opacity .3s';
        overlay.style.opacity = '0';
        setTimeout(function(){ overlay.classList.add('hidden'); overlay.style.opacity = '1'; }, 300);
      } else {
        showPinErr(j.error || 'Mã PIN không đúng');
        document.getElementById('pinInputBox').classList.add('pin-shake');
        setTimeout(function(){ document.getElementById('pinInputBox').classList.remove('pin-shake'); }, 600);
        inputs.forEach(function(i){ i.value = ''; });
        inputs[0].focus();
      }
    }).catch(function(){
      btn.disabled = false;
      btn.textContent = '🔓 Mở khóa phòng';
      showPinErr('Lỗi mạng - thử lại');
    });
  };
  function showPinErr(msg){
    var el = document.getElementById('pinError');
    el.textContent = '❌ ' + msg;
    el.classList.remove('hidden');
    setTimeout(function(){ el.classList.add('hidden'); }, 4000);
  }
})();
</script>
<% } %>

