<%
// Idol full profile (sau lay tu DB)
var idol = (typeof dbIdol !== 'undefined' && dbIdol) ? dbIdol : { name:'Idol', room:'Phòng', lock:0, color:0, emoji:'👑', age:'-', height:'-', weight:'-', city:'-', job:'-', hobby:'-', bio:'-' };
var idolId = (typeof idolKey !== 'undefined' && idolKey) ? idolKey : 'i01';
var viewers = ((idol.name.charCodeAt(0)+idolId.length) * 137) % 9000 + 500;
var follow  = ((idol.name.charCodeAt(0)+idolId.length) * 53)  % 250000 + 5000;
var tipsToday = ((idol.name.charCodeAt(0)*7+idolId.length) * 31) % 80000 + 10000;

// Sinh 9 ảnh placeholder (gradient + emoji)
var ALBUM_EMOJIS = ['📷','🌸','🌹','💃','🌺','✨','💖','🦋','🌷'];
var ALBUM = [];
for (var k=0; k<9; k++){
  var h = (idol.color + k*40) % 360;
  ALBUM.push({
    caption: ['Ảnh studio','Du lịch','Ngày thường','Sự kiện','Cosplay','Selfie','Hậu trường','Concert','Photoshoot'][k] + ' #' + (k+1),
    color: 'linear-gradient(135deg, hsl('+h+',75%,50%), hsl('+((h+60)%360)+',75%,40%))',
    emoji: ALBUM_EMOJIS[k]
  });
}
// 4 video clip
var VIDEOS = [
  { title:'Cover bài Hoa Nở Không Màu', duration:'3:42', views:'12.5K', emoji:'🎤' },
  { title:'Dance K-pop highlight',       duration:'1:20', views:'8.7K',  emoji:'💃' },
  { title:'Vlog hậu trường live',        duration:'5:18', views:'21K',   emoji:'📹' },
  { title:'Tâm sự cuối tuần',            duration:'2:45', views:'15K',   emoji:'💬' }
];

seo = {
  title: idol.name + ' - ' + idol.room + ' - ' + brand.name,
  description: 'Xem trực tiếp '+idol.name+', '+idol.age+' tuổi, '+idol.city+'. '+viewers.toLocaleString('vi-VN')+' người đang xem. '+idol.bio.slice(0,80),
  canonical: '/idol/'+idolId,
  noindex: true
};
%>
<%- include('partials/tw-layout-start') %>

<!-- ===== MOBILE FULLSCREEN LIVE ROOM ===== -->
<%- include('partials/tw-idol-mobile', { idol: idol, idolId: idolId, viewers: viewers, follow: follow, tipsToday: tipsToday, allIdols: (typeof allIdols !== 'undefined' ? allIdols : []), ALBUM: ALBUM, VIDEOS: VIDEOS }) %>

<!-- ===== AUTH + LOCK CHECK với MODAL đẹp ===== -->
<% if (idol.lock > 0) { %>
<div id="lockOverlay" class="hidden fixed inset-0 z-[100] bg-black/85 backdrop-blur-md grid place-items-center px-4">
  <!-- Swipe up hint (top) -->
  <div id="lockSwipeUpHint" class="absolute top-4 inset-x-0 z-10 text-center pointer-events-none">
    <div class="inline-flex items-center gap-2 bg-pri/20 backdrop-blur border border-pri/40 text-pri-light text-xs font-bold px-3 py-1.5 rounded-full">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="18 15 12 9 6 15"/></svg>
      <span>Vuốt lên: <span id="lockSwipeNextName">Idol kế tiếp</span></span>
    </div>
  </div>
  <!-- Swipe down hint (bottom) -->
  <div id="lockSwipeDownHint" class="absolute bottom-4 inset-x-0 z-10 text-center pointer-events-none">
    <div class="inline-flex items-center gap-2 bg-pri/20 backdrop-blur border border-pri/40 text-pri-light text-xs font-bold px-3 py-1.5 rounded-full">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
      <span>Vuốt xuống: <span id="lockSwipePrevName">Idol trước</span></span>
    </div>
  </div>
  <div class="bg-gradient-to-b from-bg-card via-bg-deep to-black border-2 border-pri/60 rounded-2xl p-6 max-w-sm w-full shadow-2xl shadow-pri/40 text-center relative overflow-hidden">
    <!-- Decorative glow -->
    <div class="absolute -top-20 -right-20 w-40 h-40 bg-pri/30 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-20 -left-20 w-40 h-40 bg-pink/30 rounded-full blur-3xl"></div>

    <!-- Lock icon -->
    <div class="relative w-24 h-24 mx-auto mb-3">
      <div class="absolute inset-0 rounded-full bg-gradient-to-br from-pri to-pink lock-modal-pulse"></div>
      <div class="absolute inset-0 grid place-items-center text-5xl">🔒</div>
      <!-- Orbiting sparkles -->
      <span class="absolute top-0 left-1/2 -translate-x-1/2 text-yellow-300 lock-sparkle-1">✨</span>
      <span class="absolute bottom-0 left-1/2 -translate-x-1/2 text-yellow-300 lock-sparkle-2">✨</span>
    </div>

    <h2 class="text-white font-black text-xl mb-1 relative z-10">PHÒNG VIP BỊ KHÓA</h2>
    <p class="text-muted text-sm mb-4 relative z-10">Phòng của <b class="text-pri-light"><%= idol.name %></b> yêu cầu mở khóa</p>

    <!-- Cost display -->
    <div class="relative z-10 bg-gradient-to-br from-yellow-500/20 via-orange-500/15 to-yellow-500/20 border-2 border-yellow-400/40 rounded-xl p-4 mb-4">
      <div class="text-[11px] text-yellow-200 uppercase tracking-widest font-bold mb-1">Chi phí mở khóa</div>
      <div class="flex items-center justify-center gap-2">
        <span class="text-3xl">🪙</span>
        <span class="text-yellow-300 font-black text-3xl tabular-nums drop-shadow"><%= idol.lock %></span>
        <span class="text-yellow-200 font-bold text-sm">X COIN</span>
      </div>
      <div class="text-[10px] text-gray-300 mt-1">Mở khóa 1 lần - xem mãi mãi</div>
    </div>

    <!-- Balance -->
    <div class="relative z-10 flex items-center justify-between bg-bg-soft border border-line rounded-lg px-3 py-2 mb-4 text-sm">
      <span class="text-muted text-xs">Số dư của bạn:</span>
      <span class="flex items-center gap-1.5">
        <span>🪙</span>
        <span class="text-gold font-extrabold tabular-nums" id="lockMyCoin">0</span>
      </span>
    </div>

    <!-- Actions -->
    <button onclick="lockUnlockNow()" id="lockUnlockBtn" class="relative z-10 w-full bg-gradient-to-r from-yellow-500 via-orange-500 to-pink-500 hover:brightness-110 text-white py-3 rounded-xl font-extrabold text-sm mb-2 active:scale-95 shadow-lg shadow-orange-500/40 flex items-center justify-center gap-2">
      <span class="text-lg">🔓</span>
      <span>MỞ KHÓA NGAY (<%= idol.lock %> 🪙)</span>
    </button>
    <a href="/idol-live" class="relative z-10 block w-full bg-bg-soft border border-line text-gray-300 py-2.5 rounded-xl font-bold text-xs hover:bg-bg-deep">← Quay lại danh sách</a>

    <!-- Info note -->
    <div class="relative z-10 mt-3 text-[10px] text-muted leading-relaxed">
      💡 Mở khóa để xem live không giới hạn · Quà tặng cho idol để bày tỏ tình cảm
    </div>
  </div>
</div>

<style>
@keyframes lockModalPulse {
  0%,100% { transform: scale(1); opacity: .9; box-shadow: 0 0 24px rgba(255,122,24,.5); }
  50%     { transform: scale(1.08); opacity: 1; box-shadow: 0 0 48px rgba(233,30,99,.7); }
}
.lock-modal-pulse { animation: lockModalPulse 2s ease-in-out infinite; }
@keyframes lockSparkleOrbit1 {
  0% { transform: translateX(-50%) rotate(0deg) translateY(-48px) rotate(0deg); }
  100% { transform: translateX(-50%) rotate(360deg) translateY(-48px) rotate(-360deg); }
}
@keyframes lockSparkleOrbit2 {
  0% { transform: translateX(-50%) rotate(180deg) translateY(-48px) rotate(-180deg); }
  100% { transform: translateX(-50%) rotate(540deg) translateY(-48px) rotate(-540deg); }
}
.lock-sparkle-1 { animation: lockSparkleOrbit1 4s linear infinite; font-size: 18px; filter: drop-shadow(0 0 6px gold); }
.lock-sparkle-2 { animation: lockSparkleOrbit2 4s linear infinite; font-size: 14px; filter: drop-shadow(0 0 6px gold); }
@keyframes lockShake { 0%,100%{transform:translateX(0)} 25%{transform:translateX(-8px)} 75%{transform:translateX(8px)} }
.lock-shake { animation: lockShake .3s ease-in-out 2; }
</style>
<script>
(function(){
  var lock = <%= idol.lock %>;
  var idolId = '<%= idolId %>';
  var idolName = '<%= idol.name.replace(/'/g, "\'") %>';
  var overlay = document.getElementById('lockOverlay');

  // ===== ADMIN BYPASS: skip lock modal completely =====
  if (typeof window.isUserAdmin === 'function' && window.isUserAdmin()) {
    if (window.x66ShowAdminBadge) window.x66ShowAdminBadge();
    return;
  }

  function showLockModal(){
    overlay.classList.remove('hidden');
    refreshBalance();
  }
  function refreshBalance(){
    try {
      var u = JSON.parse(localStorage.getItem('x66_user')||'{}');
      var coin = typeof u.coin === 'number' ? u.coin : 79;
      var el = document.getElementById('lockMyCoin');
      if (el) el.textContent = coin.toLocaleString('vi-VN');
    } catch(e){}
  }

  // Check auth + unlock status
  try {
    var u = JSON.parse(localStorage.getItem('x66_user')||'{}');
    if (!u.username) {
      // Show modal asking to login first
      overlay.querySelector('h2').textContent = 'CẦN ĐĂNG NHẬP';
      overlay.querySelector('p').innerHTML = 'Đăng nhập để mở khóa phòng <b class="text-pri-light">' + idolName + '</b>';
      document.getElementById('lockUnlockBtn').innerHTML = '<span class="text-lg">👤</span><span>ĐĂNG NHẬP NGAY</span>';
      document.getElementById('lockUnlockBtn').setAttribute('onclick', "location.href='/dang-nhap'");
      showLockModal();
      return;
    }
    var unlocked = JSON.parse(localStorage.getItem('x66_unlocked_idols')||'[]');
    if (unlocked.indexOf(idolId) < 0) {
      showLockModal();
    }
  } catch(e){
    showLockModal();
  }

  // ===== SWIPE GESTURE ON LOCK OVERLAY =====
  var lockAllIdols = <%- JSON.stringify(typeof allIdols !== 'undefined' ? allIdols : []) %>;
  var lockCurrentIdx = lockAllIdols.findIndex(function(i){ return i.id === idolId; });
  if (lockCurrentIdx < 0) lockCurrentIdx = 0;
  var lockNextI = lockAllIdols.length > 1 ? lockAllIdols[(lockCurrentIdx + 1) % lockAllIdols.length] : null;
  var lockPrevI = lockAllIdols.length > 1 ? lockAllIdols[(lockCurrentIdx - 1 + lockAllIdols.length) % lockAllIdols.length] : null;

  // Populate names in hints
  if (lockNextI) document.getElementById('lockSwipeNextName').textContent = lockNextI.emoji + ' ' + lockNextI.name;
  if (lockPrevI) document.getElementById('lockSwipePrevName').textContent = lockPrevI.emoji + ' ' + lockPrevI.name;
  if (!lockNextI) document.getElementById('lockSwipeUpHint').style.display = 'none';
  if (!lockPrevI) document.getElementById('lockSwipeDownHint').style.display = 'none';

  var lockTouchStartY = 0, lockTouchStartX = 0, lockTouchDeltaY = 0, lockSwiping = false, lockSwipeDecided = false;
  var LOCK_SWIPE_THRESHOLD = 70;

  function lockOnTouchStart(e){
    if (!e.touches || !e.touches[0]) return;
    // Don't interfere with button clicks inside modal
    if (e.target.closest('button') || e.target.closest('a') || e.target.closest('input')) return;
    lockTouchStartY = e.touches[0].clientY;
    lockTouchStartX = e.touches[0].clientX;
    lockTouchDeltaY = 0;
    lockSwiping = true;
    lockSwipeDecided = false;
  }
  function lockOnTouchMove(e){
    if (!lockSwiping || !e.touches || !e.touches[0]) return;
    var dy = e.touches[0].clientY - lockTouchStartY;
    var dx = e.touches[0].clientX - lockTouchStartX;
    if (!lockSwipeDecided && (Math.abs(dx) > 10 || Math.abs(dy) > 10)) {
      if (Math.abs(dx) > Math.abs(dy) / 1.2) { lockSwiping = false; return; }
      lockSwipeDecided = true;
    }
    if (!lockSwipeDecided) return;
    if (e.cancelable) e.preventDefault();
    lockTouchDeltaY = dy;
    var modal = overlay.querySelector('div.bg-gradient-to-b');
    if (modal) {
      modal.style.transition = 'none';
      modal.style.transform = 'translateY(' + (dy * 0.4) + 'px)';
      modal.style.opacity = Math.max(.5, 1 - Math.abs(dy)/300).toString();
    }
    // Highlight hint while swiping
    if (dy < -30 && lockNextI) {
      document.getElementById('lockSwipeUpHint').style.transform = 'scale(' + (1 + Math.min(.3, Math.abs(dy)/200)) + ')';
    } else if (dy > 30 && lockPrevI) {
      document.getElementById('lockSwipeDownHint').style.transform = 'scale(' + (1 + Math.min(.3, dy/200)) + ')';
    }
  }
  function lockOnTouchEnd(e){
    if (!lockSwiping) return;
    lockSwiping = false;
    var modal = overlay.querySelector('div.bg-gradient-to-b');
    if (modal) {
      modal.style.transition = 'transform .25s ease-out, opacity .25s ease-out';
    }
    document.getElementById('lockSwipeUpHint').style.transform = '';
    document.getElementById('lockSwipeDownHint').style.transform = '';

    if (lockTouchDeltaY < -LOCK_SWIPE_THRESHOLD && lockNextI) {
      // Slide out up + navigate
      if (modal) {
        modal.style.transform = 'translateY(-120vh)';
        modal.style.opacity = '0';
      }
      setTimeout(function(){ location.href = '/idol/' + lockNextI.id; }, 300);
    } else if (lockTouchDeltaY > LOCK_SWIPE_THRESHOLD && lockPrevI) {
      if (modal) {
        modal.style.transform = 'translateY(120vh)';
        modal.style.opacity = '0';
      }
      setTimeout(function(){ location.href = '/idol/' + lockPrevI.id; }, 300);
    } else {
      // Snap back
      if (modal) {
        modal.style.transform = '';
        modal.style.opacity = '';
      }
    }
    lockTouchDeltaY = 0;
  }
  // Attach to overlay (works on whole dark area)
  if (overlay) {
    overlay.addEventListener('touchstart', lockOnTouchStart, { passive: true });
    overlay.addEventListener('touchmove', lockOnTouchMove, { passive: false });
    overlay.addEventListener('touchend', lockOnTouchEnd, { passive: true });
    overlay.addEventListener('touchcancel', lockOnTouchEnd, { passive: true });
  }

  window.lockUnlockNow = function(){
    try {
      var u = JSON.parse(localStorage.getItem('x66_user')||'{}');
      var coin = typeof u.coin === 'number' ? u.coin : 79;
      if (coin < lock) {
        // Insufficient: shake + show error
        var modal = overlay.querySelector('div');
        modal.classList.add('lock-shake');
        setTimeout(function(){ modal.classList.remove('lock-shake'); }, 700);
        if (confirm('❌ X COIN không đủ!\n\nCần ' + lock + ' 🪙 - Bạn có ' + coin + ' 🪙\n\nNạp thêm X COIN ngay?')) {
          location.href = '/qua-tang';
        }
        return;
      }
      // Trừ coin + lưu unlocked
      u.coin = coin - lock;
      localStorage.setItem('x66_user', JSON.stringify(u));
      var unlocked = JSON.parse(localStorage.getItem('x66_unlocked_idols')||'[]');
      if (unlocked.indexOf(idolId) < 0) {
        unlocked.push(idolId);
        localStorage.setItem('x66_unlocked_idols', JSON.stringify(unlocked));
      }
      // Success animation
      overlay.querySelector('.text-5xl').textContent = '🎉';
      overlay.querySelector('h2').textContent = 'MỞ KHÓA THÀNH CÔNG!';
      overlay.querySelector('p').innerHTML = 'Đang vào phòng <b class="text-pri-light">' + idolName + '</b>...';
      setTimeout(function(){
        overlay.style.transition = 'opacity .3s';
        overlay.style.opacity = '0';
        setTimeout(function(){ overlay.classList.add('hidden'); overlay.style.opacity = '1'; }, 300);
      }, 1500);
    } catch(e){ alert('Lỗi: ' + e.message); }
  };
})();
</script>
<% } %>

<!-- ===== PIN LOCK OVERLAY (chi hien khi idol set PIN) ===== -->
<% if (typeof pinRequired !== 'undefined' && pinRequired) { %>
<div id="pinOverlay" class="fixed inset-0 z-[100] bg-black/90 backdrop-blur-md grid place-items-center px-4 hidden">
  <div class="bg-gradient-to-b from-bg-card via-bg-deep to-black border-2 border-yellow-500/60 rounded-2xl p-6 max-w-sm w-full shadow-2xl shadow-yellow-500/30 text-center">
    <div class="w-20 h-20 mx-auto mb-3 rounded-full bg-gradient-to-br from-red-600 to-orange-600 grid place-items-center text-5xl shadow-2xl shadow-red-500/40 pin-lock-anim">🔒</div>
    <h2 class="text-white font-black text-xl mb-1">PHÒNG CÓ MẬT MÃ</h2>
    <p class="text-muted text-sm mb-4"><b class="text-pri-light"><%= idol.name %></b> yêu cầu nhập mã PIN để vào xem</p>

    <div class="flex justify-center gap-2 mb-3" id="pinInputBox">
      <input type="tel" maxlength="1" class="pin-digit w-12 h-14 bg-bg-card border-2 border-line focus:border-pri text-white text-2xl font-black text-center rounded-lg outline-none tabular-nums" data-idx="0" autocomplete="off">
      <input type="tel" maxlength="1" class="pin-digit w-12 h-14 bg-bg-card border-2 border-line focus:border-pri text-white text-2xl font-black text-center rounded-lg outline-none tabular-nums" data-idx="1" autocomplete="off">
      <input type="tel" maxlength="1" class="pin-digit w-12 h-14 bg-bg-card border-2 border-line focus:border-pri text-white text-2xl font-black text-center rounded-lg outline-none tabular-nums" data-idx="2" autocomplete="off">
      <input type="tel" maxlength="1" class="pin-digit w-12 h-14 bg-bg-card border-2 border-line focus:border-pri text-white text-2xl font-black text-center rounded-lg outline-none tabular-nums" data-idx="3" autocomplete="off">
    </div>
    <div id="pinError" class="hidden text-red-400 text-[12px] font-bold mb-2"></div>

    <button onclick="pinSubmit()" id="pinSubmitBtn" class="w-full bg-gradient-to-r from-pri to-live text-white py-3 rounded-xl font-extrabold text-sm mb-2 active:scale-95 shadow-lg shadow-pri/40">🔓 Mở khóa phòng</button>
    <a href="/idol-live" class="block w-full bg-bg-soft border border-line text-gray-300 py-2.5 rounded-xl font-bold text-xs hover:bg-bg-deep">← Quay lại danh sách</a>

    <div class="mt-3 text-[10px] text-muted">💡 Liên hệ idol để xin mã PIN qua chat/Telegram</div>
  </div>
</div>
<style>
.pin-lock-anim { animation: pinLockPulse 2s ease-in-out infinite; }
@keyframes pinLockPulse {
  0%,100% { transform: scale(1); box-shadow: 0 0 24px rgba(239,68,68,.4); }
  50%     { transform: scale(1.08); box-shadow: 0 0 40px rgba(239,68,68,.8); }
}
@keyframes pinShake {
  0%,100% { transform: translateX(0); }
  25% { transform: translateX(-8px); }
  75% { transform: translateX(8px); }
}
.pin-shake { animation: pinShake .3s ease-in-out 2; }
</style>
<script>
(function(){
  var idolId = '<%= idolId %>';
  var storageKey = 'x66_pin_ok_' + idolId;
  var overlay = document.getElementById('pinOverlay');

  // ===== ADMIN BYPASS: skip PIN modal =====
  if (typeof window.isUserAdmin === 'function' && window.isUserAdmin()) {
    if (window.x66ShowAdminBadge) window.x66ShowAdminBadge();
    return;
  }
  // Check localStorage: nếu đã verify trước rồi thì không hỏi nữa
  try {
    var ok = localStorage.getItem(storageKey);
    if (!ok) {
      overlay.classList.remove('hidden');
      setTimeout(function(){ var f = document.querySelector('.pin-digit'); if (f) f.focus(); }, 200);
    }
  } catch(e) {
    overlay.classList.remove('hidden');
  }

  // PIN inputs interaction
  var inputs = document.querySelectorAll('.pin-digit');
  inputs.forEach(function(inp, idx){
    inp.addEventListener('input', function(){
      this.value = this.value.replace(/[^0-9]/g, '');
      if (this.value && idx < inputs.length - 1) inputs[idx+1].focus();
      // Auto-submit khi nhập đủ 4
      if (idx === inputs.length - 1 && this.value) {
        var pin = ''; inputs.forEach(function(i){ pin += i.value; });
        if (pin.length === 4) pinSubmit();
      }
    });
    inp.addEventListener('keydown', function(e){
      if (e.key === 'Backspace' && !this.value && idx > 0) inputs[idx-1].focus();
      if (e.key === 'Enter') pinSubmit();
    });
    inp.addEventListener('paste', function(e){
      e.preventDefault();
      var paste = (e.clipboardData || window.clipboardData).getData('text');
      var digits = (paste||'').replace(/[^0-9]/g,'').slice(0,4).split('');
      digits.forEach(function(d, i){ if (inputs[i]) inputs[i].value = d; });
      if (digits.length >= 4) pinSubmit();
    });
  });

  window.pinSubmit = function(){
    var pin = '';
    inputs.forEach(function(i){ pin += i.value; });
    if (pin.length !== 4) {
      showPinErr('Nhập đủ 4 chữ số');
      return;
    }
    var btn = document.getElementById('pinSubmitBtn');
    btn.disabled = true;
    btn.textContent = '⏳ Đang kiểm tra...';
    fetch('/api/idol/verify-pin', {
      method: 'POST', headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ idolId: idolId, pin: pin })
    }).then(function(r){ return r.json(); }).then(function(j){
      btn.disabled = false;
      btn.textContent = '🔓 Mở khóa phòng';
      if (j.ok) {
        try { localStorage.setItem(storageKey, '1'); } catch(e){}
        overlay.style.transition = 'opacity .3s';
        overlay.style.opacity = '0';
        setTimeout(function(){ overlay.classList.add('hidden'); overlay.style.opacity = '1'; }, 300);
      } else {
        showPinErr(j.error || 'Mã PIN không đúng');
        document.getElementById('pinInputBox').classList.add('pin-shake');
        setTimeout(function(){ document.getElementById('pinInputBox').classList.remove('pin-shake'); }, 600);
        inputs.forEach(function(i){ i.value = ''; });
        inputs[0].focus();
      }
    }).catch(function(){
      btn.disabled = false;
      btn.textContent = '🔓 Mở khóa phòng';
      showPinErr('Lỗi mạng - thử lại');
    });
  };
  function showPinErr(msg){
    var el = document.getElementById('pinError');
    el.textContent = '❌ ' + msg;
    el.classList.remove('hidden');
    setTimeout(function(){ el.classList.add('hidden'); }, 4000);
  }
})();
</script>
<% } %>

<article class="mb-6 hidden md:block">

  <!-- TOP ROW: Player + Chat cùng grid stretch -->
  <section class="grid lg:grid-cols-[1fr_340px] gap-4 mb-4 items-stretch">
    <!-- Player aspect-video -->

    <!-- Player -->
    <div id="livePlayer" class="bg-black aspect-video rounded-xl relative overflow-hidden grid place-items-center" style="background:linear-gradient(135deg, hsl(<%= idol.color %>,70%,40%), hsl(<%= idol.color+60 %>,70%,50%))">
      <div class="absolute inset-0 opacity-40" style="background:radial-gradient(circle at 30% 50%,rgba(255,255,255,.4),transparent 50%),radial-gradient(circle at 70% 50%,rgba(255,255,255,.3),transparent 50%)"></div>
      <span class="absolute top-3.5 left-3.5 z-[2] bg-live text-white px-3 py-1 rounded-md font-extrabold text-xs flex items-center gap-1.5"><span class="w-1.5 h-1.5 bg-white rounded-full animate-pulse-live"></span>LIVE</span>
      <span class="absolute top-3.5 right-3.5 z-[2] bg-black/70 text-gold px-2.5 py-1 rounded text-[11px] font-bold flex items-center gap-1.5">👁 <span class="tabular-nums"><%= viewers.toLocaleString('vi-VN') %></span></span>
      <div class="relative z-[1] text-[200px] filter drop-shadow-2xl" style="animation:bounceIdol 1.4s ease-in-out infinite alternate;"><%= idol.emoji || '👑' %></div>
      <div class="absolute inset-x-0 bottom-0 z-[2] px-4 py-3 bg-gradient-to-t from-black/85 to-transparent text-white flex items-center gap-3">
        <button class="w-9 h-9 grid place-items-center hover:text-pri" aria-label="Phát/Dừng">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="5" width="4" height="14" rx="1"/><rect x="14" y="5" width="4" height="14" rx="1"/></svg>
        </button>
        <button class="w-9 h-9 grid place-items-center hover:text-pri" aria-label="Tắt tiếng">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"/></svg>
        </button>
        <div class="flex-1"></div>
        <span class="text-[10px] font-bold bg-pri text-white px-1.5 py-0.5 rounded">HD 1080p</span>
        <button class="w-9 h-9 grid place-items-center hover:text-pri" aria-label="Toàn màn hình">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/></svg>
        </button>
      </div>
    </div>

    <!-- CHAT: cùng row grid với player, auto stretch theo aspect-video -->
    <aside class="bg-bg-card border border-line rounded-xl flex flex-col overflow-hidden h-full" aria-label="Chat" id="chatPanelTop">
      <div class="flex border-b border-line bg-bg-soft">
        <button class="cp-tab flex-1 py-3 bg-bg-card text-pri-light font-bold text-xs border-b-2 border-pri" data-tab="chat" onclick="switchChatTab('chat')">💬 Chat phòng</button>
        <button class="cp-tab flex-1 py-3 bg-transparent text-muted hover:text-white font-bold text-xs border-b-2 border-transparent relative" data-tab="gift" onclick="switchChatTab('gift')">
          🎁 Quà
          <span id="cpGiftBadge" class="hidden absolute top-1.5 right-2 bg-live text-white text-[9px] font-bold rounded-full min-w-[16px] h-4 grid place-items-center px-1 animate-pulse">0</span>
        </button>
      </div>
      <div class="px-3 py-2 bg-bg-soft border-b border-line text-xs text-muted flex items-center justify-between">
        <span class="text-emerald-500 flex items-center gap-1"><span class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse-live"></span><%= Math.floor(viewers/10).toLocaleString('vi-VN') %> online</span>
        <span id="cpStatLabel">Bình luận: <b class="text-pri-light" id="cpStatNum"><%= (Math.random()*5000|0)+1000 %></b></span>
      </div>
      <!-- TAB CHAT -->
      <div class="flex-1 overflow-y-auto py-1 scrollbar-thin" id="chatBody" data-panel="chat"></div>
      <!-- TAB QUÀ (initially hidden) -->
      <div class="hidden flex-1 overflow-y-auto scrollbar-thin bg-bg" id="giftLog" data-panel="gift">
        <!-- Top tippers compact -->
        <div class="px-3 py-2.5 border-b border-line bg-gradient-to-b from-pri/10 to-transparent">
          <div class="flex items-center justify-between mb-1.5">
            <h4 class="text-[11px] font-extrabold text-pri-light flex items-center gap-1">🏆 Top tặng hôm nay</h4>
            <span class="text-[10px] text-gold tabular-nums"><%= tipsToday.toLocaleString('vi-VN') %> 🪙</span>
          </div>
          <div class="space-y-1">
            <% ['vipFan88','iLove'+idol.name.charAt(0),'BoMy_X66'].forEach(function(name, i){ var amt = (3-i)*1500+200; %>
            <div class="flex items-center gap-2 text-[11px]">
              <span class="text-base"><%= ['🥇','🥈','🥉'][i] %></span>
              <span class="font-bold text-white truncate flex-1"><%= name %></span>
              <span class="text-gold font-bold tabular-nums">🪙 <%= amt.toLocaleString('vi-VN') %></span>
            </div>
            <% }); %>
          </div>
        </div>
        <!-- Recent gifts log header -->
        <div class="px-3 pt-2.5 pb-1 flex items-center justify-between">
          <h4 class="text-[11px] font-extrabold text-white flex items-center gap-1">⏱ Quà mới nhất</h4>
          <button onclick="clearGiftLog()" class="text-[10px] text-muted hover:text-live">Xóa</button>
        </div>
        <!-- Gift log list -->
        <div id="giftLogList" class="px-2 pb-2 space-y-1.5">
          <div class="text-center py-8 text-muted text-[12px]">
            <div class="text-3xl mb-2 opacity-50">🎁</div>
            <div>Chưa có quà tặng nào.</div>
            <div class="text-[10px] mt-1">Hãy tặng quà đầu tiên cho idol!</div>
