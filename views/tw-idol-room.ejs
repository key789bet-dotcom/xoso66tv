<%
// Idol full profile (sau lay tu DB)
// 🛡️ DEFENSIVE: Object.assign default → dbIdol mới đăng ký thiếu field sẽ KHÔNG crash 500
var __idolDefaults = {
  name: 'Idol',
  room: 'Phòng riêng',
  lock: 0,
  color: 0,
  emoji: '👑',
  age: '-',
  height: '-',
  weight: '-',
  city: '-',
  job: '-',
  hobby: '-',
  bio: 'Idol XOSO66 TV - chào mừng các bạn đến phòng live của mình!'
};
var idol = Object.assign({}, __idolDefaults, (typeof dbIdol !== 'undefined' && dbIdol) ? dbIdol : {});
// Bảo vệ thêm: ép kiểu cho các field text có thể null/empty trong DB
['name','room','city','job','hobby','bio'].forEach(function(k){ if (idol[k] == null || idol[k] === '') idol[k] = __idolDefaults[k]; });
var idolId = (typeof idolKey !== 'undefined' && idolKey) ? idolKey : 'i01';
var viewers = ((idol.name.charCodeAt(0)+idolId.length) * 137) % 9000 + 500;
var follow  = ((idol.name.charCodeAt(0)+idolId.length) * 53)  % 250000 + 5000;
var tipsToday = ((idol.name.charCodeAt(0)*7+idolId.length) * 31) % 80000 + 10000;

// Sinh 9 ảnh placeholder (gradient + emoji)
var ALBUM_EMOJIS = ['📷','🌸','🌹','💃','🌺','✨','💖','🦋','🌷'];
var ALBUM = [];
for (var k=0; k<9; k++){
  var h = (idol.color + k*40) % 360;
  ALBUM.push({
    caption: ['Ảnh studio','Du lịch','Ngày thường','Sự kiện','Cosplay','Selfie','Hậu trường','Concert','Photoshoot'][k] + ' #' + (k+1),
    color: 'linear-gradient(135deg, hsl('+h+',75%,50%), hsl('+((h+60)%360)+',75%,40%))',
    emoji: ALBUM_EMOJIS[k]
  });
}
// 4 video clip
var VIDEOS = [
  { title:'Cover bài Hoa Nở Không Màu', duration:'3:42', views:'12.5K', emoji:'🎤' },
  { title:'Dance K-pop highlight',       duration:'1:20', views:'8.7K',  emoji:'💃' },
  { title:'Vlog hậu trường live',        duration:'5:18', views:'21K',   emoji:'📹' },
  { title:'Tâm sự cuối tuần',            duration:'2:45', views:'15K',   emoji:'💬' }
];

seo = {
  title: 'Idol '+idol.name+' - Live Stream Tương Tác | XOSO66 TV',
  description: 'Xem live stream idol '+idol.name+' tại XOSO66 TV. '+viewers.toLocaleString('vi-VN')+' người đang xem. Tương tác chat, tặng quà X COIN, kết bạn idol. '+idol.bio.slice(0,80),
  keywords: 'idol live, '+idol.name+', xoso66, xổ số 66, idol show, livestream idol',
  canonical: '/idol/'+idolId,
  noindex: true
};
%>
<%- include('partials/tw-layout-start') %>
<%- include('partials/tw-skin-overlay') %>

<%
// 📡 streamMethod = 'obs' → render layout BLV-style cho CẢ mobile + desktop (player ngang + chat)
// streamMethod = 'mobile' (default) → mobile = fullscreen idol partial, desktop = ngang
var _obsMode = (idol.streamMethod === 'obs');
%>

<% if (!_obsMode) { %>
<!-- ===== MOBILE FULLSCREEN LIVE ROOM (chỉ render khi idol live bằng camera điện thoại) ===== -->
<%- include('partials/tw-idol-mobile', { idol: idol, idolId: idolId, viewers: viewers, follow: follow, tipsToday: tipsToday, allIdols: (typeof allIdols !== 'undefined' ? allIdols : []), ALBUM: ALBUM, VIDEOS: VIDEOS }) %>
<% } %>

<!-- ⚠️ LESSON LEARNED (xem PROJECT.md section 6): Chat aside hay tràn ngoài khung khi messages dài.
     FIX ĐÚNG: Grid `height: 528px` FIXED (KHÔNG min-height) + chat `overflow: hidden`
     - 528px = player 480 + quality bar 40 + gap 8
     - Mobile <768px: stack 1 col, chat 60vh bounded
     - Desktop ≥768px: 2 cols, grid fixed 528px → chat cell bounded → KHÔNG expand theo chat content -->
<style>
  .idol-room-grid { display: grid; grid-template-columns: 1fr; gap: 1rem; }
  .idol-player-col { display: flex; flex-direction: column; gap: 8px; min-width: 0; min-height: 0; }
  .idol-room-player { width: 100%; aspect-ratio: 16/9; height: auto; }
  .idol-room-chat { height: 60vh; min-height: 380px; max-height: 70vh; overflow: hidden !important; contain: layout size; }
  /* Chat aside flex-col children layout (CRITICAL — NEVER REMOVE) */
  .idol-room-chat > *:not(#chatBody):not(#giftLog) { flex-shrink: 0 !important; }
  .idol-room-chat #chatBody,
  .idol-room-chat #giftLog { flex: 1 1 0 !important; min-height: 0 !important; overflow-y: auto !important; }
  /* TAB nav buttons: FIXED kích thước, KHÔNG phình khi click — bug v124 */
  .idol-room-chat .cp-tab { height: 48px !important; max-height: 48px !important; min-height: 48px !important; overflow: hidden !important; }
  .idol-room-chat .cp-tab > img { max-height: 100% !important; width: auto !important; max-width: 100% !important; object-fit: contain !important; }
  @media (min-width: 768px) {
    /* Desktop: grid FIXED height 528px (player 480 + quality bar 40 + gap 8) */
    /* → chat cell bounded → KHÔNG tự expand theo messages content */
    .idol-room-grid { grid-template-columns: minmax(0,1fr) 320px; height: 528px !important; align-items: stretch; grid-template-rows: 528px; }
    .idol-room-player { height: 480px; width: auto; aspect-ratio: 16/9; margin-left: auto; max-width: 100%; }
    /* Chat 100% grid cell height = 528px FIXED, overflow hidden để messages list scroll bên trong */
    .idol-room-chat { height: 528px !important; max-height: 528px !important; min-height: 0 !important; overflow: hidden !important; }
  }
</style>

