      </div>
    </div>
  </div>
</div>

<script>
/* ╔═══ FORCE chat aside height (runtime backup — chống CSS cache) ═══╗ */
(function(){
  function forceChatHeight(){
    var chat = document.querySelector('.idol-room-chat');
    var grid = document.querySelector('.idol-room-grid');
    if (!chat) return;
    if (window.innerWidth >= 768) {
      // Desktop: bounded theo grid 528px
      if (grid) {
        grid.style.height = '528px';
        grid.style.maxHeight = '528px';
        grid.style.gridTemplateRows = '528px';
      }
      chat.style.height = '528px';
      chat.style.maxHeight = '528px';
      chat.style.minHeight = '0';
      chat.style.overflow = 'hidden';
    } else {
      // Mobile: 60vh cap 70vh
      if (grid) {
        grid.style.height = '';
        grid.style.maxHeight = '';
        grid.style.gridTemplateRows = '';
      }
      var h = Math.min(window.innerHeight * 0.6, window.innerHeight * 0.7);
      chat.style.height = h + 'px';
      chat.style.maxHeight = (window.innerHeight * 0.7) + 'px';
      chat.style.overflow = 'hidden';
    }
    // Force flex-1 panels có overflow-y: auto + min-h: 0
    var chatBody = document.getElementById('chatBody');
    var giftLog  = document.getElementById('giftLog');
    [chatBody, giftLog].forEach(function(p){
      if (!p) return;
      p.style.flex = '1 1 0';
      p.style.minHeight = '0';
      p.style.overflowY = 'auto';
    });
    // Force children fixed phần (tab nav, status, CTA, input) shrink-0
    Array.prototype.forEach.call(chat.children, function(c){
      if (c.id !== 'chatBody' && c.id !== 'giftLog') {
        c.style.flexShrink = '0';
      }
    });
  }
  if (document.readyState !== 'loading') forceChatHeight();
  else document.addEventListener('DOMContentLoaded', forceChatHeight);
  window.addEventListener('load', forceChatHeight);
  var rzT = null;
  window.addEventListener('resize', function(){
    if (rzT) clearTimeout(rzT);
    rzT = setTimeout(forceChatHeight, 120);
  });
  // Cũng chạy lại sau mỗi lần switch tab
  window.__forceChatHeight = forceChatHeight;
})();
/* ╚═══ END FORCE chat height ═══╝ */

// ===== TAB CHAT / QUÀ trong khung chat phong idol =====
window.switchChatTab = function(tab){
  if (window.__forceChatHeight) window.__forceChatHeight();
  /* CHỈ toggle ACTIVE STATE (border, bg, text color) — KHÔNG ghi đè className
     để giữ nguyên kích thước button cho cả 2 mode: TEXT và ICON IMAGE */
  document.querySelectorAll('.cp-tab').forEach(function(t){
    var isActive = t.getAttribute('data-tab') === tab;
    if (isActive) {
      t.classList.add('bg-bg-card', 'text-pri-light', 'border-pri');
      t.classList.remove('bg-transparent', 'text-muted', 'border-transparent', 'hover:text-white');
    } else {
      t.classList.add('bg-transparent', 'text-muted', 'border-transparent', 'hover:text-white');
      t.classList.remove('bg-bg-card', 'text-pri-light', 'border-pri');
    }
  });
  document.querySelectorAll('[data-panel="chat"],[data-panel="gift"]').forEach(function(p){
    if (p.id === 'chatBody' || p.id === 'giftLog') {
      if (p.getAttribute('data-panel') === tab) p.classList.remove('hidden');
      else p.classList.add('hidden');
    }
  });
  // Update header stat label
  var label = document.getElementById('cpStatLabel');
  if (label) {
    if (tab === 'gift') label.innerHTML = 'Quà nhận: <b class="text-pri-light" id="cpStatNum">' + (window.__giftLogCount || 0) + '</b>';
    else label.innerHTML = 'Bình luận: <b class="text-pri-light" id="cpStatNum"><%= (Math.random()*5000|0)+1000 %></b>';
  }
  // Khi xem tab quà => clear badge
  if (tab === 'gift') {
    var b = document.getElementById('cpGiftBadge'); if (b) b.classList.add('hidden');
    window.__giftBadgeCount = 0;
  }
};

window.clearGiftLog = function(){
  if (!confirm('Xóa toàn bộ log quà tặng?')) return;
  var list = document.getElementById('giftLogList');
  if (list) list.innerHTML = '<div class="text-center py-8 text-muted text-[12px]"><div class="text-3xl mb-2 opacity-50">🎁</div><div>Chưa có quà tặng nào.</div></div>';
  window.__giftLogCount = 0;
};

// Hook vao gift panel: moi khi co quà tặng, đẩy vào log + badge nếu đang xem tab Chat
window.x66RecordGift = function(username, icon, name, price, tier){
  var list = document.getElementById('giftLogList');
  if (!list) return;
  // Clear "empty" placeholder if any
  if (list.querySelector('.text-center')) list.innerHTML = '';
  var TIER_COLOR = { common:'border-slate-500', rare:'border-sky-500', epic:'border-purple-500', legendary:'border-orange-500' };
  var item = document.createElement('div');
