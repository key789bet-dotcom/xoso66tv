    <!-- Top tippers -->
    <aside class="bg-bg-card border border-line rounded-xl p-4">
      <h3 class="text-pri-light text-sm font-bold mb-3 flex items-center gap-1.5">🏆 Top khách tặng quà hôm nay <span class="ml-auto text-[11px] text-muted">Tổng: <span class="text-gold font-bold tabular-nums"><%= tipsToday.toLocaleString('vi-VN') %> 🪙</span></span></h3>
      <div class="grid grid-cols-3 gap-2 text-center">
        <% ['vipFan88','iLove'+idol.name.charAt(0),'BoMy_X66'].forEach(function(name, i){
          var amount = (3-i) * 1500 + 200;
        %>
          <div class="bg-bg-soft border border-line rounded-lg p-3">
            <div class="text-2xl mb-1"><%= ['🥇','🥈','🥉'][i] %></div>
            <div class="text-xs font-bold text-white truncate"><%= name %></div>
            <div class="text-[11px] text-gold font-extrabold tabular-nums mt-0.5">🪙 <%= amount.toLocaleString('vi-VN') %></div>
