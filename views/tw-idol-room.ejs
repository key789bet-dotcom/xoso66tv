<style>
@keyframes lockModalPulse {
  0%,100% { transform: scale(1); opacity: .9; box-shadow: 0 0 24px rgba(255,122,24,.5); }
  50%     { transform: scale(1.08); opacity: 1; box-shadow: 0 0 48px rgba(233,30,99,.7); }
}
.lock-modal-pulse { animation: lockModalPulse 2s ease-in-out infinite; }
@keyframes lockSparkleOrbit1 {
  0% { transform: translateX(-50%) rotate(0deg) translateY(-48px) rotate(0deg); }
  100% { transform: translateX(-50%) rotate(360deg) translateY(-48px) rotate(-360deg); }
}
@keyframes lockSparkleOrbit2 {
  0% { transform: translateX(-50%) rotate(180deg) translateY(-48px) rotate(-180deg); }
  100% { transform: translateX(-50%) rotate(540deg) translateY(-48px) rotate(-540deg); }
}
.lock-sparkle-1 { animation: lockSparkleOrbit1 4s linear infinite; font-size: 18px; filter: drop-shadow(0 0 6px gold); }
.lock-sparkle-2 { animation: lockSparkleOrbit2 4s linear infinite; font-size: 14px; filter: drop-shadow(0 0 6px gold); }
@keyframes lockShake { 0%,100%{transform:translateX(0)} 25%{transform:translateX(-8px)} 75%{transform:translateX(8px)} }
.lock-shake { animation: lockShake .3s ease-in-out 2; }
</style>
<script>
(function(){
  var lock = <%= idol.lock %>;
  var pinRequired = <%= pinRequired ? 'true' : 'false' %>;
  var idolId = '<%= idolId %>';
  var idolName = '<%= idol.name.replace(/'/g, "\'") %>';
  var overlay = document.getElementById('lockOverlay');

  // ===== ADMIN BYPASS: skip lock modal completely =====
  if (typeof window.isUserAdmin === 'function' && window.isUserAdmin()) {
    if (window.x66ShowAdminBadge) window.x66ShowAdminBadge();
    return;
  }

  // ===== PHÒNG FREE (không khóa, không PIN) → KHÔNG cần đăng nhập, vào xem trực tiếp =====
  if ((!lock || lock <= 0) && !pinRequired) {
    return;
  }

  function showLockModal(){
    overlay.classList.remove('hidden');
    refreshBalance();
  }
  function refreshBalance(){
    try {
      var u = JSON.parse(localStorage.getItem('x66_user')||'{}');
      var coin = typeof u.coin === 'number' ? u.coin : 79;
      var el = document.getElementById('lockMyCoin');
      if (el) el.textContent = coin.toLocaleString('vi-VN');
    } catch(e){}
  }

  // Chỉ phòng KHÓA (lock > 0 hoặc có PIN) mới check auth + unlock
  try {
    var u = JSON.parse(localStorage.getItem('x66_user')||'{}');
    if (!u.username) {
      overlay.querySelector('h2').textContent = 'CẦN ĐĂNG NHẬP';
      overlay.querySelector('p').innerHTML = 'Phòng này khóa. Đăng nhập để mở khóa phòng <b class="text-pri-light">' + idolName + '</b>';
      document.getElementById('lockUnlockBtn').innerHTML = '<span class="text-lg">👤</span><span>ĐĂNG NHẬP NGAY</span>';
      document.getElementById('lockUnlockBtn').setAttribute('onclick', "location.href='/dang-nhap'");
      showLockModal();
      return;
    }
    var unlocked = JSON.parse(localStorage.getItem('x66_unlocked_idols')||'[]');
    if (unlocked.indexOf(idolId) < 0) {
      showLockModal();
    }
  } catch(e){
    showLockModal();
  }

  // ===== SWIPE GESTURE ON LOCK OVERLAY =====
  var lockAllIdols = <%- JSON.stringify(typeof allIdols !== 'undefined' ? allIdols : []) %>;
  var lockCurrentIdx = lockAllIdols.findIndex(function(i){ return i.id === idolId; });
  if (lockCurrentIdx < 0) lockCurrentIdx = 0;
  var lockNextI = lockAllIdols.length > 1 ? lockAllIdols[(lockCurrentIdx + 1) % lockAllIdols.length] : null;
  var lockPrevI = lockAllIdols.length > 1 ? lockAllIdols[(lockCurrentIdx - 1 + lockAllIdols.length) % lockAllIdols.length] : null;

  // Populate names in hints
  if (lockNextI) document.getElementById('lockSwipeNextName').textContent = lockNextI.emoji + ' ' + lockNextI.name;
  if (lockPrevI) document.getElementById('lockSwipePrevName').textContent = lockPrevI.emoji + ' ' + lockPrevI.name;
  if (!lockNextI) document.getElementById('lockSwipeUpHint').style.display = 'none';
  if (!lockPrevI) document.getElementById('lockSwipeDownHint').style.display = 'none';

  var lockTouchStartY = 0, lockTouchStartX = 0, lockTouchDeltaY = 0, lockSwiping = false, lockSwipeDecided = false;
  var LOCK_SWIPE_THRESHOLD = 70;

  function lockOnTouchStart(e){
    if (!e.touches || !e.touches[0]) return;
    // Don't interfere with button clicks inside modal
    if (e.target.closest('button') || e.target.closest('a') || e.target.closest('input')) return;
    lockTouchStartY = e.touches[0].clientY;
    lockTouchStartX = e.touches[0].clientX;
    lockTouchDeltaY = 0;
    lockSwiping = true;
    lockSwipeDecided = false;
  }
  function lockOnTouchMove(e){
    if (!lockSwiping || !e.touches || !e.touches[0]) return;
    var dy = e.touches[0].clientY - lockTouchStartY;
    var dx = e.touches[0].clientX - lockTouchStartX;
    if (!lockSwipeDecided && (Math.abs(dx) > 10 || Math.abs(dy) > 10)) {
      if (Math.abs(dx) > Math.abs(dy) / 1.2) { lockSwiping = false; return; }
      lockSwipeDecided = true;
    }
    if (!lockSwipeDecided) return;
    if (e.cancelable) e.preventDefault();
    lockTouchDeltaY = dy;
    var modal = overlay.querySelector('div.bg-gradient-to-b');
    if (modal) {
      modal.style.transition = 'none';
      modal.style.transform = 'translateY(' + (dy * 0.4) + 'px)';
      modal.style.opacity = Math.max(.5, 1 - Math.abs(dy)/300).toString();
    }
    // Highlight hint while swiping
    if (dy < -30 && lockNextI) {
      document.getElementById('lockSwipeUpHint').style.transform = 'scale(' + (1 + Math.min(.3, Math.abs(dy)/200)) + ')';
    } else if (dy > 30 && lockPrevI) {
      document.getElementById('lockSwipeDownHint').style.transform = 'scale(' + (1 + Math.min(.3, dy/200)) + ')';
    }
  }
  function lockOnTouchEnd(e){
    if (!lockSwiping) return;
    lockSwiping = false;
    var modal = overlay.querySelector('div.bg-gradient-to-b');
    if (modal) {
      modal.style.transition = 'transform .25s ease-out, opacity .25s ease-out';
    }
    document.getElementById('lockSwipeUpHint').style.transform = '';
    document.getElementById('lockSwipeDownHint').style.transform = '';

    if (lockTouchDeltaY < -LOCK_SWIPE_THRESHOLD && lockNextI) {
      // Slide out up + navigate
      if (modal) {
        modal.style.transform = 'translateY(-120vh)';
        modal.style.opacity = '0';
      }
      setTimeout(function(){ location.href = '/idol/' + lockNextI.id; }, 300);
    } else if (lockTouchDeltaY > LOCK_SWIPE_THRESHOLD && lockPrevI) {
      if (modal) {
        modal.style.transform = 'translateY(120vh)';
        modal.style.opacity = '0';
      }
      setTimeout(function(){ location.href = '/idol/' + lockPrevI.id; }, 300);
    } else {
      // Snap back
      if (modal) {
        modal.style.transform = '';
        modal.style.opacity = '';
      }
    }
    lockTouchDeltaY = 0;
  }
  // Attach to overlay (works on whole dark area)
  if (overlay) {
    overlay.addEventListener('touchstart', lockOnTouchStart, { passive: true });
    overlay.addEventListener('touchmove', lockOnTouchMove, { passive: false });
    overlay.addEventListener('touchend', lockOnTouchEnd, { passive: true });
    overlay.addEventListener('touchcancel', lockOnTouchEnd, { passive: true });
  }

  window.lockUnlockNow = function(){
    try {
      var u = JSON.parse(localStorage.getItem('x66_user')||'{}');
      var coin = typeof u.coin === 'number' ? u.coin : 79;
      if (coin < lock) {
        // Insufficient: shake + show error
        var modal = overlay.querySelector('div');
        modal.classList.add('lock-shake');
        setTimeout(function(){ modal.classList.remove('lock-shake'); }, 700);
        if (confirm('❌ X COIN không đủ!\n\nCần ' + lock + ' 🪙 - Bạn có ' + coin + ' 🪙\n\nNạp thêm X COIN ngay?')) {
          location.href = '/qua-tang';
        }
        return;
      }
      // Trừ coin + lưu unlocked
      u.coin = coin - lock;
      localStorage.setItem('x66_user', JSON.stringify(u));
      var unlocked = JSON.parse(localStorage.getItem('x66_unlocked_idols')||'[]');
      if (unlocked.indexOf(idolId) < 0) {
        unlocked.push(idolId);
        localStorage.setItem('x66_unlocked_idols', JSON.stringify(unlocked));
      }
      // Success animation
      overlay.querySelector('.text-5xl').textContent = '🎉';
      overlay.querySelector('h2').textContent = 'MỞ KHÓA THÀNH CÔNG!';
      overlay.querySelector('p').innerHTML = 'Đang vào phòng <b class="text-pri-light">' + idolName + '</b>...';
      setTimeout(function(){
        overlay.style.transition = 'opacity .3s';
        overlay.style.opacity = '0';
        setTimeout(function(){ overlay.classList.add('hidden'); overlay.style.opacity = '1'; }, 300);
      }, 1500);
    } catch(e){ alert('Lỗi: ' + e.message); }
  };
})();
</script>
<% } %>

