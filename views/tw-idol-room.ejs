<script>
(function(){
  var IDOL_ID = '<%= idolId %>';
  var coinRate = 0;
  var chargeTimer = null;

  function fetchRate(){
    fetch('/api/idol/' + IDOL_ID + '/coin-rate').then(function(r){return r.json();}).then(function(d){
      if (d.ok && d.coinPerMin > 0) {
        coinRate = d.coinPerMin;
        var badge = document.getElementById('cpmBadge');
        if (badge) {
          document.getElementById('cpmRate').textContent = d.coinPerMin;
          badge.classList.remove('hidden');
          startTick();
        }
      }
    });
  }

  function updateBalance(coin){
    var el = document.getElementById('cpmBalance');
    if (el) el.textContent = (coin == null ? '—' : coin.toLocaleString('vi-VN'));
  }

  function startTick(){
    if (chargeTimer) return;
    // Tick đầu sau 60s, không trừ ngay khi vào
    chargeTimer = setInterval(function(){
      // Chỉ trừ nếu tab đang active + chưa kicked
      if (document.hidden) return;
      fetch('/api/room/' + IDOL_ID + '/charge', { method:'POST', credentials:'same-origin' })
        .then(function(r){return r.json();})
        .then(function(d){
          if (d.ok) {
            updateBalance(d.newBalance);
            if (d.free) clearInterval(chargeTimer);
          } else if (d.kicked) {
            clearInterval(chargeTimer);
            document.getElementById('cpmKickRate').textContent = d.needCoin || coinRate;
            document.getElementById('cpmKickModal').classList.remove('hidden');
          }
        })
        .catch(function(){});
    }, 60000); // 60s = 1 phút
  }

  // Lấy initial balance từ localStorage
  try {
    var u = JSON.parse(localStorage.getItem('x66_user') || '{}');
    if (typeof u.coin === 'number') updateBalance(u.coin);
  } catch(e){}

  fetchRate();
})();
</script>

