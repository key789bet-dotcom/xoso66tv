(function initIdolChat(){
  var hasObs = <%= (typeof hasObs !== 'undefined' && hasObs) ? 'true' : 'false' %>;
  // 🚨 Flag global cho gift-panel + chat-v2 biết phòng có đang live thật không
  window.__x66HasObs = hasObs;
  function start(){
    if (typeof window.startChat === 'function') {
      window.startChat('chatBody', { mode: 'idol', isLive: hasObs });
    } else {
      // Retry sau khi chat-v2.js load
      setTimeout(start, 300);
    }
  }
  if (document.readyState !== 'loading') start();
  else document.addEventListener('DOMContentLoaded', start);
})();
</script>

