/* ╔══════ ALBUM COVERFLOW controller ══════╗ */
(function(){
  var root = document.getElementById('albSlider');
  if (!root) return;
  var COUNT = parseInt(root.getAttribute('data-count'), 10) || 0;
  if (COUNT < 1) return;

  var stage    = root.querySelector('.alb-stage');
  var track    = document.getElementById('albTrack');
  var slides   = track.querySelectorAll('.alb-slide');
  var dots     = root.querySelectorAll('.alb-dot');
  var curEl    = document.getElementById('albCurr');
  var progFill = document.getElementById('albProgFill');
  var playBtn  = document.getElementById('albPlayBtn');

  var idx = 0;
  var playing = true;
  var DURATION = 4500;   // 4.5s per slide
  var TICK = 60;
  var elapsed = 0;
  var timer = null;

  /* Layout metrics theo viewport (đồng bộ với @media CSS).
     Track box-sizing: border-box → content area = stageW - padL - padR.
     CSS active flex-basis dùng %, nên phải nhân với content area. */
  function getLayout(){
    var stageW = stage.clientWidth;
    var isXs = stageW < 480;
    var isSm = !isXs && stageW < 768;
    var conf;
    if (isXs)      conf = { sideW: 44, gap: 6,  padL: 10, padR: 10, actMax: Infinity, actPct: 0.78 };
    else if (isSm) conf = { sideW: 56, gap: 6,  padL: 10, padR: 10, actMax: Infinity, actPct: 0.72 };
    else           conf = { sideW: 88, gap: 10, padL: 14, padR: 14, actMax: 640,      actPct: 0.7  };
    var content = stageW - conf.padL - conf.padR;
    var activeW = Math.min(conf.actMax, content * conf.actPct);
    return { stageW: stageW, sideW: conf.sideW, gap: conf.gap, padL: conf.padL, padR: conf.padR, activeW: activeW };
  }

  /* Re-center track: tính toán deterministic, không đo DOM (đang animate) */
  function centerTrack(){
    // Stage chưa render xong → retry
    if (!stage.clientWidth) { setTimeout(centerTrack, 80); return; }
    var m = getLayout();
    // offsetLeft TARGET của slide active:
    //   padding-left của track + idx * (sideW + gap)
    // (vì tất cả slide trước idx đều là side khi idx là active)
    var targetLeft = m.padL + idx * (m.sideW + m.gap);
    var center     = targetLeft + m.activeW / 2;
    var tx         = (m.stageW / 2) - center;
    track.style.transform = 'translateX(' + tx.toFixed(1) + 'px)';
  }

  function setActive(n, opts){
    n = ((n % COUNT) + COUNT) % COUNT;
    idx = n;
    slides.forEach(function(s, i){ s.classList.toggle('is-active', i === n); });
    dots.forEach(function(s, i){ s.classList.toggle('is-active', i === n); });
    if (curEl) curEl.textContent = (n + 1);
    elapsed = 0;
    if (progFill) progFill.style.width = '0%';
    // Tính toán deterministic → có thể gọi ngay, transform chạy đồng bộ với flex-basis
    centerTrack();
  }

  function tick(){
    if (!playing) return;
    elapsed += TICK;
    if (progFill) progFill.style.width = (elapsed / DURATION * 100) + '%';
    if (elapsed >= DURATION) setActive(idx + 1);
  }
  function start(){ if (timer) return; timer = setInterval(tick, TICK); }
  function stop(){ if (timer) { clearInterval(timer); timer = null; } }

  window.albGo = function(delta){ setActive(idx + delta); };
  window.albJump = function(n){ setActive(n); };
  window.albToggle = function(){
    playing = !playing;
    if (playBtn) playBtn.textContent = playing ? '⏸' : '▶';
    if (!playing) { elapsed = 0; if (progFill) progFill.style.width = '0%'; }
  };
  /* Click slide: nếu là slide active → mở lightbox, nếu không → đưa lên active */
  window.albSlideClick = function(n){
    if (n === idx) {
      window.openLightbox('photo', n);
    } else {
      setActive(n);
    }
  };

  /* Hover pause (desktop) */
  stage.addEventListener('mouseenter', function(){ stop(); });
  stage.addEventListener('mouseleave', function(){ if (playing) start(); });

  /* Pause khi tab inactive */
  document.addEventListener('visibilitychange', function(){
    if (document.hidden) stop(); else if (playing) start();
  });

  /* Keyboard navigation khi focus slider */
  root.setAttribute('tabindex', '0');
  root.addEventListener('keydown', function(e){
    if (e.key === 'ArrowLeft')  { setActive(idx - 1); e.preventDefault(); }
    if (e.key === 'ArrowRight') { setActive(idx + 1); e.preventDefault(); }
    if (e.key === ' ')          { window.albToggle(); e.preventDefault(); }
    if (e.key === 'Enter')      { window.openLightbox('photo', idx); e.preventDefault(); }
  });

  /* Touch swipe trên mobile */
  var tX = 0, tY = 0, swiping = false;
  stage.addEventListener('touchstart', function(e){
    if (!e.touches.length) return;
    tX = e.touches[0].clientX; tY = e.touches[0].clientY; swiping = true;
    stop();
  }, { passive: true });
  stage.addEventListener('touchend', function(e){
    if (!swiping || !e.changedTouches.length) { if (playing) start(); return; }
    var dx = e.changedTouches[0].clientX - tX;
    var dy = e.changedTouches[0].clientY - tY;
    if (Math.abs(dx) > 40 && Math.abs(dx) > Math.abs(dy)) {
      setActive(idx + (dx < 0 ? 1 : -1));
    }
    swiping = false;
    if (playing) start();
  }, { passive: true });

  /* Resize → re-center */
  var rzTimer = null;
  window.addEventListener('resize', function(){
    if (rzTimer) clearTimeout(rzTimer);
    rzTimer = setTimeout(centerTrack, 120);
  });

  /* Init: đợi font + layout settle rồi center */
  if (document.readyState === 'complete') {
    setTimeout(function(){ setActive(0); start(); }, 50);
  } else {
    window.addEventListener('load', function(){
      setTimeout(function(){ setActive(0); start(); }, 50);
    });
    // Fallback nếu load đã fire trước script
    setTimeout(function(){ setActive(0); start(); }, 300);
  }
})();
/* ╚══════ END ALBUM COVERFLOW ══════╝ */

window.openLightbox = function(type, idx){
  LB.type = type; LB.idx = idx;
  document.getElementById('lightbox').classList.remove('hidden');
  renderLightbox();
};
window.closeLightbox = function(){ document.getElementById('lightbox').classList.add('hidden'); };
window.lightboxPrev = function(){
  var arr = LB.type==='photo' ? LB.photos : LB.videos;
  LB.idx = (LB.idx - 1 + arr.length) % arr.length;
  renderLightbox();
};
window.lightboxNext = function(){
  var arr = LB.type==='photo' ? LB.photos : LB.videos;
  LB.idx = (LB.idx + 1) % arr.length;
  renderLightbox();
};
function renderLightbox(){
  var arr = LB.type==='photo' ? LB.photos : LB.videos;
  var item = arr[LB.idx];
  var content = document.getElementById('lbContent');
  if (LB.type === 'photo') {
    content.style.background = item.color;
    content.innerHTML = '<div style="font-size:160px;text-shadow:0 8px 32px rgba(0,0,0,.5)">'+item.emoji+'</div>';
    document.getElementById('lbTitle').textContent = item.caption;
  } else {
    content.style.background = 'linear-gradient(135deg,#1a1f29,#0e1116)';
    content.innerHTML = '<div style="text-align:center"><div style="font-size:120px;margin-bottom:16px">'+item.emoji+'</div></div>';
    document.getElementById('lbTitle').textContent = item.title + ' • ' + item.views + ' lượt xem';
  }
  document.getElementById('lbMeta').textContent = (LB.idx+1) + ' / ' + arr.length;
}

function toggleFollow(b){ b.textContent = b.textContent.indexOf('Đã')>=0 ? '❤ Theo dõi' : '✓ Đã theo dõi'; }

