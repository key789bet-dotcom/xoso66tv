<%
seo = {
  title: 'Đăng ký làm Bình Luận Viên (BLV) - ' + brand.name,
  description: 'Trở thành BLV thể thao trên ' + brand.domain + '. Live bình luận bóng đá, casino, esports.',
  canonical: '/dang-ky-blv',
  noindex: true
};
%>
<%- include('partials/tw-layout-start') %>

<section class="max-w-2xl mx-auto mb-8 px-3">
  <div class="relative bg-gradient-to-br from-blue-600 via-cyan-600 to-emerald-600 rounded-2xl p-6 mb-5 overflow-hidden">
    <div class="absolute -top-10 -right-10 text-9xl opacity-10">⚽</div>
    <div class="absolute -bottom-10 -left-10 text-9xl opacity-10">🎙️</div>
    <h1 class="text-3xl font-black text-white mb-2">🎙️ Đăng ký làm Bình Luận Viên</h1>
    <p class="text-cyan-100 text-sm">Trở thành BLV thể thao chuyên nghiệp, kiếm thu nhập từ <b>X COIN</b>, follower và sponsor.</p>
    <div class="mt-4 grid grid-cols-3 gap-2 text-center">
      <div class="bg-white/15 backdrop-blur rounded-lg p-2"><div class="text-2xl">⚽</div><div class="text-[10px] text-white font-bold mt-1">BLV bóng đá</div></div>
      <div class="bg-white/15 backdrop-blur rounded-lg p-2"><div class="text-2xl">🎰</div><div class="text-[10px] text-white font-bold mt-1">BLV casino</div></div>
      <div class="bg-white/15 backdrop-blur rounded-lg p-2"><div class="text-2xl">🎮</div><div class="text-[10px] text-white font-bold mt-1">BLV esports</div></div>
    </div>
  </div>

  <div id="myStatusBox" class="hidden mb-4"></div>

  <form id="applyBlvForm" class="bg-bg-card border border-line rounded-2xl p-5 shadow-2xl space-y-4">
    <h2 class="text-white font-extrabold text-lg mb-1">📝 Thông tin BLV</h2>
    <p class="text-muted text-xs mb-3">User đăng nhập: <code class="text-pri-light"><%= user.username %></code></p>

    <div>
      <label class="text-[11px] text-muted uppercase font-bold block mb-1.5">Tên BLV <span class="text-live">*</span></label>
      <input name="stageName" type="text" required minlength="2" maxlength="40" class="w-full bg-bg-deep border border-line text-white px-3 py-2.5 rounded-lg outline-none focus:border-pri" placeholder="VD: BLV Đức Huy, BLV Anh Quân..."/>
    </div>

    <div class="grid grid-cols-2 gap-3">
      <div>
        <label class="text-[11px] text-muted uppercase font-bold block mb-1.5">Môn chuyên <span class="text-live">*</span></label>
        <select name="sport" required class="w-full bg-bg-deep border border-line text-white px-3 py-2.5 rounded-lg outline-none focus:border-pri">
          <option value="">-- Chọn môn --</option>
          <option value="football">⚽ Bóng đá</option>
          <option value="basketball">🏀 Bóng rổ</option>
          <option value="tennis">🎾 Tennis</option>
          <option value="volleyball">🏐 Bóng chuyền</option>
          <option value="badminton">🏸 Cầu lông</option>
          <option value="esports">🎮 Esports</option>
          <option value="casino">🎰 Casino</option>
          <option value="boxing">🥊 Boxing/MMA</option>
          <option value="racing">🏎️ Đua xe</option>
          <option value="other">🔥 Khác</option>
        </select>
      </div>
      <div>
        <label class="text-[11px] text-muted uppercase font-bold block mb-1.5">Kinh nghiệm <span class="text-live">*</span></label>
        <input name="experience" type="number" required min="1" max="50" class="w-full bg-bg-deep border border-line text-white px-3 py-2.5 rounded-lg outline-none focus:border-pri" placeholder="Số năm (vd: 3)"/>
      </div>
    </div>

    <div>
      <label class="text-[11px] text-muted uppercase font-bold block mb-1.5">Phong cách bình luận</label>
      <select name="style" class="w-full bg-bg-deep border border-line text-white px-3 py-2.5 rounded-lg outline-none focus:border-pri">
        <option value="năng động">⚡ Năng động, hài hước</option>
        <option value="chuyên sâu">📊 Chuyên sâu, phân tích</option>
        <option value="cuồng nhiệt">🔥 Cuồng nhiệt, cảm xúc</option>
        <option value="trung lập">📖 Trung lập, khách quan</option>
        <option value="giải trí">🎭 Giải trí, vui nhộn</option>
      </select>
    </div>

    <div>
      <label class="text-[11px] text-muted uppercase font-bold block mb-1.5">Giới thiệu kinh nghiệm <span class="text-live">*</span> (≥30 ký tự)</label>
      <textarea name="bio" required minlength="30" maxlength="600" rows="4" class="w-full bg-bg-deep border border-line text-white px-3 py-2.5 rounded-lg outline-none focus:border-pri resize-none" placeholder="VD: Từng làm BLV bóng đá 3 năm tại các giải nội bộ. Đam mê thể thao, am hiểu Premier League, V-League. Có khả năng đọc trận đấu nhanh..."></textarea>
    </div>

    <!-- Avatar UPLOAD từ máy/điện thoại -->
    <div>
      <label class="text-[11px] text-muted uppercase font-bold block mb-1.5">📸 Ảnh đại diện (tùy chọn)</label>
      <div class="border-2 border-dashed border-line rounded-lg p-4 bg-bg-deep hover:border-pri/60 transition-colors">
        <div id="avatarPreview" class="hidden mb-3 text-center">
          <img id="avatarImg" alt="Preview" class="w-28 h-28 mx-auto rounded-full object-cover border-2 border-pri shadow-lg" style="object-fit:cover;">
          <button type="button" id="avatarRemove" class="mt-2 text-xs text-live hover:text-red-400 font-bold">✕ Xóa ảnh</button>
        </div>
        <div id="avatarEmpty" class="text-center">
          <div class="text-3xl mb-1.5 opacity-60">📷</div>
          <p class="text-xs text-muted mb-2">Chụp ảnh bằng điện thoại hoặc chọn từ thư viện</p>
          <div class="flex gap-2 justify-center flex-wrap">
            <label class="cursor-pointer px-3 py-2 bg-pri/20 hover:bg-pri/30 border border-pri/50 text-pri-light text-xs font-bold rounded-lg flex items-center gap-1.5">
              📸 Chụp ảnh
              <input type="file" accept="image/*" capture="user" class="hidden" data-avatar-input>
            </label>
            <label class="cursor-pointer px-3 py-2 bg-bg-card hover:bg-bg-soft border border-line text-white text-xs font-bold rounded-lg flex items-center gap-1.5">
              🖼️ Chọn từ máy
              <input type="file" accept="image/*" class="hidden" data-avatar-input>
            </label>
          </div>
          <p class="text-[10px] text-dim mt-2">JPG/PNG/WEBP/GIF/HEIC — tối đa 5MB. Để trống = tự sinh ảnh mặc định</p>
        </div>
        <input type="file" name="avatarFile" accept="image/*" class="hidden" id="avatarFinal">
      </div>
    </div>

    <div class="bg-bg-deep border border-pri/30 rounded-lg p-3 text-[12px] text-muted leading-relaxed">
      <h3 class="text-white font-bold mb-1.5 text-sm">📋 Điều khoản BLV</h3>
      <ul class="space-y-1 list-disc list-inside">
        <li>Bình luận chính xác, không thiên vị, không xúc phạm</li>
        <li>Không tiết lộ kèo cá độ bất hợp pháp</li>
        <li>Tuân thủ pháp luật Việt Nam khi live stream</li>
        <li>XOSO66 TV giữ % phí 25% trên doanh thu quà tặng</li>
        <li>Bị ban nếu vi phạm nội dung phát sóng</li>
      </ul>
    </div>

    <label class="flex items-center gap-2 text-sm text-muted cursor-pointer">
      <input type="checkbox" name="agree" required class="w-4 h-4 accent-pri">
      Tôi đồng ý điều khoản và cam kết bình luận trung thực
    </label>

    <button type="submit" id="submitBtn" class="w-full py-3.5 bg-gradient-to-r from-blue-500 via-cyan-500 to-emerald-500 hover:brightness-110 text-white font-extrabold text-base rounded-xl shadow-lg shadow-blue-500/30 active:scale-95 transition-all">
      🎙️ GỬI ĐƠN ĐĂNG KÝ BLV
    </button>

    <p class="text-center text-[11px] text-muted">
      Admin sẽ duyệt trong 24h · <a href="/dang-ky-idol" class="text-pri-light hover:underline">Muốn làm Idol live? →</a>
    </p>
  </form>
</section>

<div id="toast" class="fixed top-20 right-5 bg-bg-card border border-line border-l-4 border-l-pri px-4 py-3 rounded-lg text-white text-sm font-semibold z-[100] shadow-2xl translate-x-[120%] transition-transform"></div>

<script>
function showToast(msg, kind){
  var t = document.getElementById('toast');
  var col = kind==='success' ? '!border-l-emerald-500' : kind==='error' ? '!border-l-live' : '!border-l-pri';
  t.className = 'fixed top-20 right-5 bg-bg-card border border-line border-l-4 px-4 py-3 rounded-lg text-white text-sm font-semibold z-[100] shadow-2xl translate-x-0 transition-transform ' + col;
  t.textContent = msg;
  setTimeout(function(){ t.className = t.className.replace('translate-x-0','translate-x-[120%]'); }, 4000);
}

fetch('/api/apply/my-status', { credentials:'same-origin' })
  .then(function(r){ return r.json(); })
  .then(function(j){
    if (j.ok && j.blv) {
      var box = document.getElementById('myStatusBox');
      var st = j.blv.status;
      var color = st==='active' ? 'emerald' : st==='pending' ? 'yellow' : 'live';
      var icon  = st==='active' ? '✅' : st==='pending' ? '⏳' : '❌';
      var label = st==='active' ? 'ĐÃ DUYỆT - Bạn là BLV' : st==='pending' ? 'ĐANG CHỜ DUYỆT' : 'ĐƠN BỊ TỪ CHỐI';
      box.innerHTML = '<div class="bg-'+color+'-500/15 border-2 border-'+color+'-500/50 rounded-xl p-4 text-center">'
        + '<div class="text-4xl mb-2">'+icon+'</div>'
        + '<div class="text-white font-extrabold text-lg">'+label+'</div>'
        + '<div class="text-muted text-xs mt-1">Tên BLV: <b class="text-pri-light">'+j.blv.name+'</b></div>'
        + (j.blv.rejectReason ? '<div class="text-live text-sm mt-2">Lý do: '+j.blv.rejectReason+'</div>' : '')
        + (st==='active' ? '<a href="/idol-studio" class="inline-block mt-3 px-5 py-2 bg-gradient-to-r from-blue-500 to-cyan-500 text-white font-bold rounded-lg">📡 Vào Studio Live</a>' : '')
        + '</div>';
      box.classList.remove('hidden');
      if (st === 'pending' || st === 'active') {
        document.getElementById('applyBlvForm').style.display = 'none';
      }
    }
  });

// ═══ AVATAR UPLOAD HANDLER ═══
(function(){
  var inputs = document.querySelectorAll('[data-avatar-input]');
  var preview = document.getElementById('avatarPreview');
  var empty = document.getElementById('avatarEmpty');
  var img = document.getElementById('avatarImg');
  var final = document.getElementById('avatarFinal');
  var removeBtn = document.getElementById('avatarRemove');
  function handleFile(file) {
    if (!file) return;
    if (file.size > 5 * 1024 * 1024) { showToast('Ảnh quá lớn (max 5MB)', 'error'); return; }
    if (!/^image\//i.test(file.type)) { showToast('Chỉ chấp nhận file ảnh', 'error'); return; }
    var dt = new DataTransfer(); dt.items.add(file); final.files = dt.files;
    var r = new FileReader();
    r.onload = function(e){ img.src = e.target.result; preview.classList.remove('hidden'); empty.classList.add('hidden'); };
    r.readAsDataURL(file);
  }
  inputs.forEach(function(inp){
    inp.addEventListener('change', function(e){ if (e.target.files && e.target.files[0]) handleFile(e.target.files[0]); });
  });
  removeBtn.addEventListener('click', function(){
    final.value = ''; img.src = ''; preview.classList.add('hidden'); empty.classList.remove('hidden');
    inputs.forEach(function(inp){ inp.value = ''; });
  });
})();

document.getElementById('applyBlvForm').addEventListener('submit', async function(e){
  e.preventDefault();
  var f = this;
  var fd = new FormData();
  var fields = ['stageName','sport','experience','bio','style'];
  fields.forEach(function(k){ if (f[k]) fd.append(k, f[k].value || ''); });
  fd.append('agree', f.agree.checked ? '1' : '');
  var avatarFinal = document.getElementById('avatarFinal');
  if (avatarFinal && avatarFinal.files && avatarFinal.files[0]) fd.append('avatarFile', avatarFinal.files[0]);
  var btn = document.getElementById('submitBtn');
  btn.disabled = true; btn.textContent = 'Đang gửi...';
  try {
    var r = await fetch('/api/apply/blv', {
      method:'POST',
      credentials:'same-origin',
      body: fd
    });
    var j = await r.json();
    if (j.ok) {
      showToast('🎉 ' + j.message,'success');
      setTimeout(function(){ location.reload(); }, 2000);
    } else {
      showToast(j.error || 'Lỗi','error');
      btn.disabled = false; btn.textContent = '🎙️ GỬI ĐƠN ĐĂNG KÝ BLV';
    }
  } catch(err){
    showToast('Lỗi kết nối','error');
    btn.disabled = false; btn.textContent = '🎙️ GỬI ĐƠN ĐĂNG KÝ BLV';
  }
});
</script>

<%- include('partials/tw-footer') %>
