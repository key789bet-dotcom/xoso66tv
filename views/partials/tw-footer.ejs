<script>
// 🖼️ Auto lazy-load + async-decode cho mọi <img> không có loading attribute
// Giảm initial page load ~70%, không cần thay đổi HTML existing.
// Skip ảnh trong viewport đầu tiên (hero, top banner) bằng cách check offsetTop.
(function(){
  function applyLazy() {
    var imgs = document.querySelectorAll('img:not([loading])');
    var viewportH = window.innerHeight || 800;
    imgs.forEach(function(img){
      // Ảnh ngay đầu viewport (top 1.5x screen) → eager để LCP nhanh
      var rect = img.getBoundingClientRect();
      if (rect.top < viewportH * 1.5 && rect.top > -100) {
        img.loading = 'eager';
        img.fetchPriority = 'high';
      } else {
        img.loading = 'lazy';
      }
      if (!img.decoding) img.decoding = 'async';
    });
  }
  if (document.readyState !== 'loading') applyLazy();
  else document.addEventListener('DOMContentLoaded', applyLazy);
  // Re-apply cho ảnh thêm động (vd: infinite scroll, chat avatar mới)
  new MutationObserver(function(muts){
    var hasNew = muts.some(function(m){ return m.addedNodes && m.addedNodes.length > 0; });
    if (hasNew) applyLazy();
  }).observe(document.body, { childList: true, subtree: true });
})();
</script>
<!-- 🛡️ Sentry browser SDK — lazy loader (chỉ load khi có error xảy ra) -->
<script
  src="https://js.sentry-cdn.com/bbaaccc636dbd85ef5e06e11f60a9727.min.js"
  crossorigin="anonymous"
  async
></script>
<script>
  // Sentry config — chạy KHI loader đã load
  window.sentryOnLoad = function() {
    if (!window.Sentry) return;
    Sentry.init({
      environment: location.hostname === 'xoso66tv.com' ? 'production' : 'staging',
      release: 'xoso66tv-client@1.0.0',
      // Quota safe: chỉ capture errors, KHÔNG capture session/traces
      sampleRate: 1.0,           // 100% errors
      tracesSampleRate: 0,        // 0% performance traces
      replaysSessionSampleRate: 0,
      replaysOnErrorSampleRate: 0,
      // Filter noise
      ignoreErrors: [
        // Browser extensions / quirks
        'top.GLOBALS', 'ResizeObserver loop limit exceeded',
        'ResizeObserver loop completed with undelivered notifications',
        'Non-Error promise rejection captured',
        // Network errors (user mất WiFi)
        'NetworkError', 'Failed to fetch', 'Load failed',
        'The Internet connection appears to be offline',
        // Cancel / abort
        'AbortError', 'The operation was aborted',
        // Tampermonkey / Greasemonkey / Ad-blockers
        'TypeError: undefined is not an object (evaluating \'window.webkit',
        'Script error.', // CORS-blocked external script errors (không actionable)
        // FLV.js noise đã handle reconnect
        'pendingSeekTime', 'FLV codec invalid'
      ],
      denyUrls: [
        // Extensions
        /^chrome:\/\//i, /^chrome-extension:\/\//i, /^moz-extension:\/\//i, /^safari-extension:\/\//i,
        // 3rd party (Cloudflare insights, etc.)
        /static\.cloudflareinsights\.com/i,
        /googletagmanager\.com/i,
        /google-analytics\.com/i
      ],
      beforeSend: function(event) {
        // Skip nếu error không có stack (thường là crap từ extension)
        if (!event.exception || !event.exception.values || !event.exception.values[0].stacktrace) {
          // Vẫn cho qua các error có message rõ ràng
          if (!event.message) return null;
        }
        return event;
      }
    });
  };
</script>
