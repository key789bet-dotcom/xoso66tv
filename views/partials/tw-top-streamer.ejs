<%
// Mock data top streamer (sau có thể load từ DB qua res.locals.topStreamers)
var TOP_STREAMERS = (typeof topStreamers !== 'undefined' && topStreamers && topStreamers.length) ? topStreamers : [];
%>

<% if (TOP_STREAMERS.length === 0) { %><!-- No streamers, hide section --><% } else { %>
<section class="bg-bg-card border border-line rounded-xl overflow-hidden mb-6" aria-label="Top Streamer">

  <!-- Header bar (orange) -->
  <header class="flex items-center justify-between px-3 md:px-4 py-1.5 md:py-2.5 bg-gradient-to-r from-pri to-pri-dark text-white">
    <div class="flex items-center gap-1.5 md:gap-2.5">
      <span class="text-base md:text-xl drop-shadow">&#127942;</span>
      <h2 class="text-sm md:text-lg font-extrabold tracking-wide">Top Streamer</h2>
    </div>
    <a href="/idol-live" class="flex items-center gap-1 md:gap-1.5 text-[10px] md:text-[12px] font-bold hover:bg-white/15 px-2 md:px-3 py-1 md:py-1.5 rounded-md transition-colors">
      Xem Tất Cả
      <span class="bg-white/25 w-5 h-5 rounded grid place-items-center text-xs">&nearr;</span>
    </a>
  </header>

  <!-- Carousel body -->
  <div class="relative px-8 md:px-12 py-2 md:py-4 bg-[#11151c]">

    <!-- Left arrow -->
    <button type="button" id="tsPrev" class="absolute left-1 md:left-2 top-1/2 -translate-y-1/2 z-10 w-7 h-7 md:w-9 md:h-9 grid place-items-center bg-bg-soft hover:bg-pri text-white rounded-full border border-line hover:border-pri shadow-lg transition-all" aria-label="Trước">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
    </button>

    <!-- Right arrow -->
    <button type="button" id="tsNext" class="absolute right-1 md:right-2 top-1/2 -translate-y-1/2 z-10 w-7 h-7 md:w-9 md:h-9 grid place-items-center bg-bg-soft hover:bg-pri text-white rounded-full border border-line hover:border-pri shadow-lg transition-all" aria-label="Sau">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
    </button>

    <!-- Track (overflow hidden, scroll-snap horizontal) -->
    <div id="tsTrack" class="flex gap-2 md:gap-5 overflow-x-auto scrollbar-hide scroll-smooth snap-x snap-mandatory py-1 md:py-2" style="scroll-snap-type:x mandatory">
      <% TOP_STREAMERS.forEach(function(s, i){ %>
        <article class="ts-card snap-center shrink-0 flex flex-col items-center gap-1 md:gap-2 transition-all duration-300 w-[72px] md:!w-[120px]" data-idx="<%= i %>" data-id="<%= s.id %>">
          <!-- Avatar + Name là LINK đến phòng -->
          <a href="<%= s.href || '#' %>" class="contents" aria-label="Vào phòng <%= s.name %>">
            <!-- Avatar with orange border -->
            <div class="relative">
              <div class="ts-ring w-12 h-12 md:w-[88px] md:h-[88px] rounded-full p-[2px] md:p-[3px] bg-gradient-to-br from-pri-light via-pri to-pri-dark shadow-pri transition-all">
                <div class="w-full h-full rounded-full bg-bg-deep overflow-hidden">
                  <img src="<%= s.avatar %>" alt="<%= s.name %>" loading="lazy" class="w-full h-full object-cover" onerror="this.outerHTML='<div class=&quot;w-full h-full grid place-items-center text-2xl font-black text-white bg-gradient-to-br from-pri to-pri-dark&quot;>'+'<%= (s.name||'?')[0] %>'+'</div>'">
                </div>
              </div>
              <!-- LIVE dot - dùng s.liveNow THẬT từ DB (đã sync auto từ SRS) -->
              <% if (s.liveNow) { %>
                <span class="ts-live absolute -bottom-0.5 left-1/2 -translate-x-1/2 bg-live text-white text-[8px] md:text-[9px] font-extrabold px-1 md:px-1.5 py-0 rounded-full border md:border-2 border-bg-card animate-pulse-live">LIVE</span>
              <% } %>
            </div>

            <!-- Name -->
            <div class="ts-name text-[10px] md:text-[13px] font-extrabold text-white text-center leading-tight max-w-[72px] md:max-w-[110px] truncate hover:text-pri-light transition-colors"><%= s.name %></div>
          </a>

          <!-- Follow button (compact mobile, full desktop) - KHÔNG nằm trong link để click follow không vào phòng -->
          <button type="button" onclick="event.stopPropagation();event.preventDefault();this.classList.toggle('!bg-pri');this.classList.toggle('!text-white');var t=this.querySelector('.ts-fwd-txt'); if(t)t.textContent=t.textContent.trim()==='Theo dõi'?'Đã theo':'Theo dõi'" class="inline-flex items-center gap-0.5 md:gap-1 bg-bg-soft hover:bg-pri text-gray-200 hover:text-white text-[9px] md:text-[11px] font-semibold px-1.5 md:px-2.5 py-0.5 md:py-1 rounded-md border border-line/60 hover:border-pri transition-all">
            <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="md:w-[11px] md:h-[11px]"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            <span class="ts-fwd-txt">Theo dõi</span>
          </button>
        </article>
      <% }); %>
    </div>

    <!-- Progress bar -->
    <div class="mt-3 mx-2 h-1 bg-bg-deep rounded-full overflow-hidden">
      <div id="tsProgress" class="h-full bg-gradient-to-r from-pri to-pri-light rounded-full transition-all duration-300" style="width:8%"></div>
    </div>
  </div>
</section>
<% } %>

<style>
.ts-card.is-center .ts-ring { transform: scale(1.15); box-shadow: 0 8px 24px rgba(255,122,24,.55); }
.ts-card.is-center .ts-name { color: #ffb14a; text-shadow: 0 2px 8px rgba(255,122,24,.5); }
.ts-card { transform: scale(0.92); opacity: 0.7; }
.ts-card.is-near { transform: scale(1); opacity: 0.95; }
.ts-card.is-center { transform: scale(1.05); opacity: 1; }
</style>

<script>
(function(){
  var track = document.getElementById('tsTrack');
  var prev  = document.getElementById('tsPrev');
  var next  = document.getElementById('tsNext');
  var prog  = document.getElementById('tsProgress');
  if (!track) return;
  var cards = Array.from(track.querySelectorAll('.ts-card'));
  if (!cards.length) return;

  var cardW = cards[0].offsetWidth + 20; // width + gap
  var current = 0;

  function highlightCenter(){
    var rect = track.getBoundingClientRect();
    var centerX = rect.left + rect.width / 2;
    var nearestIdx = 0;
    var minDist = Infinity;
    cards.forEach(function(c, i){
      c.classList.remove('is-center','is-near');
      var cRect = c.getBoundingClientRect();
      var cCenter = cRect.left + cRect.width / 2;
      var d = Math.abs(centerX - cCenter);
      if (d < minDist) { minDist = d; nearestIdx = i; }
    });
    cards[nearestIdx].classList.add('is-center');
    if (cards[nearestIdx-1]) cards[nearestIdx-1].classList.add('is-near');
    if (cards[nearestIdx+1]) cards[nearestIdx+1].classList.add('is-near');
    current = nearestIdx;
    // Progress
    var pct = Math.min(100, Math.max(0, (track.scrollLeft / (track.scrollWidth - track.clientWidth)) * 100));
    if (prog) prog.style.width = (isFinite(pct) ? pct : 0) + '%';
  }

  function scrollTo(idx){
    if (idx < 0) idx = cards.length - 1;
    if (idx >= cards.length) idx = 0;
    var c = cards[idx];
    var offset = c.offsetLeft - (track.clientWidth/2 - c.offsetWidth/2);
    track.scrollTo({ left: offset, behavior: 'smooth' });
    current = idx;
  }

  prev.addEventListener('click', function(){ scrollTo(current - 1); });
  next.addEventListener('click', function(){ scrollTo(current + 1); });

  track.addEventListener('scroll', function(){
    clearTimeout(track._t);
    track._t = setTimeout(highlightCenter, 60);
  });

  // Auto-scroll RIGHT-TO-LEFT (next every 2.5s)
  var auto;
  function startAuto(){
    stopAuto();
    auto = setInterval(function(){
      var nextIdx = current + 1;
      if (nextIdx >= cards.length) nextIdx = 0;
      scrollTo(nextIdx);
    }, 2800);
  }
  function stopAuto(){ if (auto) { clearInterval(auto); auto = null; } }

  // Pause on hover
  track.addEventListener('mouseenter', stopAuto);
  track.addEventListener('mouseleave', startAuto);
  prev.addEventListener('mouseenter', stopAuto);
  next.addEventListener('mouseenter', stopAuto);

  // Init: scroll to first
  setTimeout(function(){
    scrollTo(0);
    setTimeout(highlightCenter, 400);
    startAuto();
  }, 200);
})();
</script>
