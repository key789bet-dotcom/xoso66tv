<%
// ╔════════════════════════════════════════════════════════════════╗
// ║ SKIN OVERLAY — render layers PNG/JPG/WebP đã upload qua admin    ║
// ║ Include partial này TRONG view phòng live (idol-room, live).     ║
// ║ Nếu skin chưa active → render rỗng → KHÔNG ảnh hưởng layout.    ║
// ║                                                                  ║
// ║ FLOW:                                                            ║
// ║  1. Render <style> với CSS class .skin-*                         ║
// ║  2. JS auto-inject DIV vào đúng anchor (player, chat, ...)      ║
// ║  3. body.has-skin để CSS page-bg/sidebar-bg apply                ║
// ╚════════════════════════════════════════════════════════════════╝
var _skin = (typeof skinConfig !== 'undefined' && skinConfig) ? skinConfig : null;
if (_skin && _skin.files) {
  var f = _skin.files;
%>
<style>
  /* ═══ SKIN OVERLAY LAYERS ═══ */
  <% if (f['page-bg']) { %>
  body.has-skin::before {
    content: ''; position: fixed; inset: 0; z-index: 0; pointer-events: none;
    background-image: url('<%= f['page-bg'] %>');
    background-size: cover; background-position: center; background-attachment: fixed;
    opacity: .35;
  }
  <% } %>

  /* Top header strip — full width banner trên cùng main content */
  <% if (f['top-header']) { %>
  .skin-top-header {
    display: block; width: 100%; max-height: 60px;
    background: url('<%= f['top-header'] %>') center/cover no-repeat;
    aspect-ratio: 32 / 1; margin-bottom: 8px; border-radius: 8px;
  }
  <% } %>

  /* Hero banner */
  <% if (f['hero-banner']) { %>
  .skin-hero-banner {
    display: block; width: 100%; aspect-ratio: 10/1;
    background: url('<%= f['hero-banner'] %>') center/cover no-repeat;
    border-radius: 12px; margin-bottom: 12px;
  }
  <% } %>

  /* Player frame overlay (đè lên video player) */
  <% if (f['player-frame']) { %>
  .skin-player-frame {
    position: absolute; inset: 0; z-index: 20; pointer-events: none;
    background: url('<%= f['player-frame'] %>') center/100% 100% no-repeat;
  }
  <% } %>

  /* Logo overlay (góc trên trái player) */
  <% if (f['logo-overlay']) { %>
  .skin-logo-overlay {
    position: absolute; top: 12px; left: 12px; z-index: 21; pointer-events: none;
    width: 100px; height: 30px;
    background: url('<%= f['logo-overlay'] %>') left center/contain no-repeat;
  }
  <% } %>

  /* Bottom strip (thanh dưới player) */
  <% if (f['bottom-strip']) { %>
  .skin-bottom-strip {
    display: block; width: 100%; height: 50px;
    background: url('<%= f['bottom-strip'] %>') center/cover no-repeat;
    margin-top: 6px; border-radius: 6px;
  }
  <% } %>

  /* Chat overlays */
  <% if (f['chat-header']) { %>
  .skin-chat-header {
    display: block; width: 100%; height: 50px;
    background: url('<%= f['chat-header'] %>') center/cover no-repeat;
    margin-bottom: 4px; border-top-left-radius: 12px; border-top-right-radius: 12px;
  }
  <% } %>

  <% if (f['chat-frame']) { %>
  .skin-chat-frame {
    position: absolute; inset: 0; z-index: 5; pointer-events: none;
    background: url('<%= f['chat-frame'] %>') center/100% 100% no-repeat;
  }
  <% } %>

  <% if (f['chat-input']) { %>
  .skin-chat-input {
    display: block; width: 100%; height: 60px;
    background: url('<%= f['chat-input'] %>') center/cover no-repeat;
    margin-top: 4px; border-radius: 6px;
  }
  <% } %>

  /* Sidebar background — chỉ apply khi skin active */
  <% if (f['sidebar-bg']) { %>
  body.has-skin aside#sidebar {
    background-image: url('<%= f['sidebar-bg'] %>') !important;
    background-size: cover !important;
    background-position: center !important;
  }
  <% } %>
</style>

<script>
/* Auto-inject các DIV skin vào DOM ở đúng anchor — chạy 1 lần sau DOMContentLoaded */
(function(){
  function inject(){
    document.body.classList.add('has-skin');

    var SKIN = <%- JSON.stringify(f) %>;
    var $ = function(sel){ return document.querySelector(sel); };

    function ensureAfter(anchor, className, tag){
      if (!anchor || document.querySelector('.' + className)) return;
      var el = document.createElement(tag || 'div');
      el.className = className;
      anchor.parentNode.insertBefore(el, anchor.nextSibling);
    }
    function ensurePrepend(parent, className){
      if (!parent || document.querySelector('.' + className)) return;
      var el = document.createElement('div');
      el.className = className;
      parent.insertBefore(el, parent.firstChild);
    }
    function ensureAppend(parent, className){
      if (!parent || document.querySelector('.' + className)) return;
      var el = document.createElement('div');
      el.className = className;
      parent.appendChild(el);
    }

    /* PLAYER overlays — inject vào #livePlayer (đã có position:relative) */
    var player = $('#livePlayer');
    if (player) {
      if (SKIN['player-frame']) ensureAppend(player, 'skin-player-frame');
      if (SKIN['logo-overlay']) ensureAppend(player, 'skin-logo-overlay');
      /* bottom-strip nằm BÊN NGOÀI player container (ngay sau) */
      if (SKIN['bottom-strip']) ensureAfter(player, 'skin-bottom-strip');
    }

    /* CHAT overlays — inject vào #chatPanelTop */
    var chatPanel = $('#chatPanelTop');
    if (chatPanel) {
      /* Ensure relative để skin-chat-frame absolute overlay đúng */
      if (getComputedStyle(chatPanel).position === 'static') chatPanel.style.position = 'relative';
      if (SKIN['chat-header']) ensurePrepend(chatPanel, 'skin-chat-header');
      if (SKIN['chat-frame'])  ensureAppend(chatPanel, 'skin-chat-frame');
    }
    /* chat-input: ngay sau ô input */
    var chatInput = $('#chatInput');
    if (chatInput && SKIN['chat-input']) {
      var inputWrap = chatInput.closest('form') || chatInput.parentElement;
      if (inputWrap) ensureAfter(inputWrap, 'skin-chat-input');
    }

    /* TOP HEADER + HERO BANNER — đặt ở đầu main content */
    var main = $('main') || $('.main-content') || $('#content') || player && player.closest('main,section,div.container');
    if (main) {
      if (SKIN['hero-banner']) ensurePrepend(main, 'skin-hero-banner');
      if (SKIN['top-header'])  ensurePrepend(main, 'skin-top-header');
    }
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', inject);
  } else {
    inject();
  }
})();
</script>
<% } %>
