<%
// Mobile home layout - OkwinTV style
// Props: brand, banners, live, upcoming, dbIdols, dbBlvs
var _live = live || [];
var _up = upcoming || [];
var _featured = _live[0] || _up[0] || null;
var _featuredLink = _featured ? ('/live/' + (_featured.slug || _featured.id)) : '#';
var _idolList = (typeof dbIdols !== 'undefined' && dbIdols && dbIdols.length) ? dbIdols.filter(function(i){ return i.status==='active'; }) : [];
var _blvList  = (typeof dbBlvs  !== 'undefined' && dbBlvs  && dbBlvs.length)  ? dbBlvs.filter(function(i){ return i.status==='active'; })  : [];

// 🎯 ƯU TIÊN HIỂN THỊ: idol/blv ĐANG LIVE NOW lên đầu
var _liveNowIdols = _idolList.filter(function(i){ return i.liveNow; });
var _liveNowBlvs  = _blvList.filter(function(i){ return i.liveNow; });

// Danh sách stream keys có thể đang live — priority: liveNow → canLive → all
var _candIdols = _liveNowIdols.length ? _liveNowIdols : _idolList.filter(function(i){ return i.canLive; });
if (_candIdols.length === 0) _candIdols = _idolList;
var _candBlvs  = _liveNowBlvs.length  ? _liveNowBlvs  : _blvList.filter(function(i){ return i.canLive; });

var _liveCandidates = [].concat(
  _candBlvs.map(function(b){  return { key: b.id, href: '/live/' + b.id, name: b.name, avatar: b.avatar || b.cardImage || '', kind:'blv' }; }),
  _candIdols.map(function(i){ return { key: i.id, href: '/idol/' + i.id, name: i.name, avatar: i.avatar || i.cardImage || '', kind:'idol' }; })
);

// 🖼️ POSTER FALLBACK đa tầng: ưu tiên avatar candidate, sau đó featured.poster, cuối cùng team badge
var _previewPoster = '';
if (_liveCandidates.length && _liveCandidates[0].avatar) _previewPoster = _liveCandidates[0].avatar;
else if (_featured && _featured.poster) _previewPoster = _featured.poster;
else if (_featured && _featured.homeBadge) _previewPoster = _featured.homeBadge;
else if (_idolList[0] && _idolList[0].avatar) _previewPoster = _idolList[0].avatar;

// Count by category
var _cnt = { all: _live.length + _idolList.length, hot: 0, bongda: 0, bongro: 0, tennis: 0, bongchuyen: 0, bongban: 0, esport: 0, casino: 5, idol: _idolList.length };
_live.forEach(function(x){
  if (x.sport === 'Soccer')     _cnt.bongda++;
  if (x.sport === 'Basketball') _cnt.bongro++;
  if (x.sport === 'Tennis')     _cnt.tennis++;
  if (x.sport === 'Volleyball') _cnt.bongchuyen++;
  if (x.sport === 'TableTennis')_cnt.bongban++;
  if (x.sport === 'Esports')    _cnt.esport++;
  _cnt.hot++;
});

// Map sport → category tag
function _sportToCat(s){
  if (s === 'Soccer') return 'bongda';
  if (s === 'Esports') return 'esport';
  return 'khac'; // các môn khác gộp vào "tất cả" thôi
}

// Live cards data - chỉ render IDOL cards (idol stream theo category)
// Category mặc định = 'idol' nếu idol chưa chọn
var _cards = [];

// IDOL cards - mỗi idol có category để chọn loại live (bongda/casino/esport/idol)
_idolList.forEach(function(i){
  var cat = i.category || 'idol'; // mặc định idol nếu chưa set
  _cards.push({
    cat: cat,
    type:'idol',
    href:'/idol/' + i.id,
    name: i.name,
    // ƯU TIÊN cardImage (admin set riêng), fallback avatar
    img: i.cardImage || i.avatar,
    emoji: i.emoji || '👑',
    color: i.color || 320,
    time: '21:00',
    badge: i.lock > 0 ? ('VIP ' + i.lock) : 'FREE',
    isLive: !!i.liveNow,
    viewers: i.viewers || 10 + Math.floor(Math.random()*200)
  });
});

// SPORTS cards (live + upcoming) - cho category bongda/esport
// 🏆 Fuzzy match ảnh nền giải đấu (admin upload qua /admin/league-bg)
var _mhBgs = (typeof leagueBgs !== 'undefined' && leagueBgs) ? leagueBgs : {};
function _mhNormLg(s){ return String(s||'').toLowerCase().replace(/\./g,'').replace(/\s+/g,' ').trim(); }
function _mhFindBg(name){
  if (name) {
    if (_mhBgs[name]) return _mhBgs[name];
    var t = _mhNormLg(name);
    for (var k in _mhBgs) {
      if (k === '__default__') continue;
      if (_mhNormLg(k) === t) return _mhBgs[k];
    }
  }
  // Fallback ảnh mặc định
  return _mhBgs['__default__'] || '';
}
var _allSports = (_live.concat(_up)).slice(0, 30);
_allSports.forEach(function(m){
  _cards.push({
    cat: _sportToCat(m.sport),
    type:'sports',
    href:'/live/' + (m.slug || m.id),
    home: m.home, away: m.away,
    homeBadge: m.homeBadge || '',
    awayBadge: m.awayBadge || '',
    league: m.league || '',
    leagueBg: _mhFindBg(m.league), // 🏆 ảnh nền giải đấu
    time: m.time || 'LIVE',
    isLive: m.status === 'live',
    viewers: m.viewers || Math.floor(Math.random()*500)
  });
});

// Cập nhật count chính xác từ thực tế cards
_cnt.idol = _cards.filter(function(c){ return c.cat==='idol'; }).length;
_cnt.bongda = _cards.filter(function(c){ return c.cat==='bongda'; }).length;
_cnt.esport = _cards.filter(function(c){ return c.cat==='esport'; }).length;
_cnt.casino = _cards.filter(function(c){ return c.cat==='casino'; }).length;
_cnt.all = _cards.length;
%>

<!-- ===== MOBILE HOME (md:hidden = chỉ hiện mobile) ===== -->
<div class="md:hidden" id="mobileHome">

  <!-- HEADER mobile FIXED - không di chuyển khi cuộn -->
  <header class="fixed top-0 left-0 right-0 z-40 bg-[#13171f] border-b border-line flex items-center gap-2 px-3 h-[52px]" style="backdrop-filter:blur(8px);background:rgba(19,23,31,.95);">
    <button onclick="toggleSidebar()" class="text-white text-2xl px-1 leading-none" aria-label="Menu">☰</button>
    <a href="/" class="flex items-center gap-1.5 ml-1">
      <img src="/static/img/logoxoso66tv.webp" alt="<%= brand.name %>" class="h-8 w-auto" onerror="this.style.display='none'"
        ><span class="hidden text-white font-black text-base"><%= brand.short || 'XOSO66' %><span class="text-pri">TV</span></span>
    </a>
    <div class="flex-1"></div>
    <a href="/dang-nhap" class="px-2.5 py-1 rounded text-[11px] font-bold border-2 border-pri text-pri-light">Đăng Nhập</a>
    <a href="/dang-ky" class="px-2.5 py-1 rounded text-[11px] font-bold bg-gradient-to-br from-pri to-live text-white shadow">Đăng Ký</a>
  </header>

  <!-- Body container - padding-top 52px cho header fixed, padding-bottom 80px cho bottom nav -->
  <div class="px-3 pb-24" style="padding-top:60px;">

    <!-- BANNER carousel - aspect rộng để full ảnh, contain -->
    <% if (banners && banners.length) { %>
    <div class="relative rounded-xl overflow-hidden mb-3 bg-bg-card" id="mhBanner" style="aspect-ratio:1400/240;">
      <% banners.forEach(function(b, i){ %>
        <% var _bgStyle = b.image ? ('background-image:url('+b.image+');background-size:cover;background-position:center;background-repeat:no-repeat;background-color:'+b.bg+';') : ('background:'+b.bg+';'); %>
        <div class="mh-slide absolute inset-0 flex items-center px-4 text-white" style="<%= _bgStyle %>opacity:<%= i===0?1:0 %>;transition:opacity .8s;pointer-events:<%= i===0?'auto':'none' %>">
          <% if (b.image) { %>
            <a href="<%= b.url %>" target="_blank" rel="noopener" class="absolute inset-0" aria-label="<%= b.title %>"></a>
          <% } else { %>
            <div class="relative z-[1] flex-1 min-w-0">
              <div class="text-base font-extrabold mb-1 truncate"><%= b.title %></div>
              <div class="text-[10px] opacity-90 mb-1.5 line-clamp-2"><%= b.desc %></div>
              <a href="<%= b.url %>" target="_blank" rel="noopener" class="inline-flex bg-white text-red-700 px-3 py-1 rounded font-bold text-[11px]"><%= b.cta %> →</a>
            </div>
          <% } %>
        </div>
      <% }); %>
      <% if (banners.length > 1) { %>
      <div class="absolute bottom-1.5 left-1/2 -translate-x-1/2 flex gap-1 z-[2]" id="mhDots">
        <% banners.forEach(function(b, i){ %><span class="w-1.5 h-1.5 rounded-full bg-white/40 transition-all <%= i===0?'!w-4 !bg-white':'' %>"></span><% }); %>
      </div>
      <% } %>
    </div>
    <% } %>

    <!-- LIVE PREVIEW BLOCK - VIDEO THỰC + overlay button -->
    <div id="mhLivePreview" class="block rounded-xl bg-black border border-line overflow-hidden mb-3 relative cursor-pointer" style="aspect-ratio:16/8;">
      <!-- Video element ẩn ban đầu, hiện khi có stream live -->
      <video id="mhLiveVideo" class="hidden absolute inset-0 w-full h-full object-cover bg-black" playsinline autoplay muted></video>

      <!-- Poster fallback đa tầng — avatar idol/blv/team badge, opacity FULL để rõ -->
      <% if (_previewPoster) { %>
        <img id="mhLivePoster" src="<%= _previewPoster %>" class="absolute inset-0 w-full h-full object-cover" alt="" onerror="this.style.display='none'" style="opacity:0.9;">
        <!-- Lớp phủ tối nhẹ để text CTA + badge đọc rõ, không che ảnh -->
        <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(circle at center, rgba(0,0,0,.3) 0%, rgba(0,0,0,.55) 100%);"></div>
      <% } %>
      <div id="mhLiveGradient" class="absolute inset-0 bg-gradient-to-br from-bg-card via-bg to-black" style="<%= _previewPoster ? 'display:none;' : '' %>"></div>

      <!-- LIVE badge top-left -->
      <span id="mhLiveBadge" class="hidden absolute top-2 left-2 z-[3] bg-live text-white px-2 py-0.5 rounded font-bold text-[10px] flex items-center gap-1 shadow-lg"><span class="w-1.5 h-1.5 bg-white rounded-full animate-pulse-live"></span>LIVE</span>

      <!-- Viewer count top-right -->
      <span id="mhLiveViewers" class="hidden absolute top-2 right-2 z-[3] bg-black/70 text-white px-2 py-0.5 rounded text-[10px] font-bold backdrop-blur">👁 <span class="tabular-nums">--</span></span>

      <!-- Idol name bottom -->
      <div id="mhLiveName" class="hidden absolute bottom-2 left-2 right-2 z-[3] text-white text-xs font-bold drop-shadow-lg truncate"></div>

      <!-- Overlay nút "Vào Phòng Trực Tiếp" giữa -->
      <div class="absolute inset-0 grid place-items-center z-[4] pointer-events-none">
        <div id="mhLiveCta" class="bg-black/60 border-2 border-pri/70 rounded-full px-5 py-2.5 flex items-center gap-2 text-white backdrop-blur shadow-2xl pointer-events-auto" style="box-shadow:0 0 20px rgba(255,122,24,.4);">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" class="text-pri"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          <span class="font-bold text-[13px]">Vào Phòng Trực Tiếp</span>
        </div>
      </div>

      <!-- Nút bật tiếng đã bỏ theo yêu cầu -->
    </div>

    <script src="https://cdn.jsdelivr.net/npm/flv.js@1.6.2/dist/flv.min.js"></script>
    <script>
    (function initMhLivePreview(){
      var candidates = <%- JSON.stringify(_liveCandidates) %>;
      if (!candidates.length) return;

      var box = document.getElementById('mhLivePreview');
      var video = document.getElementById('mhLiveVideo');
      var poster = document.getElementById('mhLivePoster');
      var gradient = document.getElementById('mhLiveGradient');
      var badge = document.getElementById('mhLiveBadge');
      var viewers = document.getElementById('mhLiveViewers');
      var nameEl = document.getElementById('mhLiveName');
      var unmuteBtn = document.getElementById('mhLiveUnmute');
      var ctaBtn = document.getElementById('mhLiveCta');

      var currentStream = null;
      var flvPlayer = null;
      var clickHref = candidates[0].href;

      // Click toàn vùng → vào phòng
      box.addEventListener('click', function(e){
        if (e.target === unmuteBtn || unmuteBtn.contains(e.target)) return;
        location.href = clickHref;
      });

      // Unmute button
      unmuteBtn.addEventListener('click', function(e){
        e.stopPropagation();
        if (video) { video.muted = false; video.volume = 1; }
        unmuteBtn.classList.add('hidden');
      });

      function attachStream(cand){
        // 🚀 Bypass Cloudflare 100s timeout
        var url = 'https://live.xoso66tv.com/live/' + cand.key + '.flv';
        if (!window.flvjs || !flvjs.isSupported()) return;
        try { if (flvPlayer) flvPlayer.destroy(); } catch(e){}
        flvPlayer = flvjs.createPlayer({
          type:'flv', url:url, isLive:true, hasAudio:true, hasVideo:true
        }, { enableWorker:false, enableStashBuffer:false, stashInitialSize:128 });
        flvPlayer.attachMediaElement(video);
        flvPlayer.load();
        var p = flvPlayer.play();
        if (p && p.catch) p.catch(function(){});

        var shown = false;
        function showLive(){
          if (shown) return; shown = true;
          video.classList.remove('hidden');
          if (poster) poster.style.display = 'none';
          if (gradient) gradient.style.display = 'none';
          badge.classList.remove('hidden');
          badge.style.display = 'flex';
          viewers.classList.remove('hidden');
          nameEl.classList.remove('hidden');
          nameEl.textContent = '🔴 ' + cand.name;
          unmuteBtn.classList.remove('hidden');
          clickHref = cand.href;
          // Random viewers count update
          var n = 50 + Math.floor(Math.random()*500);
          viewers.querySelector('span').textContent = n.toLocaleString('vi-VN');
          setInterval(function(){
            n += Math.floor(Math.random()*5) - 2;
            if (n < 30) n = 30;
            viewers.querySelector('span').textContent = n.toLocaleString('vi-VN');
          }, 4000);
        }

        video.addEventListener('loadedmetadata', showLive, { once:true });
        video.addEventListener('playing', showLive, { once:true });
        flvPlayer.on(flvjs.Events.ERROR, function(){
          if (shown) return; // đã có stream khác work
          tryNext();
        });
      }

      var idx = 0;
      function tryNext(){
        if (idx >= candidates.length) return; // không stream nào live
        var cand = candidates[idx++];
        // HEAD check trước để khỏi tốn FLV connect
        fetch('https://live.xoso66tv.com/live/' + cand.key + '.flv', { method:'HEAD', cache:'no-store' })
          .then(function(r){
            if (r.ok) attachStream(cand);
            else tryNext();
          })
          .catch(tryNext);
      }

      function start(){
        if (!window.flvjs) { setTimeout(start, 300); return; }
        tryNext();
        // Recheck mỗi 30s nếu chưa có stream
        setInterval(function(){
          if (!flvPlayer || video.classList.contains('hidden')) {
            idx = 0; tryNext();
          }
        }, 30000);
      }
      if (document.readyState !== 'loading') start();
      else document.addEventListener('DOMContentLoaded', start);
    })();
    </script>

    <!-- CATEGORIES FILTER - 5 nút chính (lọc inline, không navigate) -->
    <div class="grid grid-cols-5 gap-1.5 mb-3">
      <button type="button" class="mh-cat active" data-filter="all">
        <span class="mh-cat-ico bg-pri text-white">📊</span>
        <span class="mh-cat-name">Tất cả</span>
        <% if (_cnt.all > 0) { %><span class="mh-cat-cnt"><%= _cnt.all %></span><% } %>
      </button>
      <button type="button" class="mh-cat" data-filter="bongda">
        <span class="mh-cat-ico bg-emerald-500/20 text-emerald-400">⚽</span>
        <span class="mh-cat-name">Bóng đá</span>
        <% if (_cnt.bongda > 0) { %><span class="mh-cat-cnt"><%= _cnt.bongda %></span><% } %>
      </button>
      <button type="button" class="mh-cat" data-filter="idol">
        <span class="mh-cat-ico bg-pink-500/20 text-pink-400">👑</span>
        <span class="mh-cat-name">Idol</span>
        <% if (_cnt.idol > 0) { %><span class="mh-cat-cnt"><%= _cnt.idol %></span><% } %>
      </button>
      <button type="button" class="mh-cat" data-filter="casino">
        <span class="mh-cat-ico bg-amber-500/20 text-amber-400">🎰</span>
        <span class="mh-cat-name">Sòng Bài</span>
        <% if (_cnt.casino > 0) { %><span class="mh-cat-cnt"><%= _cnt.casino %></span><% } %>
      </button>
      <button type="button" class="mh-cat" data-filter="esport">
        <span class="mh-cat-ico bg-violet-500/20 text-violet-400">🎮</span>
        <span class="mh-cat-name">Esport</span>
        <% if (_cnt.esport > 0) { %><span class="mh-cat-cnt"><%= _cnt.esport %></span><% } %>
      </button>
    </div>

    <!-- STREAM CARDS 2 cột - có data-cat để filter -->
    <% if (_cards.length === 0) { %>
      <div class="bg-bg-card border border-line rounded-xl p-8 text-center text-muted">
        <div class="text-3xl mb-2 opacity-50">📺</div>
        <div class="text-sm">Chưa có phòng live nào</div>
        <a href="/lich-phat-song" class="inline-block mt-3 text-pri-light text-xs font-bold">→ Xem lịch phát sóng</a>
      </div>
    <% } else { %>
    <!-- ===== LUXURY CARDS - đồng bộ orange border, dark gradient ===== -->
    <div class="grid grid-cols-2 gap-2.5 mb-3" id="mhCardsGrid">
      <% _cards.forEach(function(c){ %>
        <a href="<%= c.href %>" class="mh-card-lux block relative overflow-hidden" data-cat="<%= c.cat %>">

          <!-- 🏆 Ảnh nền giải đấu (admin set) - hiển thị rõ, KHÔNG lớp phủ đen che -->
          <% if (c.type === 'sports' && c.leagueBg) { %>
            <img src="<%= c.leagueBg %>" alt="" loading="lazy" class="absolute inset-0 w-full h-full object-cover pointer-events-none" onerror="this.style.display='none'" style="z-index:0;opacity:1;">
            <!-- Chỉ shadow nhẹ ở 2 đầu để text dễ đọc, không che ảnh -->
            <div class="absolute inset-0 pointer-events-none" style="z-index:0;background:linear-gradient(to bottom, rgba(0,0,0,.35) 0%, transparent 25%, transparent 75%, rgba(0,0,0,.5) 100%);"></div>
            <style>
              .mh-card-lux .mh-lux-head, .mh-card-lux .mh-lux-body { position:relative; z-index:2; }
              /* Body trong suốt khi có ảnh nền league */
              .mh-card-lux .mh-lux-body { background:transparent !important; }
              .mh-card-lux .mh-lux-head { background:linear-gradient(90deg,rgba(0,0,0,.6),rgba(0,0,0,.35)) !important; }
              /* Text shadow đậm để chữ vẫn đọc rõ trên ảnh */
              .mh-card-lux .mh-lux-team-name { color:#fff !important; text-shadow:0 1px 3px rgba(0,0,0,.95), 0 0 6px rgba(0,0,0,.7); font-weight:800 !important; }
              .mh-card-lux .mh-lux-time { text-shadow:0 1px 3px rgba(0,0,0,.95), 0 0 8px rgba(0,0,0,.8) !important; }
              .mh-card-lux .mh-lux-league-name { color:#fff !important; text-shadow:0 1px 2px rgba(0,0,0,.9); }
            </style>
          <% } %>

          <!-- TOP HEADER: League/Category + Status -->
          <div class="mh-lux-head">
            <% if (c.type === 'sports') { %>
              <div class="mh-lux-league">
                <span class="mh-lux-league-ico">⚽</span>
                <span class="mh-lux-league-name"><%= c.league || 'Sự kiện' %></span>
              </div>
              <span class="mh-lux-status <%= c.isLive ? 'live' : 'soon' %>"><%= c.isLive ? '● LIVE' : 'SẮP DIỄN RA' %></span>
            <% } else if (c.type === 'idol') { %>
              <%
                var _catIco = '👑', _catTxt = 'Idol Live Show';
                if (c.cat === 'casino')      { _catIco = '🎰'; _catTxt = 'Live Sòng Bài'; }
                else if (c.cat === 'bongda') { _catIco = '⚽'; _catTxt = 'BLV Bóng Đá'; }
                else if (c.cat === 'esport') { _catIco = '🎮'; _catTxt = 'BLV Esports'; }
              %>
              <div class="mh-lux-league">
                <span class="mh-lux-league-ico"><%= _catIco %></span>
                <span class="mh-lux-league-name"><%= _catTxt %></span>
              </div>
              <span class="mh-lux-status <%= c.isLive ? 'live' : 'soon' %>"><%= c.isLive ? '● LIVE' : c.badge %></span>
            <% } %>
          </div>

          <!-- MIDDLE BODY -->
          <div class="mh-lux-body">
            <% if (c.type === 'sports') { %>
              <%
                // Hash màu từ tên đội để gradient fallback ổn định, không random
                function _hueFromName(n){ var h=0; for(var i=0;i<n.length;i++) h=(h*31+n.charCodeAt(i))&0xfff; return h%360; }
                var _hH = _hueFromName(c.home||'?');
                var _hA = _hueFromName(c.away||'?');
                var _initH = (c.home||'?').replace(/[^A-Za-zĐđ\s]/g,'').trim().split(/\s+/).map(function(w){return w[0]||'';}).join('').slice(0,2).toUpperCase();
                var _initA = (c.away||'?').replace(/[^A-Za-zĐđ\s]/g,'').trim().split(/\s+/).map(function(w){return w[0]||'';}).join('').slice(0,2).toUpperCase();
              %>
              <!-- SPORTS: 2 teams + time -->
              <div class="mh-lux-team">
                <div class="mh-lux-team-circle" style="background:linear-gradient(135deg,hsl(<%= _hH %>,70%,55%),hsl(<%= (_hH+30)%360 %>,70%,40%));padding:3px;">
                  <% if (c.homeBadge) { %>
                    <img src="<%= c.homeBadge %>" alt="<%= c.home %>" loading="lazy" class="w-full h-full rounded-full object-contain bg-white p-1" onerror="this.outerHTML='<span class=&quot;mh-lux-team-init&quot;><%= _initH %></span>'">
                  <% } else { %>
                    <span class="mh-lux-team-init"><%= _initH %></span>
                  <% } %>
                </div>
                <div class="mh-lux-team-name"><%= c.home %></div>
              </div>
              <div class="mh-lux-mid">
                <div class="mh-lux-time"><%= c.time %></div>
                <div class="mh-lux-date"><%= new Date().toLocaleDateString('vi-VN') %></div>
              </div>
              <div class="mh-lux-team">
                <div class="mh-lux-team-circle" style="background:linear-gradient(135deg,hsl(<%= _hA %>,70%,55%),hsl(<%= (_hA+30)%360 %>,70%,40%));padding:3px;">
                  <% if (c.awayBadge) { %>
                    <img src="<%= c.awayBadge %>" alt="<%= c.away %>" loading="lazy" class="w-full h-full rounded-full object-contain bg-white p-1" onerror="this.outerHTML='<span class=&quot;mh-lux-team-init&quot;><%= _initA %></span>'">
                  <% } else { %>
                    <span class="mh-lux-team-init"><%= _initA %></span>
                  <% } %>
                </div>
                <div class="mh-lux-team-name"><%= c.away %></div>
              </div>
            <% } else if (c.type === 'idol') { %>
              <!-- IDOL: avatar full + name -->
              <% if (c.img) { %>
                <img src="<%= c.img %>" alt="<%= c.name %>" class="mh-lux-idol-img" onerror="this.style.display='none'">
              <% } %>
              <div class="mh-lux-idol-bg" style="background:linear-gradient(135deg, hsl(<%= c.color %>,70%,40%), hsl(<%= (c.color+60)%360 %>,70%,25%));opacity:<%= c.img ? '0' : '1' %>;"></div>
              <div class="mh-lux-idol-overlay">
                <div class="mh-lux-time text-white"><%= c.time %></div>
                <div class="mh-lux-date"><%= new Date().toLocaleDateString('vi-VN') %></div>
                <div class="mh-lux-idol-name"><%= c.name %></div>
              </div>
            <% } %>
          </div>

          <!-- BOTTOM FOOTER: Tên BLV/streamer + Viewers (giống desktop card) -->
          <div class="mh-lux-foot">
            <div class="mh-lux-blv">
              <% if (c.type === 'idol') { %>
                <span class="mh-lux-blv-ico">📡</span>
                <span class="mh-lux-blv-name"><%= c.isLive ? c.name : 'Đang chờ idol' %></span>
              <% } else { %>
                <span class="mh-lux-blv-ico">📡</span>
                <span class="mh-lux-blv-name"><%= c.blvName || 'Đang chờ BLV' %></span>
              <% } %>
            </div>
            <div class="mh-lux-views">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="#ff7a18"><path d="M13.5.67s.74 2.65.74 4.8c0 2.06-1.35 3.73-3.41 3.73-2.07 0-3.63-1.67-3.63-3.73l.03-.36C5.21 7.51 4 10.62 4 14c0 4.42 3.58 8 8 8s8-3.58 8-8C20 8.61 17.41 3.8 13.5.67zM11.71 19c-1.78 0-3.22-1.4-3.22-3.14 0-1.62 1.05-2.76 2.81-3.12 1.77-.36 3.6-1.21 4.62-2.58.39 1.29.59 2.65.59 4.04 0 2.65-2.15 4.8-4.8 4.8z"/></svg>
              <span><%= (c.viewers || 0).toLocaleString('vi-VN') %></span>
            </div>
          </div>
        </a>
      <% }); %>
    </div>

    <!-- Empty state khi filter không có card -->
    <div id="mhEmptyFilter" class="hidden bg-bg-card border border-line rounded-xl p-8 text-center text-muted mb-3">
      <div class="text-3xl mb-2 opacity-50">🔍</div>
      <div class="text-sm">Chưa có phòng thuộc danh mục này</div>
    </div>
    <% } %>

    <!-- Link tới full list -->
    <a href="/lich-phat-song" class="block bg-bg-card border border-line rounded-lg py-2 text-center text-pri-light text-xs font-bold mb-3 hover:bg-bg-soft transition">Xem tất cả phòng live →</a>

  </div>

  <!-- BOTTOM NAVIGATION 5 tabs với center FAB -->
  <nav class="fixed bottom-0 left-0 right-0 z-30 bg-[#0f1218] border-t border-line h-16 px-2" id="mhBottomNav">
    <div class="grid grid-cols-5 h-full items-center relative">
      <a href="/lich-phat-song" class="mh-tab" data-tab="lich">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        <span>Lịch Trình</span>
      </a>
      <a href="/su-kien" class="mh-tab" data-tab="km">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
        <span>Khuyến Mãi</span>
      </a>
      <!-- CENTER FAB - về trang chủ -->
      <a href="/" class="mh-tab mh-fab-wrap" data-tab="home">
        <span class="mh-fab">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L2 12h3v8h6v-6h2v6h6v-8h3z"/></svg>
        </span>
        <span class="mt-7 text-pri-light">Trang Chủ</span>
      </a>
      <a href="/qua-tang" class="mh-tab" data-tab="qua">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="8" width="18" height="4"/><line x1="12" y1="8" x2="12" y2="21"/><path d="M19 12v7a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2v-7"/><path d="M7.5 8a2.5 2.5 0 0 1 0-5C9.5 3 12 8 12 8s2.5-5 4.5-5a2.5 2.5 0 0 1 0 5"/></svg>
        <span>Quà Tặng</span>
      </a>
      <a href="/profile" class="mh-tab" data-tab="profile">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        <span>Cá Nhân</span>
      </a>
    </div>
  </nav>
</div>

<style>
/* Mobile home - chip nhỏ gọn */
.mh-cat {
  display:flex; flex-direction:column; align-items:center; gap:1px;
  background:#1a1f29; border:1px solid #2a3344; border-radius:8px;
  padding:5px 2px; position:relative; transition:all .2s;
  min-height:54px;
}
.mh-cat:active { transform:scale(.94); }
.mh-cat.active { background:linear-gradient(135deg,#ff7a18,#ea580c); border-color:#ff7a18; }
.mh-cat.active .mh-cat-name,
.mh-cat.active .mh-cat-cnt { color:#fff; }
.mh-cat.active .mh-cat-ico { background:rgba(255,255,255,.15) !important; color:#fff !important; }

.mh-cat-ico {
  width:22px; height:22px; border-radius:50%;
  display:grid; place-items:center; font-size:11px;
}
.mh-cat-name {
  font-size:9.5px; font-weight:600; color:#cbd5e1; line-height:1.1; margin-top:1px;
  white-space:nowrap; overflow:hidden; text-overflow:ellipsis; max-width:100%;
}
.mh-cat-cnt {
  position:absolute; top:2px; right:3px;
  background:#0f1218; color:#cbd5e1;
  font-size:8px; font-weight:800; padding:0 4px;
  border-radius:6px; min-width:12px; text-align:center;
  line-height:1.4;
}
.mh-cat.active .mh-cat-cnt { background:#fff; color:#ea580c; }
/* Ẩn badge khi 0 cho gọn */
.mh-cat-cnt:empty,
.mh-cat-cnt[data-zero="1"] { display:none; }

.mh-card { transition:transform .15s; }
.mh-card:active { transform:scale(.97); }

/* ===== LUXURY CARDS - đồng bộ sang trọng ===== */
.mh-card-lux {
  display:flex; flex-direction:column;
  background:linear-gradient(180deg,#1a1f29 0%,#0a0d12 100%);
  border:1.5px solid rgba(255,122,24,.4);
  border-radius:12px; overflow:hidden;
  box-shadow:0 4px 12px rgba(0,0,0,.4), inset 0 1px 0 rgba(255,255,255,.05);
  transition:all .2s ease; text-decoration:none;
  min-height:180px;  /* tăng để footer BLV (📡 + viewers) không bị cắt */
}
.mh-card-lux:active { transform:scale(.97); border-color:rgba(255,122,24,.8); box-shadow:0 6px 20px rgba(255,122,24,.3); }

/* HEADER bar */
.mh-lux-head {
  display:flex; align-items:center; justify-content:space-between; gap:4px;
  padding:5px 7px;
  background:linear-gradient(90deg,rgba(255,122,24,.12),rgba(255,122,24,.05));
  border-bottom:1px solid rgba(255,122,24,.2);
  min-height:24px;
}
.mh-lux-league {
  display:flex; align-items:center; gap:3px; min-width:0; flex:1;
}
.mh-lux-league-ico { font-size:11px; flex-shrink:0; }
.mh-lux-league-name {
  color:#e2e8f0; font-size:9.5px; font-weight:700;
  white-space:nowrap; overflow:hidden; text-overflow:ellipsis;
}
.mh-lux-status {
  font-size:8px; font-weight:800; padding:2px 5px;
  border-radius:3px; text-transform:uppercase; letter-spacing:.3px;
  flex-shrink:0;
}
.mh-lux-status.live { background:#ef4444; color:#fff; animation:luxLivePulse 1.5s infinite; }
.mh-lux-status.soon { background:linear-gradient(135deg,#ff7a18,#ea580c); color:#fff; }
@keyframes luxLivePulse { 0%,100%{opacity:1} 50%{opacity:.7} }

/* BODY - 3 cột grid CỐ ĐỊNH (không phụ thuộc flex space-around) */
.mh-lux-body {
  flex:1;
  display:grid;
  grid-template-columns: 1fr 1.1fr 1fr;
  align-items:center; justify-items:center;
  padding:10px 8px; position:relative; min-height:95px;
  background:linear-gradient(180deg,#0f1419 0%,#070a0e 100%);
  gap:4px;
}
.mh-lux-team {
  text-align:center;
  width:100%;
  min-width:0;        /* cho phép text truncate */
  display:flex; flex-direction:column; align-items:center;
}
.mh-lux-team-circle {
  width:40px; height:40px; border-radius:50%;
  display:grid; place-items:center;
  margin:0 auto 4px;
  box-shadow:0 3px 8px rgba(0,0,0,.5);
  border:2px solid rgba(255,122,24,.4);
  overflow:hidden;
  position:relative;
  flex-shrink:0;       /* không bị co khi text dài */
}
.mh-lux-team-circle img {
  width:100%; height:100%;
  border-radius:50%;
  object-fit:contain;
  background:#fff;
  padding:2px;
  display:block;
}
.mh-lux-team-init {
  display:flex; align-items:center; justify-content:center;
  width:100%; height:100%; border-radius:50%;
  color:#fff; font-weight:900; font-size:13px;
  letter-spacing:.5px;
  text-shadow:0 1px 2px rgba(0,0,0,.4);
}
.mh-lux-team-name {
  color:#cbd5e1; font-size:9px; font-weight:700; line-height:1.15;
  white-space:nowrap; overflow:hidden; text-overflow:ellipsis;
  width:100%;
  max-width:100%;
  padding:0 2px;
}
.mh-lux-mid {
  text-align:center;
  width:100%;
  display:flex; flex-direction:column; align-items:center; justify-content:center;
}
.mh-lux-time {
  color:#fbbf24; font-size:14px; font-weight:900; line-height:1;
  text-shadow:0 0 8px rgba(251,191,36,.4);
}
.mh-lux-date {
  display:inline-block; margin-top:4px;
  background:linear-gradient(135deg,#dc2626,#991b1b);
  color:#fff; font-size:8px; font-weight:800;
  padding:1.5px 6px; border-radius:3px;
  box-shadow:0 1px 3px rgba(220,38,38,.4);
}

/* IDOL specific */
.mh-lux-idol-img,
.mh-lux-idol-bg { position:absolute; inset:0; width:100%; height:100%; object-fit:cover; }
.mh-lux-idol-overlay {
  position:relative; z-index:1; text-align:center; width:100%; padding:8px;
  background:linear-gradient(180deg,transparent,rgba(0,0,0,.6));
  height:100%; display:flex; flex-direction:column; justify-content:flex-end;
}
.mh-lux-idol-name {
  color:#fff; font-size:11px; font-weight:800; margin-top:4px;
  text-shadow:0 1px 3px rgba(0,0,0,.8);
}

/* CASINO/ESPORT */
.mh-lux-casino-bg,
.mh-lux-esport-bg { position:absolute; inset:0; }
.mh-lux-casino-bg.from-red-700.to-orange-900 { background:linear-gradient(135deg,#b91c1c,#7c2d12); }
.mh-lux-casino-bg.from-amber-700.to-yellow-900 { background:linear-gradient(135deg,#b45309,#713f12); }
.mh-lux-casino-bg.from-violet-700.to-purple-900 { background:linear-gradient(135deg,#6d28d9,#581c87); }
.mh-lux-casino-bg.from-emerald-700.to-green-900 { background:linear-gradient(135deg,#047857,#14532d); }
.mh-lux-emoji-wrap {
  position:relative; z-index:1; text-align:center; width:100%; padding:4px;
}
.mh-lux-emoji { font-size:38px; filter:drop-shadow(0 2px 8px rgba(0,0,0,.5)); margin-bottom:2px; }
.mh-lux-cas-name { color:#fff; font-size:11px; font-weight:800; text-shadow:0 1px 3px rgba(0,0,0,.6); }
.mh-lux-cta {
  display:inline-block; margin-top:4px;
  background:rgba(255,255,255,.18); backdrop-filter:blur(4px);
  color:#fff; font-size:8px; font-weight:800; padding:2px 7px;
  border-radius:3px; border:1px solid rgba(255,255,255,.15);
}
.mh-lux-cta.esport { background:rgba(139,92,246,.35); border-color:rgba(139,92,246,.4); }

/* FOOTER bar */
.mh-lux-foot {
  display:flex; align-items:center; justify-content:space-between;
  padding:4px 7px;
  background:linear-gradient(90deg,#0a0d12,#0f1419);
  border-top:1px solid rgba(255,122,24,.15);
  min-height:22px;
}
.mh-lux-blv {
  display:flex; align-items:center; gap:4px;
  min-width:0; flex:1;
  color:#cbd5e1; font-size:10px; font-weight:600;
  overflow:hidden;
}
.mh-lux-blv-ico { font-size:10px; flex-shrink:0; }
.mh-lux-blv-name {
  white-space:nowrap; overflow:hidden; text-overflow:ellipsis;
  min-width:0;
}
.mh-lux-views {
  display:flex; align-items:center; gap:3px;
  color:#cbd5e1; font-size:10px; font-weight:700;
  font-variant-numeric:tabular-nums;
}

/* Bottom nav tabs */
.mh-tab {
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  gap:2px; color:#94a3b8; font-size:10px; font-weight:600;
  height:100%; text-decoration:none; transition:color .15s;
  position:relative;
}
.mh-tab:active { color:#fff; }
.mh-tab svg { width:18px; height:18px; }

/* Center FAB */
.mh-fab-wrap {
  position:relative;
}
.mh-fab {
  position:absolute; top:-20px; left:50%; transform:translateX(-50%);
  width:52px; height:52px; border-radius:50%;
  background:linear-gradient(135deg,#ff7a18,#ea580c);
  display:grid; place-items:center; color:#fff;
  box-shadow:0 4px 16px rgba(255,122,24,.5), 0 0 0 4px #0f1218;
  z-index:1;
}
.mh-fab-wrap span:last-child { color:#ff7a18; font-weight:700; }
</style>

<script>
(function initMobileHome(){
  // ===== Banner carousel auto-play =====
  var slides = document.querySelectorAll('#mhBanner .mh-slide');
  var dots = document.querySelectorAll('#mhDots span');
  if (slides.length > 1) {
    var idx = 0;
    function show(i){
      slides.forEach(function(s,k){
        s.style.opacity = k===i ? 1 : 0;
        s.style.pointerEvents = k===i ? 'auto' : 'none';
      });
      dots.forEach(function(d,k){
        d.className = 'w-1.5 h-1.5 rounded-full bg-white/40 transition-all' + (k===i ? ' !w-4 !bg-white' : '');
      });
      idx = i;
    }
    setInterval(function(){ show((idx+1) % slides.length); }, 5000);
    dots.forEach(function(d,k){ d.addEventListener('click', function(){ show(k); }); });
  }

  // ===== Category filter (inline lọc cards) =====
  var catBtns = document.querySelectorAll('.mh-cat[data-filter]');
  var cards = document.querySelectorAll('#mhCardsGrid .mh-card[data-cat]');
  var emptyEl = document.getElementById('mhEmptyFilter');

  function applyFilter(filterVal){
    var visible = 0;
    cards.forEach(function(card){
      var ok = (filterVal === 'all') || (card.dataset.cat === filterVal);
      card.style.display = ok ? '' : 'none';
      if (ok) visible++;
    });
    if (emptyEl) emptyEl.classList.toggle('hidden', visible > 0);
  }

  catBtns.forEach(function(btn){
    btn.addEventListener('click', function(){
      catBtns.forEach(function(b){ b.classList.remove('active'); });
      btn.classList.add('active');
      applyFilter(btn.dataset.filter);
      // Scroll mượt xuống cards
      var grid = document.getElementById('mhCardsGrid');
      if (grid) grid.scrollIntoView({ behavior:'smooth', block:'start' });
    });
  });
})();
</script>
