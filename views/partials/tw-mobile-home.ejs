<%
// Mobile home layout - OkwinTV style
// Props: brand, banners, live, upcoming, dbIdols, dbBlvs
var _live = live || [];
var _up = upcoming || [];
var _featured = _live[0] || _up[0] || null;
var _featuredLink = _featured ? ('/live/' + (_featured.slug || _featured.id)) : '#';
var _idolList = (typeof dbIdols !== 'undefined' && dbIdols && dbIdols.length) ? dbIdols.filter(function(i){ return i.status==='active'; }) : [];
var _blvList  = (typeof dbBlvs  !== 'undefined' && dbBlvs  && dbBlvs.length)  ? dbBlvs.filter(function(i){ return i.status==='active'; })  : [];

// 🎯 ƯU TIÊN HIỂN THỊ: idol/blv ĐANG LIVE NOW lên đầu
var _liveNowIdols = _idolList.filter(function(i){ return i.liveNow; });
var _liveNowBlvs  = _blvList.filter(function(i){ return i.liveNow; });

// Danh sách stream keys có thể đang live — priority: liveNow → canLive → all
var _candIdols = _liveNowIdols.length ? _liveNowIdols : _idolList.filter(function(i){ return i.canLive; });
if (_candIdols.length === 0) _candIdols = _idolList;
var _candBlvs  = _liveNowBlvs.length  ? _liveNowBlvs  : _blvList.filter(function(i){ return i.canLive; });

var _liveCandidates = [].concat(
  _candBlvs.map(function(b){  return { key: b.id, href: '/live/' + b.id, name: b.name, avatar: b.avatar || b.cardImage || '', kind:'blv' }; }),
  _candIdols.map(function(i){ return { key: i.id, href: '/idol/' + i.id, name: i.name, avatar: i.avatar || i.cardImage || '', kind:'idol' }; })
);

// 🖼️ POSTER FALLBACK đa tầng: ưu tiên avatar candidate, sau đó featured.poster, cuối cùng team badge
var _previewPoster = '';
if (_liveCandidates.length && _liveCandidates[0].avatar) _previewPoster = _liveCandidates[0].avatar;
else if (_featured && _featured.poster) _previewPoster = _featured.poster;
else if (_featured && _featured.homeBadge) _previewPoster = _featured.homeBadge;
else if (_idolList[0] && _idolList[0].avatar) _previewPoster = _idolList[0].avatar;

// Count by category
var _cnt = { all: _live.length + _idolList.length, hot: 0, bongda: 0, bongro: 0, tennis: 0, bongchuyen: 0, bongban: 0, esport: 0, casino: 5, idol: _idolList.length };
_live.forEach(function(x){
  if (x.sport === 'Soccer')     _cnt.bongda++;
  if (x.sport === 'Basketball') _cnt.bongro++;
  if (x.sport === 'Tennis')     _cnt.tennis++;
  if (x.sport === 'Volleyball') _cnt.bongchuyen++;
  if (x.sport === 'TableTennis')_cnt.bongban++;
  if (x.sport === 'Esports')    _cnt.esport++;
  _cnt.hot++;
});

// Map sport → category tag
function _sportToCat(s){
  if (s === 'Soccer') return 'bongda';
  if (s === 'Esports') return 'esport';
  return 'khac'; // các môn khác gộp vào "tất cả" thôi
}

// Live cards data - chỉ render IDOL cards (idol stream theo category)
// Category mặc định = 'idol' nếu idol chưa chọn
var _cards = [];

// IDOL cards - mỗi idol có category để chọn loại live (bongda/casino/esport/idol)
_idolList.forEach(function(i){
  var cat = i.category || 'idol'; // mặc định idol nếu chưa set
  _cards.push({
    cat: cat,
    type:'idol',
    href:'/idol/' + i.id,
    name: i.name,
    // ƯU TIÊN cardImage (admin set riêng), fallback avatar
    img: i.cardImage || i.avatar,
    emoji: i.emoji || '👑',
    color: i.color || 320,
    time: '21:00',
    badge: i.lock > 0 ? ('VIP ' + i.lock) : 'FREE',
    isLive: !!i.liveNow,
    viewers: i.viewers || 10 + Math.floor(Math.random()*200)
  });
});

// SPORTS cards (live + upcoming) - cho category bongda/esport
// 🏆 Fuzzy match ảnh nền giải đấu (admin upload qua /admin/league-bg)
var _mhBgs = (typeof leagueBgs !== 'undefined' && leagueBgs) ? leagueBgs : {};
function _mhNormLg(s){ return String(s||'').toLowerCase().replace(/\./g,'').replace(/\s+/g,' ').trim(); }
function _mhFindBg(name){
  if (name) {
    if (_mhBgs[name]) return _mhBgs[name];
    var t = _mhNormLg(name);
    for (var k in _mhBgs) {
      if (k === '__default__') continue;
      if (_mhNormLg(k) === t) return _mhBgs[k];
    }
  }
  // Fallback ảnh mặc định
  return _mhBgs['__default__'] || '';
}
var _allSports = (_live.concat(_up)).slice(0, 30);
_allSports.forEach(function(m){
  _cards.push({
    cat: _sportToCat(m.sport),
    type:'sports',
    href:'/live/' + (m.slug || m.id),
    home: m.home, away: m.away,
    homeBadge: m.homeBadge || '',
    awayBadge: m.awayBadge || '',
    league: m.league || '',
    leagueLogo: m.leagueLogo || '', // 🏆 logo giải đấu (từ API/fallback league-logos.js)
    leagueBg: _mhFindBg(m.league), // 🏆 ảnh nền giải đấu
    time: m.time || 'LIVE',
    isLive: m.status === 'live',
    viewers: m.viewers || Math.floor(Math.random()*500)
  });
});

// Cập nhật count chính xác từ thực tế cards
_cnt.idol = _cards.filter(function(c){ return c.cat==='idol'; }).length;
_cnt.bongda = _cards.filter(function(c){ return c.cat==='bongda'; }).length;
_cnt.esport = _cards.filter(function(c){ return c.cat==='esport'; }).length;
_cnt.casino = _cards.filter(function(c){ return c.cat==='casino'; }).length;
_cnt.all = _cards.length;
%>

<!-- ===== MOBILE HOME (md:hidden = chỉ hiện mobile) ===== -->
<div class="md:hidden" id="mobileHome">

  <!-- HEADER mobile FIXED - không di chuyển khi cuộn -->
  <header class="fixed top-0 left-0 right-0 z-40 bg-[#13171f] border-b border-line flex items-center gap-2 px-3 h-[52px]" style="backdrop-filter:blur(8px);background:rgba(19,23,31,.95);">
    <button onclick="toggleSidebar()" class="text-white text-2xl px-1 leading-none" aria-label="Menu">☰</button>
    <a href="/" class="flex items-center gap-1.5 ml-1">
      <img src="/static/img/logoxoso66tv.webp" alt="<%= brand.name %>" class="h-8 w-auto" onerror="this.style.display='none'"
        ><span class="hidden text-white font-black text-base"><%= brand.short || 'XOSO66' %><span class="text-pri">TV</span></span>
    </a>
    <div class="flex-1"></div>
    <a href="/dang-nhap" class="px-2.5 py-1 rounded text-[11px] font-bold border-2 border-pri text-pri-light">Đăng Nhập</a>
    <a href="/dang-ky" class="px-2.5 py-1 rounded text-[11px] font-bold bg-gradient-to-br from-pri to-live text-white shadow">Đăng Ký</a>
  </header>

  <!-- Body container - padding-top 52px cho header fixed, padding-bottom 80px cho bottom nav -->
  <div class="px-3 pb-24" style="padding-top:60px;">

    <!-- BANNER carousel - aspect rộng để full ảnh, contain -->
    <% if (banners && banners.length) { %>
    <div class="relative rounded-xl overflow-hidden mb-3 bg-bg-card" id="mhBanner" style="aspect-ratio:1400/240;">
      <% banners.forEach(function(b, i){ %>
        <div class="mh-slide absolute inset-0 flex items-center px-4 text-white" style="background:<%= b.bg %>;opacity:<%= i===0?1:0 %>;transition:opacity .8s;pointer-events:<%= i===0?'auto':'none' %>">
          <% if (b.image) { %>
            <!-- 🆕 <img> object-contain: KHÔNG BAO GIỜ CROP, auto fit mọi ratio -->
            <img src="<%= b.image %>" alt="<%= b.title || 'XOSO66 TV banner' %>" class="absolute inset-0 w-full h-full object-contain block pointer-events-none" loading="<%= i===0?'eager':'lazy' %>" decoding="async">
            <a href="<%= b.url %>" target="_blank" rel="noopener" class="absolute inset-0 z-[2]" aria-label="<%= b.title %>"></a>
          <% } else { %>
            <div class="relative z-[1] flex-1 min-w-0">
              <div class="text-base font-extrabold mb-1 truncate"><%= b.title %></div>
              <div class="text-[10px] opacity-90 mb-1.5 line-clamp-2"><%= b.desc %></div>
              <a href="<%= b.url %>" target="_blank" rel="noopener" class="inline-flex bg-white text-red-700 px-3 py-1 rounded font-bold text-[11px]"><%= b.cta %> →</a>
            </div>
          <% } %>
        </div>
      <% }); %>
      <% if (banners.length > 1) { %>
      <div class="absolute bottom-1.5 left-1/2 -translate-x-1/2 flex gap-1 z-[2]" id="mhDots">
        <% banners.forEach(function(b, i){ %><span class="w-1.5 h-1.5 rounded-full bg-white/40 transition-all <%= i===0?'!w-4 !bg-white':'' %>"></span><% }); %>
      </div>
      <% } %>
    </div>
    <% } %>

    <!-- LIVE PREVIEW BLOCK - VIDEO THỰC + overlay button -->
    <div id="mhLivePreview" class="block rounded-xl bg-black border border-line overflow-hidden mb-3 relative cursor-pointer" style="aspect-ratio:16/8;">
      <!-- Video element ẩn ban đầu, hiện khi có stream live -->
      <video id="mhLiveVideo" class="hidden absolute inset-0 w-full h-full object-cover bg-black" playsinline autoplay muted></video>

      <!-- 🆕 TEAM PANEL: layout 2 logos + time + league (Option B SofaScore style) -->
      <% if (_featured) {
        var _featDate = '';
        try { _featDate = _featured.date ? new Date(_featured.date).toLocaleDateString('vi-VN',{day:'2-digit',month:'2-digit'}) : ''; } catch(e){}
      %>
      <div id="mhLiveTeamPanel" class="absolute inset-0 z-[1] flex flex-col" style="background:linear-gradient(135deg,#1a2030 0%,#0a0d12 60%,#070a0f 100%);">
        <!-- Decorative orange radial glow -->
        <div class="absolute inset-0 opacity-15 pointer-events-none" style="background:radial-gradient(ellipse at center,#ff7a18 0%,transparent 65%);"></div>
        <!-- League name TOP -->
        <div class="relative z-10 text-center pt-3 px-3">
          <% if (_featured.leagueLogo) { %>
            <img src="<%= _featured.leagueLogo %>" alt="<%= _featured.league %>" class="inline-block w-4 h-4 align-middle mr-1 rounded bg-white/90 p-0.5" onerror="this.style.display='none'">
          <% } %>
          <span class="text-pri-light text-[11px] font-bold uppercase tracking-[2px] align-middle"><%= _featured.league || 'Sự kiện' %></span>
        </div>
        <!-- 2 TEAMS + TIME center -->
        <div class="relative z-10 flex-1 flex items-center justify-center gap-5 px-4">
          <!-- HOME -->
          <div class="text-center flex flex-col items-center min-w-0 flex-1 max-w-[100px]">
            <% if (_featured.homeBadge) { %>
              <div class="w-14 h-14 bg-white rounded-full p-1.5 shadow-lg flex items-center justify-center">
                <img src="<%= _featured.homeBadge %>" alt="<%= _featured.home %>" class="w-full h-full object-contain" onerror="this.parentNode.innerHTML='&#9917;'">
              </div>
            <% } else { %>
              <div class="w-14 h-14 bg-bg-deep rounded-full grid place-items-center text-white font-extrabold text-lg border border-pri/30"><%= (_featured.home||'?')[0] %></div>
            <% } %>
            <div class="text-white text-[10px] font-bold mt-1.5 truncate w-full"><%= _featured.home || '' %></div>
          </div>
          <!-- TIME / VS -->
          <div class="text-center flex-shrink-0">
            <div class="text-pri text-[22px] font-black tracking-tight leading-none"><%= _featured.time || 'VS' %></div>
            <% if (_featDate) { %><div class="text-white/60 text-[9px] font-semibold mt-1"><%= _featDate %></div><% } %>
          </div>
          <!-- AWAY -->
          <div class="text-center flex flex-col items-center min-w-0 flex-1 max-w-[100px]">
            <% if (_featured.awayBadge) { %>
              <div class="w-14 h-14 bg-white rounded-full p-1.5 shadow-lg flex items-center justify-center">
                <img src="<%= _featured.awayBadge %>" alt="<%= _featured.away %>" class="w-full h-full object-contain" onerror="this.parentNode.innerHTML='&#9917;'">
              </div>
            <% } else { %>
              <div class="w-14 h-14 bg-bg-deep rounded-full grid place-items-center text-white font-extrabold text-lg border border-pri/30"><%= (_featured.away||'?')[0] %></div>
            <% } %>
            <div class="text-white text-[10px] font-bold mt-1.5 truncate w-full"><%= _featured.away || '' %></div>
          </div>
        </div>
        <!-- Status badge top-left -->
        <% if (_featured.status !== 'live') { %>
          <span class="absolute top-2 left-2 z-10 bg-gradient-to-r from-pri to-live text-white text-[9px] font-extrabold px-2 py-0.5 rounded shadow flex items-center gap-1"><span>&#9200;</span>SẮP DIỄN RA</span>
        <% } %>
      </div>
      <% } else { %>
      <!-- Empty fallback khi không có featured -->
      <div id="mhLiveTeamPanel" class="absolute inset-0 z-[1] grid place-items-center text-center" style="background:linear-gradient(135deg,#1a2030 0%,#0a0d12 100%);">
        <div>
          <div class="w-16 h-16 mx-auto mb-2 rounded-full bg-gradient-to-br from-pri to-live grid place-items-center text-2xl shadow-lg">&#9654;</div>
          <div class="text-white font-bold text-sm"><%= brand.name %></div>
          <div class="text-muted text-[10px] mt-1">Đang chờ trận live...</div>
        </div>
      </div>
      <% } %>

      <!-- LIVE badge top-left -->
      <span id="mhLiveBadge" class="hidden absolute top-2 left-2 z-[3] bg-live text-white px-2 py-0.5 rounded font-bold text-[10px] flex items-center gap-1 shadow-lg"><span class="w-1.5 h-1.5 bg-white rounded-full animate-pulse-live"></span>LIVE</span>

      <!-- Viewer count top-right -->
      <span id="mhLiveViewers" class="hidden absolute top-2 right-2 z-[3] bg-black/70 text-white px-2 py-0.5 rounded text-[10px] font-bold backdrop-blur">👁 <span class="tabular-nums">--</span></span>

      <!-- Idol name bottom -->
      <div id="mhLiveName" class="hidden absolute bottom-2 left-2 right-2 z-[3] text-white text-xs font-bold drop-shadow-lg truncate"></div>

      <!-- Overlay nút "Vào Phòng Trực Tiếp" giữa -->
      <div class="absolute inset-0 grid place-items-center z-[4] pointer-events-none">
        <div id="mhLiveCta" class="bg-black/60 border-2 border-pri/70 rounded-full px-5 py-2.5 flex items-center gap-2 text-white backdrop-blur shadow-2xl pointer-events-auto" style="box-shadow:0 0 20px rgba(255,122,24,.4);">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" class="text-pri"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          <span class="font-bold text-[13px]">Vào Phòng Trực Tiếp</span>
        </div>
      </div>

      <!-- Nút bật tiếng đã bỏ theo yêu cầu -->
    </div>

    <!-- 🆕 Dots carousel indicator (chỉ hiện khi có ≥2 candidates) -->
    <div id="mhLivePreviewDots" class="hidden flex justify-center items-center gap-1.5 mt-1.5 mb-2" role="tablist" aria-label="Chọn stream"></div>

    <script src="https://cdn.jsdelivr.net/npm/flv.js@1.6.2/dist/flv.min.js"></script>
    <script>
    /**
     * Mobile home preview CAROUSEL:
     * - Hiển thị nhiều candidates (BLV + Idol đang live) trong 1 khung preview
     * - Vuốt trái/phải → đổi slide → load FLV stream khác (KHÔNG vào phòng)
     * - Tap vào khung → vào phòng của slide hiện tại
     * - Dots dưới khung indicator
     * - Save team panel HTML gốc để slide 0 giữ giao diện 2-logo cũ
     */
    (function initMhLivePreview(){
      var candidates  = <%- JSON.stringify(_liveCandidates) %>;
      var fallbackHref = <%- JSON.stringify(_featuredLink || '/lich-phat-song') %>;

      var box       = document.getElementById('mhLivePreview');
      if (!box) return;
      var video     = document.getElementById('mhLiveVideo');
      var teamPanel = document.getElementById('mhLiveTeamPanel');
      var badge     = document.getElementById('mhLiveBadge');
      var viewers   = document.getElementById('mhLiveViewers');
      var nameEl    = document.getElementById('mhLiveName');
      var dotsEl    = document.getElementById('mhLivePreviewDots');

      // Không có candidates → giữ HTML team panel default, click → fallback link
      if (!candidates.length) {
        box.addEventListener('click', function(){ location.href = fallbackHref; });
        return;
      }

      var teamPanelOrigHTML = (teamPanel && teamPanel.innerHTML) || '';
      var flvPlayer = null;
      var currentIdx = 0;
      var viewersTimer = null;
      var clickHref = candidates[0].href || fallbackHref;

      // ────────────────────────────────────────────
      // Helpers
      // ────────────────────────────────────────────
      function escHtml(s){ return String(s||'').replace(/[&<>"']/g, function(m){ return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[m]; }); }

      function renderAvatarSlide(cand){
        var name = escHtml(cand.name);
        var initial = (cand.name || '?').trim().charAt(0).toUpperCase();
        var kindLabel = cand.kind === 'idol' ? '🎀 Idol Live' : '🎙️ BLV trực tiếp';
        var avatarHtml = cand.avatar
          ? '<img src="'+escHtml(cand.avatar)+'" alt="'+name+'" class="w-24 h-24 rounded-full object-cover border-2 border-pri shadow-2xl" loading="lazy" onerror="this.style.display=\'none\';var f=this.nextElementSibling;if(f)f.style.display=\'flex\'">'
          : '';
        return ''+
          '<div class="absolute inset-0 z-[1] flex flex-col items-center justify-center" style="background:linear-gradient(135deg,#1a2030 0%,#0a0d12 60%,#070a0f 100%);">'+
            '<div class="absolute inset-0 opacity-15 pointer-events-none" style="background:radial-gradient(ellipse at center,#ff7a18 0%,transparent 65%);"></div>'+
            '<div class="relative z-10 flex flex-col items-center px-4 text-center">'+
              avatarHtml+
              '<div class="w-24 h-24 rounded-full bg-gradient-to-br from-pri to-live grid place-items-center text-white font-extrabold text-3xl border-2 border-pri shadow-2xl" style="display:'+(cand.avatar?'none':'flex')+'">'+escHtml(initial)+'</div>'+
              '<div class="text-white font-bold text-sm mt-3 max-w-full truncate">'+name+'</div>'+
              '<div class="text-pri-light text-[10px] mt-1 font-bold uppercase tracking-wider">'+kindLabel+'</div>'+
            '</div>'+
          '</div>';
      }

      function renderDots(){
        if (!dotsEl) return;
        if (candidates.length <= 1) { dotsEl.classList.add('hidden'); return; }
        var html = '';
        for (var i = 0; i < candidates.length; i++) {
          var active = i === 0;
          html += '<span data-i="'+i+'" role="tab" aria-selected="'+active+'" class="mh-prev-dot rounded-full transition-all cursor-pointer '+(active?'w-4 h-1.5 bg-pri':'w-1.5 h-1.5 bg-white/40')+'"></span>';
        }
        dotsEl.innerHTML = html;
        dotsEl.classList.remove('hidden');
        Array.prototype.forEach.call(dotsEl.children, function(d){
          d.addEventListener('click', function(ev){
            ev.stopPropagation();
            goSlide(parseInt(d.getAttribute('data-i'), 10), 'click');
          });
        });
      }

      function updateDots(i){
        if (!dotsEl) return;
        Array.prototype.forEach.call(dotsEl.children, function(d, k){
          var active = k === i;
          d.className = 'mh-prev-dot rounded-full transition-all cursor-pointer '+(active?'w-4 h-1.5 bg-pri':'w-1.5 h-1.5 bg-white/40');
          d.setAttribute('aria-selected', String(active));
        });
      }

      // ────────────────────────────────────────────
      // Slide navigation
      // ────────────────────────────────────────────
      function goSlide(i, _src){
        if (!candidates.length) return;
        // loop
        if (i < 0) i = candidates.length - 1;
        if (i >= candidates.length) i = 0;
        currentIdx = i;
        var cand = candidates[i];

        // Reset UI to "loading" state
        if (video) { video.classList.add('hidden'); try { video.pause(); } catch(e){} }
        if (badge) badge.classList.add('hidden');
        if (viewers) viewers.classList.add('hidden');
        if (viewersTimer) { clearInterval(viewersTimer); viewersTimer = null; }

        // Swap team panel content
        if (teamPanel) {
          if (i === 0 && teamPanelOrigHTML) {
            teamPanel.innerHTML = teamPanelOrigHTML;
          } else {
            teamPanel.innerHTML = renderAvatarSlide(cand);
          }
          teamPanel.style.display = '';
        }

        // Show name overlay
        if (nameEl) {
          nameEl.classList.remove('hidden');
          nameEl.textContent = (cand.kind === 'idol' ? '🎀 ' : '🎙️ ') + cand.name;
        }

        clickHref = cand.href || fallbackHref;
        updateDots(i);

        // Try load FLV cho cand này
        loadFlv(cand);
      }

      function loadFlv(cand){
        if (!window.flvjs || !flvjs.isSupported() || !video) return;
        try { if (flvPlayer) flvPlayer.destroy(); flvPlayer = null; } catch(e){}

        var url = 'https://live.xoso66tv.com/live/' + cand.key + '.flv';
        // HEAD check trước → tránh tốn FLV connect nếu không có stream
        fetch(url, { method:'HEAD', cache:'no-store' })
          .then(function(r){
            if (!r.ok) return;                             // không live → giữ panel
            if (candidates[currentIdx] !== cand) return;   // user đã vuốt sang cand khác

            flvPlayer = flvjs.createPlayer({
              type:'flv', url:url, isLive:true, hasAudio:true, hasVideo:true
            }, { enableWorker:false, enableStashBuffer:false, stashInitialSize:128 });
            flvPlayer.attachMediaElement(video);
            flvPlayer.load();
            var p = flvPlayer.play();
            if (p && p.catch) p.catch(function(){});

            var shown = false;
            function showLive(){
              if (shown) return; shown = true;
              if (candidates[currentIdx] !== cand) {
                try { flvPlayer.destroy(); } catch(e){}
                return;
              }
              video.classList.remove('hidden');
              if (teamPanel) teamPanel.style.display = 'none';
              if (badge)   { badge.classList.remove('hidden'); badge.style.display = 'flex'; }
              if (viewers) {
                viewers.classList.remove('hidden');
                var n = 50 + Math.floor(Math.random()*500);
                var span = viewers.querySelector('span');
                if (span) span.textContent = n.toLocaleString('vi-VN');
                if (viewersTimer) clearInterval(viewersTimer);
                viewersTimer = setInterval(function(){
                  n += Math.floor(Math.random()*5) - 2;
                  if (n < 30) n = 30;
                  if (span) span.textContent = n.toLocaleString('vi-VN');
                }, 4000);
              }
            }
            video.addEventListener('loadedmetadata', showLive, { once:true });
            video.addEventListener('playing', showLive, { once:true });
            flvPlayer.on(flvjs.Events.ERROR, function(){ /* im lặng, giữ panel */ });
          })
          .catch(function(){ /* HEAD fail → giữ panel */ });
      }

      // ────────────────────────────────────────────
      // Swipe gesture
      // ────────────────────────────────────────────
      var touchX0 = 0, touchY0 = 0, touchT0 = 0, swiping = false, swiped = false;
      box.addEventListener('touchstart', function(e){
        if (!e.touches || e.touches.length !== 1) { swiping = false; return; }
        touchX0 = e.touches[0].clientX;
        touchY0 = e.touches[0].clientY;
        touchT0 = Date.now();
        swiping = true;
        swiped = false;
      }, { passive:true });
      box.addEventListener('touchend', function(e){
        if (!swiping) return;
        swiping = false;
        var t = e.changedTouches && e.changedTouches[0];
        if (!t) return;
        var dx = t.clientX - touchX0;
        var dy = t.clientY - touchY0;
        var dt = Date.now() - touchT0;
        // 🆕 Bất kỳ touch nào di chuyển >10px đều CHẶN click (kể cả vuốt nhẹ/xéo
        // không đủ ngưỡng đổi slide) — tránh vô tình navigate vào phòng khi đang vuốt.
        // Chỉ TAP thật (gần như không move) mới được navigate.
        if (Math.abs(dx) > 10 || Math.abs(dy) > 10) swiped = true;
        // Swipe đủ ngưỡng → đổi slide
        if (Math.abs(dx) > 50 && Math.abs(dx) > Math.abs(dy)*2 && dt < 800) {
          if (dx < 0) goSlide(currentIdx + 1, 'swipe');
          else        goSlide(currentIdx - 1, 'swipe');
        }
      }, { passive:true });

      // ────────────────────────────────────────────
      // Click toàn vùng → vào phòng (nhưng KHÔNG nếu vừa swipe)
      // ────────────────────────────────────────────
      box.addEventListener('click', function(e){
        if (swiped) { swiped = false; return; }
        // Bỏ qua nếu click vào dot (đã stopPropagation rồi nhưng phòng hờ)
        if (e.target && e.target.classList && e.target.classList.contains('mh-prev-dot')) return;
        location.href = clickHref;
      });

      // ────────────────────────────────────────────
      // Desktop keyboard: ← → khi focus mobile preview (chỉ áp dụng nếu mobile preview hiển thị)
      // ────────────────────────────────────────────
      document.addEventListener('keydown', function(e){
        // Chỉ nếu mobile home đang hiện (md:hidden = ẩn ≥768px)
        if (window.innerWidth >= 768) return;
        if (e.target && (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA' || e.target.isContentEditable)) return;
        if (e.key === 'ArrowLeft')  { e.preventDefault(); goSlide(currentIdx - 1, 'key'); }
        else if (e.key === 'ArrowRight') { e.preventDefault(); goSlide(currentIdx + 1, 'key'); }
      });

      // ────────────────────────────────────────────
      // Init
      // ────────────────────────────────────────────
      function start(){
        if (!window.flvjs) { setTimeout(start, 300); return; }
        renderDots();
        goSlide(0, 'init');
        // Recheck mỗi 30s nếu chưa có stream live cho slide hiện tại
        setInterval(function(){
          if (!flvPlayer || (video && video.classList.contains('hidden'))) {
            loadFlv(candidates[currentIdx]);
          }
        }, 30000);
      }
      if (document.readyState !== 'loading') start();
      else document.addEventListener('DOMContentLoaded', start);
    })();
    </script>

