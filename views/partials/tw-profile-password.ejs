<header class="mb-5">
  <h1 class="text-xl font-extrabold text-white mb-1">Thay đổi mật khẩu</h1>
  <p class="text-muted text-sm">Đặt mật khẩu mạnh để bảo vệ tài khoản. Tối thiểu 8 ký tự gồm chữ và số.</p>
</header>

<form id="pwdForm" class="max-w-md space-y-4" novalidate>
  <label class="block">
    <span class="block text-xs font-bold text-muted mb-1.5 uppercase tracking-wide">Mật khẩu hiện tại</span>
    <div class="relative">
      <input id="pwOld" type="password" required minlength="8" class="w-full bg-bg-deep border border-line text-white px-3 py-2.5 pr-10 rounded-lg outline-none focus:border-pri">
      <button type="button" onclick="togglePw('pwOld')" class="absolute right-2.5 top-1/2 -translate-y-1/2 text-muted">&#128065;</button>
    </div>
  </label>
  <label class="block">
    <span class="block text-xs font-bold text-muted mb-1.5 uppercase tracking-wide">Mật khẩu mới</span>
    <div class="relative">
      <input id="pwNew" type="password" required minlength="8" class="w-full bg-bg-deep border border-line text-white px-3 py-2.5 pr-10 rounded-lg outline-none focus:border-pri" oninput="checkStrength(this.value)">
      <button type="button" onclick="togglePw('pwNew')" class="absolute right-2.5 top-1/2 -translate-y-1/2 text-muted">&#128065;</button>
    </div>
    <div class="mt-1.5 h-1 bg-bg-deep rounded-full overflow-hidden">
      <div id="pwStrength" class="h-full bg-live transition-all" style="width:0%"></div>
    </div>
    <div class="text-[11px] mt-1" id="pwStrengthText">Mức độ: <span class="text-muted">—</span></div>
  </label>
  <label class="block">
    <span class="block text-xs font-bold text-muted mb-1.5 uppercase tracking-wide">Nhập lại mật khẩu mới</span>
    <div class="relative">
      <input id="pwConfirm" type="password" required minlength="8" class="w-full bg-bg-deep border border-line text-white px-3 py-2.5 pr-10 rounded-lg outline-none focus:border-pri">
      <button type="button" onclick="togglePw('pwConfirm')" class="absolute right-2.5 top-1/2 -translate-y-1/2 text-muted">&#128065;</button>
    </div>
  </label>
  <button type="submit" class="px-6 py-2.5 bg-gradient-to-br from-pri to-pri-dark hover:brightness-110 text-white rounded-lg font-extrabold shadow-pri">&#128274; Đổi mật khẩu</button>
</form>

<script>
function togglePw(id){ var i=document.getElementById(id); i.type=i.type==='password'?'text':'password'; }
function checkStrength(p){
  var score = 0;
  if (p.length >= 8) score++;
  if (p.length >= 12) score++;
  if (/[A-Z]/.test(p) && /[a-z]/.test(p)) score++;
  if (/[0-9]/.test(p)) score++;
  if (/[^A-Za-z0-9]/.test(p)) score++;
  var bar = document.getElementById('pwStrength');
  var text = document.getElementById('pwStrengthText');
  var pct = score * 20;
  var color = score < 2 ? '#ff3b3b' : score < 4 ? '#ffd23f' : '#27ae60';
  var label = score < 2 ? 'Yếu' : score < 4 ? 'Trung bình' : 'Mạnh';
  bar.style.width = pct + '%';
  bar.style.background = color;
  text.innerHTML = 'Mức độ: <span style="color:' + color + '">' + label + '</span>';
}
document.getElementById('pwdForm').addEventListener('submit', function(e){
  e.preventDefault();
  var old = document.getElementById('pwOld').value;
  var n   = document.getElementById('pwNew').value;
  var c   = document.getElementById('pwConfirm').value;
  if (n.length < 8)  { showToast('Mật khẩu mới tối thiểu 8 ký tự','error'); return; }
  if (n !== c)       { showToast('Mật khẩu nhập lại không khớp','error'); return; }
  if (n === old)     { showToast('Mật khẩu mới phải khác mật khẩu cũ','error'); return; }
  // Demo: chỉ thông báo. Production: POST /api/profile/password
  showToast('Đổi mật khẩu thành công!', 'success');
  this.reset();
  document.getElementById('pwStrength').style.width = '0%';
  document.getElementById('pwStrengthText').innerHTML = 'Mức độ: <span class="text-muted">—</span>';
});
</script>
