<header class="bg-gradient-to-b from-[#1a1f29] to-[#13171f] border-b border-line items-center gap-3.5 px-5 sticky top-0 z-40 h-16 hidden md:flex">
  <button class="md:hidden bg-transparent border-0 text-white text-2xl px-1.5" onclick="toggleSidebar()" aria-label="Menu">&#9776;</button>
  <%# 🔥 LIVE TICKER — thay banner cam cũ (sofascore-style scrolling) %>
  <div id="liveTicker" class="flex-1 hidden sm:flex items-center overflow-hidden rounded-lg h-11 relative"
       style="background:transparent;border:1px solid rgba(255,122,24,.25);backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px);">
    <!-- LIVE label sticky trái -->
    <div class="flex items-center gap-1.5 px-3 h-full z-10 shrink-0" style="background:linear-gradient(90deg,#dc2626 0%,#ea580c 100%);">
      <span class="w-2 h-2 bg-white rounded-full" style="animation:tk-pulse 1.4s ease-in-out infinite;"></span>
      <span class="text-white font-extrabold text-[11px] uppercase tracking-wider">LIVE</span>
    </div>
    <!-- Scroll track -->
    <div class="flex-1 overflow-hidden h-full">
      <div id="liveTickerInner" class="inline-flex h-full items-center whitespace-nowrap" style="will-change:transform;animation:tk-scroll 80s linear infinite;">
        <span class="px-4 text-pri-light text-[11px] font-bold">&#272;ang t&#7843;i l&#7883;ch live&hellip;</span>
      </div>
    </div>
    <!-- Pause/play -->
    <button id="liveTickerPause" type="button" class="absolute right-1.5 top-1/2 -translate-y-1/2 z-20 bg-black/60 hover:bg-black/85 text-white w-6 h-6 rounded-full grid place-items-center backdrop-blur transition-colors" aria-label="T&#7841;m d&#7915;ng ticker">
      <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><path d="M6 4h4v16H6zm8 0h4v16h-4z"/></svg>
    </button>
  </div>
  <style>
    @keyframes tk-scroll { from { transform: translateX(0); } to { transform: translateX(-50%); } }
    @keyframes tk-pulse { 0%,100% { opacity:1; transform:scale(1); } 50% { opacity:.5; transform:scale(.85); } }
    @keyframes tk-glow { 0%,100% { box-shadow:0 0 8px rgba(255,68,68,.45),inset 0 0 12px rgba(255,255,255,.15); } 50% { box-shadow:0 0 18px rgba(255,68,68,.85),inset 0 0 16px rgba(255,255,255,.25); } }
    #liveTicker { transition: box-shadow .3s ease, transform .3s ease; will-change: transform; }
    #liveTicker:hover { transform: translateY(-1px); box-shadow:0 6px 24px rgba(255,122,24,.25); }
    #liveTickerInner { transition: filter .3s ease; }
    /* Mask fade 2 đầu — chips xuất hiện/biến mất mềm mại */
    #liveTicker > div:nth-child(2) { -webkit-mask-image: linear-gradient(90deg, transparent 0, #000 40px, #000 calc(100% - 40px), transparent 100%); mask-image: linear-gradient(90deg, transparent 0, #000 40px, #000 calc(100% - 40px), transparent 100%); }
    /* LIVE label — luôn glow pulse */
    #liveTicker > div:first-child { animation: tk-glow 2.4s ease-in-out infinite; }
    /* Chip — lift + scale on hover */
    .tk-chip { display:inline-flex; align-items:center; gap:6px; padding:0 14px; height:100%; border-right:1px solid rgba(255,255,255,.08); color:#fff; font-size:11px; font-weight:600; text-decoration:none; transition: background .2s ease, transform .2s cubic-bezier(.34,1.56,.64,1), box-shadow .2s ease; transform-origin: center; will-change: transform; position:relative; }
    .tk-chip:hover { background:rgba(255,122,24,.22); transform: translateY(-2px) scale(1.06); box-shadow:0 4px 14px rgba(255,122,24,.35); z-index:5; border-radius:6px; }
    .tk-chip::after { content:''; position:absolute; left:0; right:0; bottom:0; height:2px; background:linear-gradient(90deg, transparent, #ff7a18, transparent); transform: scaleX(0); transition: transform .25s ease; }
    .tk-chip:hover::after { transform: scaleX(1); }
    .tk-time { color:#ffb86b; font-family:'JetBrains Mono','Courier New',monospace; font-weight:700; font-size:10px; transition: color .15s ease; }
    .tk-time.live { color:#fca5a5; text-shadow:0 0 6px rgba(252,165,165,.6); }
    .tk-chip:hover .tk-time { color:#fff; }
    .tk-score { color:#fde68a; font-weight:800; padding:0 4px; transition: transform .2s ease; }
    .tk-chip:hover .tk-score { transform: scale(1.15); }
    .tk-vs { color:#94a3b8; font-size:10px; padding:0 2px; }
    .tk-team { max-width:96px; text-overflow:ellipsis; overflow:hidden; }
    .tk-badge { width:14px; height:14px; border-radius:9999px; background:rgba(255,255,255,.85); padding:1px; object-fit:contain; transition: transform .25s cubic-bezier(.34,1.56,.64,1); }
    .tk-chip:hover .tk-badge { transform: scale(1.25) rotate(-8deg); }
    .tk-sep { color:#ff7a18; font-weight:900; padding:0 14px; font-size:10px; text-transform:uppercase; letter-spacing:1.5px; opacity:.95; text-shadow:0 0 8px rgba(255,122,24,.5); }
    html:not(.dark) #liveTicker { background:transparent !important; border-color:rgba(234,88,12,.3) !important; }
    html:not(.dark) #liveTicker:hover { box-shadow:0 6px 24px rgba(234,88,12,.2); }
    html:not(.dark) .tk-chip { color:#1f2937; }
    html:not(.dark) .tk-chip:hover { background:rgba(234,88,12,.14); box-shadow:0 4px 14px rgba(234,88,12,.25); }
    html:not(.dark) .tk-time { color:#c2410c; }
    html:not(.dark) .tk-time.live { color:#dc2626; text-shadow:0 0 6px rgba(220,38,38,.4); }
    html:not(.dark) .tk-chip:hover .tk-time { color:#7c2d12; }
    html:not(.dark) .tk-score { color:#b45309; }
    html:not(.dark) .tk-vs { color:#6b7280; }
    html:not(.dark) .tk-badge { background:#fff; box-shadow:0 0 0 1px rgba(0,0,0,.08); }
    html:not(.dark) .tk-sep { text-shadow:0 0 6px rgba(234,88,12,.3); }
  </style>
  <script>
  (function(){
    var ticker = document.getElementById('liveTicker');
    if (!ticker) return;
    var inner = document.getElementById('liveTickerInner');
    var pauseBtn = document.getElementById('liveTickerPause');
    var userPaused = false; // user click pause → giữ paused kể cả khi rời chuột

    // Hover pause/resume (vì inline `animation` shorthand override CSS :hover rule)
    ticker.addEventListener('mouseenter', function(){
      if (inner) inner.style.animationPlayState = 'paused';
    });
    ticker.addEventListener('mouseleave', function(){
      if (inner) inner.style.animationPlayState = userPaused ? 'paused' : 'running';
    });

    // Click pause/play button — toggle userPaused
    if (pauseBtn) {
      pauseBtn.addEventListener('click', function(e){
        e.stopPropagation();
        userPaused = !userPaused;
        if (inner) inner.style.animationPlayState = userPaused ? 'paused' : 'running';
        pauseBtn.innerHTML = userPaused
          ? '<svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>'
          : '<svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><path d="M6 4h4v16H6zm8 0h4v16h-4z"/></svg>';
        pauseBtn.setAttribute('aria-label', userPaused ? 'Phát ticker' : 'Tạm dừng ticker');
      });
    }
    function esc(s){ return String(s||'').replace(/[&<>"']/g, function(m){ return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[m]; }); }
    function chip(m, kind){
      var time = kind==='live' ? '<span class="tk-time live">&#9679; LIVE</span>' : '<span class="tk-time">'+esc(m.time||'--:--')+'</span>';
      var hb = m.homeBadge ? '<img class="tk-badge" src="'+esc(m.homeBadge)+'" alt="" onerror="this.style.display=\'none\'">' : '';
      var ab = m.awayBadge ? '<img class="tk-badge" src="'+esc(m.awayBadge)+'" alt="" onerror="this.style.display=\'none\'">' : '';
      var sc = (m.score && m.score.length===2) ? '<span class="tk-score">'+m.score[0]+':'+m.score[1]+'</span>' : '<span class="tk-vs">vs</span>';
      return '<a class="tk-chip" href="/live/'+esc(m.slug||m.id)+'">'+time+hb+'<span class="tk-team">'+esc(m.home||'?')+'</span>'+sc+'<span class="tk-team">'+esc(m.away||'?')+'</span>'+ab+'</a>';
    }
    function sep(label){ return '<span class="tk-sep">&bull; '+esc(label)+' &bull;</span>'; }
    function load(){
      Promise.all([
        fetch('/api/live').then(function(r){return r.json();}).catch(function(){return {list:[]};}),
        fetch('/api/upcoming').then(function(r){return r.json();}).catch(function(){return {list:[]};})
      ]).then(function(arr){
        var live = (arr[0] && arr[0].list || []).slice(0, 20);
        var up   = (arr[1] && arr[1].list || []).slice(0, 25);
        var chips = [];
        if (live.length) { chips.push(sep('Đang LIVE')); live.forEach(function(m){ chips.push(chip(m,'live')); }); }
        if (up.length)   { chips.push(sep('Sắp diễn ra')); up.forEach(function(m){ chips.push(chip(m,'upcoming')); }); }
        if (!chips.length) { inner.innerHTML = '<a href="/lich-phat-song" class="px-4 text-pri-light text-[11px] font-bold">Xem lịch phát sóng &rarr;</a>'; return; }
        inner.innerHTML = chips.join('') + chips.join(''); // duplicate cho seamless loop
        requestAnimationFrame(function(){
          var w = inner.scrollWidth / 2;
          var duration = Math.max(45, Math.round(w / 50)); // ~50px/sec
          inner.style.animation = 'tk-scroll ' + duration + 's linear infinite';
        });
      }).catch(function(){
        inner.innerHTML = '<span class="px-4 text-red-300 text-[11px] font-bold">Lỗi tải lịch live</span>';
      });
    }
    load();
    setInterval(load, 120000); // refresh mỗi 2 phút
  })();
  </script>

