<script>
window.isUserAdmin = function(){
  try {
    var u = JSON.parse(localStorage.getItem('x66_user') || '{}');
    return !!(u && (u.isAdmin === true || (u.username||'').toLowerCase() === 'admin'));
  } catch(e){ return false; }
};
window.x66ShowAdminBadge = function(){
  if (!window.isUserAdmin() || document.getElementById('x66AdminBadge')) return;
  var b = document.createElement('div');
  b.id = 'x66AdminBadge';
  b.style.cssText = 'position:fixed;top:8px;left:50%;transform:translateX(-50%);z-index:9999;background:linear-gradient(90deg,#10b981,#059669);color:#fff;font-weight:900;font-size:11px;padding:4px 12px;border-radius:999px;box-shadow:0 4px 12px rgba(16,185,129,.5);pointer-events:none;';
  b.textContent = 'ADMIN VIEW - Full access';
  document.body.appendChild(b);
  setTimeout(function(){ if (b.parentNode) b.remove(); }, 4000);
};

(function(){
  function paintHeader(){
    try {
      var u = JSON.parse(localStorage.getItem('x66_user') || 'null');
      var guest = document.getElementById('hdrGuest');
      var user  = document.getElementById('hdrUser');
      if (u && u.username) {
        guest.classList.add('hidden');
        user.classList.remove('hidden');
        user.classList.add('flex');
        var name = (u.fullname || u.username).toUpperCase();
        var letter = name.charAt(0);
        var id = u.id || (u.username.toUpperCase() + 'X66X66').slice(0,7);
        // Render avatar - ảnh thật nếu có, chữ cái nếu không
        hdrPaintAvatar(u.avatar, letter);
        document.getElementById('hdrDropName').textContent    = name;
        document.getElementById('hdrDropId').textContent      = id;
        document.getElementById('hdrDropCoin').textContent    = (typeof u.coin==='number'?u.coin:79).toLocaleString('vi-VN');
        // 🎬 Show shortcut tuỳ role: admin → Trang QL Admin, idol/blv → Quản Lý Kênh
        var studioLink = document.getElementById('hdrDropStudio');
        fetch('/api/auth/me', { credentials:'same-origin' })
          .then(function(r){ return r.json(); })
          .then(function(d){
            if (!d || !d.ok) return;
            if (studioLink) {
              if (d.role === 'admin') {
                // Admin: đổi link sang /admin + đổi text + đổi icon
                studioLink.setAttribute('href', '/admin');
                studioLink.innerHTML = '<span class="text-pri">🛠️</span> Trang Quản Lý Admin <span class="ml-auto bg-pri text-white text-[9px] font-extrabold px-1.5 py-0.5 rounded">ADMIN</span>';
                studioLink.classList.remove('hidden');
                studioLink.classList.add('flex');
              } else if (['idol','blv'].indexOf(d.role) !== -1) {
                // Idol/BLV: giữ nguyên "Quản Lý Kênh"
                studioLink.classList.remove('hidden');
                studioLink.classList.add('flex');
              }
            }
            // Update avatar nếu server có URL mới
            if (d.user && d.user.avatar) {
              hdrPaintAvatar(d.user.avatar, letter);
              try {
                var cu = JSON.parse(localStorage.getItem('x66_user') || '{}');
                cu.avatar = d.user.avatar;
                localStorage.setItem('x66_user', JSON.stringify(cu));
              } catch(e){}
            }
          }).catch(function(){});
        hdrNotifSeedIfEmpty(name);
        hdrNotifRender();
      } else {
        guest.classList.remove('hidden');
        user.classList.add('hidden');
        user.classList.remove('flex');
      }
    } catch(e){}
  }
  // Render avatar: nếu có URL → <img>, không có → chữ cái
  function hdrPaintAvatar(url, letter){
    var btn = document.getElementById('hdrAvatarBtn');
    var drop = document.getElementById('hdrDropAvatar');
    var letterEl = document.getElementById('hdrAvatarLetter');
    if (url) {
      var imgHtml = '<img src="' + url + '?t=' + Date.now() + '" alt="Avatar" class="w-full h-full object-cover rounded-full" style="display:block">';
      if (btn) {
        btn.innerHTML = imgHtml;
        btn.classList.remove('grid','place-items-center');
      }
      if (drop) {
        drop.innerHTML = imgHtml;
        drop.classList.remove('grid','place-items-center');
      }
    } else {
      if (letterEl) letterEl.textContent = letter;
      else if (btn) btn.innerHTML = '<span id="hdrAvatarLetter">'+letter+'</span>';
      if (drop) drop.textContent = letter;
    }
  }
  // Ensure btn/drop có overflow-hidden để image bo tròn
  (function(){
    var b = document.getElementById('hdrAvatarBtn');
    var d = document.getElementById('hdrDropAvatar');
    if (b) b.style.overflow = 'hidden';
    if (d) d.style.overflow = 'hidden';
  })();

  paintHeader();
  window.addEventListener('storage', paintHeader);
  // Khi profile page upload xong → reload header avatar
  window.addEventListener('x66:avatarChanged', function(e){
    if (e.detail && e.detail.avatar) {
      try { var u = JSON.parse(localStorage.getItem('x66_user') || '{}'); var l = (u.fullname || u.username || 'U').charAt(0).toUpperCase(); hdrPaintAvatar(e.detail.avatar, l); } catch(_){}
    }
  });

  var btn  = document.getElementById('hdrAvatarBtn');
  var drop = document.getElementById('hdrDropdown');
  if (btn && drop) {
    btn.addEventListener('click', function(e){
      e.stopPropagation();
      var np = document.getElementById('hdrNotifPanel'); if (np) np.classList.add('hidden');
      drop.classList.toggle('hidden');
    });
    document.addEventListener('click', function(e){
      if (!drop.contains(e.target) && e.target !== btn) drop.classList.add('hidden');
    });
  }

  var bellBtn   = document.getElementById('hdrBellBtn');
  var notifPanel= document.getElementById('hdrNotifPanel');
  var notifList = document.getElementById('hdrNotifList');
  var notifBadge= document.getElementById('hdrBellBadge');
  var notifCount= document.getElementById('hdrNotifUnreadCount');
  var currentFilter = 'all';

  if (bellBtn && notifPanel) {
    bellBtn.addEventListener('click', function(e){
      e.stopPropagation();
      if (drop) drop.classList.add('hidden');
      notifPanel.classList.toggle('hidden');
      if (!notifPanel.classList.contains('hidden')) hdrNotifRender();
    });
    document.addEventListener('click', function(e){
      if (!notifPanel.contains(e.target) && !bellBtn.contains(e.target)) notifPanel.classList.add('hidden');
    });
    document.querySelectorAll('.hdr-notif-tab').forEach(function(t){
      t.addEventListener('click', function(){
        document.querySelectorAll('.hdr-notif-tab').forEach(function(x){
          x.className = x.className.replace('bg-pri text-white','bg-bg-deep text-gray-200 hover:bg-bg-soft');
        });
        this.className = this.className.replace('bg-bg-deep text-gray-200 hover:bg-bg-soft','bg-pri text-white');
        currentFilter = this.getAttribute('data-filter');
        hdrNotifRender();
      });
    });
  }

  function hdrNotifGet(){ try { return JSON.parse(localStorage.getItem('x66_notifs') || '[]'); } catch(e){ return []; } }
  function hdrNotifSave(list){ try { localStorage.setItem('x66_notifs', JSON.stringify(list)); } catch(e){} hdrNotifUpdateBadge(); }
  function hdrNotifUpdateBadge(){
    var list = hdrNotifGet();
    var unread = list.filter(function(n){ return !n.read; }).length;
    if (notifBadge){
      if (unread > 0){ notifBadge.classList.remove('hidden'); notifBadge.textContent = unread > 99 ? '99+' : unread; }
      else { notifBadge.classList.add('hidden'); }
    }
    if (notifCount) notifCount.textContent = unread;
  }
  function hdrNotifSeedIfEmpty(displayName){
    var list = hdrNotifGet();
    if (list.length > 0) return;
    var now = Date.now();
    hdrNotifSave([
      { id:'n1', type:'system', icon:'👋', title:'Chao mung '+displayName+'!', body:'Cam on ban da tham gia.', link:'/profile?tab=wallet', time:now-300000, read:false },
      { id:'n2', type:'gift',   icon:'🎁', title:'Qua diem danh', body:'Diem danh hom nay.', link:'/profile?tab=checkin', time:now-3600000, read:false },
      { id:'n3', type:'system', icon:'🔥', title:'Su kien hot', body:'Ve cuoc thua HOAN 100%', link:'/su-kien', time:now-7200000, read:false }
    ]);
  }
  function hdrEsc(s){ return String(s||'').replace(/[<>&]/g, function(c){return ({'<':'&lt;','>':'&gt;','&':'&amp;'})[c];}); }
  function hdrNotifAgo(ts){
    var diff = Date.now() - ts;
    var s = Math.floor(diff/1000);
    if (s < 60) return s+'s';
    var m = Math.floor(s/60); if (m < 60) return m+' phut';
    var h = Math.floor(m/60); if (h < 24) return h+' gio';
    return Math.floor(h/24)+' ngay';
  }
  function hdrNotifRender(){
    if (!notifList) return;
    var list = hdrNotifGet();
    var filtered = list;
    if (currentFilter === 'unread') filtered = list.filter(function(n){return !n.read;});
    else if (currentFilter === 'gift')   filtered = list.filter(function(n){return n.type==='gift';});
    else if (currentFilter === 'system') filtered = list.filter(function(n){return n.type==='system';});
    filtered.sort(function(a,b){ return b.time - a.time; });
    if (filtered.length === 0){
      notifList.innerHTML = '<div class="px-4 py-12 text-center text-muted text-[13px]"><div class="text-4xl mb-2 opacity-60">📭</div>Khong co thong bao</div>';
      hdrNotifUpdateBadge();
      return;
    }
    notifList.innerHTML = filtered.map(function(n){
      var ago = hdrNotifAgo(n.time);
      var ucls = n.read ? '' : 'bg-pri/5 border-l-2 border-pri';
      var tcls = n.read ? 'text-gray-200' : 'text-white';
      return '<a href="'+(n.link||'#')+'" data-id="'+n.id+'" class="hdr-notif-item block px-2.5 py-2 border-b border-line/40 hover:bg-bg-soft transition-colors '+ucls+'"><div class="flex items-start gap-2"><div class="w-7 h-7 rounded-full bg-bg-deep grid place-items-center text-base shrink-0">'+n.icon+'</div><div class="flex-1 min-w-0"><div class="flex items-start gap-1"><div class="font-bold text-[12px] '+tcls+' flex-1 truncate">'+hdrEsc(n.title)+'</div>'+(n.read?'':'<span class="w-1.5 h-1.5 rounded-full bg-live mt-1.5 shrink-0"></span>')+'</div><div class="text-[10.5px] text-muted mt-0.5 leading-snug">'+hdrEsc(n.body)+'</div><div class="text-[9.5px] text-pri-light/70 mt-0.5">'+ago+'</div></div></div></a>';
    }).join('');
    notifList.querySelectorAll('.hdr-notif-item').forEach(function(a){
      a.addEventListener('click', function(){
        var id = this.getAttribute('data-id');
        var lst = hdrNotifGet();
        lst.forEach(function(n){ if (n.id === id) n.read = true; });
        hdrNotifSave(lst);
      });
    });
    hdrNotifUpdateBadge();
  }
  window.hdrNotifMarkAllRead = function(){
    var lst = hdrNotifGet();
    lst.forEach(function(n){ n.read = true; });
    hdrNotifSave(lst);
    hdrNotifRender();
  };
  window.hdrNotifClearAll = function(){
    if (!confirm('Xoa toan bo thong bao?')) return;
    hdrNotifSave([]);
    hdrNotifRender();
  };
  window.x66NotifPush = function(notif){
    var lst = hdrNotifGet();
    notif.id = notif.id || ('n_'+Date.now());
    notif.time = notif.time || Date.now();
    notif.read = false;
    lst.unshift(notif);
    if (lst.length > 50) lst = lst.slice(0,50);
    hdrNotifSave(lst);
    if (notifPanel && !notifPanel.classList.contains('hidden')) hdrNotifRender();
  };
})();

/* 🎨 Mục 17: 3-mode theme — cycle Auto → Light → Dark → Auto.
   Apply ngay đã được thực hiện trong head.ejs script — đây chỉ là user toggle. */
function toggleTheme(){
  var html = document.documentElement;
  var cur;
  try { cur = localStorage.getItem('x66_theme') || 'auto'; } catch(e){ cur = 'auto'; }
  var next;
  if (cur === 'auto')       next = 'light';
  else if (cur === 'light') next = 'dark';
  else                      next = 'auto';
  try { localStorage.setItem('x66_theme', next); } catch(e){}
  // Apply ngay
  if (next === 'light') {
    html.classList.remove('dark');
  } else if (next === 'dark') {
    html.classList.add('dark');
  } else { /* auto → follow OS */
    var osLight = window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches;
    if (osLight) html.classList.remove('dark');
    else         html.classList.add('dark');
  }
  updateThemeIcon();
}
function updateThemeIcon(){
  var html = document.documentElement;
  var isDark = html.classList.contains('dark');
  var d = document.getElementById('themeIconDark');
  var l = document.getElementById('themeIconLight');
  if (d && l) { d.classList.toggle('hidden', !isDark); l.classList.toggle('hidden', isDark); }
  // Update tooltip để user biết mode hiện tại
  var btn = document.getElementById('themeToggle');
  if (btn) {
    var cur = 'auto';
    try { cur = localStorage.getItem('x66_theme') || 'auto'; } catch(e){}
    var label = cur === 'auto' ? 'Tự động (theo hệ điều hành)'
              : cur === 'light' ? 'Chế độ Sáng'
              : 'Chế độ Tối';
    btn.setAttribute('title', label + ' — Click để đổi');
    btn.setAttribute('aria-label', label);
  }
}
(function(){
  // Update icon khi page load (head.ejs đã apply class rồi)
  if (document.readyState !== 'loading') updateThemeIcon();
  else document.addEventListener('DOMContentLoaded', updateThemeIcon);
  // Listen OS change qua custom event từ head.ejs script
  window.addEventListener('x66:themechange', updateThemeIcon);
})();
function hdrLogout(){
  if (!confirm('Ban co chac muon dang xuat?')) return;
  try { localStorage.removeItem('x66_user'); } catch(e){}
  // Also clear server cookie
  fetch('/api/auth/logout', { method:'POST', credentials:'same-origin' }).catch(function(){}).finally(function(){
    location.href = '/';
  });
}
</script>
