<%
// ╔════════════════════════════════════════════════════════════════════╗
// ║ HERO BANNER PARTIAL - tái sử dụng cho mọi trang                  ║
// ║ Data: res.locals.banners (set ở server.js line 338)              ║
// ║ Aspect: 1400x140 (10:1), height 70px mobile / 140px desktop      ║
// ║ Auto slide 5s, hover-pause, cross-fade smooth                    ║
// ║ JS guarded - safe khi include nhiều lần                          ║
// ╚════════════════════════════════════════════════════════════════════╝
var _banners = (typeof banners !== 'undefined' && banners && banners.length) ? banners : [];
%>
<% if (_banners.length > 0) { %>
<div class="relative rounded-xl overflow-hidden mb-3.5 h-[70px] md:h-[140px] bg-bg-card hero-banner-wrap" style="contain:layout paint;will-change:contents">
  <% _banners.forEach(function(b, i){ %>
    <div class="hero-slide absolute inset-0 flex items-center px-5 md:px-8 py-5 md:py-7 text-white" style="background:<%= b.bg || 'linear-gradient(135deg,#ff7a18,#dc2626)' %>;opacity:<%= i===0?1:0 %>;transition:opacity 1s ease-in-out;pointer-events:<%= i===0?'auto':'none' %>;will-change:opacity;transform:translateZ(0)">
      <% if (!b.image) { %>
        <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(circle at 75% 50%,rgba(255,255,255,.18),transparent 60%);"></div>
        <div class="relative z-[1] flex-1 min-w-0">
          <div class="text-base md:text-2xl font-extrabold drop-shadow-lg mb-1 md:mb-1.5 leading-tight truncate"><%= b.title || '' %></div>
          <% if (b.desc) { %><div class="text-xs md:text-sm opacity-95 mb-2 md:mb-3 line-clamp-2"><%= b.desc %></div><% } %>
          <% if (b.cta && b.url) { %>
            <a href="<%= b.url %>" target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-white text-red-700 px-5 md:px-7 py-1.5 md:py-2.5 rounded-lg font-extrabold shadow-lg hover:scale-105 transition-transform text-xs md:text-sm"><%= b.cta %> &rarr;</a>
          <% } %>
        </div>
      <% } else { %>
        <img src="<%= b.image %>" alt="<%= b.title || 'XOSO66 TV banner' %>" class="absolute inset-0 w-full h-full object-contain block pointer-events-none" loading="<%= i===0?'eager':'lazy' %>" decoding="async">
        <% if (b.url) { %><a href="<%= b.url %>" target="_blank" rel="noopener" class="absolute inset-0 z-[2]" aria-label="<%= b.title || 'XOSO66' %>"></a><% } %>
      <% } %>
    </div>
  <% }); %>
  <% if (_banners.length > 1) { %>
  <div class="absolute bottom-2 left-1/2 -translate-x-1/2 flex gap-1.5 z-[3] hero-banner-dots">
    <% _banners.forEach(function(b, i){ %><span class="w-1.5 h-1.5 rounded-full bg-white/40 cursor-pointer transition-all duration-500 <%= i===0?'!w-5 !bg-white':'' %>"></span><% }); %>
  </div>
  <% } %>
</div>

<script>
// Hero banner slider - GUARDED để safe khi include nhiều lần
(function(){
  if (window.__heroBannerInit) return;
  window.__heroBannerInit = true;

  function initBanner(wrap){
    if (wrap.__inited) return;
    wrap.__inited = true;
    var slides = wrap.querySelectorAll('.hero-slide');
    var dots = wrap.querySelectorAll('.hero-banner-dots span');
    if (slides.length < 2) return;
    var idx = 0, paused = false;
    document.addEventListener('visibilitychange', function(){ paused = document.hidden; });
    wrap.addEventListener('mouseenter', function(){ paused = true; });
    wrap.addEventListener('mouseleave', function(){ paused = false; });
    var FADE_MS = 1000;
    function switchTo(nextIdx){
      if (nextIdx === idx) return;
      slides[nextIdx].style.zIndex = '2';
      slides[nextIdx].style.opacity = '1';
      slides[nextIdx].style.pointerEvents = 'auto';
      if (dots[idx]) { dots[idx].classList.remove('!w-5','!bg-white'); }
      if (dots[nextIdx]) { dots[nextIdx].classList.add('!w-5','!bg-white'); }
      var prevIdx = idx;
      idx = nextIdx;
      setTimeout(function(){
        if (prevIdx === idx) return;
        slides[prevIdx].style.opacity = '0';
        slides[prevIdx].style.pointerEvents = 'none';
        slides[prevIdx].style.zIndex = '1';
      }, FADE_MS);
    }
    setInterval(function(){ if (!paused) switchTo((idx + 1) % slides.length); }, 5000);
    dots.forEach(function(d, i){ d.addEventListener('click', function(){ switchTo(i); }); });
  }

  function initAll(){
    document.querySelectorAll('.hero-banner-wrap').forEach(initBanner);
  }
  if (document.readyState !== 'loading') initAll();
  else document.addEventListener('DOMContentLoaded', initAll);
})();
</script>
<% } %>
