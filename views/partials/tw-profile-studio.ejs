<%
// Tab "Quản Lý Kênh Live" trong /profile - chỉ idol/blv/admin
var __role = (typeof publicUser !== 'undefined' && publicUser && publicUser.role) ? publicUser.role : 'user';
%>

<!-- Server-side guard nếu user thường truy cập trực tiếp /profile?tab=studio -->
<% if (__role !== 'idol' && __role !== 'blv' && __role !== 'admin') { %>
  <div class="text-center py-12">
    <div class="text-6xl mb-3">🔒</div>
    <h2 class="text-xl font-extrabold text-white mb-2">Chỉ Idol/BLV mới truy cập</h2>
    <p class="text-muted mb-4">Tab "Quản lý kênh" dành cho user đã được duyệt làm Idol hoặc BLV.</p>
    <div class="flex gap-3 justify-center">
      <a href="/dang-ky-idol" class="bg-gradient-to-br from-pink-500 to-rose-600 text-white font-bold px-5 py-2.5 rounded-lg">👑 Đăng ký làm Idol</a>
      <a href="/dang-ky-blv" class="bg-gradient-to-br from-blue-500 to-indigo-600 text-white font-bold px-5 py-2.5 rounded-lg">🎙️ Đăng ký làm BLV</a>
    </div>
  </div>
<% } else { %>

<div>
  <!-- Header -->
  <header class="flex items-center justify-between mb-4 pb-3 border-b border-line">
    <div>
      <h1 class="text-xl font-extrabold text-white flex items-center gap-2"><span class="text-2xl">🎬</span> Quản Lý Kênh Live</h1>
      <p class="text-muted text-xs mt-1">Đăng ký lịch, lên sóng, xem thông báo từ admin</p>
    </div>
    <span class="text-[10px] bg-pri/20 text-pri-light font-bold px-2.5 py-1 rounded-full"><%= __role.toUpperCase() %></span>
  </header>

  <!-- Quick stats -->
  <div class="grid grid-cols-3 gap-3 mb-5">
    <div class="bg-bg-deep border border-line rounded-lg p-3 text-center">
      <div class="text-[10px] text-muted uppercase font-bold">Lịch chờ duyệt</div>
      <div class="text-2xl font-black text-yellow-400 mt-1 tabular-nums" id="pfStudioPending">—</div>
    </div>
    <div class="bg-bg-deep border border-line rounded-lg p-3 text-center">
      <div class="text-[10px] text-muted uppercase font-bold">Lịch đã duyệt</div>
      <div class="text-2xl font-black text-emerald-400 mt-1 tabular-nums" id="pfStudioApproved">—</div>
    </div>
    <div class="bg-bg-deep border border-line rounded-lg p-3 text-center">
      <div class="text-[10px] text-muted uppercase font-bold">Thông báo mới</div>
      <div class="text-2xl font-black text-pri-light mt-1 tabular-nums" id="pfStudioNotif">—</div>
    </div>
  </div>

  <!-- CTA: mở studio để lên sóng -->
  <a href="/idol-studio" class="block bg-gradient-to-r from-pri to-live hover:brightness-110 text-white font-extrabold py-4 rounded-xl text-center mb-5 shadow-lg shadow-pri/30 active:scale-95 transition-all">
    <div class="flex items-center justify-center gap-3">
      <span class="text-3xl">📡</span>
      <div class="text-left">
        <div class="text-base">Mở Studio - Lên Sóng Ngay</div>
        <div class="text-[11px] opacity-90 font-medium">Camera điện thoại hoặc OBS</div>
      </div>
    </div>
  </a>

  <!-- Nội dung 2 cột: Lịch của tôi + Thông báo -->
  <div class="grid md:grid-cols-2 gap-4">

    <!-- LEFT: Lịch live của tôi -->
    <div class="bg-bg-deep border border-line rounded-xl p-4">
      <div class="flex items-center justify-between mb-3">
        <h2 class="font-extrabold text-white flex items-center gap-2"><span>📅</span> Lịch của tôi</h2>
        <a href="/idol-studio" class="text-[10px] text-pri-light font-bold hover:underline">+ Đăng ký mới</a>
      </div>
      <div id="pfStudioSchList" class="space-y-2 max-h-[400px] overflow-y-auto scrollbar-thin">
        <div class="text-center text-muted text-xs py-6">Đang tải...</div>
      </div>
    </div>

    <!-- RIGHT: Thông báo admin -->
    <div class="bg-bg-deep border border-line rounded-xl p-4">
      <div class="flex items-center justify-between mb-3">
        <h2 class="font-extrabold text-white flex items-center gap-2"><span>🔔</span> Thông báo</h2>
        <button onclick="pfStudioMarkAllRead()" class="text-[10px] text-pri-light font-bold hover:underline">✓ Đánh dấu đã đọc</button>
      </div>
      <div id="pfStudioNotifList" class="space-y-2 max-h-[400px] overflow-y-auto scrollbar-thin">
        <div class="text-center text-muted text-xs py-6">Đang tải...</div>
      </div>
    </div>
  </div>

  <!-- ═══════════ PHIÊN LIVE THỐNG KÊ ═══════════ -->
  <div class="mt-5 bg-bg-deep border border-line rounded-xl p-4">
    <div class="flex items-center justify-between mb-3">
      <h2 class="font-extrabold text-white flex items-center gap-2"><span>📊</span> Phiên Live & Tiền Công</h2>
      <span class="text-[10px] text-muted">Auto track khi go live</span>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-2 mb-3">
      <div class="bg-bg-card border border-line rounded-lg p-2.5"><div class="text-[9px] text-muted uppercase">Tổng session</div><div class="text-lg font-black text-white" id="pfMyTotalSess">—</div></div>
      <div class="bg-bg-card border border-line rounded-lg p-2.5"><div class="text-[9px] text-muted uppercase">Tổng giờ</div><div class="text-lg font-black text-pri-light" id="pfMyTotalHours">—</div></div>
      <div class="bg-bg-card border border-line rounded-lg p-2.5"><div class="text-[9px] text-muted uppercase">Đã kiếm</div><div class="text-base font-black text-emerald-400 tabular-nums" id="pfMyEarn">—</div></div>
      <div class="bg-bg-card border border-line rounded-lg p-2.5"><div class="text-[9px] text-muted uppercase">Chưa nhận</div><div class="text-base font-black text-yellow-400 tabular-nums" id="pfMyUnpaid">—</div></div>
    </div>

    <!-- Session list -->
    <div class="bg-bg-card border border-line rounded-lg overflow-x-auto">
      <table class="w-full text-[11px]">
        <thead class="bg-bg-soft border-b border-line text-muted text-[9px] uppercase tracking-wider">
          <tr>
            <th class="px-2 py-2 text-left">Bắt đầu</th>
            <th class="px-2 py-2 text-left">Kết thúc</th>
            <th class="px-2 py-2 text-center">Thời lượng</th>
            <th class="px-2 py-2 text-left">Lịch / Trận</th>
            <th class="px-2 py-2 text-right">Tiền</th>
            <th class="px-2 py-2 text-center">Status</th>
          </tr>
        </thead>
        <tbody id="pfMySessTbody" class="text-gray-200">
          <tr><td colspan="6" class="text-center text-muted py-6">Đang tải...</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- ════════════ QUÀ THẬT NHẬN ĐƯỢC ════════════ -->
  <div class="mt-5 bg-gradient-to-br from-amber-900/20 to-bg-card border border-amber-500/30 rounded-xl p-4">
    <h2 class="text-base font-extrabold text-white mb-3 flex items-center gap-2">
      <span class="text-xl">💎</span> Quà THẬT nhận được
      <span class="text-[10px] bg-amber-500/30 text-amber-200 px-2 py-0.5 rounded-full font-bold">QUY ĐỔI RA VND</span>
    </h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-2 mb-3">
      <div class="bg-bg-deep border border-line rounded-lg p-2.5">
        <div class="text-[9px] text-muted uppercase">Tổng lượt tặng</div>
        <div class="text-lg font-black text-white" id="pfGiftCount">—</div>
      </div>
      <div class="bg-bg-deep border border-line rounded-lg p-2.5">
        <div class="text-[9px] text-muted uppercase">User chi</div>
        <div class="text-lg font-black text-pri-light tabular-nums" id="pfGiftRevenue">—</div>
      </div>
      <div class="bg-emerald-500/10 border border-emerald-500/30 rounded-lg p-2.5">
        <div class="text-[9px] text-emerald-300 uppercase font-bold">Bạn nhận được</div>
        <div class="text-lg font-black text-emerald-300 tabular-nums" id="pfGiftEarned">—</div>
      </div>
      <div class="bg-amber-500/10 border border-amber-500/30 rounded-lg p-2.5">
        <div class="text-[9px] text-amber-300 uppercase font-bold">Top fan</div>
        <div class="text-sm font-extrabold text-amber-200 truncate" id="pfGiftTopFan">—</div>
      </div>
    </div>

    <div class="overflow-x-auto border border-line rounded-lg max-h-[260px] overflow-y-auto">
      <table class="w-full text-[11px]">
        <thead class="bg-bg-deep text-muted text-[10px] uppercase sticky top-0">
          <tr>
            <th class="px-2 py-1.5 text-left">Thời gian</th>
            <th class="px-2 py-1.5 text-left">Từ user</th>
            <th class="px-2 py-1.5 text-left">Quà</th>
            <th class="px-2 py-1.5 text-right">User trả</th>
            <th class="px-2 py-1.5 text-right">Bạn nhận</th>
          </tr>
        </thead>
        <tbody id="pfGiftTbody" class="text-gray-200">
          <tr><td colspan="5" class="text-center text-muted py-4">Đang tải...</td></tr>
        </tbody>
      </table>
    </div>

    <div class="mt-2 text-[10px] text-muted">
      ℹ️ Quà ảo (X COIN) tặng từ điểm danh/vòng quay <b class="text-yellow-300">KHÔNG</b> tính vào thu nhập. Chỉ quà THẬT trả bằng VND mới quy đổi rút tiền được.
    </div>
  </div>

  <!-- Guidelines -->
  <div class="mt-5 bg-bg-soft border border-line rounded-xl p-4">
    <h3 class="text-pri-light font-bold mb-2 flex items-center gap-2"><span>💡</span> Quy tắc lên sóng</h3>
    <ul class="text-muted text-xs space-y-1.5 list-disc pl-5">
      <li>Mỗi lịch live cần admin duyệt <b class="text-white">TRƯỚC KHI</b> bạn được push OBS / mở camera</li>
      <li>Cửa sổ live: <b class="text-emerald-400">30 phút trước</b> giờ bắt đầu → <b class="text-emerald-400">3 giờ sau</b> giờ kết thúc</li>
      <li>Có thể đăng ký theo <b class="text-white">giờ tự do</b> (tiêu đề + start/end) hoặc <b class="text-white">theo trận đấu</b> (BLV bình luận)</li>
      <li>Bị admin từ chối → xem lý do trong thông báo, có thể submit lịch mới</li>
      <li>Vi phạm nội dung → bị khoá lịch, liên hệ <a href="<%= partner.telegram %>" target="_blank" class="text-pri-light">Telegram CSKH</a></li>
    </ul>
  </div>
</div>

<script>
(function(){
  function $(id){ return document.getElementById(id); }
  function escHtml(s){ return String(s||'').replace(/[<>&"]/g,function(c){return ({'<':'&lt;','>':'&gt;','&':'&amp;','"':'&quot;'})[c];}); }
  function fmtTime(ts){
    if (!ts) return '-';
    var d = new Date(ts);
    return d.getDate()+'/'+(d.getMonth()+1)+' '+String(d.getHours()).padStart(2,'0')+':'+String(d.getMinutes()).padStart(2,'0');
  }

  function loadSchedules(){
    fetch('/api/schedule/mine', { credentials:'same-origin' })
      .then(function(r){ return r.json(); })
      .then(function(data){
        if (!data || !data.ok) { $('pfStudioSchList').innerHTML = '<div class="text-center text-red-400 text-xs py-4">Lỗi tải</div>'; return; }
        var list = data.list || [];
        // Update stats
        var pending = list.filter(function(s){return s.status==='pending';}).length;
        var approved = list.filter(function(s){return s.status==='approved';}).length;
        $('pfStudioPending').textContent = pending;
        $('pfStudioApproved').textContent = approved;

        if (list.length === 0) {
          $('pfStudioSchList').innerHTML = '<div class="text-center text-muted text-xs py-8"><div class="text-3xl mb-1 opacity-60">📭</div>Chưa có lịch nào.<br><a href="/idol-studio" class="text-pri-light hover:underline mt-2 inline-block">+ Đăng ký lịch đầu tiên</a></div>';
          return;
        }
        $('pfStudioSchList').innerHTML = list.slice(0,10).map(function(s){
          var statusBadge =
            s.status === 'pending'  ? '<span class="bg-yellow-500/20 text-yellow-300 text-[10px] font-bold px-1.5 py-0.5 rounded">CHỜ</span>' :
            s.status === 'approved' ? '<span class="bg-emerald-500/20 text-emerald-300 text-[10px] font-bold px-1.5 py-0.5 rounded">✅</span>' :
                                       '<span class="bg-red-500/20 text-red-300 text-[10px] font-bold px-1.5 py-0.5 rounded">❌</span>';
          var typeIcon = s.type === 'match' ? '⚽' : '⏰';
          var rejectInfo = s.rejectReason ? '<div class="text-[10px] text-red-300 mt-0.5">⚠ '+escHtml(s.rejectReason)+'</div>' : '';
          return ''
            + '<div class="bg-bg-card border border-line rounded-lg p-2.5">'
            +   '<div class="flex items-center justify-between mb-1">'
            +     '<div class="flex items-center gap-1.5 min-w-0">'
            +       '<span>'+typeIcon+'</span>'
            +       '<span class="text-white text-xs font-bold truncate">'+escHtml(s.title)+'</span>'
            +     '</div>'
            +     statusBadge
            +   '</div>'
            +   '<div class="text-[11px] text-gray-300">⏰ '+fmtTime(s.startTime)+' → '+fmtTime(s.endTime)+'</div>'
            +   rejectInfo
            + '</div>';
        }).join('');
      })
      .catch(function(){ $('pfStudioSchList').innerHTML = '<div class="text-center text-red-400 text-xs py-4">Lỗi kết nối</div>'; });
  }

  function loadNotifications(){
    fetch('/api/schedule/notifications', { credentials:'same-origin' })
      .then(function(r){ return r.json(); })
      .then(function(data){
        if (!data || !data.ok) { $('pfStudioNotifList').innerHTML = '<div class="text-center text-red-400 text-xs py-4">Lỗi tải</div>'; return; }
        $('pfStudioNotif').textContent = data.unread || 0;
        var list = data.list || [];
        if (list.length === 0) {
          $('pfStudioNotifList').innerHTML = '<div class="text-center text-muted text-xs py-8"><div class="text-3xl mb-1 opacity-60">🔕</div>Chưa có thông báo nào</div>';
          return;
        }
        $('pfStudioNotifList').innerHTML = list.map(function(n){
          var unreadCls = n.read ? '' : 'bg-pri/5 border-pri/30';
          var dotCls = n.read ? '' : '<span class="w-1.5 h-1.5 bg-pri rounded-full shrink-0 mt-1.5"></span>';
          var icon = n.type === 'schedule-approved' ? '✅' : (n.type === 'schedule-rejected' ? '❌' : '🔔');
          var time = '';
          var diff = Date.now() - n.createdAt;
          if (diff < 60000) time = 'vừa xong';
          else if (diff < 3600000) time = Math.floor(diff/60000) + ' phút trước';
          else if (diff < 86400000) time = Math.floor(diff/3600000) + ' giờ trước';
          else time = Math.floor(diff/86400000) + ' ngày trước';

          return ''
            + '<div class="bg-bg-card border border-line rounded-lg p-2.5 ' + unreadCls + '" onclick="pfStudioMarkRead(\''+n.id+'\')">'
            +   '<div class="flex items-start gap-2">'
            +     '<span class="text-base">' + icon + '</span>'
            +     '<div class="flex-1 min-w-0">'
            +       '<div class="font-bold text-white text-xs leading-tight">'+escHtml(n.title)+'</div>'
            +       '<div class="text-[11px] text-gray-300 mt-0.5">'+escHtml(n.body)+'</div>'
            +       '<div class="text-[9px] text-muted mt-1">'+time+'</div>'
            +     '</div>'
            +     dotCls
            +   '</div>'
            + '</div>';
        }).join('');
      })
      .catch(function(){ $('pfStudioNotifList').innerHTML = '<div class="text-center text-red-400 text-xs py-4">Lỗi kết nối</div>'; });
  }

  window.pfStudioMarkRead = function(id){
    fetch('/api/schedule/notifications/'+id+'/read', { method:'POST', credentials:'same-origin' })
      .then(function(){ loadNotifications(); });
  };

  window.pfStudioMarkAllRead = function(){
    if (!confirm('Đánh dấu tất cả đã đọc?')) return;
    fetch('/api/schedule/notifications', { credentials:'same-origin' })
      .then(function(r){ return r.json(); })
      .then(function(data){
        var unreads = (data.list||[]).filter(function(n){ return !n.read; });
        var promises = unreads.map(function(n){
          return fetch('/api/schedule/notifications/'+n.id+'/read', { method:'POST', credentials:'same-origin' });
        });
        Promise.all(promises).then(function(){ loadNotifications(); });
      });
  };

  // ===== LOAD MY SESSIONS =====
  function fmt(ts){ return ts ? new Date(ts).toLocaleString('vi-VN',{day:'2-digit',month:'2-digit',hour:'2-digit',minute:'2-digit'}) : '—'; }
  function dur(ms){
    if (!ms || ms < 0) return '—';
    var s = Math.floor(ms/1000);
    var h = Math.floor(s/3600), m = Math.floor((s%3600)/60);
    return h + 'h ' + String(m).padStart(2,'0') + 'm';
  }
  function vnd(n){ return (n||0).toLocaleString('vi-VN') + 'đ'; }

  function loadSessions(){
    fetch('/api/sessions/mine', { credentials:'same-origin' })
      .then(function(r){ return r.json(); })
      .then(function(data){
        if (!data || !data.ok) { $('pfMySessTbody').innerHTML = '<tr><td colspan="6" class="text-center text-red-400 py-4">Lỗi tải</td></tr>'; return; }
        var st = data.stats || {};
        $('pfMyTotalSess').textContent = st.totalSessions || 0;
        $('pfMyTotalHours').textContent = (st.totalHours || 0) + 'h';
        $('pfMyEarn').textContent = vnd(st.totalEarning);
        $('pfMyUnpaid').textContent = vnd(st.unpaidAmount);

        var list = data.list || [];
        if (list.length === 0) {
          $('pfMySessTbody').innerHTML = '<tr><td colspan="6" class="text-center text-muted py-6">Chưa có phiên live nào. Hãy lên sóng để bắt đầu!</td></tr>';
          return;
        }
        $('pfMySessTbody').innerHTML = list.map(function(s){
          var statusBadge = !s.endTime
            ? '<span class="bg-emerald-500/20 text-emerald-300 text-[9px] font-bold px-1.5 py-0.5 rounded animate-pulse">🔴 LIVE</span>'
            : (s.paid
              ? '<span class="bg-emerald-500/20 text-emerald-300 text-[9px] font-bold px-1.5 py-0.5 rounded">✓ ĐÃ NHẬN</span>'
              : '<span class="bg-yellow-500/20 text-yellow-300 text-[9px] font-bold px-1.5 py-0.5 rounded">⏳ CHỜ</span>');
          var matchInfo = s.matchTitle
            ? '<div class="text-[10px] text-pri-light truncate max-w-[140px]" title="'+escHtml(s.matchTitle)+'">⚽ '+escHtml(s.matchTitle.slice(0,30))+'</div>'
            : '<span class="text-[10px] text-muted">⏰ Tự do</span>';
          return ''
            + '<tr class="border-b border-line/40">'
            +   '<td class="px-2 py-1.5 tabular-nums">'+fmt(s.startTime)+'</td>'
            +   '<td class="px-2 py-1.5 tabular-nums">'+fmt(s.endTime)+'</td>'
            +   '<td class="px-2 py-1.5 text-center font-bold text-pri-light">'+dur(s.duration)+'</td>'
            +   '<td class="px-2 py-1.5">'+matchInfo+'</td>'
            +   '<td class="px-2 py-1.5 text-right font-extrabold text-gold tabular-nums">'+vnd(s.paymentAmount)+'</td>'
            +   '<td class="px-2 py-1.5 text-center">'+statusBadge+'</td>'
            + '</tr>';
        }).join('');
      })
      .catch(function(){ $('pfMySessTbody').innerHTML = '<tr><td colspan="6" class="text-center text-red-400 py-4">Lỗi kết nối</td></tr>'; });
  }

  function loadGifts(){
    fetch('/api/gifts/received', { credentials:'same-origin' })
      .then(function(r){ return r.json(); })
      .then(function(d){
        if (!d || !d.ok) { $('pfGiftTbody').innerHTML = '<tr><td colspan="5" class="text-center text-red-400 py-4">Lỗi tải</td></tr>'; return; }
        var s = d.stats || {};
        $('pfGiftCount').textContent   = s.totalTx || 0;
        $('pfGiftRevenue').textContent = vnd(s.totalVndIn);
        $('pfGiftEarned').textContent  = vnd(s.totalEarned);
        var top = (d.topDonors && d.topDonors[0]) ? d.topDonors[0] : null;
        $('pfGiftTopFan').textContent = top ? ('@' + top.user + ' (' + vnd(top.totalVnd) + ')') : '—';

        var list = d.list || [];
        if (list.length === 0) {
          $('pfGiftTbody').innerHTML = '<tr><td colspan="5" class="text-center text-muted py-4">Chưa có quà thật nào. Hãy mời fan tặng quà 💎 khi live!</td></tr>';
          return;
        }
        $('pfGiftTbody').innerHTML = list.slice(0, 50).map(function(g){
          return ''
            + '<tr class="border-b border-line/30">'
            +   '<td class="px-2 py-1.5 tabular-nums text-muted">'+fmt(g.createdAt)+'</td>'
            +   '<td class="px-2 py-1.5 font-bold text-white">@'+escHtml(g.fromUser)+'</td>'
            +   '<td class="px-2 py-1.5">'+g.giftIcon+' '+escHtml(g.giftName)+' <span class="text-muted">x'+g.qty+'</span></td>'
            +   '<td class="px-2 py-1.5 text-right text-pri-light tabular-nums">'+vnd(g.totalVnd)+'</td>'
            +   '<td class="px-2 py-1.5 text-right font-extrabold text-emerald-400 tabular-nums">+'+vnd(g.earnedVnd)+'</td>'
            + '</tr>';
        }).join('');
      })
      .catch(function(){ $('pfGiftTbody').innerHTML = '<tr><td colspan="5" class="text-center text-red-400 py-4">Lỗi kết nối</td></tr>'; });
  }

  loadSchedules();
  loadNotifications();
  loadSessions();
  loadGifts();
  // Auto refresh mỗi 20s
  setInterval(function(){ loadSchedules(); loadNotifications(); loadSessions(); loadGifts(); }, 20000);
