<% list.forEach(function(m){
  var sportIcon = m.sport==='Soccer'?'&#9917;':m.sport==='Basketball'?'&#127936;':m.sport==='Tennis'?'&#127934;':m.sport==='Volleyball'?'&#127952;':'&#127918;';
  var fmtDate=''; try { fmtDate = m.date ? new Date(m.date).toLocaleDateString('vi-VN',{day:'2-digit',month:'2-digit'}) : ''; } catch(e){}
  var viewers = ((m.id?Number(String(m.id).slice(-3)):100) * 7 + 1200);
  // 🏆 Ảnh nền giải đấu (admin set qua /admin/league-bg)
  var _bgs = (typeof leagueBgs !== 'undefined' && leagueBgs) ? leagueBgs : {};
  // 🔍 Fuzzy match: lower + trim + bỏ dấu chấm/khoảng thừa để khớp khi
  //    API trả "1. Lyga" mà admin upload "1 Lyga" (hoặc ngược lại)
  function _normLg(s){ return String(s||'').toLowerCase().replace(/\./g,'').replace(/\s+/g,' ').trim(); }
  var leagueBg = '';
  if (m.league) {
    // 1) Exact match (nhanh nhất)
    if (_bgs[m.league]) leagueBg = _bgs[m.league];
    else {
      // 2) Normalized match — duyệt toàn bộ keys của _bgs
      var _target = _normLg(m.league);
      for (var _k in _bgs) {
        if (_normLg(_k) === _target) { leagueBg = _bgs[_k]; break; }
      }
    }
  }
%>
<a href="/live/<%= m.slug || m.id %>" class="group bg-bg-card border border-line rounded-xl overflow-hidden transition-all hover:-translate-y-1 hover:border-pri hover:shadow-pri flex flex-col">
  <div class="relative aspect-video bg-gradient-to-br from-[#1a2030] to-bg overflow-hidden flex items-center justify-center">
    <% if (leagueBg) { %>
      <!-- Ảnh nền giải đấu (admin set) -->
      <img src="<%= leagueBg %>" loading="lazy" alt="<%= m.league %>" class="absolute inset-0 w-full h-full object-cover" onerror="this.style.display='none'">
      <!-- Lớp phủ tối để text/logo team nổi bật -->
      <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/40 to-black/55"></div>
    <% } else if (m.poster) { %>
      <img src="<%= m.poster %>" loading="lazy" alt="" class="absolute inset-0 w-full h-full object-cover opacity-50" onerror="this.style.display='none'">
    <% } %>
    <% if (m.status==='live') { %>
      <span class="absolute top-2 left-2 z-10 bg-live text-white text-[10px] font-extrabold px-2 py-0.5 rounded flex items-center gap-1"><span class="w-1.5 h-1.5 bg-white rounded-full animate-pulse-live"></span>LIVE</span>
    <% } else if (m.status==='finished') { %>
      <span class="absolute top-2 left-2 z-10 bg-black/70 text-white text-[10px] font-extrabold px-2 py-0.5 rounded">FT</span>
    <% } else { %>
      <span class="absolute top-2 left-2 z-10 bg-gradient-to-br from-pri-light to-pri text-white text-[10px] font-extrabold px-2 py-0.5 rounded">&#9200; <%= m.time||'' %></span>
    <% } %>
    <span class="absolute top-2 right-2 z-10 bg-black/70 text-white text-[10px] font-extrabold px-2 py-0.5 rounded flex items-center gap-1"><%- sportIcon %> <%= m.sport %></span>

    <div class="relative z-[1] flex items-center gap-3.5 p-3 text-center">
      <% if (m.homeBadge) { %>
        <div class="w-11 h-11 bg-white rounded-full p-1 shadow-md shrink-0 flex items-center justify-center"><img src="<%= m.homeBadge %>" alt="<%= m.home %>" class="w-full h-full object-contain" onerror="this.parentNode.innerHTML='&#9917;'"></div>
      <% } else { %>
        <div class="w-11 h-11 bg-bg-deep rounded-full grid place-items-center text-white font-bold shrink-0"><%= (m.home||'?')[0] %></div>
      <% } %>
      <% if (m.score) { %>
        <div class="text-3xl font-black text-white drop-shadow-lg"><%= m.score[0] %>:<%= m.score[1] %></div>
      <% } else { %>
        <div class="font-black text-gold text-sm"><%= m.time || 'VS' %><% if (fmtDate) { %><span class="block bg-pri text-white text-[11px] px-2 py-0.5 rounded mt-1"><%= fmtDate %></span><% } %></div>
      <% } %>
      <% if (m.awayBadge) { %>
        <div class="w-11 h-11 bg-white rounded-full p-1 shadow-md shrink-0 flex items-center justify-center"><img src="<%= m.awayBadge %>" alt="<%= m.away %>" class="w-full h-full object-contain" onerror="this.parentNode.innerHTML='&#9917;'"></div>
      <% } else { %>
        <div class="w-11 h-11 bg-bg-deep rounded-full grid place-items-center text-white font-bold shrink-0"><%= (m.away||'?')[0] %></div>
      <% } %>
    </div>

    <div class="absolute inset-0 z-[3] grid place-items-center bg-black/0 group-hover:bg-black/40 transition-colors">
      <span class="px-5 py-2 bg-pri text-white rounded-full font-bold text-xs opacity-0 translate-y-2 group-hover:opacity-100 group-hover:translate-y-0 transition-all"><%= m.status==='live' ? 'Vao phong' : m.status==='finished' ? 'Xem highlight' : 'Dat lich' %></span>
    </div>
  </div>
  <div class="px-3 pt-2.5 pb-3 flex flex-col gap-1.5 flex-1">
    <div class="text-[11px] text-pri-light font-bold uppercase tracking-wider flex items-center gap-1.5"><span><%- sportIcon %></span> <%= m.league %></div>
    <div class="text-[13px] font-bold text-white leading-snug line-clamp-2"><%= m.home %> <%= m.score ? m.score[0]+'-'+m.score[1] : 'vs' %> <%= m.away %></div>
    <div class="flex items-center justify-between text-[11px] text-dim mt-0.5">
      <span class="flex items-center gap-1">&#127908; <%= m.blvName || 'Đang chờ BLV' %></span>
      <% if (m.status==='live') { %>
        <span class="flex items-center gap-1 text-pri-light">&#128065; <%= viewers.toLocaleString('vi-VN') %></span>
      <% } else { %>
        <span><%= fmtDate %></span>
      <% } %>
    </div>
  </div>
</a>
<% }); %>
