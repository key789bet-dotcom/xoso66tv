<%
// Partial: Video player FLV.js cho idol/blv live room
// Cach goi: include('partials/tw-live-video-player', { streamKey: idolId })
var __sk = (typeof streamKey !== 'undefined') ? streamKey : (typeof idolId !== 'undefined' ? idolId : 'unknown');
// 🔑 ID gốc để resolve key thật đang push (OBS có thể dùng key có suffix random)
var __resolveBase = (typeof resolveBase !== 'undefined' && resolveBase) ? resolveBase : __sk;

// 🐰 BunnyCDN: nếu admin đã enable + idol có bunny_video_id → ưu tiên play HLS qua Bunny (scale 10k+ viewers)
var __bunnyHls = '';
try {
  var _bcfg   = require('../../lib/bunny-config-store');
  var _bunny  = _bcfg.get();
  var _vidId = '';
  if (typeof dbIdol !== 'undefined' && dbIdol) {
    _vidId = (dbIdol.bunny_video_id) || (dbIdol.extra && dbIdol.extra.bunny_video_id) || '';
  }
  if (!_vidId && typeof dbBlv !== 'undefined' && dbBlv) {
    _vidId = (dbBlv.bunny_video_id) || (dbBlv.extra && dbBlv.extra.bunny_video_id) || '';
  }
  if (_bunny.enabled && _bunny.cdnHostname && _vidId) {
    __bunnyHls = 'https://' + _bunny.cdnHostname + '/' + _vidId + '/playlist.m3u8';
  }
} catch (_e) { /* ignore — Bunny chưa cài/chưa cấu hình */ }
%>
<!-- VIDEO ELEMENT - autoplay muted để vượt qua chính sách autoplay browser -->
<video id="liveVideo" class="hidden absolute inset-0 w-full h-full object-contain bg-black z-[5]" playsinline autoplay muted controls></video>

<%# Quality badge OLD top-right → đã chuyển thành QUALITY BAR dưới video (xem cuối partial)
   Giữ _qBadge cho data-active button + có thể dùng JS sau %>
<% var _qBadge = (typeof dbIdol !== 'undefined' && dbIdol && dbIdol.quality) ? dbIdol.quality : '360p';
   var _qActive = _qBadge === '1080p' ? '1080p' : _qBadge === '720p' ? '720p' : _qBadge === '480p' ? '480p' : '360p'; %>

<!-- ⏱ Latency badge (live) — hiện độ trễ video so với mốc live thực -->
<span id="liveLatencyBadgeWrap" title="Độ trễ video (idol → bạn)"
  style="position:absolute; top:12px; left:12px; z-index:6; display:inline-flex; align-items:center; gap:4px; background:rgba(0,0,0,0.75); backdrop-filter:blur(4px); color:#fff; font-size:11px; font-family:'JetBrains Mono','Courier New',monospace; font-weight:700; padding:4px 10px; border-radius:6px; box-shadow:0 2px 8px rgba(0,0,0,0.4); border:1px solid rgba(255,255,255,0.1); pointer-events:none;">
  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
  <span style="color:#94a3b8; font-weight:500;">Trễ</span>
  <span id="liveLatencyBadge" style="color:#10b981; min-width:32px; text-align:right;">--</span>
</span>

<!-- Nút BẬT TIẾNG đã bỏ theo yêu cầu — user dùng nút loa trong native video controls để unmute -->

<!-- 🎬 PiP + Fullscreen buttons - CHỈ HIỆN MOBILE (< 768px), tránh trùng native controls desktop
     Vị trí top:56px = DƯỚI badge LIVE (top:12px, h:30px) tránh đè -->
