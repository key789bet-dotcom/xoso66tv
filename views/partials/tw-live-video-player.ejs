<!-- 📊 DEBUG STATS OVERLAY (mặc định ẨN — bật bằng Shift+S hoặc ?stats=1) -->
<div id="liveStatsOverlay" class="hidden absolute top-2 left-2 z-[8] text-[11px] font-mono leading-tight text-white pointer-events-none select-none"
     style="background:rgba(0,0,0,.85);padding:8px 10px;border-radius:6px;min-width:240px;border:1px solid rgba(255,210,63,.4);text-shadow:0 1px 2px rgba(0,0,0,.9);">
  <div style="font-weight:700;color:#fbbf24;margin-bottom:4px;">📊 Stream Stats</div>
  <div>URL:&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span id="ls_url" style="color:#fbbf24">⏳ checking…</span></div>
  <div>Network:&nbsp;<span id="ls_net" style="color:#10b981">—</span></div>
  <div>Speed:&nbsp;&nbsp;&nbsp;<span id="ls_speed">— Kbps</span></div>
  <div>Buffer:&nbsp;&nbsp;<span id="ls_buf">— s</span></div>
  <div>Latency:&nbsp;<span id="ls_lat">— s</span></div>
  <div>Dropped:&nbsp;<span id="ls_drop">0</span></div>
  <div>Decoded:&nbsp;<span id="ls_dec">0 fps</span></div>
  <div>Res:&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span id="ls_res">—</span></div>
  <div>Codec:&nbsp;&nbsp;&nbsp;<span id="ls_codec">—</span></div>
  <div>Player:&nbsp;&nbsp;<span id="ls_state">⏳ chưa attach</span></div>
  <div style="margin-top:4px;font-size:10px;color:#94a3b8;">Shift+S = ẩn/hiện</div>
</div>

<!-- 🎬 HLS + FLV libraries -->
<!-- HLS first (iOS Safari native + hls.js for Chromium) -->
<script src="https://cdn.jsdelivr.net/npm/hls.js@1.5.17/dist/hls.min.js"></script>
<!-- FLV.js fallback (Chromium browsers, low-latency) -->
<script src="https://cdn.jsdelivr.net/npm/flv.js@1.6.2/dist/flv.min.js"></script>
<script>
(function initLiveStream(){
  var STREAM_KEY = '<%= __sk %>';
  // 🔑 ID gốc để hỏi server key thật đang push (map idolId → key có suffix)
  var RESOLVE_ID = '<%= __resolveBase %>';
  // 🐰 BunnyCDN HLS URL (nếu admin đã enable + idol/blv có bunny_video_id)
  var BUNNY_HLS  = '<%= __bunnyHls %>';
  var USE_BUNNY  = !!BUNNY_HLS;
  // 🚀 Dùng live.xoso66tv.com (DNS-only, bypass Cloudflare 100s timeout)
  var STREAM_URL     = 'https://live.xoso66tv.com/live/' + STREAM_KEY + '.flv';
  var STREAM_URL_HLS = USE_BUNNY ? BUNNY_HLS : ('https://live.xoso66tv.com/live/' + STREAM_KEY + '.m3u8');
  // 🍎 Detect iOS Safari/macOS Safari (native HLS only, không có MSE)
  // ⚠️ canPlayType chỉ trust khi === 'probably'. Chrome desktop trả 'maybe' (experimental, buggy)
  //    → KHÔNG dùng HLS cho Chrome, dùng FLV (low latency + ổn định hơn)
  var _v = document.createElement('video');
  var HAS_NATIVE_HLS = _v.canPlayType('application/vnd.apple.mpegurl') === 'probably';
  var IS_IOS = /iPad|iPhone|iPod/.test(navigator.userAgent) || (navigator.platform === 'MacIntel' && navigator.maxTouchPoints > 1);
  var IS_SAFARI = /^((?!chrome|android|crios|fxios).)*safari/i.test(navigator.userAgent);
  // Chỉ dùng HLS khi THỰC SỰ là Safari/iOS (không phải Chrome trên Mac có experimental HLS)
  HAS_NATIVE_HLS = HAS_NATIVE_HLS && (IS_IOS || IS_SAFARI);
  // 🐰 Bunny BẮT BUỘC dùng HLS (Bunny không phát FLV). iOS cũng BUỘC HLS. Khác → ưu tiên FLV (low-latency hơn HLS)
  var USE_HLS = USE_BUNNY || IS_IOS || HAS_NATIVE_HLS;
  var CHECK_URL = USE_HLS ? STREAM_URL_HLS : STREAM_URL;
  if (USE_BUNNY) console.log('[LIVE] 🐰 Using BunnyCDN HLS:', BUNNY_HLS);
  var POLL_INTERVAL = 8000;
  var video, flvPlayer, hlsPlayer, isPlaying = false;
  console.log('[LIVE] mode=' + (USE_HLS ? 'HLS' : 'FLV') + ', native HLS=' + HAS_NATIVE_HLS + ', iOS=' + IS_IOS);

  // ═══════════════════════════════════════════════════════════════
  // 🔑 RESOLVE STREAM KEY — hỏi server key THẬT đang push
  //   OBS có thể push key có suffix (i_yennhi_2ypczk0e) → viewer chỉ biết
  //   idolId → gọi /api/live/key/:id để lấy đúng key. Fallback giữ key cũ.
  // ═══════════════════════════════════════════════════════════════
  function rebuildStreamUrls(){
    STREAM_URL     = 'https://live.xoso66tv.com/live/' + STREAM_KEY + '.flv';
    STREAM_URL_HLS = USE_BUNNY ? BUNNY_HLS : ('https://live.xoso66tv.com/live/' + STREAM_KEY + '.m3u8');
    CHECK_URL      = USE_HLS ? STREAM_URL_HLS : STREAM_URL;
  }
  function resolveStreamKey(done){
    if (USE_BUNNY) { if (done) done(); return; } // Bunny dùng video id riêng, không resolve
    var called = false;
    function finish(){ if (called) return; called = true; if (done) done(); }
    var _to = setTimeout(finish, 2500); // guard: không chặn UI quá lâu nếu API chậm
    fetch('/api/live/key/' + encodeURIComponent(RESOLVE_ID), { cache:'no-store' })
      .then(function(r){ return r.ok ? r.json() : null; })
      .then(function(j){
        if (j && j.key && j.key !== STREAM_KEY) {
          console.log('[LIVE] 🔑 Resolved key:', STREAM_KEY, '→', j.key);
          STREAM_KEY = j.key;
          rebuildStreamUrls();
        }
        clearTimeout(_to); finish();
      })
      .catch(function(){ clearTimeout(_to); finish(); }); // lỗi → giữ key cũ
  }

  /* ═══════════════════════════════════════════════════════════════
     🎬 Mục 16: PICTURE-IN-PICTURE
     ─────────────────────────────────────────────────────────────── */
  (function initPiP(){
    var pipBtn = document.getElementById('livePipBtn');
    if (!pipBtn) return;
    var v = document.getElementById('liveVideo');
    if (!v) return;
    // Detect support
    //   - Chrome/Edge/Firefox: document.pictureInPictureEnabled + video.requestPictureInPicture()
    //   - iOS Safari:          video.webkitSetPresentationMode('picture-in-picture')
    var STANDARD = ('pictureInPictureEnabled' in document) && document.pictureInPictureEnabled;
    var WEBKIT = typeof v.webkitSetPresentationMode === 'function' &&
                 typeof v.webkitSupportsPresentationMode === 'function' &&
                 v.webkitSupportsPresentationMode('picture-in-picture');
    if (!STANDARD && !WEBKIT) {
      console.log('[PIP] Browser KHÔNG support — ẩn nút');
      pipBtn.style.display = 'none';
      return;
    }
    // Show button (chỉ khi video có stream) — chỉ trên MOBILE (< 768px), desktop dùng native controls
    function isMobileVp(){ return window.innerWidth < 768; }
    function showPipBtn(){ if (isMobileVp()) pipBtn.style.display = 'inline-flex'; }
    function hidePipBtn(){ pipBtn.style.display = 'none'; }
    // Hook vào event 'playing' của video → show button
    v.addEventListener('playing', showPipBtn);
    v.addEventListener('emptied', hidePipBtn);
    v.addEventListener('error',   hidePipBtn);
    // Click handler
    pipBtn.addEventListener('click', async function(){
      try {
        if (WEBKIT) {
          // iOS Safari
          var mode = v.webkitPresentationMode === 'picture-in-picture' ? 'inline' : 'picture-in-picture';
          v.webkitSetPresentationMode(mode);
        } else {
          // Standard API
          if (document.pictureInPictureElement === v) {
            await document.exitPictureInPicture();
          } else {
            await v.requestPictureInPicture();
          }
        }
      } catch (e) {
        console.warn('[PIP] error:', e.message || e);
      }
    });
    // Visual state khi enter/leave PiP
    v.addEventListener('enterpictureinpicture', function(){
      pipBtn.classList.add('bg-pri');
      pipBtn.classList.remove('bg-black/70');
      pipBtn.setAttribute('title', 'Đang ở chế độ Picture-in-Picture — Click để đóng');
    });
    v.addEventListener('leavepictureinpicture', function(){
      pipBtn.classList.remove('bg-pri');
      pipBtn.classList.add('bg-black/70');
      pipBtn.setAttribute('title', 'Picture-in-Picture');
    });
    console.log('[PIP] ✅ Initialized (' + (WEBKIT ? 'webkit' : 'standard') + ')');
  })();

  /* ═══════════════════════════════════════════════════════════════
     📱 FULLSCREEN LANDSCAPE (xoay ngang full màn hình - mobile)
     ─────────────────────────────────────────────────────────────── */
  (function initFs(){
    var fsBtn = document.getElementById('liveFsBtn');
    var v = document.getElementById('liveVideo');
    if (!fsBtn || !v) return;
    // Show button khi video bắt đầu play — chỉ MOBILE (< 768px), desktop dùng native fullscreen
    function isMobileFs(){ return window.innerWidth < 768; }
    function showFsBtn(){ if (isMobileFs()) fsBtn.style.display = 'inline-flex'; }
    function hideFsBtn(){ fsBtn.style.display = 'none'; }
    v.addEventListener('playing', showFsBtn);
    v.addEventListener('emptied', hideFsBtn);
    v.addEventListener('error',   hideFsBtn);

    // Click handler — enter fullscreen + lock landscape
    fsBtn.addEventListener('click', async function(){
      try {
        // 🍎 iOS Safari: dùng video native fullscreen (auto landscape)
        if (typeof v.webkitEnterFullscreen === 'function') {
          v.webkitEnterFullscreen();
          return;
        }
        // 🌐 Standard: fullscreen video element trước (audio đi cùng video)
        var target = v;
        if (target.requestFullscreen)         await target.requestFullscreen();
        else if (target.webkitRequestFullscreen)  target.webkitRequestFullscreen();
        else if (target.msRequestFullscreen)      target.msRequestFullscreen();
        // 📱 Force landscape (Android Chrome support, iOS không support orientation.lock)
        if (screen && screen.orientation && typeof screen.orientation.lock === 'function') {
          try { await screen.orientation.lock('landscape'); } catch(e) { /* desktop ignore */ }
        }
      } catch (err) {
        console.warn('[FS] error:', err && err.message);
      }
    });

    // Khi exit fullscreen → unlock orientation
    document.addEventListener('fullscreenchange', function(){
      if (!document.fullscreenElement) {
        if (screen && screen.orientation && typeof screen.orientation.unlock === 'function') {
          try { screen.orientation.unlock(); } catch(e){}
        }
      }
    });
    console.log('[FS] ✅ Initialized fullscreen-landscape button');
  })();

  function showEl(id){ var e=document.getElementById(id); if(e)e.classList.remove('hidden'); }
  function hideEl(id){ var e=document.getElementById(id); if(e)e.classList.add('hidden'); }

  // Helper: element có giữ lại không (theo id whitelist hoặc class skin-*)
  function _keepEl(el){
    var keepIds = ['liveVideo','liveUnmute','liveOffline','liveLoading','liveReconnect','liveQualityBadge','liveStatsOverlay','liveLatencyBadgeWrap','livePipBtn','liveFsBtn'];
    if (keepIds.indexOf(el.id) !== -1) return true;
    // 🎨 SKIN OVERLAY: giữ mọi element class skin-* (player-frame, logo-overlay, ...)
    if (el.className && typeof el.className === 'string' && /\bskin-/.test(el.className)) return true;
    return false;
  }
  // Ẩn TẤT CẢ placeholder con (butterfly/avatar/gradient) trong #livePlayer
  function hidePlaceholder(){
    var container = document.getElementById('livePlayer');
    if (!container) return;
    var kids = container.children;
    for (var i=0; i<kids.length; i++){
      var el = kids[i];
      if (!_keepEl(el)) {
        el.style.transition = 'opacity .3s';
        el.style.opacity = '0';
        setTimeout((function(e){ return function(){ e.style.display='none'; }; })(el), 350);
      }
    }
  }
  function showPlaceholder(){
    var container = document.getElementById('livePlayer');
    if (!container) return;
    var kids = container.children;
    for (var i=0; i<kids.length; i++){
      var el = kids[i];
      if (!_keepEl(el)) {
        el.style.display = '';
        el.style.opacity = '1';
      }
    }
  }

  function onVideoReady(){
    console.log('[LIVE] ✅ Video ready, dims=', video.videoWidth+'x'+video.videoHeight);
    showEl('liveVideo');
    hideEl('liveOffline');
    hideEl('liveLoading');
    hidePlaceholder();
    showEl('liveQualityBadge'); // Hiện badge HD/SD
    isPlaying = true;
    if (video.muted) showEl('liveUnmute');
  }

  // ═══════════════════════════════════════════════════════
  // 🍎 HLS ATTACH — iOS Safari native + hls.js fallback
  // ═══════════════════════════════════════════════════════
  function attachStreamHls(){
    video = document.getElementById('liveVideo');
    if (!video) return;
    if (hlsPlayer) try{ hlsPlayer.destroy(); hlsPlayer=null; }catch(e){}
    if (flvPlayer) try{ flvPlayer.destroy(); flvPlayer=null; }catch(e){}

    var onErr = function(){
      console.log('[LIVE] HLS error → reconnect');
      hideEl('liveVideo'); hideEl('liveLoading'); hideEl('liveOffline');
      showEl('liveReconnect');
      isPlaying = false;
      startReconnectLoop();
    };

    if (HAS_NATIVE_HLS) {
      // 🍎 iOS Safari / macOS Safari — set src trực tiếp, browser tự handle
      video.src = STREAM_URL_HLS;
      video.addEventListener('loadedmetadata', onVideoReady, { once: true });
      video.addEventListener('playing',        onVideoReady, { once: true });
      video.addEventListener('error', onErr);
      var p = video.play();
      if (p && p.catch) p.catch(function(e){
        console.log('[LIVE] Native HLS autoplay blocked:', e.message);
        showEl('liveVideo'); hidePlaceholder(); showEl('liveUnmute');
      });
      startLatencyGuard();
      startStatsLoop();
      return;
    }

    // Other browsers — dùng hls.js (Chromium, Firefox, Android)
    if (!window.Hls || !Hls.isSupported()) {
      console.warn('[LIVE] hls.js not supported, fallback FLV');
      return attachStreamFlv();
    }
    hlsPlayer = new Hls({
      lowLatencyMode: true,
      backBufferLength: 4,
      maxBufferLength: 8,
      maxMaxBufferLength: 12,
      liveSyncDuration: 3,
      liveMaxLatencyDuration: 8
    });
    hlsPlayer.loadSource(STREAM_URL_HLS);
    hlsPlayer.attachMedia(video);
    hlsPlayer.on(Hls.Events.MANIFEST_PARSED, function(){
      var p = video.play();
      if (p && p.catch) p.catch(function(){ showEl('liveUnmute'); });
    });
    hlsPlayer.on(Hls.Events.ERROR, function(_, data){
      if (data && data.fatal) onErr();
    });
    video.addEventListener('loadedmetadata', onVideoReady, { once: true });
    video.addEventListener('playing',        onVideoReady, { once: true });
    startLatencyGuard();
    startStatsLoop();
  }

  // ═══════════════════════════════════════════════════════
  // ⚡ ROUTER — chọn player phù hợp theo platform
  // ═══════════════════════════════════════════════════════
  function attachStream(){
    return USE_HLS ? attachStreamHls() : attachStreamFlv();
  }

  // ═══════════════════════════════════════════════════════
  // 🎞️ FLV ATTACH (Chromium - giữ nguyên logic cũ low-latency)
  // ═══════════════════════════════════════════════════════
  function attachStreamFlv(){
    if (!window.flvjs || !flvjs.isSupported()) { console.log('[LIVE] FLV.js not supported'); return; }
    video = document.getElementById('liveVideo');
    if (!video) return;
    if (flvPlayer) try{ flvPlayer.destroy(); }catch(e){}

    flvPlayer = flvjs.createPlayer({
      type: 'flv', url: STREAM_URL, isLive: true, hasAudio: true, hasVideo: true
    }, {
      // ⚡ Config low-latency + ÍT LAG hơn (giảm reset decoder)
      enableWorker: false,
      enableStashBuffer: false,
      stashInitialSize: 384,           // tăng từ 128 → 384: ít flush hơn, mượt hơn
      lazyLoad: false,
      fixAudioTimestampGap: true,      // bật để smooth audio (giảm pop/click)
      reuseRedirectedURL: true,
      autoCleanupSourceBuffer: true,   // tự clean MSE buffer cũ tránh memory creep
      autoCleanupMaxBackwardDuration: 12,
      autoCleanupMinBackwardDuration: 8
    });
    flvPlayer.attachMediaElement(video);
    flvPlayer.load();

    // Native video events - đáng tin cậy hơn flvjs events
    video.addEventListener('loadedmetadata', onVideoReady, { once: true });
    video.addEventListener('playing', onVideoReady, { once: true });
    video.addEventListener('canplay', function(){
      console.log('[LIVE] canplay');
      var pr = video.play();
      if (pr && pr.catch) pr.catch(function(e){ console.log('[LIVE] play() blocked:', e.message); });
    });

    var p = flvPlayer.play();
    if (p && p.catch) p.catch(function(err){
      console.log('[LIVE] Autoplay blocked:', err.message);
      // Vẫn hiện video element để user click play manually
      showEl('liveVideo'); hidePlaceholder(); showEl('liveUnmute');
    });

    // FLV error: SMART handling tránh false-positive "Đang khôi phục" lúc vừa F5 vào phòng
    var __errStreak = 0; var __lastErrAt = 0;
    flvPlayer.on(flvjs.Events.ERROR, function(type, detail){
      console.log('[LIVE] FLV error:', type, detail, 'isPlaying=' + isPlaying);
      var now = Date.now();
      // Debounce: nếu error cách nhau >10s → reset streak (recent only)
      if (now - __lastErrAt > 10000) __errStreak = 0;
      __errStreak++;
      __lastErrAt = now;

      // 🟢 CASE 1: User MỚI VÀO TRANG, chưa từng play (isPlaying=false)
      //    → Đây có thể chỉ là transient error trong lúc FLV.js attach lần đầu (network slow, buffer chưa đủ)
      //    → KHÔNG show reconnect overlay (đỡ user khó chịu). Silently retry attach sau 2s.
      //    Chỉ show reconnect overlay sau 3 lần fail liên tiếp.
      if (!isPlaying && __errStreak < 3) {
        console.log('[LIVE] Silent retry attach (streak=' + __errStreak + ')');
        if (flvPlayer) try{ flvPlayer.destroy(); flvPlayer=null; }catch(e){}
        hideEl('liveReconnect'); hideEl('liveOffline');
        showEl('liveLoading');
        setTimeout(function(){ try { attachStream(); } catch(e){} }, 2000);
        return;
      }

      // 🔴 CASE 2: Đã từng play THẬT (isPlaying=true) → stream gián đoạn → show "Đang khôi phục"
      // 🔴 CASE 3: Mới vào trang nhưng đã fail 3 lần → coi như offline thật
      hideEl('liveVideo'); hideEl('liveLoading'); hideEl('liveOffline');
      showEl('liveReconnect');
      if (flvPlayer) try{ flvPlayer.destroy(); flvPlayer=null; }catch(e){}
      isPlaying = false;
      startReconnectLoop();
    });
    flvPlayer.on(flvjs.Events.MEDIA_INFO, function(info){
      console.log('[LIVE] MEDIA_INFO:', info && info.mimeType);
      try {
        var _r = document.getElementById('ls_res');
        var _c = document.getElementById('ls_codec');
        if (_r && info) _r.textContent = (info.width||'?')+'x'+(info.height||'?')+' @ '+(info.fps||info.frameRate||'?')+'fps';
        if (_c && info) _c.textContent = (info.videoCodec||info.mimeType||'').replace('video/','');
      } catch(e){}
      onVideoReady();
    });

    // 📊 STATISTICS_INFO — cập nhật stats overlay
    flvPlayer.on(flvjs.Events.STATISTICS_INFO, function(stats){
      __lastStats = stats || {};
    });

    // ⚡ Custom seek-to-live: tránh latency drift sau khi viewer lag
    // FLV.js built-in liveBufferLatencyChasing bị bug remove negative range → tự code thay thế
    startLatencyGuard();
    startStatsLoop();
  }

  // ═══════════════════════════════════════════════════════════
  // 📊 DEBUG STATS LOOP — update mỗi 1s (chạy NGAY từ đầu)
  // ═══════════════════════════════════════════════════════════
  var __lastStats = {};
  var __lastBytes = 0, __lastBytesTime = 0;
  var __statsLoopId = null;
  var __urlCheckCount = 0;
  function startStatsLoop(){
    if (__statsLoopId) clearInterval(__statsLoopId);
    var overlay = document.getElementById('liveStatsOverlay');
    if (!overlay) return;
    var $ = function(id){ return document.getElementById(id); };

    // Check stream URL status mỗi 3s
    function checkStreamUrl(){
      var elU = $('ls_url');
      if (!elU) return;
      fetch(CHECK_URL, { method:'HEAD', cache:'no-store' })
        .then(function(r){
          if (r.ok) {
            elU.innerHTML = '<span style="color:#10b981">✅ '+r.status+' OK</span>';
          } else {
            elU.innerHTML = '<span style="color:#ef4444">❌ HTTP '+r.status+'</span> (OBS chưa push?)';
          }
        })
        .catch(function(e){
          elU.innerHTML = '<span style="color:#ef4444">❌ network err</span>';
        });
    }
    checkStreamUrl();

    __statsLoopId = setInterval(function(){
      // ⏭️ Mặc định ẨN cho production — chỉ update DOM khi overlay đang hiện
      if (overlay.classList.contains('hidden')) return;

      // Update Network info ngay cả khi chưa attach stream
      try {
        var conn = navigator.connection || navigator.mozConnection || navigator.webkitConnection;
        if (conn) {
          var netStr = (conn.effectiveType || '?').toUpperCase() + ' · ' +
                       (conn.downlink ? conn.downlink.toFixed(1)+'Mbps' : '?');
          $('ls_net').textContent = netStr;
          $('ls_net').style.color = conn.effectiveType === '4g' ? '#10b981' :
                                    conn.effectiveType === '3g' ? '#fbbf24' : '#ef4444';
        } else {
          $('ls_net').textContent = 'unknown (browser cũ)';
        }
      } catch(e){}

      // Recheck URL mỗi 3s
      __urlCheckCount++;
      if (__urlCheckCount % 3 === 0) checkStreamUrl();

      // Nếu chưa attach stream → state = chưa attach, không update phần stream
      if (!video || !flvPlayer) {
        $('ls_state').innerHTML = '<span style="color:#fbbf24">⏳ chưa attach (stream offline?)</span>';
        return;
      }

      try {
        var s = __lastStats || {};

        // Speed (Kbps)
        if (s.speed !== undefined) {
          $('ls_speed').textContent = (s.speed * 8).toFixed(0) + ' Kbps';
        }

        // Buffer
        var bufStr = '—';
        var drift = 0;
        if (video.buffered && video.buffered.length) {
          var bEnd = video.buffered.end(video.buffered.length-1);
          drift = Math.max(0, bEnd - video.currentTime);
          bufStr = drift.toFixed(2) + ' s';
        }
        $('ls_buf').textContent = bufStr;

        var latColor = drift < 4 ? '#10b981' : drift < 8 ? '#fbbf24' : '#ef4444';
        $('ls_lat').innerHTML = '<span style="color:'+latColor+'">'+drift.toFixed(2)+' s</span>';

        // Dropped frames + decoded fps
        var q = (video.getVideoPlaybackQuality) ? video.getVideoPlaybackQuality() : {};
        var drop = q.droppedVideoFrames || 0;
        var total = q.totalVideoFrames || 0;
        var dropColor = drop === 0 ? '#10b981' : (drop/Math.max(total,1) > 0.05 ? '#ef4444' : '#fbbf24');
        $('ls_drop').innerHTML = '<span style="color:'+dropColor+'">'+drop+' / '+total+'</span>';

        if (!window.__lastDecCount) window.__lastDecCount = total;
        var fps = total - window.__lastDecCount;
        window.__lastDecCount = total;
        $('ls_dec').textContent = fps + ' fps';

        if (video.videoWidth) {
          $('ls_res').textContent = video.videoWidth+'x'+video.videoHeight;
        }

        var state = '—';
        if (video.paused) state = '<span style="color:#fbbf24">⏸ paused</span>';
        else if (video.readyState >= 3) state = '<span style="color:#10b981">▶ playing</span>';
        else state = '<span style="color:#fbbf24">⏳ buffering</span>';
        $('ls_state').innerHTML = state;
      } catch(e) {
        console.warn('[LIVE-STATS]', e.message);
      }
    }, 1000);
  }

  // Toggle stats overlay: mặc định ẨN (production) — bật bằng ?stats=1 hoặc Shift+S
  function initStatsToggle(){
    var overlay = document.getElementById('liveStatsOverlay');
    if (!overlay) return;
    // Mặc định ẨN cho user thường — chỉ bật khi dev cần debug
    try {
      var qs = new URLSearchParams(location.search);
      if (qs.get('stats') === '1') overlay.classList.remove('hidden');
    } catch(e){}
    // Restore previous state (admin/dev đã bật trước đó)
    try {
      if (localStorage.getItem('liveStatsShown') === '1') overlay.classList.remove('hidden');
    } catch(_){}
    // Shift+S = toggle (giữ cho admin/dev)
    document.addEventListener('keydown', function(e){
      if (e.shiftKey && (e.key === 'S' || e.key === 's')) {
        overlay.classList.toggle('hidden');
        try { localStorage.setItem('liveStatsShown', overlay.classList.contains('hidden') ? '0' : '1'); } catch(_) {}
      }
    });
  }

  // Stop previous guard interval khi destroy/reload
  var __latencyGuardId = null;
  var __latencyStatId  = null;
  function startLatencyGuard(){
    if (__latencyGuardId) clearInterval(__latencyGuardId);
    if (__latencyStatId)  clearInterval(__latencyStatId);

    // 1️⃣ Seek về live — chỉ khi drift QUÁ CAO (>10s), playbackRate trick khi drift 4-10s
    //    Cách playbackRate mượt hơn seek (không giật, không hard reset decoder)
    __latencyGuardId = setInterval(function(){
      if (!video || video.paused || video.readyState < 2) return;
      var b = video.buffered;
      if (!b || b.length === 0) return;
      var bufferEnd = b.end(b.length - 1);
      var drift = bufferEnd - video.currentTime;
      if (drift > 10) {
        // Drift quá lớn → HARD seek (không có cách khác, đành chịu giật 1 lần)
        var target = bufferEnd - 1.5;
        console.log('[LIVE] ⚡ HARD seek drift=' + drift.toFixed(1) + 's → target=' + target.toFixed(1));
        try { video.currentTime = target; video.playbackRate = 1.0; } catch(e){}
      } else if (drift > 4) {
        // Drift trung bình → tăng playbackRate nhẹ (1.06x) để catchup mượt, không giật
        if (video.playbackRate < 1.05) {
          video.playbackRate = 1.06;
          console.log('[LIVE] ⏩ Soft catchup playbackRate=1.06 (drift=' + drift.toFixed(1) + 's)');
        }
      } else if (drift < 2.5) {
        // Đã catch up → về tốc độ bình thường
        if (video.playbackRate > 1.0) {
          video.playbackRate = 1.0;
        }
      }
    }, 8000); // check mỗi 8s (giảm tần suất từ 5s → ít can thiệp hơn)

    // 2️⃣ Update latency badge realtime mỗi 1s (cho user thấy độ trễ thật)
    var badge = document.getElementById('liveLatencyBadge');
    if (badge) {
      __latencyStatId = setInterval(function(){
        if (!video || video.paused || video.readyState < 2) { badge.textContent = '--'; return; }
        var b = video.buffered;
        if (!b || b.length === 0) { badge.textContent = '--'; return; }
        var d = b.end(b.length - 1) - video.currentTime;
        badge.textContent = d.toFixed(1) + 's';
        badge.style.color = d < 3 ? '#10b981' : d < 6 ? '#facc15' : '#ef4444';
      }, 1000);
    }
  }

  // Đếm lần check fail liên tiếp khi CHƯA từng play (để decide show offline)
  var __initialFailCount = 0;

  function checkStream(){
    fetch(STREAM_URL, { method:'HEAD', cache:'no-store' })
      .then(function(r){
        if (r.ok) {
          __initialFailCount = 0;
          if (!isPlaying) {
            // Stream sống lại / hoặc lần đầu thấy có stream → attach
            hideEl('liveOffline'); hideEl('liveReconnect');
            showEl('liveLoading');
            stopReconnectLoop();
            setTimeout(attachStream, 500);
          }
        } else {
          // !r.ok = stream không có
          if (isPlaying) {
            // Đang play mà mất stream → reconnect overlay
            if (flvPlayer) try{ flvPlayer.destroy(); flvPlayer=null; }catch(e){}
            hideEl('liveVideo'); hideEl('liveOffline');
            showEl('liveReconnect');
            isPlaying = false;
            startReconnectLoop();
          } else {
            // Chưa từng play, stream chưa lên → show offline ngay sau 2 lần fail (16s)
            __initialFailCount++;
            if (__initialFailCount >= 2 && __reconnectCount === 0) {
              hideEl('liveVideo'); hideEl('liveReconnect');
              showEl('liveOffline');
              showPlaceholder();
            }
          }
        }
      })
      .catch(function(){
        if (isPlaying) {
          if (flvPlayer) try{ flvPlayer.destroy(); flvPlayer=null; }catch(e){}
          hideEl('liveVideo');
          showEl('liveReconnect');
          isPlaying = false;
          startReconnectLoop();
        }
      });
  }

  // 🔄 RECONNECT LOOP - retry 20 lần × 3s = 60s, sau đó mới giả định offline
  var __reconnectId = null;
  var __reconnectCount = 0;
  function startReconnectLoop(){
    if (__reconnectId) return;
    __reconnectCount = 0;
    var countEl = document.getElementById('liveRetryCount');
    __reconnectId = setInterval(function(){
      __reconnectCount++;
      if (countEl) countEl.textContent = __reconnectCount;
      resolveStreamKey(); // 🔑 cập nhật key nếu idol restart OBS với key mới (tick sau dùng key mới)
      // Check stream còn sống không
      fetch(CHECK_URL, { method:'HEAD', cache:'no-store' })
        .then(function(r){
          if (r.ok) {
            console.log('[LIVE] ✅ Stream hồi phục sau', __reconnectCount, 'lần thử');
            hideEl('liveReconnect');
            showEl('liveLoading');
            stopReconnectLoop();
            setTimeout(attachStream, 500);
          } else if (__reconnectCount >= 20) {
            // Sau 60s vẫn không có → coi như offline thật
            console.log('[LIVE] ❌ Hết 60s không hồi phục → offline');
            stopReconnectLoop();
            hideEl('liveReconnect');
            showEl('liveOffline');
            showPlaceholder();
          }
        })
        .catch(function(){
          if (__reconnectCount >= 20) {
            stopReconnectLoop();
            hideEl('liveReconnect');
            showEl('liveOffline');
            showPlaceholder();
          }
        });
    }, 3000);
  }
  function stopReconnectLoop(){
    if (__reconnectId) { clearInterval(__reconnectId); __reconnectId = null; }
    __reconnectCount = 0;
  }

  // Nút Bật tiếng - bind click sau khi DOM ready
  function bindUnmute(){
    var btn = document.getElementById('liveUnmute');
    if (btn) btn.addEventListener('click', function(){
      if (video) { video.muted = false; video.volume = 1; }
      btn.classList.add('hidden');
    });
  }

  function start(){
    // Đợi library phù hợp load xong (HLS cho iOS, hls.js/FLV cho khác)
    if (USE_HLS) {
      if (!HAS_NATIVE_HLS && !window.Hls) { setTimeout(start, 300); return; }
    } else {
      if (!window.flvjs) { setTimeout(start, 300); return; }
    }
    bindUnmute();
    initStatsToggle();
    startStatsLoop(); // 🚀 Start stats loop NGAY, không chờ attach
    resolveStreamKey(function(){   // 🔑 lấy key thật đang push trước khi check/attach
      checkStream();
      setInterval(checkStream, POLL_INTERVAL);
    });
  }
  if (document.readyState !== 'loading') start();
  else document.addEventListener('DOMContentLoaded', start);
})();
</script>
