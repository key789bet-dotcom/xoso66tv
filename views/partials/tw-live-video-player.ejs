  /* Desktop (>=768px): ẩn hoàn toàn 2 nút custom — dùng native controls (đã có fullscreen + PiP qua menu ⋮) */
  @media (min-width: 768px) {
    .live-mobile-ctrl { display: none !important; }
  }
</style>

