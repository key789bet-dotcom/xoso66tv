<%
// Partial: Video player FLV.js cho idol/blv live room
// Cach goi: include('partials/tw-live-video-player', { streamKey: idolId })
var __sk = (typeof streamKey !== 'undefined') ? streamKey : (typeof idolId !== 'undefined' ? idolId : 'unknown');
%>
<!-- VIDEO ELEMENT - autoplay muted để vượt qua chính sách autoplay browser -->
<video id="liveVideo" class="hidden absolute inset-0 w-full h-full object-contain bg-black z-[5]" playsinline autoplay muted controls></video>

<!-- Quality badge (HD/SD - hiện khi stream live) -->
<% var _qBadge = (typeof dbIdol !== 'undefined' && dbIdol && dbIdol.quality) ? dbIdol.quality : null;
   var _qLabel = _qBadge === '1080p' ? 'FULL HD' : _qBadge === '720p' ? 'HD' : _qBadge === '480p' ? 'SD' : _qBadge === '360p' ? 'LOW' : '';
   var _qColor = _qBadge === '1080p' ? '#10b981' : _qBadge === '720p' ? '#3b82f6' : _qBadge === '480p' ? '#f59e0b' : '#ef4444';
%>
<% if (_qBadge) { %>
<span id="liveQualityBadge" class="hidden absolute top-3 right-16 z-[6] text-white text-[10px] font-extrabold px-2 py-1 rounded shadow-lg flex items-center gap-1" style="background:<%= _qColor %>">
  <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
  <%= _qLabel %> · <%= _qBadge %>
</span>
<% } %>

<!-- Nút bật tiếng (cần user click vì muted autoplay) -->
<button id="liveUnmute" class="hidden absolute bottom-20 left-4 z-[6] bg-pri text-white px-4 py-2 rounded-lg shadow-2xl font-bold text-sm hover:scale-110 transition animate-pulse" type="button">🔊 BẬT TIẾNG</button>

<!-- Status overlay "Idol chưa lên sóng" -->
<div id="liveOffline" class="hidden absolute inset-0 z-[3] grid place-items-center bg-black/60 backdrop-blur-sm">
  <div class="text-center text-white px-4">
    <div class="text-5xl mb-2">📵</div>
    <div class="text-lg font-extrabold mb-1">Chưa lên sóng</div>
    <div class="text-xs text-gray-300">Quay lại sau hoặc theo dõi để được thông báo</div>
  </div>
</div>

<!-- 🔄 RECONNECT overlay - hiện khi OBS ngắt tạm thời -->
<div id="liveReconnect" class="hidden absolute inset-0 z-[4] grid place-items-center bg-black/75 backdrop-blur">
  <div class="text-center text-white px-4 max-w-xs">
    <div class="relative mx-auto w-16 h-16 mb-3">
      <div class="absolute inset-0 border-4 border-pri/30 rounded-full"></div>
      <div class="absolute inset-0 border-4 border-pri border-t-transparent rounded-full animate-spin"></div>
      <div class="absolute inset-0 grid place-items-center text-2xl">📡</div>
    </div>
    <div class="text-lg font-extrabold mb-1 text-pri-light">Đang khôi phục stream...</div>
    <div class="text-xs text-gray-300 mb-1">Tín hiệu tạm gián đoạn, đang tự động kết nối lại</div>
    <div class="text-[10px] text-muted">Lần thử: <span id="liveRetryCount">1</span>/20</div>
  </div>
</div>

<!-- Loading spinner -->
<div id="liveLoading" class="hidden absolute inset-0 z-[3] grid place-items-center bg-black/40">
  <div class="w-12 h-12 border-4 border-pri border-t-transparent rounded-full animate-spin"></div>
</div>

<!-- 📊 DEBUG STATS OVERLAY (mặc định HIỆN — ẩn bằng Shift+S hoặc ?stats=0) -->
<div id="liveStatsOverlay" class="absolute top-2 left-2 z-[8] text-[11px] font-mono leading-tight text-white pointer-events-none select-none"
     style="background:rgba(0,0,0,.78);padding:8px 10px;border-radius:6px;min-width:220px;border:1px solid rgba(255,255,255,.15);text-shadow:0 1px 2px rgba(0,0,0,.9);">
  <div style="font-weight:700;color:#fbbf24;margin-bottom:4px;">📊 Stream Stats</div>
  <div>Network:&nbsp;<span id="ls_net" style="color:#10b981">—</span></div>
  <div>Speed:&nbsp;&nbsp;&nbsp;<span id="ls_speed">— Kbps</span></div>
  <div>Buffer:&nbsp;&nbsp;<span id="ls_buf">— s</span></div>
  <div>Latency:&nbsp;<span id="ls_lat">— s</span></div>
  <div>Dropped:&nbsp;<span id="ls_drop">0</span></div>
  <div>Decoded:&nbsp;<span id="ls_dec">0 fps</span></div>
  <div>Res:&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span id="ls_res">—</span></div>
  <div>Codec:&nbsp;&nbsp;&nbsp;<span id="ls_codec">—</span></div>
  <div>Player:&nbsp;&nbsp;<span id="ls_state">—</span></div>
  <div style="margin-top:4px;font-size:10px;color:#94a3b8;">Shift+S = ẩn/hiện</div>
</div>

<!-- FLV.js library + auto-attach to stream -->
<script src="https://cdn.jsdelivr.net/npm/flv.js@1.6.2/dist/flv.min.js"></script>
<script>
(function initLiveStream(){
  var STREAM_KEY = '<%= __sk %>';
  var STREAM_URL = 'https://xoso66tv.com/live/' + STREAM_KEY + '.flv';
  var POLL_INTERVAL = 8000;
  var video, flvPlayer, isPlaying = false;

  function showEl(id){ var e=document.getElementById(id); if(e)e.classList.remove('hidden'); }
  function hideEl(id){ var e=document.getElementById(id); if(e)e.classList.add('hidden'); }

  // Ẩn TẤT CẢ placeholder con (butterfly/avatar/gradient) trong #livePlayer
  function hidePlaceholder(){
    var container = document.getElementById('livePlayer');
    if (!container) return;
    var keepIds = ['liveVideo','liveUnmute','liveOffline','liveLoading'];
    var kids = container.children;
    for (var i=0; i<kids.length; i++){
      var el = kids[i];
      if (keepIds.indexOf(el.id) === -1) {
        el.style.transition = 'opacity .3s';
        el.style.opacity = '0';
        setTimeout((function(e){ return function(){ e.style.display='none'; }; })(el), 350);
      }
    }
  }
  function showPlaceholder(){
    var container = document.getElementById('livePlayer');
    if (!container) return;
    var keepIds = ['liveVideo','liveUnmute','liveOffline','liveLoading'];
    var kids = container.children;
    for (var i=0; i<kids.length; i++){
      var el = kids[i];
      if (keepIds.indexOf(el.id) === -1) {
        el.style.display = '';
        el.style.opacity = '1';
      }
    }
  }

  function onVideoReady(){
    console.log('[LIVE] ✅ Video ready, dims=', video.videoWidth+'x'+video.videoHeight);
    showEl('liveVideo');
    hideEl('liveOffline');
    hideEl('liveLoading');
    hidePlaceholder();
    showEl('liveQualityBadge'); // Hiện badge HD/SD
    isPlaying = true;
    if (video.muted) showEl('liveUnmute');
  }

  function attachStream(){
    if (!window.flvjs || !flvjs.isSupported()) { console.log('[LIVE] FLV.js not supported'); return; }
    video = document.getElementById('liveVideo');
    if (!video) return;
    if (flvPlayer) try{ flvPlayer.destroy(); }catch(e){}

    flvPlayer = flvjs.createPlayer({
      type: 'flv', url: STREAM_URL, isLive: true, hasAudio: true, hasVideo: true
    }, {
      // ⚡ Config TỐI THIỂU SAFE (low latency từ SRS server)
      // Bỏ liveBufferLatencyChasing vì FLV.js v1.6.2 bug remove negative range gây lag
      enableWorker: false,
      enableStashBuffer: false,
      stashInitialSize: 128,
      lazyLoad: false,
      fixAudioTimestampGap: false
    });
    flvPlayer.attachMediaElement(video);
    flvPlayer.load();

    // Native video events - đáng tin cậy hơn flvjs events
    video.addEventListener('loadedmetadata', onVideoReady, { once: true });
    video.addEventListener('playing', onVideoReady, { once: true });
    video.addEventListener('canplay', function(){
      console.log('[LIVE] canplay');
      var pr = video.play();
      if (pr && pr.catch) pr.catch(function(e){ console.log('[LIVE] play() blocked:', e.message); });
    });

    var p = flvPlayer.play();
    if (p && p.catch) p.catch(function(err){
      console.log('[LIVE] Autoplay blocked:', err.message);
      // Vẫn hiện video element để user click play manually
      showEl('liveVideo'); hidePlaceholder(); showEl('liveUnmute');
    });

    flvPlayer.on(flvjs.Events.ERROR, function(type, detail){
      console.log('[LIVE] FLV error:', type, detail);
      // 🔄 BẤT KỲ error nào → coi như stream bị mất → reconnect mode
      // (FLV.js báo nhiều type: NetworkError, MediaError, OtherError, hoặc qua loader error)
      hideEl('liveVideo');
      hideEl('liveLoading');
      hideEl('liveOffline');  // tắt overlay offline (sẽ chỉ hiện sau khi reconnect hết)
      showEl('liveReconnect');
      if (flvPlayer) try{ flvPlayer.destroy(); flvPlayer=null; }catch(e){}
      isPlaying = false;
      startReconnectLoop();
    });
    flvPlayer.on(flvjs.Events.MEDIA_INFO, function(info){
      console.log('[LIVE] MEDIA_INFO:', info && info.mimeType);
      try {
        var _r = document.getElementById('ls_res');
        var _c = document.getElementById('ls_codec');
        if (_r && info) _r.textContent = (info.width||'?')+'x'+(info.height||'?')+' @ '+(info.fps||info.frameRate||'?')+'fps';
        if (_c && info) _c.textContent = (info.videoCodec||info.mimeType||'').replace('video/','');
      } catch(e){}
      onVideoReady();
    });

    // 📊 STATISTICS_INFO — cập nhật stats overlay
    flvPlayer.on(flvjs.Events.STATISTICS_INFO, function(stats){
      __lastStats = stats || {};
    });

    // ⚡ Custom seek-to-live: tránh latency drift sau khi viewer lag
    // FLV.js built-in liveBufferLatencyChasing bị bug remove negative range → tự code thay thế
    startLatencyGuard();
    startStatsLoop();
  }

  // ═══════════════════════════════════════════════════════════
  // 📊 DEBUG STATS LOOP — update mỗi 1s
  // ═══════════════════════════════════════════════════════════
  var __lastStats = {};
  var __lastBytes = 0, __lastBytesTime = 0;
  var __statsLoopId = null;
  function startStatsLoop(){
    if (__statsLoopId) clearInterval(__statsLoopId);
    var overlay = document.getElementById('liveStatsOverlay');
    if (!overlay) return;
    var $ = function(id){ return document.getElementById(id); };
    __statsLoopId = setInterval(function(){
      if (!video || !flvPlayer) return;
      try {
        var s = __lastStats || {};
        var now = Date.now();

        // Speed (Kbps)
        var bytes = s.loaderType ? (s.speed || 0) : 0;
        // Some FLV.js versions expose speed in KB/s
        if (s.speed) {
          $('ls_speed').textContent = (s.speed * 8).toFixed(0) + ' Kbps';
        } else if (s.currentSegmentIndex !== undefined) {
          $('ls_speed').textContent = '— Kbps';
        }

        // Buffer
        var bufStr = '—';
        var drift = 0;
        if (video.buffered && video.buffered.length) {
          var bEnd = video.buffered.end(video.buffered.length-1);
          drift = Math.max(0, bEnd - video.currentTime);
          bufStr = drift.toFixed(2) + ' s';
        }
        $('ls_buf').textContent = bufStr;

        // Latency = drift + RTT approx (xấp xỉ buffer = client latency)
        var latColor = drift < 4 ? '#10b981' : drift < 8 ? '#fbbf24' : '#ef4444';
        $('ls_lat').innerHTML = '<span style="color:'+latColor+'">'+drift.toFixed(2)+' s</span>';

        // Dropped frames + decoded fps
        var q = (video.getVideoPlaybackQuality) ? video.getVideoPlaybackQuality() : {};
        var drop = q.droppedVideoFrames || 0;
        var total = q.totalVideoFrames || 0;
        var dropColor = drop === 0 ? '#10b981' : (drop/Math.max(total,1) > 0.05 ? '#ef4444' : '#fbbf24');
        $('ls_drop').innerHTML = '<span style="color:'+dropColor+'">'+drop+' / '+total+'</span>';

        // Decoded fps (delta trong 1s)
        if (!window.__lastDecCount) window.__lastDecCount = total;
        var fps = total - window.__lastDecCount;
        window.__lastDecCount = total;
        $('ls_dec').textContent = fps + ' fps';

        // Resolution (đề phòng MEDIA_INFO chưa fire)
        if (video.videoWidth) {
          $('ls_res').textContent = video.videoWidth+'x'+video.videoHeight;
        }

        // Player state
        var state = '—';
        if (video.paused) state = '⏸ paused';
        else if (video.readyState >= 3) state = '▶ playing';
        else state = '⏳ buffering';
        $('ls_state').textContent = state;

        // Network type (nếu browser support)
        var conn = navigator.connection || navigator.mozConnection || navigator.webkitConnection;
        if (conn) {
          var netStr = (conn.effectiveType || '?').toUpperCase() + ' · ' +
                       (conn.downlink ? conn.downlink.toFixed(1)+'Mbps' : '?');
          $('ls_net').textContent = netStr;
          $('ls_net').style.color = conn.effectiveType === '4g' ? '#10b981' :
                                    conn.effectiveType === '3g' ? '#fbbf24' : '#ef4444';
        } else {
          $('ls_net').textContent = 'unknown';
        }
      } catch(e) {
        console.warn('[LIVE-STATS]', e.message);
      }
    }, 1000);
  }

  // Toggle stats overlay: mặc định HIỆN, ẩn bằng ?stats=0 hoặc Shift+S
  function initStatsToggle(){
    var overlay = document.getElementById('liveStatsOverlay');
    if (!overlay) return;
    try {
      var qs = new URLSearchParams(location.search);
      if (qs.get('stats') === '0') overlay.classList.add('hidden');
    } catch(e){}
    document.addEventListener('keydown', function(e){
      if (e.shiftKey && (e.key === 'S' || e.key === 's')) {
        overlay.classList.toggle('hidden');
        try { localStorage.setItem('liveStatsShown', overlay.classList.contains('hidden') ? '0' : '1'); } catch(_) {}
      }
    });
    // Restore previous state
    try {
      if (localStorage.getItem('liveStatsShown') === '0') overlay.classList.add('hidden');
    } catch(_){}
  }

  // Stop previous guard interval khi destroy/reload
  var __latencyGuardId = null;
  function startLatencyGuard(){
    if (__latencyGuardId) clearInterval(__latencyGuardId);
    __latencyGuardId = setInterval(function(){
      if (!video || video.paused || video.readyState < 2) return;
      var b = video.buffered;
      if (!b || b.length === 0) return;
      var bufferEnd = b.end(b.length - 1);
      var drift = bufferEnd - video.currentTime;
      // Skip về live khi drift > 6s (giữ 1s buffer cho mượt)
      if (drift > 6) {
        var target = bufferEnd - 1;
        console.log('[LIVE] ⚡ Drift', drift.toFixed(1) + 's → seek về live (target=' + target.toFixed(1) + ')');
        try { video.currentTime = target; } catch(e) { console.warn('[LIVE] seek fail:', e.message); }
      }
    }, 5000);
  }

  // Đếm lần check fail liên tiếp khi CHƯA từng play (để decide show offline)
  var __initialFailCount = 0;

  function checkStream(){
    fetch(STREAM_URL, { method:'HEAD', cache:'no-store' })
      .then(function(r){
        if (r.ok) {
          __initialFailCount = 0;
          if (!isPlaying) {
            // Stream sống lại / hoặc lần đầu thấy có stream → attach
            hideEl('liveOffline'); hideEl('liveReconnect');
            showEl('liveLoading');
            stopReconnectLoop();
            setTimeout(attachStream, 500);
          }
        } else {
          // !r.ok = stream không có
          if (isPlaying) {
            // Đang play mà mất stream → reconnect overlay
            if (flvPlayer) try{ flvPlayer.destroy(); flvPlayer=null; }catch(e){}
            hideEl('liveVideo'); hideEl('liveOffline');
            showEl('liveReconnect');
            isPlaying = false;
            startReconnectLoop();
          } else {
            // Chưa từng play, stream chưa lên → show offline ngay sau 2 lần fail (16s)
            __initialFailCount++;
            if (__initialFailCount >= 2 && __reconnectCount === 0) {
              hideEl('liveVideo'); hideEl('liveReconnect');
              showEl('liveOffline');
              showPlaceholder();
            }
          }
        }
      })
      .catch(function(){
        if (isPlaying) {
          if (flvPlayer) try{ flvPlayer.destroy(); flvPlayer=null; }catch(e){}
          hideEl('liveVideo');
          showEl('liveReconnect');
          isPlaying = false;
          startReconnectLoop();
        }
      });
  }

  // 🔄 RECONNECT LOOP - retry 20 lần × 3s = 60s, sau đó mới giả định offline
  var __reconnectId = null;
  var __reconnectCount = 0;
  function startReconnectLoop(){
    if (__reconnectId) return;
    __reconnectCount = 0;
    var countEl = document.getElementById('liveRetryCount');
    __reconnectId = setInterval(function(){
      __reconnectCount++;
      if (countEl) countEl.textContent = __reconnectCount;
      // Check stream còn sống không
      fetch(STREAM_URL, { method:'HEAD', cache:'no-store' })
        .then(function(r){
          if (r.ok) {
            console.log('[LIVE] ✅ Stream hồi phục sau', __reconnectCount, 'lần thử');
            hideEl('liveReconnect');
            showEl('liveLoading');
            stopReconnectLoop();
            setTimeout(attachStream, 500);
          } else if (__reconnectCount >= 20) {
            // Sau 60s vẫn không có → coi như offline thật
            console.log('[LIVE] ❌ Hết 60s không hồi phục → offline');
            stopReconnectLoop();
            hideEl('liveReconnect');
            showEl('liveOffline');
            showPlaceholder();
          }
        })
        .catch(function(){
          if (__reconnectCount >= 20) {
            stopReconnectLoop();
            hideEl('liveReconnect');
            showEl('liveOffline');
            showPlaceholder();
          }
        });
    }, 3000);
  }
  function stopReconnectLoop(){
    if (__reconnectId) { clearInterval(__reconnectId); __reconnectId = null; }
    __reconnectCount = 0;
  }

  // Nút Bật tiếng - bind click sau khi DOM ready
  function bindUnmute(){
    var btn = document.getElementById('liveUnmute');
    if (btn) btn.addEventListener('click', function(){
      if (video) { video.muted = false; video.volume = 1; }
      btn.classList.add('hidden');
    });
  }

  function start(){
    if (!window.flvjs) { setTimeout(start, 300); return; }
    bindUnmute();
    initStatsToggle();
    checkStream();
    setInterval(checkStream, POLL_INTERVAL);
  }
  if (document.readyState !== 'loading') start();
  else document.addEventListener('DOMContentLoaded', start);
})();
</script>
