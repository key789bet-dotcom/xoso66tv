        </div>

        <!-- Top tippers -->
        <div class="px-4 pb-3">
          <h3 class="text-pri-light text-[11px] font-extrabold uppercase tracking-wider mb-2 flex items-center gap-1.5">🏆 Top tặng quà hôm nay <span class="ml-auto text-[10px] text-gold tabular-nums normal-case"><%= tipsToday.toLocaleString('vi-VN') %> 🪙</span></h3>
          <div class="space-y-1.5">
            <% ['vipFan88','iLove'+idol.name.charAt(0),'BoMy_X66'].forEach(function(name, i){ var amt = (3-i)*1500+200; %>
              <div class="flex items-center gap-2 bg-bg-soft border border-line rounded-lg p-2 text-[12px]">
                <span class="text-xl"><%= ['🥇','🥈','🥉'][i] %></span>
                <span class="flex-1 font-bold text-white truncate"><%= name %></span>
                <span class="text-gold font-extrabold tabular-nums shrink-0">🪙 <%= amt.toLocaleString('vi-VN') %></span>
              </div>
            <% }); %>
          </div>
        </div>

        <!-- Quick links to desktop sections -->
        <div class="px-4 pb-4 grid grid-cols-2 gap-2">
          <a href="/idol-live" class="bg-bg-soft border border-line hover:border-pri rounded-xl py-2.5 text-center text-white font-bold text-[12px] transition-colors flex items-center justify-center gap-1.5">
            <span class="text-lg">🏠</span><span>DS Idol</span>
          </a>
          <button onclick="mlrShowAlbum()" class="bg-bg-soft border border-line hover:border-pri rounded-xl py-2.5 text-center text-white font-bold text-[12px] transition-colors flex items-center justify-center gap-1.5 active:scale-95">
            <span class="text-lg">📷</span><span>Album & Video</span>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- ===== SWIPE PREVIEW INDICATORS (top + bottom) ===== -->
  <div id="mlrSwipeTopHint" class="hidden absolute top-0 inset-x-0 z-[28] pointer-events-none transition-all">
    <div class="bg-gradient-to-b from-black/90 to-transparent py-3 px-4 flex items-center justify-center gap-2 text-white text-xs font-bold">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="18 15 12 9 6 15"/></svg>
      <span>Tiếp tục vuốt lên:</span>
      <span class="text-2xl" id="mlrSwipeNextEmoji">💃</span>
      <span class="text-yellow-300" id="mlrSwipeNextName">Idol</span>
    </div>
  </div>
  <div id="mlrSwipeBottomHint" class="hidden absolute bottom-0 inset-x-0 z-[28] pointer-events-none transition-all">
    <div class="bg-gradient-to-t from-black/90 to-transparent py-3 px-4 flex items-center justify-center gap-2 text-white text-xs font-bold">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
      <span>Tiếp tục vuốt xuống:</span>
      <span class="text-2xl" id="mlrSwipePrevEmoji">👑</span>
      <span class="text-yellow-300" id="mlrSwipePrevName">Idol</span>
    </div>
  </div>

  <!-- ===== ROOM TRANSITION OVERLAY ===== -->
  <div id="mlrRoomTransition" class="hidden absolute inset-0 z-[40] bg-black grid place-items-center pointer-events-none">
    <div class="text-center">
      <div class="text-7xl mb-3 mlr-trans-emoji">💃</div>
      <div class="text-yellow-300 font-black text-lg" id="mlrTransName">Đang vào phòng...</div>
      <div class="mt-3 flex justify-center gap-1">
        <div class="w-2 h-2 bg-pri rounded-full animate-bounce" style="animation-delay:0s"></div>
        <div class="w-2 h-2 bg-pri rounded-full animate-bounce" style="animation-delay:.15s"></div>
        <div class="w-2 h-2 bg-pri rounded-full animate-bounce" style="animation-delay:.3s"></div>
      </div>
    </div>
  </div>

  <!-- ===== COMBO COUNTER OVERLAY (xuat hien khi tang qua lien tuc) ===== -->
  <div id="mlrComboBox" class="hidden absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-[18] pointer-events-none">
    <div class="bg-gradient-to-br from-yellow-400 via-orange-500 to-red-600 px-6 py-4 rounded-2xl shadow-2xl border-2 border-yellow-300 text-center" style="animation: mlrComboBounce .4s ease-out;">
      <div class="text-5xl font-black text-white drop-shadow-lg" id="mlrComboNum">x2</div>
      <div class="text-xs font-extrabold text-white/90 mt-0.5">COMBO</div>
    </div>
  </div>

</div>

<style>
/* Idol idle animation */
.mlr-idol-anim { animation: mlrIdolBounce 1.4s ease-in-out infinite alternate; }
@keyframes mlrIdolBounce { from { transform: translateY(0); } to { transform: translateY(-12px); } }

/* Marquee */
@keyframes mlrMarquee { 0% { transform: translateX(100%); } 100% { transform: translateX(-100%); } }

/* Chat message slide-in */
@keyframes mlrChatIn { from { opacity:0; transform: translateX(-8px); } to { opacity:1; transform: translateX(0); } }
@keyframes mlrChatOut { to { opacity: 0; transform: translateY(-4px); } }
.mlr-chat-msg { animation: mlrChatIn .25s ease-out; pointer-events: auto; }

/* Heart float up (free reaction) */
@keyframes mlrHeartFloat {
  0%   { transform: translate(0, 0) scale(0); opacity: 0; }
  10%  { transform: translate(var(--sw,0), -20px) scale(1); opacity: 1; }
  70%  { transform: translate(calc(var(--sw,0) * -1), -240px) scale(1.1); opacity: 1; }
  100% { transform: translate(var(--sw,0), -360px) scale(0.6); opacity: 0; }
}
.mlr-heart { position: absolute; bottom: 90px; right: 50px; font-size: 28px; animation: mlrHeartFloat 3.5s ease-out forwards; filter: drop-shadow(0 0 8px rgba(255,80,120,.8)); }

/* Reaction emoji float */
@keyframes mlrReactionFloat {
  0%   { transform: scale(0) rotate(-20deg); opacity: 0; }
  15%  { transform: scale(1.4) rotate(0); opacity: 1; }
  100% { transform: translateY(-280px) scale(.8) rotate(20deg); opacity: 0; }
}
.mlr-reaction { position: absolute; font-size: 36px; animation: mlrReactionFloat 2.5s ease-out forwards; pointer-events: none; }

/* Combo bounce */
@keyframes mlrComboBounce {
  0%   { transform: translate(-50%,-50%) scale(0) rotate(-15deg); opacity: 0; }
  60%  { transform: translate(-50%,-50%) scale(1.2) rotate(5deg); opacity: 1; }
  100% { transform: translate(-50%,-50%) scale(1) rotate(0); opacity: 1; }
}

/* UI hide (cinema mode) */
.mlr-ui-hidden #mlrTopBar,
.mlr-ui-hidden #mlrRightWidgets { opacity: 0; pointer-events: none; transition: opacity .3s; }

/* ============ GIFT GOAL BAR ============ */
.mlr-goal-glow { box-shadow: 0 0 12px rgba(255,180,0,.8), inset 0 -1px 0 rgba(255,255,255,.3); }
@keyframes mlrGoalShimmer { 0%,100% {filter:brightness(1)} 50% {filter:brightness(1.4)} }
#mlrGoalProgress { animation: mlrGoalShimmer 2s ease-in-out infinite; position: relative; }

/* ============ VIP ENTRY ============ */
.mlr-vip-slide { animation: mlrVipSlideAnim 5s ease-in-out forwards; }
@keyframes mlrVipSlideAnim {
  0%   { transform: translateX(120%); opacity: 0; }
  12%  { transform: translateX(0); opacity: 1; }
  20%  { transform: translateX(-8px); }
  25%  { transform: translateX(0); }
  85%  { transform: translateX(0); opacity: 1; }
  100% { transform: translateX(-120%); opacity: 0; }
}
.mlr-vip-shine {
  background: linear-gradient(120deg, transparent 30%, rgba(255,255,255,.7) 50%, transparent 70%);
  background-size: 200% 100%;
  animation: mlrVipShineMove 2.5s linear infinite;
}
@keyframes mlrVipShineMove { 0% {background-position:200% 0} 100% {background-position:-100% 0} }

/* ============ LUCKY DRAW ============ */
.mlr-lottery-pulse { animation: mlrLotteryPulse 2s ease-in-out infinite; }
@keyframes mlrLotteryPulse {
  0%,100% { transform: scale(1) rotate(0); filter: drop-shadow(0 0 4px rgba(255,180,0,.6)); }
  50%     { transform: scale(1.1) rotate(-5deg); filter: drop-shadow(0 0 12px rgba(255,180,0,1)); }
}

/* ============ PARTICLE EFFECTS ============ */
@keyframes mlrParticleFall {
  0%   { transform: translateY(-30px) translateX(0) rotate(0); opacity: 0; }
  10%  { opacity: 1; }
  90%  { opacity: 1; }
  100% { transform: translateY(110vh) translateX(var(--drift, 0px)) rotate(var(--rot, 360deg)); opacity: 0; }
}
@keyframes mlrParticleFloat {
  0%   { transform: translateY(-20px) translateX(0) scale(0); opacity: 0; }
  20%  { transform: translateY(-100px) translateX(var(--driftX,20px)) scale(1); opacity: 1; }
  100% { transform: translateY(-400px) translateX(calc(var(--driftX,20px) * 3)) scale(.6); opacity: 0; }
}
.mlr-particle { position: absolute; pointer-events: none; will-change: transform, opacity; }
.mlr-particle.fall  { animation: mlrParticleFall  linear forwards; }
.mlr-particle.float { animation: mlrParticleFloat ease-out forwards; }

/* ============ CINEMA MODE ============ */
.mlr-cinema-mode #mlrTopBar,
.mlr-cinema-mode #mlrRightWidgets,
.mlr-cinema-mode #mlrChatContainer,
.mlr-cinema-mode #mlrVipEntry,
.mlr-cinema-mode .mlr-cinema-hide {
  opacity: 0;
  pointer-events: none;
  transition: opacity .4s;
}
.mlr-cinema-mode #mlrCinemaExitHint {
  opacity: 1 !important;
  pointer-events: auto;
}
.mlr-cinema-mode #mobileLiveRoom { cursor: pointer; }
#mlrCinemaExitHint {
  position: absolute; top: 20px; left: 50%; transform: translateX(-50%);
  z-index: 30; pointer-events: none; opacity: 0;
  background: rgba(0,0,0,.7); backdrop-filter: blur(8px);
  color: white; font-size: 11px; padding: 6px 14px;
  border-radius: 999px; transition: opacity .4s;
  border: 1px solid rgba(255,255,255,.2);
}

/* ============ IDOL PROFILE MODAL ============ */
@keyframes mlrProfileSlideUp {
  from { transform: translateY(100%); }
  to   { transform: translateY(0); }
}
.mlr-profile-slide { animation: mlrProfileSlideUp .35s ease-out forwards; }
.mlr-album-slide   { animation: mlrProfileSlideUp .35s ease-out forwards; }
.mlr-profile-avatar { animation: mlrProfileAvatarPulse 2s ease-in-out infinite; }
@keyframes mlrProfileAvatarPulse {
  0%,100% { box-shadow: 0 0 24px rgba(255,122,24,.4), 0 0 60px rgba(255,122,24,.2); }
  50%     { box-shadow: 0 0 40px rgba(255,122,24,.8), 0 0 100px rgba(255,122,24,.4); }
}

/* ============ SWIPE GESTURE (chuyen phong) ============ */
#mobileLiveRoom.mlr-swiping-up { animation: mlrSwipeUpAnim .4s ease-out forwards; }
#mobileLiveRoom.mlr-swiping-down { animation: mlrSwipeDownAnim .4s ease-out forwards; }
@keyframes mlrSwipeUpAnim {
  to { transform: translateY(-100vh); opacity: 0; }
}
@keyframes mlrSwipeDownAnim {
  to { transform: translateY(100vh); opacity: 0; }
}
#mobileLiveRoom { transition: transform .15s ease-out; }
.mlr-swipe-following { will-change: transform; }
.mlr-trans-emoji { animation: mlrTransPulse 1s ease-in-out infinite alternate; }
@keyframes mlrTransPulse {
  from { transform: scale(.9); filter: drop-shadow(0 0 12px gold); }
  to   { transform: scale(1.1); filter: drop-shadow(0 0 24px gold); }
}
</style>

<script>
(function(){
  // ===== DATA =====
  var BOT_MSGS = [
    {user:'VTNT.Com', lvl:41, c:'emerald', text:'Hoan nghênh đại gia'},
    {user:'Max12',    lvl:2,  c:'pink',    text:'Đến rồi'},
    {user:'nhtky',    lvl:42, c:'emerald', text:'Hoan nghênh đại gia'},
    {user:'KingX66',  lvl:55, c:'amber',   text:'Idol xinh quá ❤️'},
    {user:'LinhT',    lvl:8,  c:'sky',     text:'Mọi người tặng quà ủng hộ nha'},
    {user:'BoMy_X66', lvl:30, c:'purple',  text:'Vừa nạp 100K coin'},
    {user:'CauBe88',  lvl:12, c:'pink',    text:'Hello idol'},
    {user:'GirlVN',   lvl:21, c:'sky',     text:'Phòng vui ghê'},
    {user:'Anh3T',    lvl:67, c:'amber',   text:'🔥🔥🔥'},
    {user:'NgocBich', lvl:5,  c:'pink',    text:'Like'}
  ];
  var COLOR_MAP = {
    emerald:{bg:'bg-emerald-500',  txt:'text-emerald-300'},
    pink:   {bg:'bg-pink-500',     txt:'text-pink-300'},
    amber:  {bg:'bg-amber-500',    txt:'text-amber-300'},
    sky:    {bg:'bg-sky-500',      txt:'text-sky-300'},
    purple: {bg:'bg-purple-500',   txt:'text-purple-300'}
  };

  function escMlr(s){ return String(s||'').replace(/[<>&"]/g, function(c){return ({'<':'&lt;','>':'&gt;','&':'&amp;','"':'&quot;'})[c];}); }

  // ===== CHAT OVERLAY (auto-fade) =====
  function pushMlrChat(user, lvl, color, text, isSystem, isGift){
    var body = document.getElementById('mlrChatBody');
    if (!body) return;
    var el = document.createElement('div');
    var cm = COLOR_MAP[color] || COLOR_MAP.sky;
    el.className = 'mlr-chat-msg backdrop-blur-sm rounded-full text-[11px] flex items-center gap-1.5 max-w-[90%] self-start pointer-events-auto';
    if (isSystem) {
      el.className += ' bg-blue-900/50 px-3 py-1.5 text-blue-200 mx-auto';
      el.innerHTML = '<span>' + escMlr(text) + '</span>';
    } else if (isGift) {
      el.className += ' bg-gradient-to-r from-yellow-500/70 to-orange-500/70 px-2 py-1.5';
      el.innerHTML = '<span class="text-yellow-200 font-bold truncate">' + escMlr(user) + '</span>'
        + '<span class="text-white">' + escMlr(text) + '</span>';
    } else {
      el.className += ' bg-black/60 px-2 py-1';
      el.innerHTML = '<span class="' + cm.bg + ' text-white text-[8.5px] font-black px-1 py-0.5 rounded shrink-0">' + lvl + '</span>'
        + '<span class="font-bold ' + cm.txt + ' truncate">' + escMlr(user) + '</span>'
        + '<span class="text-white/95 truncate">' + escMlr(text) + '</span>';
    }
    body.appendChild(el);
    while (body.children.length > 6) body.removeChild(body.firstChild);
    // Auto-fade old messages after 8s
    setTimeout(function(){
      el.style.animation = 'mlrChatOut .4s ease-out forwards';
      setTimeout(function(){ if (el.parentNode) el.remove(); }, 400);
    }, 8000);
  }

  // Seed welcome messages
  setTimeout(function(){ pushMlrChat('','','','Chào mừng đến phòng <%= idol.name %> 🎉', true); }, 400);
  setTimeout(function(){ pushMlrChat('VTNT.Com', 41, 'emerald', 'Hoan nghênh đại gia'); }, 1400);
  setTimeout(function(){ pushMlrChat('Max12', 2, 'pink', 'Đến rồi'); }, 2400);
  setTimeout(function(){ pushMlrChat('nhtky', 42, 'emerald', 'Hoan nghênh đại gia'); }, 3400);

  // Random bot chat every 4-10s
  function scheduleChat(){
    var delay = 4000 + Math.random()*6000;
    setTimeout(function(){
      var m = BOT_MSGS[Math.floor(Math.random()*BOT_MSGS.length)];
      pushMlrChat(m.user, m.lvl, m.c, m.text);
      scheduleChat();
    }, delay);
  }
  scheduleChat();

  // ===== TIMER COUNTDOWN =====
  var timerStart = Date.now();
  var timerInitial = 5*3600 + 46*60 + 27;
  setInterval(function(){
    var elapsed = Math.floor((Date.now()-timerStart)/1000);
    var total = timerInitial - elapsed;
    if (total < 0) total = 0;
    var h = Math.floor(total/3600), m = Math.floor((total%3600)/60), s = total%60;
    var t = document.getElementById('mlrTimer');
    if (t) t.textContent = (h<10?'0':'')+h+':'+(m<10?'0':'')+m+':'+(s<10?'0':'')+s;
  }, 1000);

  // ===== VIEWER COUNT FLUCTUATION =====
  setInterval(function(){
    var el = document.getElementById('mlrViewerCount');
    if (!el) return;
    var base = <%= viewers %>;
    var v = base + Math.floor((Math.random()-.5)*40);
    el.textContent = Math.max(100, v).toLocaleString('vi-VN');
  }, 8000);

  // ===== GESTURES: Double-tap = heart, tap = toggle UI =====
  var gestureLayer = document.getElementById('mlrGestureLayer');
  var lastTap = 0;
  if (gestureLayer) {
    gestureLayer.addEventListener('click', function(e){
      var now = Date.now();
      if (now - lastTap < 300) {
        // Double tap
        mlrSpawnReaction('❤️', e.clientX, e.clientY);
        lastTap = 0;
      } else {
        lastTap = now;
      }
    });
  }

  // ===== HEART / REACTION SPAWNING =====
  var reactionLayer = document.getElementById('mlrReactionLayer');
  window.mlrSendHeart = function(){
    var el = document.createElement('div');
    el.className = 'mlr-heart';
    el.textContent = ['❤️','💖','💗','💕','💝'][Math.floor(Math.random()*5)];
    el.style.setProperty('--sw', (Math.random()*60 - 30) + 'px');
    el.style.right = (40 + Math.random()*30) + 'px';
    reactionLayer.appendChild(el);
    setTimeout(function(){ el.remove(); }, 3500);
  };
  window.mlrSpawnReaction = function(emoji, x, y){
    var el = document.createElement('div');
    el.className = 'mlr-reaction';
    el.textContent = emoji;
    var rect = reactionLayer.getBoundingClientRect();
    el.style.left = ((x !== undefined ? x - rect.left : rect.width/2) - 18) + 'px';
    el.style.top  = ((y !== undefined ? y - rect.top  : rect.height/2) - 18) + 'px';
    reactionLayer.appendChild(el);
    setTimeout(function(){ el.remove(); }, 2500);
    document.getElementById('mlrReactionMenu').classList.add('hidden');
  };

  // ===== REACTION MENU =====
  window.mlrShowReactionMenu = function(e){
    var menu = document.getElementById('mlrReactionMenu');
    var rect = e.currentTarget.getBoundingClientRect();
    menu.style.right = (window.innerWidth - rect.left + 6) + 'px';
    menu.style.top = (rect.top + window.scrollY) + 'px';
    menu.classList.toggle('hidden');
  };

  // ===== QUICK GIFT BAR =====
  window.mlrToggleQuickGifts = function(){
    document.getElementById('mlrQuickGiftBar').classList.toggle('hidden');
    document.getElementById('mlrMoreMenu').classList.add('hidden');
  };
  window.mlrCloseQuickGifts = function(){ document.getElementById('mlrQuickGiftBar').classList.add('hidden'); };
  window.mlrQuickSendGift = function(icon, name, price, tier){
    var u = {};
    try { u = JSON.parse(localStorage.getItem('x66_user')||'{}'); } catch(e){}
    if (!u.username) { if (confirm('Bạn cần đăng nhập để tặng quà. Đăng nhập?')) location.href='/dang-nhap'; return; }
    var coin = typeof u.coin === 'number' ? u.coin : 79;
    if (coin < price) { alert('X COIN không đủ! Cần ' + price + ', còn ' + coin); return; }
    u.coin = coin - price;
    localStorage.setItem('x66_user', JSON.stringify(u));
    // Combo logic
    mlrCombo(icon);
    // Trigger gift animation overlay on main player + chat + log
    if (typeof window.playGiftOnPlayer === 'function') window.playGiftOnPlayer(icon, name, tier, u.username, u.fullname || u.username);
    if (typeof window.pushChatGift === 'function') window.pushChatGift(u.username, icon, name, price);
    if (typeof window.x66RecordGift === 'function') window.x66RecordGift(u.username, icon, name, price, tier);
    // Push to mobile chat overlay
    pushMlrChat(u.username, 99, 'amber', 'tặng ' + icon + ' ' + name, false, true);
  };

  // ===== COMBO COUNTER =====
  var comboCount = 0, comboTimer = null, lastComboIcon = '';
  function mlrCombo(icon){
    if (icon !== lastComboIcon) comboCount = 0;
    lastComboIcon = icon;
    comboCount++;
    var box = document.getElementById('mlrComboBox');
    var num = document.getElementById('mlrComboNum');
    if (comboCount >= 2) {
      box.classList.remove('hidden');
      num.textContent = 'x' + comboCount;
      box.querySelector('div').style.animation = 'none';
      void box.offsetWidth; // restart animation
      box.querySelector('div').style.animation = 'mlrComboBounce .4s ease-out';
    }
    clearTimeout(comboTimer);
    comboTimer = setTimeout(function(){
      box.classList.add('hidden');
      comboCount = 0;
      lastComboIcon = '';
    }, 3000);
  }

  // ===== MORE MENU =====
  window.mlrShowMoreMenu = function(){
    document.getElementById('mlrMoreMenu').classList.toggle('hidden');
    document.getElementById('mlrQuickGiftBar').classList.add('hidden');
  };
  window.mlrShare = function(){
    var url = location.href;
    var text = 'Vào xem <%= idol.name %> live ngay!';
    if (navigator.share) navigator.share({ title:text, url:url }).catch(function(){});
    else mlrCopyLink();
    document.getElementById('mlrMoreMenu').classList.add('hidden');
  };
  window.mlrCopyLink = function(){
    var url = location.href;
    if (navigator.clipboard) navigator.clipboard.writeText(url).then(function(){ alert('Đã sao chép link!'); });
    else { prompt('Sao chép link:', url); }
    document.getElementById('mlrMoreMenu').classList.add('hidden');
  };
  window.mlrReport = function(){
    if (confirm('Báo cáo phòng này vi phạm?')) alert('Cảm ơn báo cáo, admin sẽ xem xét.');
    document.getElementById('mlrMoreMenu').classList.add('hidden');
  };

  // ===== CHAT INPUT MODAL =====
  window.mlrOpenChatInput = function(){
    document.getElementById('mlrChatInputModal').classList.remove('hidden');
    setTimeout(function(){ document.getElementById('mlrChatInputField').focus(); }, 100);
  };
  window.mlrCloseChatInput = function(){ document.getElementById('mlrChatInputModal').classList.add('hidden'); };
  window.mlrSendChat = function(){
    var inp = document.getElementById('mlrChatInputField');
    if (!inp || !inp.value.trim()) return;
    var u = {};
    try { u = JSON.parse(localStorage.getItem('x66_user')||'{}'); } catch(e){}
    if (!u.username) { if (confirm('Cần đăng nhập để chat. Đăng nhập?')) location.href='/dang-nhap'; return; }
    pushMlrChat(u.username, u.level||1, 'amber', inp.value.trim());
    inp.value = '';
    mlrCloseChatInput();
  };

  // ===== FOLLOW TOGGLE =====
  var following = false;
  window.mlrToggleFollow = function(b){
    following = !following;
    b.textContent = following ? '✓' : '+';
    b.classList.toggle('bg-pri', !following);
    b.classList.toggle('bg-emerald-500', following);
    if (following) pushMlrChat('','','','Bạn đã theo dõi <%= idol.name %> ❤️', true);
  };

  // ===== MINI GAME TOGGLE =====
  var gameOpen = false, gameTimers = [];
  window.mlrToggleGameCards = function(btn){
    var cards = document.getElementById('mlrGameCards');
    var dot   = document.getElementById('mlrGameToggleDot');
    var label = document.getElementById('mlrGameToggleLabel');
    gameOpen = !gameOpen;
    if (gameOpen) {
      cards.classList.remove('hidden');
      dot.classList.remove('hidden');
      label.textContent = 'Đóng';
      btn.classList.add('ring-2','ring-yellow-300');
      refreshTaiXiu(); refreshXocDia();
      gameTimers.push(setInterval(refreshTaiXiu, 30000));
      gameTimers.push(setInterval(refreshXocDia, 25000));
      pushMlrChat('','','','Idol mở mini-game XÓC ĐĨA & TÀI XỈU 🎲', true);
    } else {
      cards.classList.add('hidden');
      dot.classList.add('hidden');
      label.textContent = 'Mở game';
      btn.classList.remove('ring-2','ring-yellow-300');
      gameTimers.forEach(clearInterval);
      gameTimers = [];
    }
  };
  function refreshTaiXiu(){
    // Random 3 dice 1-6, render qua API 3D
    var a = Math.floor(Math.random()*6)+1;
    var b = Math.floor(Math.random()*6)+1;
    var c = Math.floor(Math.random()*6)+1;
    if (typeof window.mlrSetDice === 'function'){
      window.mlrSetDice(a, b, c);
    }
    var ky = document.getElementById('mlrTaiXiuKy');
    if (ky) ky.textContent = Date.now().toString().slice(0,10);
  }
  function refreshXocDia(){
    // Random 4 đồng xu r/w, render qua API 3D
    var arr = [];
    for (var i=0;i<4;i++) arr.push(Math.random() < .5 ? 'r' : 'w');
    if (typeof window.mlrSetXocDia === 'function'){
      window.mlrSetXocDia(arr);
    }
    var ky = document.getElementById('mlrXocDiaKy');
    if (ky) ky.textContent = Date.now().toString().slice(0,8);
  }

  // ===== HOOK gift events tu gift panel chinh =====
  var originalRecord = window.x66RecordGift;
  window.x66RecordGift = function(user, icon, name, price, tier){
    if (originalRecord) originalRecord.apply(null, arguments);
    pushMlrChat(user, 99, 'amber', 'tặng ' + icon + ' ' + name, false, true);
    mlrCombo(icon);
    // Hook them: add to Gift Goal + Lottery tickets
    if (typeof addGoalProgress === 'function') addGoalProgress(price);
    if (typeof addLotteryTickets === 'function') addLotteryTickets(price);
    // Trigger romantic particle on legendary
    if (tier === 'legendary' && typeof mlrSetMood === 'function') mlrSetMood('fireworks');
    else if (tier === 'epic' && typeof mlrSetMood === 'function') mlrSetMood('party');
  };

  // ===== CLOSE MENUS ON OUTSIDE CLICK =====
  document.addEventListener('click', function(e){
    var rm = document.getElementById('mlrReactionMenu');
    var mm = document.getElementById('mlrMoreMenu');
    if (rm && !rm.contains(e.target) && !e.target.closest('[onclick*="mlrShowReactionMenu"]')) rm.classList.add('hidden');
    if (mm && !mm.contains(e.target) && !e.target.closest('[onclick*="mlrShowMoreMenu"]')) mm.classList.add('hidden');
  });

  // ============================================================
  // ===== TOP 5 PREMIUM FEATURES =================================
  // ============================================================

  // ===== 1. GIFT GOAL BAR =====
  var GOALS = [
    { name: 'Cover Hoa Nở Không Màu', target: 10000 },
    { name: 'Nhảy K-pop dance 1 phút', target: 25000 },
    { name: 'Live ăn cay siêu cay', target: 5000 },
    { name: 'Hôn gió cho top tippers', target: 50000 },
    { name: 'Mặc áo cosplay anime', target: 100000 },
    { name: 'Story Instagram đặc biệt', target: 30000 }
  ];
  var currentGoalIdx = 0, goalProgress = 0;
  function fmtCoin(n){
    if (n >= 1e6) return (n/1e6).toFixed(1) + 'M';
    if (n >= 1e3) return (n/1e3).toFixed(1) + 'K';
    return n.toLocaleString('vi-VN');
  }
  function updateGoalBar(){
    var g = GOALS[currentGoalIdx];
    var nameEl = document.getElementById('mlrGoalName');
    var curEl  = document.getElementById('mlrGoalCur');
    var tgtEl  = document.getElementById('mlrGoalTarget');
    var progEl = document.getElementById('mlrGoalProgress');
    if (!nameEl) return;
    nameEl.textContent = g.name;
    curEl.textContent  = fmtCoin(goalProgress);
    tgtEl.textContent  = fmtCoin(g.target);
    var pct = Math.min(100, (goalProgress / g.target) * 100);
    progEl.style.width = pct + '%';
  }
  window.addGoalProgress = function(amt){
    goalProgress += amt;
    updateGoalBar();
    var g = GOALS[currentGoalIdx];
    if (goalProgress >= g.target) {
      pushMlrChat('','','','🎉 ĐẠT MỤC TIÊU "' + g.name + '"! Idol sẽ thực hiện ngay 🎊', true);
      mlrSetMood('fireworks');
      currentGoalIdx = (currentGoalIdx + 1) % GOALS.length;
      goalProgress = 0;
      setTimeout(updateGoalBar, 3500);
    }
  };
  updateGoalBar();

  // ===== 2. VIP ENTRY EFFECT =====
  var VIP_PROFILES = [
    { name:'VipFan88',    meta:'LV 99 · Đại Gia · 💎 Kim cương' },
    { name:'KingHero_X',  meta:'LV 87 · 🥇 Vàng · Top 1 tuần' },
    { name:'BoMy_X66',    meta:'LV 75 · 💎 Kim cương · 50M tổng nạp' },
    { name:'TaiPhu_77',   meta:'LV 92 · 👑 Vương Giả' },
    { name:'PhuQuy_999',  meta:'LV 88 · 💎 Kim cương · Fan ruột' },
    { name:'MisterTop',   meta:'LV 95 · 👑 Top 3 toàn nền tảng' }
  ];
  function spawnVipEntry(){
    var v = VIP_PROFILES[Math.floor(Math.random()*VIP_PROFILES.length)];
    var box = document.getElementById('mlrVipEntry');
    var nameEl = document.getElementById('mlrVipName');
    var metaEl = document.getElementById('mlrVipMeta');
    if (!box) return;
    nameEl.textContent = v.name;
    metaEl.textContent = v.meta;
    box.classList.remove('hidden');
    var slider = box.querySelector('.mlr-vip-slide');
    if (slider) {
      slider.style.animation = 'none';
      void slider.offsetWidth;
      slider.style.animation = 'mlrVipSlideAnim 5s ease-in-out forwards';
    }
    pushMlrChat('','','','👑 ' + v.name + ' đã vào phòng - Đại Gia VIP!', true);
    setTimeout(function(){ if (box) box.classList.add('hidden'); }, 5600);
  }
  function scheduleVip(){
    setTimeout(function(){
      spawnVipEntry();
      scheduleVip();
    }, 60000 + Math.random()*120000); // every 60-180s
  }
  setTimeout(spawnVipEntry, 10000); // First spawn after 10s
  scheduleVip();

  // ===== 3. LUCKY DRAW / JACKPOT =====
  var lotteryState = { jackpot: 88888888, myTickets: 0, secLeft: 30*60 };
  function updateLotteryUI(){
    var jpStr = fmtCoin(lotteryState.jackpot);
    var ticketEl = document.getElementById('mlrTickets');
    var jpSmall  = document.getElementById('mlrLotteryJackpot');
    if (jpSmall) jpSmall.textContent = jpStr;
    if (ticketEl) ticketEl.textContent = '🎫' + lotteryState.myTickets;
    var amt   = document.getElementById('mlrLotteryAmt');
    var myTk  = document.getElementById('mlrLotteryMyTickets');
    var cdn   = document.getElementById('mlrLotteryCountdown');
    if (amt)  amt.textContent  = lotteryState.jackpot.toLocaleString('vi-VN');
    if (myTk) myTk.textContent = lotteryState.myTickets;
    if (cdn) {
      var m = Math.floor(lotteryState.secLeft/60), s = lotteryState.secLeft%60;
      cdn.textContent = (m<10?'0':'')+m+':'+(s<10?'0':'')+s;
    }
  }
  window.mlrShowLottery = function(){
    document.getElementById('mlrLotteryModal').classList.remove('hidden');
    updateLotteryUI();
  };
  window.addLotteryTickets = function(coinSpent){
    var tickets = Math.floor(coinSpent / 100);
    if (tickets > 0) {
      lotteryState.myTickets += tickets;
      pushMlrChat('','','','🎫 Bạn nhận +' + tickets + ' vé số Jackpot!', true);
    }
    lotteryState.jackpot += coinSpent * 10;
    updateLotteryUI();
  };
  setInterval(function(){
    lotteryState.secLeft--;
    lotteryState.jackpot += Math.floor(Math.random()*10000);
    if (lotteryState.secLeft <= 0) {
      var winnerName = ['VipFan88','luckyOne_X','KingHero','BoMy_X66','PhuQuy_999'][Math.floor(Math.random()*5)];
      pushMlrChat('','','','🎰 🎊 JACKPOT ' + lotteryState.jackpot.toLocaleString('vi-VN') + ' 🪙 thuộc về ' + winnerName + '!', true);
      mlrSetMood('fireworks');
      lotteryState.jackpot = 80000000 + Math.floor(Math.random()*20000000);
      lotteryState.secLeft = 30*60;
      lotteryState.myTickets = 0;
    }
    updateLotteryUI();
  }, 1000);
  updateLotteryUI();

  // ===== 4. PARTICLE EFFECTS (moods) =====
  var particleTimer = null;
  var particleStopTimer = null;
  var MOOD_CONFIG = {
    happy:     { emojis:['❤️','💖','💕','💗','💝'],     rate: 700,  duration: 8000,  type:'float', size:[18,28] },
    romantic:  { emojis:['🌹','🌷','🌸','🌺','💐'],     rate: 900,  duration: 10000, type:'fall',  size:[16,26] },
    snow:      { emojis:['❄️','☃️','❅','❆','⛄'],       rate: 350,  duration: 12000, type:'fall',  size:[14,22] },
    rain:      { emojis:['💧','💦','🌧'],                rate: 180,  duration: 8000,  type:'fall',  size:[10,16] },
    fireworks: { emojis:['🎉','🎊','✨','⭐','💫','🌟','🎆','🎇'], rate: 120,  duration: 6000,  type:'float', size:[20,32] },
    party:     { emojis:['🎈','🎁','🎀','🎂','🍾','🥳'], rate: 500,  duration: 9000,  type:'float', size:[18,28] }
  };
  window.mlrSetMood = function(mood){
    var cfg = MOOD_CONFIG[mood];
    if (!cfg) return;
    if (particleTimer) clearInterval(particleTimer);
    if (particleStopTimer) clearTimeout(particleStopTimer);
    particleTimer = setInterval(function(){ spawnParticle(cfg); }, cfg.rate);
    particleStopTimer = setTimeout(function(){
      clearInterval(particleTimer);
      particleTimer = null;
    }, cfg.duration);
  };
  function spawnParticle(cfg){
    var layer = document.getElementById('mlrParticleLayer');
    if (!layer) return;
    var em = cfg.emojis[Math.floor(Math.random()*cfg.emojis.length)];
    var el = document.createElement('div');
    el.className = 'mlr-particle ' + (cfg.type === 'fall' ? 'fall' : 'float');
    el.textContent = em;
    var startX = Math.random() * 100;
    var duration = 4 + Math.random() * 4;
    var size = cfg.size[0] + Math.random()*(cfg.size[1] - cfg.size[0]);
    el.style.left = startX + '%';
    el.style.fontSize = size + 'px';
    if (cfg.type === 'fall') {
      el.style.top = '-30px';
      el.style.setProperty('--drift', (Math.random()*100 - 50) + 'px');
      el.style.setProperty('--rot', (Math.random()*720 - 360) + 'deg');
    } else {
      el.style.bottom = '20%';
      el.style.setProperty('--driftX', (Math.random()*40 - 20) + 'px');
    }
    el.style.animationDuration = duration + 's';
    layer.appendChild(el);
    setTimeout(function(){ if (el.parentNode) el.remove(); }, duration*1000 + 200);
  }
  // Auto cycle mood every 60s
  var moodCycle = ['happy','romantic','party','snow','fireworks'];
  var moodIdx = 0;
  setInterval(function(){
    moodIdx = (moodIdx + 1) % moodCycle.length;
    mlrSetMood(moodCycle[moodIdx]);
  }, 60000);
  mlrSetMood('happy'); // Initial mood

  // ===== 5. CINEMA MODE =====
  var cinemaOn = false;
  window.mlrToggleCinemaMode = function(){
    cinemaOn = !cinemaOn;
    var root = document.getElementById('mobileLiveRoom');
    if (cinemaOn) {
      root.classList.add('mlr-cinema-mode');
      pushMlrChat('','','','🎬 Đang ở chế độ Rạp Phim - tap màn hình để thoát', true);
    } else {
      root.classList.remove('mlr-cinema-mode');
    }
  };
  // In cinema mode, any tap on gesture layer exits
  var origGesture = document.getElementById('mlrGestureLayer');
  if (origGesture) {
    var existingHandler = origGesture.onclick;
    origGesture.addEventListener('click', function(e){
      if (cinemaOn) {
        cinemaOn = false;
        document.getElementById('mobileLiveRoom').classList.remove('mlr-cinema-mode');
        e.stopPropagation();
      }
    }, true);
  }

  // ===== 6. SWIPE GESTURE TO CHANGE IDOL ROOM (TikTok-style) =====
  var allIdols = <%- JSON.stringify(typeof allIdols !== 'undefined' ? allIdols : []) %>;
  var currentIdolId = '<%= idolId %>';
  var currentIdx = allIdols.findIndex(function(i){ return i.id === currentIdolId; });
  if (currentIdx < 0) currentIdx = 0;

  function getNextIdol() {
    if (allIdols.length < 2) return null;
    var nextIdx = (currentIdx + 1) % allIdols.length;
    return allIdols[nextIdx];
  }
  function getPrevIdol() {
    if (allIdols.length < 2) return null;
    var prevIdx = (currentIdx - 1 + allIdols.length) % allIdols.length;
    return allIdols[prevIdx];
  }

  // Pre-populate hint emoji/name
  var nextI = getNextIdol(), prevI = getPrevIdol();
  if (nextI) {
    document.getElementById('mlrSwipeNextEmoji').textContent = nextI.emoji;
    document.getElementById('mlrSwipeNextName').textContent  = nextI.name;
  }
  if (prevI) {
    document.getElementById('mlrSwipePrevEmoji').textContent = prevI.emoji;
    document.getElementById('mlrSwipePrevName').textContent  = prevI.name;
  }

  // Touch tracking
  var touchStartY = 0, touchStartX = 0, touchDeltaY = 0, isSwiping = false, swipeDecided = false;
  var SWIPE_THRESHOLD = 70;  // px de trigger chuyen phong (giam tu 100)
  var SWIPE_RATIO = 1.2;     // vertical > horizontal/1.2

  function onTouchStart(e){
    if (cinemaOn || !e.touches || !e.touches[0]) return;
    // Don't interfere with chat input, modals, gift panel, profile modal, album modal
    var target = e.target;
    if (target.closest('#mlrChatInputModal') || target.closest('#mlrLotteryModal')
        || target.closest('#mlrMoreMenu') || target.closest('#mlrReactionMenu')
        || target.closest('#giftPanel') || target.closest('#mlrQuickGiftBar')
        || target.closest('#mlrIdolProfileModal') || target.closest('#mlrAlbumModal')
        || target.closest('#mlrLightbox') || target.closest('#mlrRightWidgets')
        || target.closest('#mlrTopBar')
        || target.closest('button') || target.closest('a') || target.closest('input')) return;
    touchStartY = e.touches[0].clientY;
    touchStartX = e.touches[0].clientX;
    touchDeltaY = 0;
    isSwiping = true;
    swipeDecided = false;
  }
  function onTouchMove(e){
    if (!isSwiping || !e.touches || !e.touches[0]) return;
    var dy = e.touches[0].clientY - touchStartY;
    var dx = e.touches[0].clientX - touchStartX;
    // Quyet dinh huong swipe sau khi di chuyen > 10px
    if (!swipeDecided && (Math.abs(dx) > 10 || Math.abs(dy) > 10)) {
      // Reject horizontal swipes
      if (Math.abs(dx) > Math.abs(dy) / SWIPE_RATIO) { isSwiping = false; return; }
      swipeDecided = true;
    }
    if (!swipeDecided) return;
    // Chan browser default scroll/pull-to-refresh khi vertical swipe
    if (e.cancelable) e.preventDefault();
    touchDeltaY = dy;

    var root = document.getElementById('mobileLiveRoom');
    var topHint = document.getElementById('mlrSwipeTopHint');
    var botHint = document.getElementById('mlrSwipeBottomHint');

    // Follow finger with damping
    var damped = dy * 0.3;
    root.classList.add('mlr-swipe-following');
    root.style.transform = 'translateY(' + damped + 'px)';

    if (dy < -30 && nextI) {
      // Swipe up = show next preview
      topHint.classList.remove('hidden');
      botHint.classList.add('hidden');
      topHint.style.transform = 'translateY(0)';
      topHint.style.opacity = Math.min(1, Math.abs(dy)/SWIPE_THRESHOLD).toString();
    } else if (dy > 30 && prevI) {
      // Swipe down = show prev preview
      botHint.classList.remove('hidden');
      topHint.classList.add('hidden');
      botHint.style.transform = 'translateY(0)';
      botHint.style.opacity = Math.min(1, dy/SWIPE_THRESHOLD).toString();
    } else {
      topHint.classList.add('hidden');
      botHint.classList.add('hidden');
    }
  }
  function onTouchEnd(e){
    if (!isSwiping) return;
    isSwiping = false;
    var root = document.getElementById('mobileLiveRoom');
    var topHint = document.getElementById('mlrSwipeTopHint');
    var botHint = document.getElementById('mlrSwipeBottomHint');
    topHint.classList.add('hidden');
    botHint.classList.add('hidden');
    root.classList.remove('mlr-swipe-following');
    root.style.transform = '';

    if (touchDeltaY < -SWIPE_THRESHOLD && nextI) {
      navigateToIdol(nextI, 'up');
    } else if (touchDeltaY > SWIPE_THRESHOLD && prevI) {
      navigateToIdol(prevI, 'down');
    }
    touchDeltaY = 0;
  }
  function navigateToIdol(idol, dir){
    var root = document.getElementById('mobileLiveRoom');
    var trans = document.getElementById('mlrRoomTransition');
    var transName = document.getElementById('mlrTransName');
    var transEmoji = trans.querySelector('.mlr-trans-emoji');
    transEmoji.textContent = idol.emoji;
    transName.textContent = 'Đang vào phòng ' + idol.name + '...';
    trans.classList.remove('hidden');
    // Slide-out animation
    root.classList.add(dir === 'up' ? 'mlr-swiping-up' : 'mlr-swiping-down');
    setTimeout(function(){
      location.href = '/idol/' + idol.id;
    }, 350);
  }

  // Attach touch events to ROOT - swipe anywhere works (except modals/buttons)
  // passive:false cho touchmove de chan browser scroll/pull-to-refresh
  var swipeRoot = document.getElementById('mobileLiveRoom');
  if (swipeRoot) {
    swipeRoot.addEventListener('touchstart', onTouchStart, { passive: true });
    swipeRoot.addEventListener('touchmove', onTouchMove, { passive: false });
    swipeRoot.addEventListener('touchend', onTouchEnd, { passive: true });
    swipeRoot.addEventListener('touchcancel', onTouchEnd, { passive: true });
  }
  // Debug log
  if (window.console) {
    console.log('[Swipe] Ready. Idols:', allIdols.length, '| Next:', nextI && nextI.name, '| Prev:', prevI && prevI.name);
  }


  // ===== ALBUM & VIDEO MODAL =====
  var ALBUM_DATA  = <%- JSON.stringify(typeof ALBUM  !== 'undefined' ? ALBUM  : []) %>;
  var VIDEOS_DATA = <%- JSON.stringify(typeof VIDEOS !== 'undefined' ? VIDEOS : []) %>;
  var lbState = { type:'photo', idx:0 };

  window.mlrShowAlbum = function(){
    mlrCloseIdolProfile();
    document.getElementById('mlrAlbumModal').classList.remove('hidden');
    mlrAlbumTab('photo');
  };
  window.mlrCloseAlbum = function(){
    document.getElementById('mlrAlbumModal').classList.add('hidden');
  };
  window.mlrAlbumTab = function(tab){
    var photoTab = document.getElementById('mlrAlbumTabPhoto');
    var videoTab = document.getElementById('mlrAlbumTabVideo');
    var photoPanel = document.getElementById('mlrAlbumPhotoPanel');
    var videoPanel = document.getElementById('mlrAlbumVideoPanel');
    if (tab === 'photo'){
      photoTab.className  = 'flex-1 py-1.5 rounded-full text-[12px] font-bold bg-pri text-white transition-all';
      videoTab.className  = 'flex-1 py-1.5 rounded-full text-[12px] font-bold text-gray-300 transition-all';
      photoPanel.classList.remove('hidden');
      videoPanel.classList.add('hidden');
    } else {
      videoTab.className  = 'flex-1 py-1.5 rounded-full text-[12px] font-bold bg-pri text-white transition-all';
      photoTab.className  = 'flex-1 py-1.5 rounded-full text-[12px] font-bold text-gray-300 transition-all';
      videoPanel.classList.remove('hidden');
      photoPanel.classList.add('hidden');
    }
  };

  window.mlrOpenLightbox = function(type, idx){
    lbState.type = type; lbState.idx = idx;
    document.getElementById('mlrLightbox').classList.remove('hidden');
    mlrRenderLightbox();
  };
  window.mlrCloseLightbox = function(){
    document.getElementById('mlrLightbox').classList.add('hidden');
  };
  window.mlrLbPrev = function(){
    var arr = lbState.type === 'photo' ? ALBUM_DATA : VIDEOS_DATA;
    if (!arr.length) return;
    lbState.idx = (lbState.idx - 1 + arr.length) % arr.length;
    mlrRenderLightbox();
  };
  window.mlrLbNext = function(){
    var arr = lbState.type === 'photo' ? ALBUM_DATA : VIDEOS_DATA;
    if (!arr.length) return;
    lbState.idx = (lbState.idx + 1) % arr.length;
    mlrRenderLightbox();
  };
  function mlrRenderLightbox(){
    var arr = lbState.type === 'photo' ? ALBUM_DATA : VIDEOS_DATA;
    if (!arr.length) return;
    var item = arr[lbState.idx];
    var content = document.getElementById('mlrLbContent');
    var titleEl = document.getElementById('mlrLbTitle');
    var metaEl  = document.getElementById('mlrLbMeta');
    var counter = document.getElementById('mlrLbCounter');
    counter.textContent = (lbState.idx+1) + ' / ' + arr.length;
    if (lbState.type === 'photo'){
      content.style.background = item.color;
      content.innerHTML = '<div style="font-size:160px;text-shadow:0 8px 32px rgba(0,0,0,.5);filter:drop-shadow(0 0 24px rgba(255,255,255,.3))">'+item.emoji+'</div>';
      titleEl.textContent = item.caption;
      metaEl.textContent = 'Ảnh ' + (lbState.idx+1) + ' / ' + arr.length;
    } else {
      content.style.background = 'linear-gradient(135deg,#1a1f29,#0e1116)';
      content.innerHTML = '<div style="text-align:center"><div style="font-size:120px;margin-bottom:16px">'+item.emoji+'</div>'
        + '<div style="display:inline-flex;align-items:center;gap:10px;background:rgba(255,255,255,.15);backdrop-filter:blur(8px);color:#fff;padding:10px 24px;border-radius:50px;font-weight:800;cursor:pointer"><span style="font-size:24px">▶</span> Phát video</div>'
        + '<div style="color:#888;margin-top:12px;font-size:12px">📺 Demo - Video thực sẽ embed VideoJS/Plyr</div></div>';
      titleEl.textContent = item.title;
      metaEl.textContent  = '⏱ ' + item.duration + ' · 👁 ' + item.views + ' lượt xem';
    }
  }

  // ===== IDOL PROFILE MODAL =====
  window.mlrShowIdolProfile = function(){
    var modal = document.getElementById('mlrIdolProfileModal');
    var sheet = document.getElementById('mlrIdolProfileSheet');
    if (!modal) return;
    modal.classList.remove('hidden');
    // Restart slide animation
    if (sheet) {
      sheet.style.animation = 'none';
      void sheet.offsetWidth;
      sheet.style.animation = 'mlrProfileSlideUp .35s ease-out forwards';
    }
  };
  window.mlrCloseIdolProfile = function(){
    var modal = document.getElementById('mlrIdolProfileModal');
    if (modal) modal.classList.add('hidden');
  };
})();
</script>
