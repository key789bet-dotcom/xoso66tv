      <div class="text-[10px] text-gray-300 ml-auto bg-black/40 backdrop-blur px-2 py-0.5 rounded-full">HD 1080p</div>
    </div>
  </header>

  <!-- ===== MARQUEE: super-gift notification (top) ===== -->
  <div class="absolute top-[88px] left-2 right-2 z-[15] overflow-hidden rounded-full">
    <div class="bg-gradient-to-r from-yellow-500/90 via-orange-500/90 to-yellow-500/90 backdrop-blur py-1 px-3 flex items-center gap-1.5 shadow-lg shadow-orange-500/30">
