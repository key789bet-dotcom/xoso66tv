  <!-- ===== 3D DICE & COIN STYLES (realistic, GPU-light) ===== -->
  <style>
    /* === XÓC ĐĨA - đồng xu 3D === */
    .xd-coin {
      width: 30px; height: 30px;
      border-radius: 50%;
      position: relative;
      display: inline-block;
      transform-style: preserve-3d;
      animation: xdSpin 4s linear infinite;
      filter: drop-shadow(0 3px 4px rgba(0,0,0,.6));
    }
    .xd-coin::before {
      content:''; position:absolute; inset:0;
      border-radius:50%;
      box-shadow:
        inset 0 -3px 6px rgba(0,0,0,.4),
        inset 0 2px 3px rgba(255,255,255,.7),
        inset -2px -2px 5px rgba(0,0,0,.3);
    }
    .xd-coin::after {
      content:''; position:absolute;
      top:14%; left:22%;
      width:35%; height:25%;
      border-radius:50%;
      background: radial-gradient(ellipse, rgba(255,255,255,.85), rgba(255,255,255,0) 70%);
      filter: blur(.5px);
    }
    .xd-red {
      background: radial-gradient(circle at 35% 30%, #ff6464 0%, #e02020 40%, #8a0808 100%);
      border: 1px solid #5a0404;
    }
    .xd-white {
      background: radial-gradient(circle at 35% 30%, #ffffff 0%, #e8e8e8 50%, #999 100%);
      border: 1px solid #777;
    }
    @keyframes xdSpin {
      0%   { transform: rotateY(0)    scale(1); }
      25%  { transform: rotateY(180deg) scaleX(.15); }
      50%  { transform: rotateY(360deg) scale(1); }
      75%  { transform: rotateY(540deg) scaleX(.15); }
      100% { transform: rotateY(720deg) scale(1); }
    }
    .xd-coin:nth-child(1) { animation-delay: 0s; }
    .xd-coin:nth-child(2) { animation-delay: .2s; }
    .xd-coin:nth-child(3) { animation-delay: .4s; }
    .xd-coin:nth-child(4) { animation-delay: .6s; }

    /* === TÀI XỈU - xúc xắc 3D === */
    .tx-dice {
      width: 32px; height: 32px;
      position: relative;
      display: inline-block;
      perspective: 200px;
      animation: txRoll 3s ease-in-out infinite;
      filter: drop-shadow(0 4px 5px rgba(0,0,0,.65));
    }
    .tx-face {
      position: absolute; inset: 0;
      background: linear-gradient(135deg, #ffffff 0%, #f0f0f0 50%, #d0d0d0 100%);
      border-radius: 6px;
      border: 1px solid rgba(0,0,0,.15);
      box-shadow:
        inset 2px 2px 4px rgba(255,255,255,.9),
        inset -2px -2px 4px rgba(0,0,0,.25),
        inset 0 0 0 1px rgba(255,255,255,.4);
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      grid-template-rows: repeat(3, 1fr);
      padding: 3px;
      gap: 1px;
    }
    .tx-pip {
      width: 5px; height: 5px;
      border-radius: 50%;
      background: radial-gradient(circle at 30% 30%, #555 0%, #1a1a1a 100%);
      box-shadow:
        inset 1px 1px 1px rgba(255,255,255,.15),
        inset -.5px -.5px 1px rgba(0,0,0,.5),
        0 .5px 0 rgba(255,255,255,.7);
      align-self: center;
      justify-self: center;
    }
    /* pip-position helpers: 9 grid cells, mark which to show */
    .tx-pip.p1 { grid-area: 1/1; }
    .tx-pip.p2 { grid-area: 1/2; }
    .tx-pip.p3 { grid-area: 1/3; }
    .tx-pip.p4 { grid-area: 2/1; }
    .tx-pip.p5 { grid-area: 2/2; }
    .tx-pip.p6 { grid-area: 2/3; }
    .tx-pip.p7 { grid-area: 3/1; }
    .tx-pip.p8 { grid-area: 3/2; }
    .tx-pip.p9 { grid-area: 3/3; }

    @keyframes txRoll {
      0%, 100% { transform: rotate(-6deg) translateY(0); }
      25%      { transform: rotate(8deg)  translateY(-2px); }
      50%      { transform: rotate(-4deg) translateY(0); }
      75%      { transform: rotate(6deg)  translateY(-1px); }
    }
    #mlrTaiXiuDice .tx-dice:nth-child(1) { animation-delay: 0s; }
    #mlrTaiXiuDice .tx-dice:nth-child(2) { animation-delay: .3s; }
    #mlrTaiXiuDice .tx-dice:nth-child(3) { animation-delay: .6s; }
  </style>

  <script>
    (function initDice3D(){
      // Map số 1-6 thành các pip position chuẩn
      var DICE_PIPS = {
        1: [5],
        2: [1, 9],
        3: [1, 5, 9],
        4: [1, 3, 7, 9],
        5: [1, 3, 5, 7, 9],
        6: [1, 3, 4, 6, 7, 9]
      };
      function makeDie(n){
        n = parseInt(n,10) || 1;
        if (n < 1) n = 1; if (n > 6) n = 6;
        var pips = (DICE_PIPS[n] || [5]).map(function(p){
          return '<span class="tx-pip p'+p+'"></span>';
        }).join('');
        return '<span class="tx-dice"><span class="tx-face">'+pips+'</span></span>';
      }
      var box = document.getElementById('mlrTaiXiuDice');
      if (!box) return;
      var d1 = box.getAttribute('data-d1') || 5;
      var d2 = box.getAttribute('data-d2') || 1;
      var d3 = box.getAttribute('data-d3') || 2;
      box.innerHTML = makeDie(d1) + makeDie(d2) + makeDie(d3);

      // Expose API for runtime update (khi kỳ mới ra)
      window.mlrSetDice = function(a, b, c){
        box.setAttribute('data-d1', a);
        box.setAttribute('data-d2', b);
        box.setAttribute('data-d3', c);
        box.innerHTML = makeDie(a) + makeDie(b) + makeDie(c);
      };
      window.mlrSetXocDia = function(arr){
        // arr = ['r','r','w','w'] - r=red, w=white
        var balls = document.getElementById('mlrXocDiaBalls');
        if (!balls) return;
        balls.innerHTML = arr.map(function(c){
          return '<span class="xd-coin '+(c==='r'?'xd-red':'xd-white')+'"></span>';
        }).join('');
      };
    })();
  </script>

