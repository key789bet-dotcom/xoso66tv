<%
// Mobile fullscreen idol live UI - chuan UI/UX cao cap
var fakeViewers = ['🦊','🐯','🐱','🐰','🐼','🐻','🐧','🦁','🐸','🦄'];
var marqueeMsgs = [
  '🎁 Lì xì rơi hàng ngày lên đến 88.888.000đ',
  '🔥 Top 1 tuần được tặng iPhone 15 Pro Max',
  '⭐ Tặng quà huyền thoại nhận VIP 30 ngày'
];
var quickGifts = [
  { icon:'🌹', name:'Hoa hồng', price:1, tier:'common' },
  { icon:'❤️', name:'Trái tim', price:2, tier:'common' },
  { icon:'💋', name:'Nụ hôn', price:5, tier:'common' },
  { icon:'🌹', name:'Bó hồng', price:100, tier:'rare' },
  { icon:'💎', name:'Kim cương', price:1000, tier:'epic' }
];
%>

<!-- ============================================== -->
<!-- ===== MOBILE IDOL LIVE ROOM (premium UX) ===== -->
<!-- ============================================== -->
<div class="md:hidden fixed inset-0 z-[60] overflow-hidden bg-black select-none" id="mobileLiveRoom" style="touch-action: manipulation;">

  <!-- ===== LAYER 1: Player background (full screen) ===== -->
  <div class="absolute inset-0" id="mlrPlayerBg" style="background:linear-gradient(135deg, hsl(<%= idol.color %>,70%,40%), hsl(<%= idol.color+60 %>,70%,50%))">
    <!-- Radial spotlight -->
    <div class="absolute inset-0 opacity-50" style="background:radial-gradient(circle at 30% 40%,rgba(255,255,255,.35),transparent 60%),radial-gradient(circle at 70% 60%,rgba(255,255,255,.25),transparent 55%)"></div>
    <!-- Idol emoji center (placeholder cho video) -->
    <div class="absolute inset-0 grid place-items-center pointer-events-none" id="mlrEmojiBox">
      <div class="text-[200px] drop-shadow-2xl mlr-idol-anim"><%= idol.emoji || '👑' %></div>
    </div>

    <!-- VIDEO ELEMENT (ẩn ban đầu, hiện khi stream live) -->
    <video id="mlrLiveVideo" class="hidden absolute inset-0 w-full h-full object-cover bg-black z-[2]" playsinline muted autoplay></video>

    <!-- Subtle vignette -->
    <div class="absolute inset-0 pointer-events-none z-[3]" style="background:radial-gradient(ellipse at center,transparent 40%,rgba(0,0,0,.4) 100%)"></div>
  </div>

  <!-- Nút bật tiếng mobile (chỉ hiện khi đã có video play muted) -->
  <button id="mlrUnmuteBtn" class="hidden absolute top-[60px] right-2 z-[10] bg-pri text-white w-10 h-10 rounded-full grid place-items-center shadow-2xl animate-pulse" type="button" aria-label="Bật tiếng">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"/></svg>
  </button>

  <!-- FLV.js + stream loader for mobile -->
  <script src="https://cdn.jsdelivr.net/npm/flv.js@1.6.2/dist/flv.min.js"></script>
  <script>
  (function initMobileStream(){
    var STREAM_KEY = '<%= idolId %>';
    var STREAM_URL = 'https://xoso66tv.com/live/' + STREAM_KEY + '.flv';
    var player, isLive = false, video, emojiBox, unmuteBtn;

    function showVideo(){
      if (isLive) return;
      console.log('[MLR] ✅ Mobile video ready');
      isLive = true;
      if (video) video.classList.remove('hidden');
      if (emojiBox) emojiBox.style.display = 'none';
      if (unmuteBtn && video && video.muted) unmuteBtn.classList.remove('hidden');
    }
    function hideVideo(){
      isLive = false;
      if (video) video.classList.add('hidden');
      if (emojiBox) emojiBox.style.display = '';
      if (unmuteBtn) unmuteBtn.classList.add('hidden');
    }

    function attach(){
      if (!window.flvjs || !flvjs.isSupported()) return;
      video = document.getElementById('mlrLiveVideo');
      emojiBox = document.getElementById('mlrEmojiBox');
      if (!video) return;
      if (player) try{ player.destroy(); }catch(e){}

      player = flvjs.createPlayer({ type:'flv', url:STREAM_URL, isLive:true, hasAudio:true, hasVideo:true }, {
        // ⚡ LOW LATENCY mobile
        enableWorker:true, enableStashBuffer:false, stashInitialSize:64,
        autoCleanupSourceBuffer:true, autoCleanupMaxBackwardDuration:3,
        liveBufferLatencyChasing:true, liveBufferLatencyMaxLatency:2.0, liveBufferLatencyMinRemain:0.3,
        lazyLoad:false, lazyLoadMaxDuration:1
      });
      player.attachMediaElement(video);
      player.load();

      // Listen native video events (đáng tin cậy hơn MEDIA_INFO)
      video.addEventListener('loadedmetadata', showVideo, { once:true });
      video.addEventListener('playing', showVideo, { once:true });
      video.addEventListener('canplay', function(){
        var p = video.play(); if(p&&p.catch) p.catch(function(){});
      });

      var p = player.play();
      if (p && p.catch) p.catch(function(){
        // Autoplay blocked - vẫn show video để user tap
        showVideo();
      });

      player.on(flvjs.Events.MEDIA_INFO, showVideo);
      player.on(flvjs.Events.ERROR, function(type){
        if (type === 'NetworkError') {
          if (player) try{ player.destroy(); player=null; }catch(e){}
          hideVideo();
        }
      });
    }

    function check(){
      fetch(STREAM_URL, { method:'HEAD', cache:'no-store' })
        .then(function(r){ if (r.ok && !isLive) setTimeout(attach, 300); else if (!r.ok && isLive) { hideVideo(); if (player) try{ player.destroy(); player=null; }catch(e){} } })
        .catch(function(){});
    }

    function bindUnmute(){
      unmuteBtn = document.getElementById('mlrUnmuteBtn');
      if (unmuteBtn) unmuteBtn.addEventListener('click', function(e){
        e.stopPropagation();
        if (video) { video.muted = false; video.volume = 1; }
        unmuteBtn.classList.add('hidden');
      });
    }

    function start(){
      if (!window.flvjs) { setTimeout(start, 300); return; }
      bindUnmute();
      check();
      setInterval(check, 10000);
    }
    if (document.readyState !== 'loading') start();
    else document.addEventListener('DOMContentLoaded', start);
  })();
  </script>

  <!-- ===== LAYER 2: Gesture catcher (transparent overlay for taps) ===== -->
  <div class="absolute inset-0 z-[5]" id="mlrGestureLayer"></div>

  <!-- ===== LAYER 3: Floating hearts/reactions overlay ===== -->
  <div class="absolute inset-0 z-[6] pointer-events-none overflow-hidden" id="mlrReactionLayer"></div>

  <!-- ===== LAYER 4: Particle effects by mood ===== -->
