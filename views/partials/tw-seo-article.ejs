<script>
// Scroll-spy: highlight TOC mục đang xem (scroll trong khung article)
(function(){
  var tocLinks = document.querySelectorAll('.seo-toc');
  if (!tocLinks.length) return;
  var article = document.querySelector('article[itemprop="articleBody"]');
  if (!article) return;
  var targets = Array.from(tocLinks).map(function(a){ return article.querySelector(a.getAttribute('href')); }).filter(Boolean);

  function activate(idx){
    tocLinks.forEach(function(a, i){
      var active = i === idx;
      a.classList.toggle('border-pri', active);
      a.classList.toggle('bg-bg-soft', active);
      var ttl = a.querySelector('div:first-child');
      if (ttl) {
        ttl.classList.toggle('text-pri-light', active);
        ttl.classList.toggle('text-white', !active);
      }
    });
  }

  function onScroll(){
    var sy = article.scrollTop + 20;
    var idx = 0;
    for (var i=0; i<targets.length; i++) {
      if (targets[i].offsetTop - article.offsetTop <= sy) idx = i; else break;
    }
    activate(idx);
  }
  article.addEventListener('scroll', onScroll, { passive: true });

  // Override TOC click: scroll trong article thay vì cả page
  tocLinks.forEach(function(a){
    a.addEventListener('click', function(e){
      e.preventDefault();
      var target = article.querySelector(this.getAttribute('href'));
      if (target) {
        article.scrollTo({ top: target.offsetTop - article.offsetTop - 8, behavior: 'smooth' });
      }
    });
  });

  onScroll();
})();
</script>
