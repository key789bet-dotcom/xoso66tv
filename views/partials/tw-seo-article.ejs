var TOC = [
  { id:'gioi-thieu',  text: brand.short, sub:'Nền tảng phát sóng trực tiếp Bóng Đá & Esport 24/7 miễn phí, không quảng cáo, full HD tốc độ cao' },
  { id:'la-gi',       text: brand.short + ' Là Gì?' },
  { id:'lich-su',     text: 'Lịch Sử Hình Thành Của ' + brand.short },
