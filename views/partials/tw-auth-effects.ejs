<!--
  Auth pages hover effects (login + register)
  Scope: body co #loginForm hoac #regForm
  Pure CSS - khong dung HTML/JS
-->
<style>
/* === AUTH PAGES HOVER EFFECTS === */

/* 1. Form card lift + outer glow */
body:has(#loginForm) section.rounded-2xl,
body:has(#regForm) section.rounded-2xl {
  transition: transform .4s cubic-bezier(.4,0,.2,1),
              box-shadow .4s ease,
              border-color .4s ease;
}
body:has(#loginForm) section.rounded-2xl:hover,
body:has(#regForm) section.rounded-2xl:hover {
  transform: translateY(-4px);
  box-shadow: 0 25px 60px -15px rgba(255,122,24,.4),
              0 10px 30px -5px rgba(0,0,0,.5);
  border-color: rgba(255,122,24,.55);
}

/* 2. Logo bounce on hover */
body:has(#loginForm) .text-center.mb-5 a img,
body:has(#regForm) .text-center.mb-5 a img {
  transition: transform .3s ease, filter .3s ease;
}
body:has(#loginForm) .text-center.mb-5 a:hover img,
body:has(#regForm) .text-center.mb-5 a:hover img {
  animation: x66LogoBounce .65s ease;
  filter: drop-shadow(0 6px 18px rgba(255,122,24,.45));
}
@keyframes x66LogoBounce {
  0%, 100% { transform: translateY(0) scale(1); }
  30%      { transform: translateY(-8px) scale(1.06); }
  60%      { transform: translateY(2px)  scale(.98); }
}

/* 3. Close (×) button - rotate + glow */
body:has(#loginForm) a[aria-label="Đóng"],
body:has(#regForm) a[aria-label="Đóng"] {
  transition: transform .4s cubic-bezier(.34,1.56,.64,1),
              box-shadow .3s ease,
              background .3s ease !important;
}
body:has(#loginForm) a[aria-label="Đóng"]:hover,
body:has(#regForm) a[aria-label="Đóng"]:hover {
  transform: rotate(90deg) scale(1.15);
  box-shadow: 0 0 24px rgba(255,122,24,.7),
              0 6px 18px rgba(0,0,0,.4);
}

/* 4. Tab nav (Đăng Nhập / Đăng ký) - lift + glow */
body:has(#loginForm) nav.grid-cols-2 > a,
body:has(#regForm) nav.grid-cols-2 > a {
  position: relative;
  overflow: hidden;
  transition: transform .3s cubic-bezier(.4,0,.2,1),
              box-shadow .3s ease,
              background .3s ease,
              color .3s ease !important;
}
body:has(#loginForm) nav.grid-cols-2 > a:hover,
body:has(#regForm) nav.grid-cols-2 > a:hover {
  transform: translateY(-2px) scale(1.02);
  box-shadow: 0 10px 24px -8px rgba(255,122,24,.5);
}

/* 5. Inputs - hover border tint + focus lift + glow */
#loginForm input,
#regForm input {
  transition: border-color .3s ease,
              box-shadow .3s ease,
              transform .25s ease,
              background .3s ease !important;
}
#loginForm input:hover:not(:focus),
#regForm input:hover:not(:focus) {
  border-color: rgba(255,122,24,.5) !important;
  background: #11161e !important;
}
#loginForm input:focus,
#regForm input:focus {
  transform: translateY(-1px);
  box-shadow: 0 0 0 3px rgba(255,122,24,.28),
              0 10px 24px -10px rgba(255,122,24,.5) !important;
}

/* 6. Input icons - color shift + scale khi field focused */
#loginForm .relative > span.absolute,
#regForm  .relative > span.absolute {
  transition: color .3s ease,
              transform .35s cubic-bezier(.34,1.56,.64,1),
              text-shadow .3s ease;
  transform-origin: center;
}
#loginForm .relative:focus-within > span.absolute,
#regForm  .relative:focus-within > span.absolute {
  color: #ff9933 !important;
  transform: translateY(-50%) scale(1.18);
  text-shadow: 0 0 12px rgba(255,153,51,.5);
}

/* 7. Submit button - shimmer slide + lift + brightness */
#loginForm button[type="submit"],
#regForm  button[type="submit"] {
  position: relative;
  overflow: hidden;
  transition: transform .28s cubic-bezier(.34,1.56,.64,1),
              box-shadow .3s ease,
              filter .25s ease !important;
}
#loginForm button[type="submit"]::before,
#regForm  button[type="submit"]::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(110deg,
              transparent 30%,
              rgba(255,255,255,.4) 50%,
              transparent 70%);
  transform: translateX(-100%);
  transition: transform .7s ease;
  pointer-events: none;
}
#loginForm button[type="submit"]:hover::before,
#regForm  button[type="submit"]:hover::before {
  transform: translateX(100%);
}
#loginForm button[type="submit"]:hover,
#regForm  button[type="submit"]:hover {
  transform: translateY(-2px) scale(1.015);
  box-shadow: 0 18px 38px -12px rgba(255,122,24,.65),
              0 6px 16px -4px rgba(0,0,0,.45);
  filter: brightness(1.12);
}
#loginForm button[type="submit"]:active,
#regForm  button[type="submit"]:active {
  transform: translateY(0) scale(.98);
  filter: brightness(.93);
  transition-duration: .1s;
}

/* 8. Eye (toggle password) button */
#loginForm button[onclick^="togglePw"],
#regForm  button[onclick^="togglePw"] {
  transition: transform .35s cubic-bezier(.34,1.56,.64,1),
              color .25s ease !important;
}
#loginForm button[onclick^="togglePw"]:hover,
#regForm  button[onclick^="togglePw"]:hover {
  transform: translateY(-50%) scale(1.25) rotate(-8deg);
  color: #ff9933 !important;
}

/* 9. Links (Quên mật khẩu / Đăng nhập / chính sách) - underline slide */
body:has(#loginForm) a.hover\:underline,
body:has(#regForm)  a.hover\:underline,
body:has(#loginForm) a[href="/quen-mat-khau"],
body:has(#regForm)  a[href="/quen-mat-khau"] {
  position: relative;
  text-decoration: none !important;
  transition: color .25s ease;
}
body:has(#loginForm) a.hover\:underline::after,
body:has(#regForm)  a.hover\:underline::after,
body:has(#loginForm) a[href="/quen-mat-khau"]::after,
body:has(#regForm)  a[href="/quen-mat-khau"]::after {
  content: '';
  position: absolute;
  left: 0;
  bottom: -2px;
  width: 0;
  height: 2px;
  background: linear-gradient(90deg, #ff7a18, #ff9933);
  border-radius: 1px;
  transition: width .35s cubic-bezier(.4,0,.2,1);
}
body:has(#loginForm) a.hover\:underline:hover::after,
body:has(#regForm)  a.hover\:underline:hover::after,
body:has(#loginForm) a[href="/quen-mat-khau"]:hover::after,
body:has(#regForm)  a[href="/quen-mat-khau"]:hover::after {
  width: 100%;
}

/* 10. Captcha refresh button (fallback khi Turnstile chua config) */
body:has(#loginForm) button[onclick*="aptcha"],
body:has(#regForm)  button[onclick*="aptcha"],
body:has(#loginForm) button[onclick*="aptcha"] *,
body:has(#regForm)  button[onclick*="aptcha"] * {
  transition: transform .5s cubic-bezier(.4,0,.2,1),
              color .25s ease !important;
}
body:has(#loginForm) button[onclick*="aptcha"]:hover,
body:has(#regForm)  button[onclick*="aptcha"]:hover {
  transform: rotate(180deg);
  color: #ff9933 !important;
}

/* 11. Turnstile widget subtle pulse on hover */
body:has(#loginForm) .cf-turnstile,
body:has(#regForm)  .cf-turnstile {
  transition: transform .35s ease, filter .35s ease;
  border-radius: 8px;
}
body:has(#loginForm) .cf-turnstile:hover,
body:has(#regForm)  .cf-turnstile:hover {
  transform: scale(1.025);
  filter: drop-shadow(0 8px 18px rgba(255,122,24,.25));
}

/* 12. Checkbox / radio - subtle scale */
#loginForm input[type="checkbox"],
#regForm  input[type="checkbox"],
#loginForm input[type="radio"],
#regForm  input[type="radio"] {
  transition: transform .25s ease, box-shadow .25s ease !important;
  cursor: pointer;
}
#loginForm input[type="checkbox"]:hover,
#regForm  input[type="checkbox"]:hover,
#loginForm input[type="radio"]:hover,
#regForm  input[type="radio"]:hover {
  transform: scale(1.15);
  box-shadow: 0 0 0 4px rgba(255,122,24,.15);
}

/* 13. Outline buttons / secondary buttons (vd OTP request) */
#loginForm button:not([type="submit"]):not([onclick^="togglePw"]):not([onclick*="aptcha"]),
#regForm  button:not([type="submit"]):not([onclick^="togglePw"]):not([onclick*="aptcha"]) {
  transition: transform .25s ease,
              border-color .25s ease,
              background .25s ease,
              color .25s ease,
              box-shadow .25s ease !important;
}
#loginForm button:not([type="submit"]):not([onclick^="togglePw"]):not([onclick*="aptcha"]):hover,
#regForm  button:not([type="submit"]):not([onclick^="togglePw"]):not([onclick*="aptcha"]):hover {
  transform: translateY(-1px);
  box-shadow: 0 8px 18px -8px rgba(255,122,24,.4);
}

/* 14. Form section initial entrance animation */
@keyframes x66AuthFadeUp {
  from { opacity: 0; transform: translateY(20px); }
  to   { opacity: 1; transform: translateY(0); }
}
body:has(#loginForm) section.rounded-2xl,
body:has(#regForm)  section.rounded-2xl {
  animation: x66AuthFadeUp .55s cubic-bezier(.4,0,.2,1) both;
}
body:has(#loginForm) .text-center.mb-5,
body:has(#regForm)  .text-center.mb-5 {
  animation: x66AuthFadeUp .45s cubic-bezier(.4,0,.2,1) both;
  animation-delay: .05s;
}

/* 15. Respect reduced-motion preference */
@media (prefers-reduced-motion: reduce) {
  body:has(#loginForm) *,
  body:has(#regForm)  * {
    animation-duration: .01ms !important;
    transition-duration: .01ms !important;
  }
}
</style>
