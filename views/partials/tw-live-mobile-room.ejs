    <div class="p-2">
      <% if (match.status !== 'finished') { %>
      <form id="mobilePredictForm" class="space-y-2"
            data-match-id="<%= match.id %>"
            data-ou-line="<%= _mOuLine %>"
            data-ah-line="<%= _mAhLine %>"
            data-odds-tai="<%= _mOuTai || '' %>"
            data-odds-xiu="<%= _mOuXiu || '' %>"
            data-odds-ah-home="<%= _mAhHome || '' %>"
            data-odds-ah-away="<%= _mAhAway || '' %>">

        <div class="bg-bg-card border border-line rounded-lg p-2.5">
          <div class="text-[10px] text-pri-light font-bold uppercase mb-1.5">Tài/Xỉu · Mốc <%= _mOuLine %></div>
          <div class="grid grid-cols-2 gap-1.5">
            <label class="m-pick-btn">
              <input type="radio" name="m_pickOU" value="tai" class="sr-only">
              <span class="text-[11px] font-black text-white">TÀI</span>
              <% if (_mOuTai) { %><span class="m-pick-odds"><%= _mOuTai.toFixed(2) %></span><% } %>
            </label>
            <label class="m-pick-btn">
              <input type="radio" name="m_pickOU" value="xiu" class="sr-only">
              <span class="text-[11px] font-black text-white">XỈU</span>
              <% if (_mOuXiu) { %><span class="m-pick-odds"><%= _mOuXiu.toFixed(2) %></span><% } %>
            </label>
          </div>
        </div>

        <div class="bg-bg-card border border-line rounded-lg p-2.5">
          <div class="text-[10px] text-pri-light font-bold uppercase mb-1.5">Kèo Chấp · Line <%= _mAhLine %></div>
          <div class="grid grid-cols-2 gap-1.5">
            <label class="m-pick-btn">
              <input type="radio" name="m_pickAH" value="home" class="sr-only">
              <span class="text-[10px] font-bold text-white truncate"><%= match.home %></span>
              <% if (_mAhHome) { %><span class="m-pick-odds"><%= _mAhHome.toFixed(2) %></span><% } %>
            </label>
            <label class="m-pick-btn">
              <input type="radio" name="m_pickAH" value="away" class="sr-only">
              <span class="text-[10px] font-bold text-white truncate"><%= match.away %></span>
              <% if (_mAhAway) { %><span class="m-pick-odds"><%= _mAhAway.toFixed(2) %></span><% } %>
            </label>
          </div>
        </div>

        <div class="flex gap-1.5">
          <input type="number" id="mobileStakeInput" name="stake" value="50" min="10" max="10000" step="10"
                 class="flex-1 bg-bg-deep border border-line text-white px-2.5 py-1.5 rounded text-[12px] outline-none focus:border-pri tabular-nums" placeholder="X COIN">
          <button type="submit" class="bg-pri text-white px-3 rounded font-extrabold text-[11px]">🎯 ĐẶT</button>
        </div>
        <div id="mobilePredictRes" class="hidden text-center text-[11px] font-bold"></div>
        <div class="text-[10px] text-muted text-center">Đoán đúng nhận X COIN · <a href="/cao-thu" class="text-pri-light">BXH cao thủ →</a></div>
      </form>
      <% } else { %>
        <div class="text-center text-muted text-[12px] py-6">Trận đã kết thúc</div>
      <% } %>
    </div>
  </div>

  <!-- TAB OTHER (trận khác) -->
  <div class="mobile-tab-panel" data-panel="other">
    <div class="p-2">
      <% if (typeof others !== 'undefined' && others && others.length > 0) { %>
        <div class="grid grid-cols-2 gap-2">
          <% others.slice(0, 8).forEach(function(o){ %>
            <a href="/live/<%= o.slug || o.id %>" class="bg-bg-card border border-line hover:border-pri rounded-md p-2 block">
              <div class="text-[9px] text-muted truncate mb-1"><%= o.league || '' %></div>
              <div class="text-[10px] text-white truncate"><%= o.home || '' %></div>
              <div class="text-[10px] text-white truncate"><%= o.away || '' %></div>
              <div class="mt-1 flex items-center justify-between">
                <span class="text-[9px] text-pri-light"><%= o.time || '' %></span>
                <% if (o.isLive) { %>
                  <span class="text-[8px] bg-live text-white px-1 rounded font-black">LIVE</span>
                <% } %>
              </div>
            </a>
          <% }); %>
        </div>
      <% } else { %>
        <div class="text-center text-muted text-[12px] py-6">
          <div class="text-3xl mb-2 opacity-50">⚡</div>
          Chưa có trận khác live
        </div>
      <% } %>
    </div>
  </div>
</div>

