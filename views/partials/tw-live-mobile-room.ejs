<%
// ═══════════════════════════════════════════════════════════════════
// 📱 PARTIAL: PHÒNG LIVE BÓNG ĐÁ - LAYOUT MOBILE (style xoilac/8xbet)
// Used by: tw-live.ejs - chỉ render khi viewport < 1024px (lg breakpoint)
// Required vars from parent: match, partner, liveBlvs?, blvStreamKey?,
//                            hasObs?, liveOdds?, matchInsights?, others?
// ═══════════════════════════════════════════════════════════════════

// Compute lại các biến predict (parent có nhưng partial cần local copy)
var _mHasBlvStream = (typeof blvStreamKey !== 'undefined' && blvStreamKey);
var _mHasObs = (typeof hasObs !== 'undefined' && hasObs);
var _mHasOdds = (typeof liveOdds !== 'undefined' && liveOdds && (liveOdds.ah || liveOdds.ou || liveOdds.x12));
var _mOuLine = (_mHasOdds && liveOdds.ou && typeof liveOdds.ou.line === 'number') ? liveOdds.ou.line : 2.5;
var _mAhLine = (_mHasOdds && liveOdds.ah && typeof liveOdds.ah.line === 'number') ? liveOdds.ah.line : 0.5;
var _mOuTai = (_mHasOdds && liveOdds.ou && typeof liveOdds.ou.taiOdds === 'number') ? liveOdds.ou.taiOdds : null;
var _mOuXiu = (_mHasOdds && liveOdds.ou && typeof liveOdds.ou.xiuOdds === 'number') ? liveOdds.ou.xiuOdds : null;
var _mAhHome = (_mHasOdds && liveOdds.ah && typeof liveOdds.ah.homeOdds === 'number') ? liveOdds.ah.homeOdds : null;
var _mAhAway = (_mHasOdds && liveOdds.ah && typeof liveOdds.ah.awayOdds === 'number') ? liveOdds.ah.awayOdds : null;
var _mHomeShort = (match.home||'').slice(0, 3).toUpperCase();
var _mAwayShort = (match.away||'').slice(0, 3).toUpperCase();
var _mLiveBlvs = (typeof liveBlvs !== 'undefined' && Array.isArray(liveBlvs)) ? liveBlvs : [];
var _mInsights = (typeof matchInsights !== 'undefined' && matchInsights) ? matchInsights : null;
var _mViewers = ((match.viewers || match.viewerCount || (Math.random()*8000|0)+2000));
%>

<!-- ═══ TOP BANNER CTA CƯỢC ═══ -->
<a href="<%= partner.sportbet %>" target="_blank" rel="noopener"
   class="block bg-gradient-to-r from-pri via-orange-500 to-yellow-500 px-3 py-2 -mx-3 mb-2 sm:mx-0 sm:rounded-lg flex items-center gap-2 active:opacity-90">
  <span class="text-base flex-shrink-0">🎓</span>
  <span class="text-white text-xs font-extrabold flex-1 truncate uppercase tracking-wide">Đặt Cược XOSO66 Uy Tín Nhất Hiện Nay</span>
  <span class="text-white/90 text-[10px] font-bold flex-shrink-0">CƯỢC NGAY →</span>
</a>

<!-- ═══ VIDEO PLAYER MOBILE — SLOT để JS move #livePlayer vào ═══ -->
<!-- KHÔNG include partial tw-live-video-player ở đây (sẽ duplicate FLV instance).
     Mobile dùng CHUNG #livePlayer element với desktop, JS sẽ TELEPORT vào slot này. -->
<div id="mobilePlayerSlot" class="aspect-video relative rounded-xl overflow-hidden border border-line bg-black">
  <!-- Score overlay top-left (đè lên video sau khi #livePlayer được move vào) -->
  <div class="absolute top-1.5 left-1.5 bg-black/75 backdrop-blur px-2 py-1 rounded flex items-center gap-1.5 text-white text-[11px] font-bold pointer-events-none z-[20] m-player-overlay">
    <span class="text-yellow-300 tabular-nums"><%= match.time || '--:--' %></span>
    <% if (match.homeBadge) { %>
      <img src="<%= match.homeBadge %>" alt="" class="w-4 h-4 rounded-full bg-white/90 p-px" onerror="this.style.display='none'">
    <% } else { %>
      <span class="w-4 h-4 rounded-full bg-pri grid place-items-center text-[7px] text-white"><%= _mHomeShort.slice(0,2) %></span>
    <% } %>
    <span class="tabular-nums"><%= match.score ? match.score[0] : '0' %></span>
    <span class="text-yellow-300">-</span>
    <span class="tabular-nums"><%= match.score ? match.score[1] : '0' %></span>
    <% if (match.awayBadge) { %>
      <img src="<%= match.awayBadge %>" alt="" class="w-4 h-4 rounded-full bg-white/90 p-px" onerror="this.style.display='none'">
    <% } else { %>
      <span class="w-4 h-4 rounded-full bg-indigo-600 grid place-items-center text-[7px] text-white"><%= _mAwayShort.slice(0,2) %></span>
    <% } %>
  </div>

  <!-- Logo brand top-right -->
  <div class="absolute top-1.5 right-1.5 bg-live text-white px-2 py-1 rounded text-[10px] font-black tracking-wider pointer-events-none z-10 m-player-overlay">XOSO66.TV</div>

  <!-- 🎛 CUSTOM CONTROLS top-right (dưới brand): VOLUME + FULLSCREEN -->
  <!-- Luôn visible, click được. Bổ sung cho native controls có thể bị che. -->
  <div class="absolute top-9 right-1.5 z-[15] flex gap-1 m-player-overlay">
    <button type="button" id="mobileVolumeBtn" aria-label="Bật/tắt âm thanh"
            class="w-7 h-7 grid place-items-center bg-black/70 backdrop-blur text-white rounded-md hover:bg-black active:scale-95 transition">
      <svg id="mobileVolumeIcon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
        <line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/>
      </svg>
    </button>
    <button type="button" id="mobileFullscreenBtn" aria-label="Phóng to / Thu nhỏ"
            class="w-7 h-7 grid place-items-center bg-black/70 backdrop-blur text-white rounded-md hover:bg-black active:scale-95 transition">
      <svg id="mobileFullscreenIcon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M8 3H5a2 2 0 0 0-2 2v3"/><path d="M21 8V5a2 2 0 0 0-2-2h-3"/>
        <path d="M3 16v3a2 2 0 0 0 2 2h3"/><path d="M16 21h3a2 2 0 0 0 2-2v-3"/>
      </svg>
    </button>
  </div>

  <!-- LIVE badge bottom-left -->
  <% if (_mHasBlvStream || _mHasObs) { %>
  <div class="absolute bottom-1.5 left-1.5 bg-pri text-white px-2 py-0.5 rounded text-[9px] font-black tracking-wider pointer-events-none z-10 flex items-center gap-1 m-player-overlay">
    <span class="w-1.5 h-1.5 bg-white rounded-full animate-pulse"></span>LIVE
  </div>
  <% } %>

  <!-- Viewers bottom-right -->
  <div class="absolute bottom-1.5 right-1.5 bg-black/65 text-white px-1.5 py-0.5 rounded text-[9px] font-bold pointer-events-none z-10 flex items-center gap-1 tabular-nums m-player-overlay">
    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
    <%= _mViewers.toLocaleString('vi-VN') %>
  </div>
</div>

<!-- ═══ QUALITY SELECTOR BAR ═══ -->
<div class="mt-1.5 flex gap-1 overflow-x-auto scrollbar-thin" id="mobileQualityBar">
  <button type="button" data-quality="hd" data-key="<%= blvStreamKey || '' %>"
          class="quality-btn-m active flex items-center gap-1.5 px-2.5 py-1.5 rounded-md text-[11px] font-extrabold whitespace-nowrap flex-shrink-0">
    <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><rect x="6" y="4" width="4" height="16" rx="1"/><rect x="14" y="4" width="4" height="16" rx="1"/></svg>HD MAX
  </button>
  <button type="button" data-quality="720" data-key="<%= blvStreamKey || '' %>"
          class="quality-btn-m flex items-center gap-1.5 px-2.5 py-1.5 rounded-md text-[11px] font-bold whitespace-nowrap flex-shrink-0">
    <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="5 3 19 12 5 21 5 3"/></svg>720p
  </button>
  <button type="button" data-quality="480" data-key="<%= blvStreamKey || '' %>"
          class="quality-btn-m flex items-center gap-1.5 px-2.5 py-1.5 rounded-md text-[11px] font-bold whitespace-nowrap flex-shrink-0">
    <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="5 3 19 12 5 21 5 3"/></svg>SD 480
  </button>
  <button type="button" data-quality="mobile" data-key="<%= blvStreamKey || '' %>"
          class="quality-btn-m flex items-center gap-1.5 px-2.5 py-1.5 rounded-md text-[11px] font-bold whitespace-nowrap flex-shrink-0">
    <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="5 3 19 12 5 21 5 3"/></svg>Mobile
  </button>
  <button type="button" id="mobileShareBtn"
          class="ml-auto flex items-center gap-1.5 px-2.5 py-1.5 rounded-md text-[11px] font-bold whitespace-nowrap flex-shrink-0 bg-bg-card border border-pri text-pri-light">
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
    <span id="mobileShareBtnLabel">CHIA SẺ</span>
  </button>
</div>

<!-- ═══ SCORE BAR (Home vs Away big) ═══ -->
<div class="mt-1.5 bg-bg-card border border-line rounded-lg px-2.5 py-2 flex items-center gap-2">
  <div class="flex items-center gap-1.5 flex-1 min-w-0">
    <% if (match.homeBadge) { %>
      <img src="<%= match.homeBadge %>" alt="<%= match.home %>" class="w-7 h-7 rounded-full bg-white p-0.5 flex-shrink-0" onerror="this.style.display='none'">
    <% } else { %>
      <span class="w-7 h-7 rounded-full bg-pri grid place-items-center text-white text-[10px] font-black flex-shrink-0"><%= _mHomeShort.slice(0,2) %></span>
    <% } %>
    <span class="text-white text-[12px] font-bold truncate"><%= match.home %></span>
  </div>
  <div class="text-lg font-black text-gold tabular-nums px-2 flex-shrink-0">
    <%= match.score ? match.score[0] : '--' %> : <%= match.score ? match.score[1] : '--' %>
  </div>
  <div class="flex items-center gap-1.5 flex-1 min-w-0 justify-end">
    <span class="text-white text-[12px] font-bold truncate text-right"><%= match.away %></span>
    <% if (match.awayBadge) { %>
      <img src="<%= match.awayBadge %>" alt="<%= match.away %>" class="w-7 h-7 rounded-full bg-white p-0.5 flex-shrink-0" onerror="this.style.display='none'">
    <% } else { %>
      <span class="w-7 h-7 rounded-full bg-indigo-600 grid place-items-center text-white text-[10px] font-black flex-shrink-0"><%= _mAwayShort.slice(0,2) %></span>
    <% } %>
  </div>
</div>

<!-- ═══ BLV ROW (nếu có) ═══ -->
<% if (_mLiveBlvs.length > 0) { %>
<div class="mt-1.5 flex gap-1.5 overflow-x-auto scrollbar-thin py-1">
  <% _mLiveBlvs.forEach(function(b, i){ %>
    <div class="flex items-center gap-1.5 bg-bg-card border <%= i===0?'border-pri':'border-line' %> px-2 py-1 rounded-full text-[10px] font-bold whitespace-nowrap flex-shrink-0">
      <% if (b.avatar) { %>
        <img src="<%= b.avatar %>" alt="" class="w-4 h-4 rounded-full">
      <% } else { %>
        <span class="w-4 h-4 rounded-full bg-gradient-to-br from-pri to-rose-500 grid place-items-center text-[8px]">🎙️</span>
      <% } %>
      <span class="<%= i===0?'text-pri-light':'text-white' %>"><%= b.name %></span>
      <% if (b.isLive) { %><span class="w-1 h-1 bg-live rounded-full animate-pulse"></span><% } %>
    </div>
  <% }); %>
</div>
<% } %>

<!-- ═══ BANNER PARTNER ═══ -->
<a href="<%= partner.register %>" target="_blank" rel="noopener"
   class="mt-2 flex items-center gap-2 bg-bg-card border border-pri/50 rounded-lg px-2.5 py-1.5 active:opacity-90">
  <div class="w-8 h-8 bg-pri rounded-md grid place-items-center text-white text-xs font-black flex-shrink-0">66</div>
  <div class="flex-1 min-w-0">
    <div class="text-pri-light text-[11px] font-extrabold">XOSO66</div>
    <div class="text-white text-[10px]">Hoàn tiền 100% vé cược đầu tiên</div>
  </div>
  <span class="bg-pri text-white text-[10px] font-extrabold px-2.5 py-1 rounded">CƯỢC NGAY</span>
</a>

<!-- ═══ TAB NAVIGATION ═══ -->
<div class="mt-2 bg-bg-deep border border-line rounded-lg overflow-hidden">
  <div class="flex border-b border-line overflow-x-auto scrollbar-thin" id="mobileLiveTabs" role="tablist">
    <button type="button" data-tab="chat" class="mobile-tab-btn active" aria-label="Chat">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
      <span class="text-[9px]">CHAT</span>
    </button>
    <button type="button" data-tab="info" class="mobile-tab-btn" aria-label="Thông tin">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="13" y2="17"/></svg>
      <span class="text-[9px]">Thông tin</span>
    </button>
    <button type="button" data-tab="odds" class="mobile-tab-btn" aria-label="Tỷ lệ">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/><line x1="3" y1="20" x2="21" y2="20"/></svg>
      <span class="text-[9px]">Tỷ lệ</span>
    </button>
    <button type="button" data-tab="h2h" class="mobile-tab-btn" aria-label="H2H">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="14.5 17.5 3 6 3 3 6 3 17.5 14.5"/><line x1="13" y1="19" x2="19" y2="13"/><line x1="16" y1="16" x2="20" y2="20"/><line x1="19" y1="21" x2="21" y2="19"/><polyline points="14.5 6.5 18 3 21 3 21 6 17.5 9.5"/><line x1="5" y1="14" x2="9" y2="18"/><line x1="7" y1="17" x2="4" y2="20"/><line x1="3" y1="19" x2="5" y2="21"/></svg>
      <span class="text-[9px]">H2H</span>
    </button>
    <button type="button" data-tab="form" class="mobile-tab-btn" aria-label="Phong độ">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
      <span class="text-[9px]">Phong độ</span>
    </button>
    <button type="button" data-tab="predict" class="mobile-tab-btn" aria-label="Dự đoán">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
      <span class="text-[9px]">Dự đoán</span>
    </button>
    <button type="button" data-tab="other" class="mobile-tab-btn" aria-label="Trận khác">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
      <span class="text-[9px]">Trận khác</span>
    </button>
  </div>

  <!-- ═══ TAB PANELS ═══ -->

  <!-- TAB CHAT (default active) -->
  <div class="mobile-tab-panel active" data-panel="chat">
    <!-- Social buttons row -->
    <div class="flex gap-1.5 p-2 border-b border-line bg-bg-soft">
      <a href="https://t.me/xoso66tv" target="_blank" rel="noopener"
         class="flex-1 bg-sky-500 hover:bg-sky-600 text-white py-1.5 rounded text-[10px] font-extrabold text-center flex items-center justify-center gap-1.5">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M9.78 18.65l.28-4.23 7.68-6.92c.34-.31-.07-.46-.52-.19L7.74 13.3 3.64 12c-.88-.25-.89-.86.2-1.3l15.97-6.16c.73-.33 1.43.18 1.15 1.3l-2.72 12.81c-.19.91-.74 1.13-1.5.71L12.6 16.3l-1.99 1.93c-.23.23-.42.42-.83.42z"/></svg>
        TELEGRAM
      </a>
      <a href="https://facebook.com/xoso66tv" target="_blank" rel="noopener"
         class="flex-1 bg-blue-600 hover:bg-blue-700 text-white py-1.5 rounded text-[10px] font-extrabold text-center flex items-center justify-center gap-1.5">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        FACEBOOK
      </a>
      <button type="button" id="mobileChatToggleBtn"
              class="bg-bg-card border border-line text-muted py-1.5 px-2.5 rounded text-[10px] font-bold whitespace-nowrap flex items-center gap-1">
        <svg id="mobileChatToggleIcon" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13.73 21a2 2 0 0 1-3.46 0"/><path d="M18.63 13A17.89 17.89 0 0 1 18 8"/><path d="M6.26 6.26A5.86 5.86 0 0 0 6 8c0 7-3 9-3 9h14"/><path d="M18 8a6 6 0 0 0-9.33-5"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
        <span id="mobileChatToggleLabel">TẮT</span>
      </button>
    </div>
    <!-- Online counter -->
    <div class="px-2.5 py-1.5 bg-bg-soft border-b border-line text-[10px] text-muted flex items-center justify-between">
      <span class="text-emerald-400 flex items-center gap-1">
        <span class="w-1.5 h-1.5 bg-emerald-400 rounded-full animate-pulse"></span>
        <span id="mobileOnlineCount"><%= ((Math.random()*3000|0)+1500).toLocaleString('vi-VN') %></span> online
      </span>
      <span>Bình luận: <b class="text-pri-light tabular-nums"><%= ((Math.random()*5000|0)+1000).toLocaleString('vi-VN') %></b></span>
    </div>
    <!-- Chat body -->
    <div id="mobileChatBody" class="overflow-y-auto scrollbar-thin px-1" style="height:260px"></div>
    <!-- Input -->
    <div class="flex gap-1.5 p-2 border-t border-line bg-bg-soft">
      <button type="button" class="text-yellow-400 text-lg leading-none" aria-label="Emoji">😊</button>
      <input id="mobileChatInput" maxlength="200"
             class="flex-1 bg-bg-deep border border-line text-gray-100 px-2.5 py-1.5 rounded-full text-[11px] outline-none focus:border-pri"
             placeholder="Gõ tin nhắn..."
             onkeydown="if(event.key==='Enter')sendChat('mobileChatInput','mobileChatBody')">
      <button type="button" onclick="sendChat('mobileChatInput','mobileChatBody')"
              class="bg-pri text-white px-3 rounded-full text-[11px] font-extrabold">Gửi</button>
    </div>
  </div>

  <!-- TAB INFO -->
  <div class="mobile-tab-panel" data-panel="info">
    <div class="p-3 space-y-1.5 text-[12px]">
      <div class="flex gap-2 text-muted py-1 border-b border-dashed border-line"><b class="text-white min-w-[100px]">🏆 Giải:</b> <%= match.league %></div>
      <div class="flex gap-2 text-muted py-1 border-b border-dashed border-line"><b class="text-white min-w-[100px]">⚽ Môn:</b> <%= match.sport %></div>
      <div class="flex gap-2 text-muted py-1 border-b border-dashed border-line"><b class="text-white min-w-[100px]">⏰ Giờ VN:</b> <%= match.date %> <%= match.time %></div>
      <% if (match.venue) { %><div class="flex gap-2 text-muted py-1 border-b border-dashed border-line"><b class="text-white min-w-[100px]">🏟 Sân:</b> <%= match.venue %></div><% } %>
      <% if (match.round) { %><div class="flex gap-2 text-muted py-1 border-b border-dashed border-line"><b class="text-white min-w-[100px]">🔢 Vòng:</b> <%= match.round %></div><% } %>
      <% if (match.season) { %><div class="flex gap-2 text-muted py-1 border-b border-dashed border-line"><b class="text-white min-w-[100px]">📅 Mùa:</b> <%= match.season %></div><% } %>
      <div class="flex gap-2 text-muted py-1"><b class="text-white min-w-[100px]">📺 Chất lượng:</b> Full HD 1080p, BLV tiếng Việt</div>
    </div>
  </div>

  <!-- TAB ODDS (tỷ lệ kèo) -->
  <div class="mobile-tab-panel" data-panel="odds">
    <div class="p-2 space-y-2">
      <% if (_mHasOdds) { %>
        <!-- Tài / Xỉu -->
        <% if (_mOuTai && _mOuXiu) { %>
        <div class="bg-bg-card border border-line rounded-lg p-2.5">
          <div class="flex items-center justify-between mb-1.5">
            <span class="text-[11px] text-pri-light font-bold uppercase">Tài/Xỉu</span>
            <span class="text-[10px] text-yellow-300 font-bold">Mốc <%= _mOuLine %></span>
          </div>
          <div class="grid grid-cols-2 gap-2">
            <div class="bg-bg-deep border border-line rounded-md p-2 text-center">
              <div class="text-[10px] text-muted mb-0.5">TÀI (&gt;<%= _mOuLine %>)</div>
              <div class="text-emerald-400 font-black text-base tabular-nums"><%= _mOuTai.toFixed(2) %></div>
            </div>
            <div class="bg-bg-deep border border-line rounded-md p-2 text-center">
              <div class="text-[10px] text-muted mb-0.5">XỈU (&lt;<%= _mOuLine %>)</div>
              <div class="text-rose-400 font-black text-base tabular-nums"><%= _mOuXiu.toFixed(2) %></div>
            </div>
          </div>
        </div>
        <% } %>
        <!-- Kèo chấp -->
        <% if (_mAhHome && _mAhAway) { %>
        <div class="bg-bg-card border border-line rounded-lg p-2.5">
          <div class="flex items-center justify-between mb-1.5">
            <span class="text-[11px] text-pri-light font-bold uppercase">Kèo Chấp</span>
            <span class="text-[10px] text-yellow-300 font-bold">Line <%= _mAhLine %></span>
          </div>
          <div class="grid grid-cols-2 gap-2">
            <div class="bg-bg-deep border border-line rounded-md p-2 text-center">
              <div class="text-[10px] text-muted mb-0.5 truncate"><%= match.home %></div>
              <div class="text-emerald-400 font-black text-base tabular-nums"><%= _mAhHome.toFixed(2) %></div>
            </div>
            <div class="bg-bg-deep border border-line rounded-md p-2 text-center">
              <div class="text-[10px] text-muted mb-0.5 truncate"><%= match.away %></div>
              <div class="text-rose-400 font-black text-base tabular-nums"><%= _mAhAway.toFixed(2) %></div>
            </div>
          </div>
        </div>
        <% } %>
        <a href="<%= partner.sportbet %>" target="_blank" rel="noopener"
           class="block bg-gradient-to-r from-pri to-live text-white text-center py-2 rounded-md text-[11px] font-extrabold">💰 ĐẶT CƯỢC NGAY</a>
      <% } else { %>
        <div class="text-center text-muted text-[12px] py-6">
          <div class="text-3xl mb-2 opacity-50">📊</div>
          Tỷ lệ kèo đang cập nhật...
        </div>
      <% } %>
    </div>
  </div>

  <!-- TAB H2H -->
  <div class="mobile-tab-panel" data-panel="h2h">
    <div class="p-2">
      <% if (_mInsights && _mInsights.h2h && _mInsights.h2h.length > 0) { %>
        <div class="text-[11px] text-pri-light font-bold uppercase mb-2 px-1">Đối đầu gần nhất</div>
        <div class="space-y-1.5">
          <% _mInsights.h2h.slice(0, 8).forEach(function(m){ %>
            <div class="bg-bg-card border border-line rounded-md p-2 flex items-center text-[11px]">
              <span class="text-muted flex-shrink-0 mr-2 tabular-nums"><%= m.date || '' %></span>
              <span class="text-white truncate flex-1 text-right pr-1.5"><%= m.home %></span>
              <span class="text-gold font-black tabular-nums px-1.5 flex-shrink-0"><%= m.score || '--:--' %></span>
              <span class="text-white truncate flex-1 pl-1.5"><%= m.away %></span>
            </div>
          <% }); %>
        </div>
      <% } else { %>
        <div class="text-center text-muted text-[12px] py-6">
          <div class="text-3xl mb-2 opacity-50">⚔️</div>
          Chưa có dữ liệu đối đầu
        </div>
      <% } %>
    </div>
  </div>

  <!-- TAB FORM (phong độ) -->
  <div class="mobile-tab-panel" data-panel="form">
    <div class="p-2 space-y-3">
      <% if (_mInsights && (_mInsights.formHome || _mInsights.formAway)) { %>
        <% if (_mInsights.formHome && _mInsights.formHome.length > 0) { %>
        <div>
          <div class="text-[11px] text-pri-light font-bold uppercase mb-1.5 px-1"><%= match.home %> - 5 trận gần nhất</div>
          <div class="flex gap-1">
            <% _mInsights.formHome.slice(0,5).forEach(function(r){
              var color = r === 'W' ? 'bg-emerald-500' : (r === 'L' ? 'bg-rose-500' : 'bg-gray-500');
              var label = r === 'W' ? 'T' : (r === 'L' ? 'B' : 'H'); %>
              <span class="<%= color %> text-white text-[11px] font-black w-7 h-7 rounded-md grid place-items-center"><%= label %></span>
            <% }); %>
          </div>
        </div>
        <% } %>
        <% if (_mInsights.formAway && _mInsights.formAway.length > 0) { %>
        <div>
          <div class="text-[11px] text-pri-light font-bold uppercase mb-1.5 px-1"><%= match.away %> - 5 trận gần nhất</div>
          <div class="flex gap-1">
            <% _mInsights.formAway.slice(0,5).forEach(function(r){
              var color = r === 'W' ? 'bg-emerald-500' : (r === 'L' ? 'bg-rose-500' : 'bg-gray-500');
              var label = r === 'W' ? 'T' : (r === 'L' ? 'B' : 'H'); %>
              <span class="<%= color %> text-white text-[11px] font-black w-7 h-7 rounded-md grid place-items-center"><%= label %></span>
