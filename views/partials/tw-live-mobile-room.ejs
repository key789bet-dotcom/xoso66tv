  /* Player overlay auto-hide animation */
  .m-player-overlay { transition: opacity .25s ease, transform .25s ease; }
  #mobilePlayerSlot.player-clean .m-player-overlay { opacity: 0; pointer-events: none; }
  /* Khi fullscreen, slot fill toàn màn */
  #mobilePlayerSlot:fullscreen { background: #000; }
  #mobilePlayerSlot:fullscreen video { object-fit: contain; }
</style>

<!-- ═══ JS: TAB SWITCH + QUALITY SELECTOR + CHAT + PREDICT ═══ -->
<script>
(function(){
  // ─── 0. TELEPORT #livePlayer (desktop) → #mobilePlayerSlot khi viewport mobile ───
  // Lý do: tw-live-video-player.ejs render TRONG desktop layout (hidden lg:block),
  // mobile layout cần CÙNG video element (không thể duplicate FLV.js instance).
  // → MOVE DOM element giữa 2 wrappers theo viewport, KHÔNG restart player.
  var mediaMobile = window.matchMedia('(max-width: 1023px)');
  var __origPlayerParent = null;  // remember để move back lên desktop
  function teleportPlayer(){
    var player = document.getElementById('livePlayer');
    var slot   = document.getElementById('mobilePlayerSlot');
    if (!player || !slot) return;
    if (mediaMobile.matches) {
      // Mobile: move vào slot mobile (nếu chưa)
      if (player.parentNode !== slot) {
        if (!__origPlayerParent) __origPlayerParent = player.parentNode;
        // remove aspect-video + bg-black class trên #livePlayer khi mobile
        // (slot mobile đã có aspect-video → tránh double box)
        player.classList.remove('aspect-video', 'rounded-xl', 'bg-black');
        // make #livePlayer absolute fill slot
        player.style.position = 'absolute';
        player.style.inset = '0';
        player.style.width = '100%';
        player.style.height = '100%';
        slot.appendChild(player);
      }
    } else {
      // Desktop: move về wrapper gốc (nếu trước đó đã move sang mobile)
      if (__origPlayerParent && player.parentNode !== __origPlayerParent) {
        player.classList.add('aspect-video', 'rounded-xl', 'bg-black');
        player.style.position = '';
        player.style.inset = '';
        player.style.width = '';
        player.style.height = '';
        // prepend để giữ đúng thứ tự (livePlayer là child đầu của container desktop)
        __origPlayerParent.insertBefore(player, __origPlayerParent.firstChild);
      }
    }
  }
  // Run ngay, và lắng nghe resize/orientation
  teleportPlayer();
  if (mediaMobile.addEventListener) mediaMobile.addEventListener('change', teleportPlayer);
  else if (mediaMobile.addListener) mediaMobile.addListener(teleportPlayer);

  // ─── 0.5. CUSTOM PLAYER CONTROLS: VOLUME + FULLSCREEN + AUTO-HIDE OVERLAY ───
  var slot = document.getElementById('mobilePlayerSlot');
  var volBtn = document.getElementById('mobileVolumeBtn');
  var volIcon = document.getElementById('mobileVolumeIcon');
  var fsBtn = document.getElementById('mobileFullscreenBtn');
  var fsIcon = document.getElementById('mobileFullscreenIcon');
  // SVG paths
  var VOL_MUTE_SVG = '<polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/>';
  var VOL_UP_SVG   = '<polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/>';
  var FS_EXPAND_SVG  = '<path d="M8 3H5a2 2 0 0 0-2 2v3"/><path d="M21 8V5a2 2 0 0 0-2-2h-3"/><path d="M3 16v3a2 2 0 0 0 2 2h3"/><path d="M16 21h3a2 2 0 0 0 2-2v-3"/>';
  var FS_COLLAPSE_SVG = '<path d="M4 14h6v6"/><path d="M20 10h-6V4"/><path d="M14 10l7-7"/><path d="M3 21l7-7"/>';

  // Helper lấy video element (có thể chưa render xong nếu FLV chưa attach)
  function getVid(){ return document.getElementById('liveVideo'); }

  // 🔊 VOLUME: toggle muted
  if (volBtn) {
    volBtn.addEventListener('click', function(e){
      e.stopPropagation();  // không trigger overlay toggle
      var v = getVid();
      if (!v) return;
      v.muted = !v.muted;
      if (!v.muted && v.volume < 0.1) v.volume = 0.7;  // ensure hearable
      volIcon.innerHTML = v.muted ? VOL_MUTE_SVG : VOL_UP_SVG;
    });
    // Sync icon trên load + khi video change muted state
    var syncVolIcon = function(){
      var v = getVid();
      if (!v) return;
      volIcon.innerHTML = v.muted ? VOL_MUTE_SVG : VOL_UP_SVG;
    };
    // Initial check sau 500ms (chờ video element render)
    setTimeout(syncVolIcon, 500);
    // Watch video muted change (e.g., user dùng native controls)
    setInterval(syncVolIcon, 2000);
  }

  // ⛶ FULLSCREEN: toggle on slot
  if (fsBtn && slot) {
    fsBtn.addEventListener('click', function(e){
      e.stopPropagation();
      var isFs = document.fullscreenElement === slot || document.webkitFullscreenElement === slot;
      try {
        if (!isFs) {
          // iOS Safari: webkitEnterFullscreen trên video element (không phải slot)
          var v = getVid();
          if (v && typeof v.webkitEnterFullscreen === 'function') {
            v.webkitEnterFullscreen();
          } else if (slot.requestFullscreen) {
            slot.requestFullscreen();
          } else if (slot.webkitRequestFullscreen) {
            slot.webkitRequestFullscreen();
          }
        } else {
          if (document.exitFullscreen) document.exitFullscreen();
          else if (document.webkitExitFullscreen) document.webkitExitFullscreen();
        }
      } catch(err) { console.warn('[mobile-fs]', err.message); }
    });
    // Update icon khi fullscreen state thay đổi
    var syncFsIcon = function(){
      var isFs = document.fullscreenElement === slot || document.webkitFullscreenElement === slot;
      fsIcon.innerHTML = isFs ? FS_COLLAPSE_SVG : FS_EXPAND_SVG;
    };
    document.addEventListener('fullscreenchange', syncFsIcon);
    document.addEventListener('webkitfullscreenchange', syncFsIcon);
  }

  // 👆 AUTO-HIDE OVERLAY: tap vào slot → toggle .player-clean class
  // Mặc định visible. Tap 1 lần → ẩn 4s rồi hiện lại. Tap khi đang ẩn → hiện ngay.
  if (slot) {
    var hideTimer = null;
    function scheduleAutoHide(){
      if (hideTimer) clearTimeout(hideTimer);
      hideTimer = setTimeout(function(){ slot.classList.add('player-clean'); }, 4000);
    }
    slot.addEventListener('click', function(e){
      // Bỏ qua click vào custom controls (đã có stopPropagation), check fallback
      if (e.target.closest('#mobileVolumeBtn') || e.target.closest('#mobileFullscreenBtn')) return;
      if (slot.classList.contains('player-clean')) {
        slot.classList.remove('player-clean');
        scheduleAutoHide();
      } else {
        slot.classList.add('player-clean');
        if (hideTimer) { clearTimeout(hideTimer); hideTimer = null; }
      }
    });
    // Bắt đầu countdown auto-hide ngay sau khi player ready
    setTimeout(scheduleAutoHide, 1500);
  }

  // ─── 1. TAB SWITCHING ───
  var tabBtns = document.querySelectorAll('#mobileLiveTabs .mobile-tab-btn');
  var tabPanels = document.querySelectorAll('.mobile-tab-panel');
  tabBtns.forEach(function(btn){
    btn.addEventListener('click', function(){
      var key = btn.dataset.tab;
      tabBtns.forEach(function(b){ b.classList.remove('active'); });
      tabPanels.forEach(function(p){ p.classList.remove('active'); });
      btn.classList.add('active');
      var panel = document.querySelector('.mobile-tab-panel[data-panel="' + key + '"]');
      if (panel) panel.classList.add('active');
    });
  });

  // ─── 2. QUALITY SELECTOR ───
  var qBtns = document.querySelectorAll('.quality-btn-m');
  qBtns.forEach(function(btn){
    btn.addEventListener('click', function(){
      qBtns.forEach(function(b){ b.classList.remove('active'); });
      btn.classList.add('active');
      // Trigger reload player nếu có api swap stream URL
      var key = btn.dataset.key;
      var quality = btn.dataset.quality;
      if (key && window.x66SwapStreamQuality) {
        window.x66SwapStreamQuality(key, quality);
      }
    });
  });

  // ─── 3. SHARE BUTTON ───
  var shareBtn = document.getElementById('mobileShareBtn');
  var shareBtnLabel = document.getElementById('mobileShareBtnLabel');
  if (shareBtn && shareBtnLabel) {
    shareBtn.addEventListener('click', function(){
      var url = location.href;
      var title = document.title;
      if (navigator.share) {
        navigator.share({ title: title, url: url }).catch(function(){});
      } else if (navigator.clipboard) {
        navigator.clipboard.writeText(url).then(function(){
          shareBtnLabel.textContent = 'ĐÃ COPY';
          setTimeout(function(){ shareBtnLabel.textContent = 'CHIA SẺ'; }, 1500);
        });
      } else {
        prompt('Copy link:', url);
      }
    });
  }

  // ─── 4. CHAT TOGGLE ───
  // Swap text + icon path d="..." để giữ structure, KHÔNG dùng innerHTML
  var chatToggle = document.getElementById('mobileChatToggleBtn');
  var chatToggleIcon = document.getElementById('mobileChatToggleIcon');
  var chatToggleLabel = document.getElementById('mobileChatToggleLabel');
  var chatBody = document.getElementById('mobileChatBody');
  // SVG path string - bell on/off (feather icons style)
  var BELL_OFF_SVG = '<path d="M13.73 21a2 2 0 0 1-3.46 0"/><path d="M18.63 13A17.89 17.89 0 0 1 18 8"/><path d="M6.26 6.26A5.86 5.86 0 0 0 6 8c0 7-3 9-3 9h14"/><path d="M18 8a6 6 0 0 0-9.33-5"/><line x1="1" y1="1" x2="23" y2="23"/>';
  var BELL_ON_SVG  = '<path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/>';
  if (chatToggle && chatBody && chatToggleIcon && chatToggleLabel) {
    var isOff = false;
    chatToggle.addEventListener('click', function(){
      isOff = !isOff;
      if (isOff) {
        chatBody.style.opacity = '.3';
        chatBody.style.pointerEvents = 'none';
        chatToggleIcon.innerHTML = BELL_ON_SVG;
        chatToggleLabel.textContent = 'BẬT';
        chatToggle.classList.add('text-pri-light', 'border-pri');
      } else {
        chatBody.style.opacity = '1';
        chatBody.style.pointerEvents = 'auto';
        chatToggleIcon.innerHTML = BELL_OFF_SVG;
        chatToggleLabel.textContent = 'TẮT';
        chatToggle.classList.remove('text-pri-light', 'border-pri');
      }
    });
  }

  // ─── 5. PREDICT FORM ───
  var pForm = document.getElementById('mobilePredictForm');
  if (pForm) {
    pForm.addEventListener('submit', function(e){
      e.preventDefault();
      var matchId = pForm.dataset.matchId;
      var pickOU = (pForm.querySelector('input[name="m_pickOU"]:checked') || {}).value;
      var pickAH = (pForm.querySelector('input[name="m_pickAH"]:checked') || {}).value;
      var res = document.getElementById('mobilePredictRes');
      if (!pickOU && !pickAH) {
        res.className = 'text-center text-[11px] font-bold text-live';
        res.textContent = '⚠️ Chọn ít nhất 1 kèo';
        res.classList.remove('hidden');
        return;
      }
      var stake = parseInt(document.getElementById('mobileStakeInput').value, 10) || 50;
      var oddsTai = parseFloat(pForm.dataset.oddsTai) || null;
      var oddsXiu = parseFloat(pForm.dataset.oddsXiu) || null;
      var oddsAhHome = parseFloat(pForm.dataset.oddsAhHome) || null;
      var oddsAhAway = parseFloat(pForm.dataset.oddsAhAway) || null;
      var data = {
        matchId: matchId,
        home: <%- JSON.stringify(match.home||'') %>,
        away: <%- JSON.stringify(match.away||'') %>,
        league: <%- JSON.stringify(match.league||'') %>,
        pickOU: pickOU || null,
        pickAH: pickAH || null,
        stake: stake,
        oddsOU: pickOU === 'tai' ? oddsTai : (pickOU === 'xiu' ? oddsXiu : null),
        oddsAH: pickAH === 'home' ? oddsAhHome : (pickAH === 'away' ? oddsAhAway : null)
      };
      res.textContent = 'Đang gửi...';
      res.className = 'text-center text-[11px] font-bold text-muted';
      res.classList.remove('hidden');
      fetch('/api/predict', {
        method:'POST', headers:{'Content-Type':'application/json'}, credentials:'same-origin',
        body: JSON.stringify(data)
      }).then(function(r){return r.json();}).then(function(j){
        res.className = 'text-center text-[11px] font-bold ' + (j.ok ? 'text-emerald-300' : 'text-live');
        res.textContent = j.ok ? ('✅ ' + j.message) : ('❌ ' + (j.error || 'Lỗi'));
        if (j.error && j.error.indexOf('đăng nhập') !== -1) {
          setTimeout(function(){ location.href = '/dang-nhap?redirect=' + encodeURIComponent(location.pathname); }, 1500);
        }
      }).catch(function(){
        res.className = 'text-center text-[11px] font-bold text-live';
        res.textContent = '❌ Lỗi kết nối';
      });
    });

    // Load existing prediction
    var mid = pForm.dataset.matchId;
    if (mid) {
      fetch('/api/predict/my/' + encodeURIComponent(mid), { credentials: 'same-origin' })
        .then(function(r){return r.json();}).then(function(j){
          if (j.ok && j.prediction) {
            var p = j.prediction;
            if (p.pickOU) { var r1 = pForm.querySelector('input[name="m_pickOU"][value="' + p.pickOU + '"]'); if (r1) r1.checked = true; }
            if (p.pickAH) { var r2 = pForm.querySelector('input[name="m_pickAH"][value="' + p.pickAH + '"]'); if (r2) r2.checked = true; }
            if (p.stake) document.getElementById('mobileStakeInput').value = p.stake;
            var res = document.getElementById('mobilePredictRes');
            res.className = 'text-center text-[11px] font-bold text-emerald-300';
            res.textContent = '✅ Đã đặt cược ' + (p.stake || 0) + ' X COIN';
            res.classList.remove('hidden');
          }
        }).catch(function(){});
    }
  }

  // ─── 6. INIT CHAT cho mobileChatBody ───
  // Wait for chat-v2.js loaded (it's already loaded by parent tw-live.ejs)
  function tryInitMobileChat(retries){
    if (typeof startChat === 'function') {
      try {
        startChat('mobileChatBody', { isLive: !!window.__x66HasObs });
      } catch(e){}
    } else if (retries > 0) {
      setTimeout(function(){ tryInitMobileChat(retries - 1); }, 300);
    }
  }
  // Chỉ init chat mobile nếu thực sự ở viewport mobile (tránh duplicate khi resize)
  if (window.matchMedia('(max-width: 1023px)').matches) {
    tryInitMobileChat(10);
  }
})();
</script>
