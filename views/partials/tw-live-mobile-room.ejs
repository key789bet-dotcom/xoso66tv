        <% } %>
        <% if (_mInsights.pick) { %>
        <div class="bg-pri/10 border border-pri/40 rounded-md p-2.5">
          <div class="text-[10px] text-pri-light font-bold uppercase mb-1">🎯 Smart Pick</div>
          <div class="text-white text-[12px]"><%= _mInsights.pick %></div>
        </div>
        <% } %>
      <% } else { %>
        <div class="text-center text-muted text-[12px] py-6">
          <div class="text-3xl mb-2 opacity-50">📈</div>
          Đang cập nhật phong độ...
        </div>
      <% } %>
