/* ===== HERO TITLE ANIMATED BACKGROUND (giống logo header) ===== */
.hero-animated-bg { position: relative; overflow: hidden; isolation: isolate; }
.hero-animated-bg::before {
  content: ''; position: absolute; inset: 0;
  background:
    radial-gradient(ellipse at 20% 50%, rgba(255,122,24,.35), transparent 55%),
    radial-gradient(ellipse at 80% 50%, rgba(233,30,99,.28), transparent 55%),
    radial-gradient(ellipse at 50% 100%, rgba(241,196,15,.18), transparent 60%);
  background-size: 200% 200%;
  animation: heroBgShift 8s ease-in-out infinite alternate;
  z-index: -2;
}
.hero-animated-bg::after {
  content: ''; position: absolute; inset: 0;
  background: conic-gradient(from 0deg at 50% 50%,
    transparent 0deg, rgba(255,122,24,.12) 60deg, transparent 120deg,
    transparent 240deg, rgba(241,196,15,.1) 300deg, transparent 360deg);
  animation: heroSpin 14s linear infinite;
  z-index: -1;
}
.hero-animated-bg > * { position: relative; }
@keyframes heroBgShift {
  0%   { background-position: 0% 50%, 100% 50%, 50% 100%; }
  50%  { background-position: 100% 0%, 0% 100%, 0% 0%; }
  100% { background-position: 50% 100%, 50% 0%, 100% 50%; }
}
@keyframes heroSpin {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}
/* Sparkles cho heading */
.hero-animated-bg .hero-sparkles {
  position: absolute; inset: 0; pointer-events: none; overflow: hidden;
}
.hero-animated-bg .hero-sparkles span {
  position: absolute; width: 3px; height: 3px; border-radius: 50%;
  background: #fff; box-shadow: 0 0 6px #fff, 0 0 10px rgba(255,200,80,.8);
  opacity: 0; animation: hsparkle 5s ease-in infinite;
}
.hero-animated-bg .hero-sparkles span:nth-child(1) { left: 8%;  top: 70%; animation-delay: 0s; }
.hero-animated-bg .hero-sparkles span:nth-child(2) { left: 25%; top: 85%; animation-delay: 1s; }
.hero-animated-bg .hero-sparkles span:nth-child(3) { left: 45%; top: 80%; animation-delay: 2s; }
.hero-animated-bg .hero-sparkles span:nth-child(4) { left: 65%; top: 90%; animation-delay: 3s; }
.hero-animated-bg .hero-sparkles span:nth-child(5) { left: 85%; top: 75%; animation-delay: 4s; }
@keyframes hsparkle {
  0%   { transform: translateY(0) scale(0); opacity: 0; }
  20%  { transform: translateY(-15px) scale(1); opacity: 1; }
  80%  { transform: translateY(-50px) scale(.8); opacity: .8; }
  100% { transform: translateY(-80px) scale(0); opacity: 0; }
}
/* Border viền cam glow */
.hero-animated-bg { border-color: rgba(255,122,24,.3) !important; box-shadow: 0 0 24px rgba(255,122,24,.15) inset, 0 4px 16px rgba(0,0,0,.2); }

/* ===== TEXT SHIMMER EFFECT cho H1 ===== */
.text-shimmer {
  background: linear-gradient(
    90deg,
    #ff7a18 0%,
    #ffd700 25%,
    #ffffff 50%,
    #ffd700 75%,
    #ff7a18 100%
  );
  background-size: 200% 100%;
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  color: transparent;
  animation: textShimmer 3s linear infinite;
  display: inline-block;
  filter: drop-shadow(0 2px 8px rgba(255,122,24,.4));
}
@keyframes textShimmer {
  0%   { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}
/* Light mode text-shimmer */
html:not(.dark) .text-shimmer {
  background: linear-gradient(90deg, #d65a00 0%, #b8860b 25%, #1a1a1a 50%, #b8860b 75%, #d65a00 100%);
  background-size: 200% 100%;
  -webkit-background-clip: text;
  background-clip: text;
}

/* ===== CSKH CARD ANIMATIONS ===== */
.cskh-card {
  box-shadow: 0 4px 20px rgba(0,0,0,.3), 0 0 30px rgba(255,122,24,.08) inset;
  transition: transform .3s ease, box-shadow .3s ease;
}
.cskh-card:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 28px rgba(255,122,24,.18), 0 0 40px rgba(255,122,24,.12) inset;
}
.cskh-glow {
  background:
    radial-gradient(circle at 20% 0%, rgba(255,122,24,.25), transparent 50%),
    radial-gradient(circle at 80% 100%, rgba(233,30,99,.18), transparent 50%),
    radial-gradient(circle at 50% 50%, rgba(241,196,15,.08), transparent 70%);
  background-size: 200% 200%;
  animation: cskhGlowMove 6s ease-in-out infinite alternate;
}
@keyframes cskhGlowMove {
  0%   { background-position: 0% 0%, 100% 100%, 50% 50%; }
  100% { background-position: 100% 50%, 0% 50%, 50% 50%; }
}
.cskh-badge {
  background: linear-gradient(135deg, #ff7a18, #e91e63);
  box-shadow: 0 2px 8px rgba(255,122,24,.4);
  animation: cskhBadgePulse 2s ease-in-out infinite;
}
@keyframes cskhBadgePulse {
  0%, 100% { box-shadow: 0 2px 8px rgba(255,122,24,.4); }
  50%      { box-shadow: 0 2px 14px rgba(255,122,24,.7), 0 0 0 4px rgba(255,122,24,.15); }
}
.cskh-pulse {
  box-shadow: 0 0 0 0 rgba(16,185,129,.6);
  animation: cskhDotPulse 2s infinite;
}
@keyframes cskhDotPulse {
  0%   { box-shadow: 0 0 0 0 rgba(16,185,129,.7); }
  70%  { box-shadow: 0 0 0 8px rgba(16,185,129,0); }
  100% { box-shadow: 0 0 0 0 rgba(16,185,129,0); }
}
.cskh-shine {
  background: linear-gradient(120deg, transparent 30%, rgba(255,255,255,.35) 50%, transparent 70%);
  background-size: 200% 100%;
  animation: cskhShine 1s ease-in-out;
  transition: opacity .2s;
}
@keyframes cskhShine {
  from { background-position: -100% 0; }
  to   { background-position: 200% 0; }
}

