            <ellipse cx="400" cy="253" rx="47" ry="24" stroke-width="2" stroke="rgba(179, 218, 174, .35)" fill="none"/>
            <ellipse cx="401" cy="252" rx="4.2" ry="2.7" stroke-width="0" fill="rgba(179, 218, 174, 0.4)"/>
            <ellipse cx="159" cy="252" rx="2.6" ry="1.4" stroke-width="0" fill="rgba(179, 218, 174, 0.4)"/>
            <ellipse cx="642" cy="252" rx="2.6" ry="1.4" stroke-width="0" fill="rgba(179, 218, 174, 0.4)"/>
            <path vector-effect="non-scaling-stroke" stroke-width="2" stroke="rgba(179, 218, 174, .35)" fill="none" d="M 145 180 c 2 1 7 0 8 -4 M 648 175 c 0 5 7 4.5 7 4 M 24 359 c 0 0 5 0 5 6 M 771 365 c 0 0 0 -5 7 -6"/>
          </g>

          <!-- Live box: customer logo + score (thay logo URL bằng text xoso66tv.com) -->
          <g class="g-live-box">
            <g transform="translate(644 337)">
              <rect width="115" height="22" fill="#ff7a18" rx="3"/>
              <text x="57.5" y="15" font-size="11" font-weight="700" fill="#fff" text-anchor="middle" letter-spacing="1">xoso66tv.com</text>
            </g>
            <g transform="translate(331 174)" class="tab-statistics-score-g">
              <rect fill="rgba(21,32,64,1)" x="0" y="0" width="138" height="4"/>
              <foreignObject width="138" height="56" x="0" y="4">
                <div xmlns="http://www.w3.org/1999/xhtml" style="background-color:rgba(21,32,64,0.65); color:rgb(255,255,255); text-align:center; padding:6px 0; font-family:system-ui;">
                  <div style="font-size:9px; color:#94a3b8; letter-spacing:1.2px; margin-bottom:2px;">XOSO66TV.COM</div>
                  <div style="font-size:22px; font-weight:700;">
                    <span style="color:rgb(0, 118, 255);"><%= match.score ? match.score[0] : '0' %></span>
                    <span> - </span>
                    <span style="color:rgb(10, 201, 0);"><%= match.score ? match.score[1] : '0' %></span>
                  </div>
                </div>
              </foreignObject>
            </g>
          </g>
        </svg>

        <!-- SVG 3: BALL với ripple animation (NGUYÊN code thesports01) -->
        <svg version="1.1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" preserveAspectRatio="xMinYMin meet" viewBox="0 0 800 404" width="100%" height="auto" class="dzs-svg-box pointer-events-none" style="position:absolute; inset:0; z-index:4; display:block;">
          <g class="g-live-box">
            <g class="tracing-line-box home">
              <!-- Bóng di chuyển quanh sân: 12 waypoints giả lập tấn công 2 chiều (24s/loop)
                   Waypoints: giữa sân → vòng cấm home (trái) → giữa → vòng cấm away (phải) → giữa,
                   bám chiều cao sân (y: 200-350) + chiều dài (x: 150-650) -->
              <g class="radius-g" id="dlrBallGroup">
                <animateTransform attributeName="transform" attributeType="XML" type="translate"
                  dur="24s" repeatCount="indefinite"
                  calcMode="spline"
                  values="400,269; 320,230; 230,260; 180,310; 250,350; 400,330; 530,300; 620,260; 670,280; 600,330; 480,310; 400,269"
                  keyTimes="0; 0.09; 0.18; 0.27; 0.36; 0.45; 0.54; 0.63; 0.72; 0.81; 0.9; 1"
                  keySplines="0.42 0 0.58 1; 0.42 0 0.58 1; 0.42 0 0.58 1; 0.42 0 0.58 1; 0.42 0 0.58 1; 0.42 0 0.58 1; 0.42 0 0.58 1; 0.42 0 0.58 1; 0.42 0 0.58 1; 0.42 0 0.58 1; 0.42 0 0.58 1"/>
                <g transform="translate(-.9, -2)">
                  <g transform="translate(0 0)">
                    <g>
                      <use xlink:href="#dball-svg" class="ball-rotate">
                        <animateTransform attributeName="transform" attributeType="XML" type="rotate" from="0" to="360" dur="2.5s" repeatCount="indefinite"/>
                      </use>
                    </g>
                  </g>
                  <g>
                    <!-- Shadow ripple dưới bóng (2 ellipse mờ pulse) -->
                    <ellipse stroke-width="0" cy="10" rx="14" ry="3" fill="rgba(0,0,0,.4)"/>
                    <ellipse stroke-width="0" rx="22" ry="12" fill="rgba(255,255,255,.12)" opacity="0">
                      <animate attributeName="opacity" values="0;1;0;0" keyTimes="0;.2;.35;1" calcMode="linear" begin=".66s" dur="2.6s" repeatCount="indefinite" fill="freeze"/>
                      <animate attributeName="rx" values="14;22;22;22" keyTimes="0;.2;.35;1" calcMode="linear" begin=".66s" dur="2.6s" repeatCount="indefinite" fill="freeze"/>
                    </ellipse>
                  </g>
                </g>
              </g>

              <!-- Highlight spot — vòng tròn flash nhẹ đánh dấu vị trí "tấn công" hiện tại -->
              <g opacity="0.6">
                <animateTransform attributeName="transform" attributeType="XML" type="translate"
                  dur="24s" repeatCount="indefinite"
                  calcMode="spline"
                  values="400,269; 320,230; 230,260; 180,310; 250,350; 400,330; 530,300; 620,260; 670,280; 600,330; 480,310; 400,269"
                  keyTimes="0; 0.09; 0.18; 0.27; 0.36; 0.45; 0.54; 0.63; 0.72; 0.81; 0.9; 1"
                  keySplines="0.42 0 0.58 1; 0.42 0 0.58 1; 0.42 0 0.58 1; 0.42 0 0.58 1; 0.42 0 0.58 1; 0.42 0 0.58 1; 0.42 0 0.58 1; 0.42 0 0.58 1; 0.42 0 0.58 1; 0.42 0 0.58 1; 0.42 0 0.58 1"/>
                <circle cx="0" cy="0" r="0" fill="none" stroke="#ff7a18" stroke-width="1.2" opacity="0">
                  <animate attributeName="r" values="0;30;0" dur="2.5s" repeatCount="indefinite"/>
                  <animate attributeName="opacity" values="0;.5;0" dur="2.5s" repeatCount="indefinite"/>
                </circle>
              </g>
            </g>
          </g>
        </svg>
      </div>

      <!-- ═══ SCORE BAR DƯỚI PITCH (logo + tên + cards + timer + score) ═══ -->
      <%
        var _dStatsObj = (_dInsights && _dInsights.stats) ? _dInsights.stats : {};
        var _dCardsHome = (_dStatsObj.cards && _dStatsObj.cards.home) || { yellow:0, red:0 };
        var _dCardsAway = (_dStatsObj.cards && _dStatsObj.cards.away) || { yellow:0, red:0 };
        var _dCornersHome = (_dStatsObj.corners && _dStatsObj.corners.home) || 0;
        var _dCornersAway = (_dStatsObj.corners && _dStatsObj.corners.away) || 0;
        var _dHomeShortS = (match.home||'').slice(0,2).toUpperCase();
        var _dAwayShortS = (match.away||'').slice(0,2).toUpperCase();
        var _dHtScore = (_dStatsObj.htScore || (match.score ? (Math.max(0,(match.score[0]||0)-1) + ':' + Math.max(0,(match.score[1]||0)-1)) : '0:0'));
      %>
      <div class="dlr-sim-scorebar">
        <div class="dlr-sb-team dlr-sb-home">
          <% if (match.homeBadge) { %>
            <img src="<%= match.homeBadge %>" alt="<%= match.home %>" class="dlr-sb-logo" onerror="this.style.display='none'">
          <% } else { %>
            <span class="dlr-sb-logo-fb" style="background:rgb(0,118,255)"><%= _dHomeShortS %></span>
          <% } %>
          <div class="dlr-sb-info">
            <div class="dlr-sb-name"><%= match.home %></div>
            <div class="dlr-sb-cards">
              <span class="dlr-card dlr-card-yellow"><%= _dCardsHome.yellow %></span>
              <span class="dlr-card dlr-card-red"><%= _dCardsHome.red %></span>
              <span class="dlr-card dlr-card-corner"><%= _dCornersHome %></span>
            </div>
          </div>
        </div>
        <div class="dlr-sb-center">
          <div class="dlr-sb-timer"><%= match.time || '--:--' %></div>
          <div class="dlr-sb-score">
            <span style="color:rgb(0,118,255);"><%= match.score ? match.score[0] : '0' %></span>
            <span style="color:#fff; margin:0 6px;">:</span>
            <span style="color:rgb(10,201,0);"><%= match.score ? match.score[1] : '0' %></span>
            <% if (match.status === 'live') { %><span class="dlr-sb-live-dot"></span><% } %>
          </div>
          <div class="dlr-sb-ht">HT <%= _dHtScore %></div>
        </div>
        <div class="dlr-sb-team dlr-sb-away">
          <div class="dlr-sb-info" style="text-align:right;">
            <div class="dlr-sb-name"><%= match.away %></div>
            <div class="dlr-sb-cards" style="justify-content:flex-end;">
              <span class="dlr-card dlr-card-corner"><%= _dCornersAway %></span>
              <span class="dlr-card dlr-card-yellow"><%= _dCardsAway.yellow %></span>
              <span class="dlr-card dlr-card-red"><%= _dCardsAway.red %></span>
            </div>
          </div>
          <% if (match.awayBadge) { %>
            <img src="<%= match.awayBadge %>" alt="<%= match.away %>" class="dlr-sb-logo" onerror="this.style.display='none'">
          <% } else { %>
            <span class="dlr-sb-logo-fb" style="background:rgb(10,201,0)"><%= _dAwayShortS %></span>
          <% } %>
        </div>
      </div>

      <!-- ═══ TIMELINE CHART (cường độ tấn công 2 đội) + EVENT MARKERS ═══ -->
      <%
        var _dEvents = (_dInsights && Array.isArray(_dInsights.events)) ? _dInsights.events : [];
        var _dAttackTl = (_dInsights && Array.isArray(_dInsights.attackTimeline)) ? _dInsights.attackTimeline : null;
      %>
      <div class="dlr-sim-timeline">
        <div class="dlr-tl-header">
          <span class="dlr-tl-team-label"><%= match.home %></span>
        </div>
        <div class="dlr-tl-chart-wrap">
          <% if (_dEvents.length > 0) { %>
          <div class="dlr-tl-markers">
            <% _dEvents.forEach(function(ev){
              var leftPct = Math.min(100, Math.max(0, (ev.minute / 90) * 100));
              var isHome = ev.team === 'home';
              var color = isHome ? 'rgb(0,118,255)' : 'rgb(10,201,0)';
              var label = ev.type === 'goal' ? 'Bàn thắng' : ev.type === 'yellow' ? 'Thẻ vàng' : ev.type === 'red' ? 'Thẻ đỏ' : ev.type === 'corner' ? 'Phạt góc' : (ev.type||'');
              var teamName = isHome ? match.home : match.away;
              var iconSvg = '';
              if (ev.type === 'goal') iconSvg = '<svg viewBox="0 0 24 24" width="10" height="10"><circle cx="12" cy="12" r="9" fill="#fff" stroke="#000" stroke-width="1"/><polygon points="12,6 16,9 14,14 10,14 8,9" fill="#000"/></svg>';
              else if (ev.type === 'yellow') iconSvg = '<svg viewBox="0 0 24 24" width="8" height="11"><rect x="7" y="4" width="10" height="16" fill="#facc15" rx="1"/></svg>';
              else if (ev.type === 'red') iconSvg = '<svg viewBox="0 0 24 24" width="8" height="11"><rect x="7" y="4" width="10" height="16" fill="#dc2626" rx="1"/></svg>';
              else iconSvg = '<svg viewBox="0 0 24 24" width="10" height="10"><line x1="6" y1="20" x2="6" y2="4" stroke="#fff" stroke-width="2"/><polygon points="6,4 16,8 6,11" fill="#fff"/></svg>';
            %>
            <div class="dlr-tl-marker" style="left:<%= leftPct.toFixed(2) %>%;" title="<%= ev.minute %>' <%= label %> - <%= teamName %>">
              <div class="dlr-tl-marker-icon" style="background:<%= color %>;"><%- iconSvg %></div>
              <div class="dlr-tl-marker-tooltip">
                <strong><%= ev.minute %>'</strong> <%= label %><br><span style="opacity:.7"><%= teamName %></span>
              </div>
            </div>
            <% }); %>
          </div>
          <% } %>
          <div class="dlr-tl-canvas-wrap">
            <canvas id="dlrTimelineCanvas" role="img" aria-label="Cường độ tấn công 2 đội theo phút"></canvas>
          </div>
          <div class="dlr-tl-axis">
            <span>0'</span><span>15'</span><span>30'</span><span style="color:#facc15;">HT</span><span>60'</span><span>75'</span><span>90'</span>
          </div>
        </div>
        <div class="dlr-tl-footer">
          <span class="dlr-tl-team-label"><%= match.away %></span>
        </div>
      </div>

      <script>
      (function(){
        function initDlrTl(){
          var c = document.getElementById('dlrTimelineCanvas');
          if (!c) return;
          if (!window.Chart) {
            var s = document.createElement('script');
            s.src = 'https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js';
            s.onload = initDlrTl;
            document.head.appendChild(s);
            return;
          }
          var apiTl = <%- JSON.stringify(_dAttackTl) %>;
          var labels = ['0','5','10','15','20','25','30','35','40','HT','50','55','60','65','70','75','80','85','90'];
          var home, away;
          if (apiTl && apiTl.home && apiTl.away) {
            home = apiTl.home; away = apiTl.away;
          } else {
            // Fallback random-ish (chỉ visual demo - sẽ thay khi API có data)
            home = [10,18,25,32,28,40,55,45,42,50,38,52,60,68,55,50,42,38,30];
            away = [8,12,28,20,18,22,28,25,22,18,30,28,25,32,28,25,20,22,18];
          }
          new Chart(c, {
            type: 'line',
            data: { labels: labels, datasets: [
              { data: home, borderColor:'rgb(0,118,255)', backgroundColor:'rgba(0,118,255,.1)', tension:0.35, borderWidth:2, pointRadius:0, fill:true },
              { data: away, borderColor:'rgb(10,201,0)', backgroundColor:'rgba(10,201,0,.1)', tension:0.35, borderWidth:2, pointRadius:0, fill:true }
            ]},
            options: { responsive:true, maintainAspectRatio:false, plugins:{ legend:{display:false}, tooltip:{enabled:false} }, scales:{ x:{display:false}, y:{display:false, beginAtZero:true} } }
          });
        }
        if (document.readyState !== 'loading') initDlrTl();
        else document.addEventListener('DOMContentLoaded', initDlrTl);
      })();
      </script>
    </div>

    <!-- TOP NHÀ CÁI / CTA bên phải -->
    <div>
      <div class="dlr-section-h"><span></span><h3>NHÀ CÁI <span>TOP 1</span></h3></div>
      <div class="dlr-top-bookie">
        <div class="dlr-tb-head">
          <div class="dlr-tb-rank">1</div>
          <div class="dlr-tb-brand">XOSO66</div>
        </div>
        <p class="dlr-tb-desc">Đặt cược thể thao đầu hoàn 100% · BLV tiếng Việt 24/7 · Rút tiền nhanh 5 phút</p>
        <a href="<%= partner.sportbet %>" target="_blank" rel="noopener" class="dlr-tb-btn">💰 Đặt cược ngay</a>
      </div>

      <% if (typeof others !== 'undefined' && others && others.length > 0) { %>
      <div class="dlr-other-matches">
        <div class="dlr-other-head">⚡ Trận khác LIVE</div>
        <% others.slice(0, 4).forEach(function(o){ %>
          <a href="/live/<%= o.slug || o.id %>" class="dlr-other-item">
            <span class="dlr-other-time"><%= o.time || '' %></span>
            <span class="dlr-other-match"><%= o.home || '' %> vs <%= o.away || '' %></span>
            <% if (o.isLive) { %><span class="dlr-other-live">LIVE</span><% } %>
          </a>
        <% }); %>
      </div>
      <% } %>
    </div>
  </div>

  <!-- ═══ 8. BÌNH LUẬN (SEO ARTICLE) ═══ -->
  <div class="dlr-comment-section">
    <div class="dlr-section-h"><span></span><h3>BÌNH <span>LUẬN</span></h3></div>
    <article class="dlr-seo">
      <h4>Đường link xem trực tuyến trận đấu <%= match.home %> vs <%= match.away %> chuẩn nhất</h4>
      <p>Tường thuật trận đấu <b><%= match.home %> vs <%= match.away %></b> miễn phí hôm nay tại giải <b><%= match.league %></b>. Xem ngay <%= match.home %> vs <%= match.away %> trên <b>XOSO66 TV Official</b> với đường truyền tốc độ cao, không giật lag, không quảng cáo gây phiền. Trang xem trực tiếp này được tối ưu cho mọi thiết bị (điện thoại, máy tính, smart TV).</p>

      <h4>Địa chỉ xem trận đấu <%= match.home %> vs <%= match.away %> ở đâu?</h4>
      <p>Cập nhật tỷ số, dữ liệu bóng đá, đội hình xuất phát, link trực tiếp sẽ được cập nhật sớm trước 15 phút.
        <% if (match.score) { %>Tỷ số hiện tại là <b class="dlr-gold"><%= match.score[0] %> - <%= match.score[1] %></b>.<% } %>
        Cập nhật <a href="/livescore">livescore</a>, <a href="/bxh">bảng xếp hạng</a>, <a href="/ty-le-keo">tỷ lệ kèo</a> ngay tại trang chủ.</p>

      <h4>Cách xem <%= match.home %> vs <%= match.away %> miễn phí</h4>
      <p>Để xem trực tiếp trận <b><%= match.home %> vs <%= match.away %></b>, bạn chỉ cần truy cập <b>xoso66tv.com</b>, không cần đăng ký tài khoản. Nếu muốn chat cùng BLV và cộng đồng, hãy <a href="/dang-ky">đăng ký tài khoản miễn phí</a> để tham gia bình luận trực tiếp, săn X COIN và đổi quà tặng giá trị.</p>

      <div class="dlr-tags">
        <span class="dlr-tags-label">Tags:</span>
        <a href="/lich-phat-song" class="dlr-tag">#<%= (match.home||'').replace(/\s+/g,'') %></a>
        <a href="/lich-phat-song" class="dlr-tag">#<%= (match.away||'').replace(/\s+/g,'') %></a>
        <a href="/lich-phat-song" class="dlr-tag">#<%= (match.league||'').replace(/\s+/g,'') %></a>
        <a href="/livescore" class="dlr-tag">#TrucTiepBongDa</a>
        <a href="/ty-le-keo" class="dlr-tag">#XOSO66TV</a>
        <a href="/" class="dlr-tag">#XemBongDaHD</a>
      </div>
    </article>
  </div>

</div>

<!-- ════════ CSS ════════ -->
<style>
.dlr-wrap { display:flex; flex-direction:column; gap:8px; }

/* TOP HEADER */
.dlr-top-bar { background:linear-gradient(180deg,#1a1f29,#13171f); border:1px solid #1a1f29; border-radius:8px; padding:10px 14px; display:grid; grid-template-columns:200px 1fr 200px; gap:14px; align-items:center; }
.dlr-mini-scores { display:flex; gap:6px; align-items:center; flex-wrap:wrap; }
.dlr-mini-label { font-size:10px; color:#94a3b8; font-weight:700; }
.dlr-chip-blv { background:#0a0d12; border:1px solid #1a1f29; padding:4px 8px; border-radius:4px; font-size:10px; color:#fff; font-weight:700; display:flex; align-items:center; gap:5px; }
.dlr-chip-blv img { width:14px; height:14px; border-radius:50%; }
.dlr-blv-emoji { width:14px; height:14px; background:linear-gradient(135deg,#ff7a18,#dc2626); border-radius:50%; display:grid; place-items:center; font-size:7px; }
.dlr-live-dot { width:5px; height:5px; background:#ef4444; border-radius:50%; animation:dlrPulse 1.5s infinite; }
@keyframes dlrPulse { 50% { opacity:.4 } }

.dlr-teams-center { display:flex; align-items:center; justify-content:center; gap:18px; }
.dlr-team-info { display:flex; align-items:center; gap:8px; }
