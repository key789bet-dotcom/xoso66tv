            </g>
            <path fill="rgba(0,0,0,.1)" vector-effect="non-scaling-stroke" stroke-width="0" d="M 149 175 l 33 0 l -110 190 l -51 0  M 220 175 l 35 0 l -74 190 l -53 0  M 292 175 l 35 0 l -37 190 l -53 0   M 364 175 l 35 0 l 0 190 l -53 0   M 438 175 l 35 0 l 37 190 l -53 0  M 511 175 l 35 0 l 73 190 l -53 0  M 584 175 l 35 0 l 109 190 l -53 0"/>
            <path vector-effect="non-scaling-stroke" stroke-width="2" stroke="rgba(179, 218, 174, .35)" fill="none" d="M147 175 l 506 0 l 129 191 l -764 0 l 130 -192"/>
            <path vector-effect="non-scaling-stroke" stroke-width="2" stroke="rgba(179, 218, 174, .35)" fill="none" d="M 191 233 c 7 0 22 22 -18 38 M 130 202 l 76 0 l -54 111 l -97 0 M 113 227 l 39 0 l -28 50 l -45 0"/>
            <path vector-effect="non-scaling-stroke" stroke-width="2" stroke="rgba(179, 218, 174, .35)" fill="none" d="M 611 233 c -7 0 -25 22 18 38 M 672 202 l -77 0 l 54 111 l 98 0 M 688 227 l -39 0 l 30 50 l 43 0"/>
            <g class="flag-g">
