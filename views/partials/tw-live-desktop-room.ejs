<%
// ════════════════════════════════════════════════════════════════════
// 🖥 PARTIAL: PHÒNG LIVE BÓNG ĐÁ - LAYOUT DESKTOP (style xoilac/8xbet)
// Hiện ≥ 768px (md). Mobile dùng partial tw-live-mobile-room.ejs.
// Required vars: match, partner, liveBlvs?, blvStreamKey?, hasObs?,
//                liveOdds?, matchInsights?, others?, leagueBgs?
// ════════════════════════════════════════════════════════════════════

// Compute biến local
var _dHasBlvStream = (typeof blvStreamKey !== 'undefined' && blvStreamKey);
var _dHasObs       = (typeof hasObs !== 'undefined' && hasObs);
var _dHasOdds      = (typeof liveOdds !== 'undefined' && liveOdds && (liveOdds.ah || liveOdds.ou || liveOdds.x12));
var _dOuLine       = (_dHasOdds && liveOdds.ou && typeof liveOdds.ou.line === 'number') ? liveOdds.ou.line : 2.5;
var _dAhLine       = (_dHasOdds && liveOdds.ah && typeof liveOdds.ah.line === 'number') ? liveOdds.ah.line : 0.5;
var _dOuTai        = (_dHasOdds && liveOdds.ou && typeof liveOdds.ou.taiOdds === 'number') ? liveOdds.ou.taiOdds : null;
var _dOuXiu        = (_dHasOdds && liveOdds.ou && typeof liveOdds.ou.xiuOdds === 'number') ? liveOdds.ou.xiuOdds : null;
var _dAhHome       = (_dHasOdds && liveOdds.ah && typeof liveOdds.ah.homeOdds === 'number') ? liveOdds.ah.homeOdds : null;
var _dAhAway       = (_dHasOdds && liveOdds.ah && typeof liveOdds.ah.awayOdds === 'number') ? liveOdds.ah.awayOdds : null;
var _dX12Home      = (_dHasOdds && liveOdds.x12 && typeof liveOdds.x12.homeOdds === 'number') ? liveOdds.x12.homeOdds : null;
var _dX12Draw      = (_dHasOdds && liveOdds.x12 && typeof liveOdds.x12.drawOdds === 'number') ? liveOdds.x12.drawOdds : null;
var _dX12Away      = (_dHasOdds && liveOdds.x12 && typeof liveOdds.x12.awayOdds === 'number') ? liveOdds.x12.awayOdds : null;
var _dHomeShort    = (match.home||'').slice(0, 3).toUpperCase();
var _dAwayShort    = (match.away||'').slice(0, 3).toUpperCase();
var _dInsights     = (typeof matchInsights !== 'undefined' && matchInsights) ? matchInsights : null;
var _dLiveBlvs     = (typeof liveBlvs !== 'undefined' && Array.isArray(liveBlvs)) ? liveBlvs : [];
var _dViewers      = (match.viewers || match.viewerCount || (Math.random()*15000|0)+5000);

// Stats trận đấu - lấy từ matchInsights nếu có, không có thì hide
var _dStats = (_dInsights && _dInsights.stats) ? _dInsights.stats : null;
var _dPossession = _dStats ? (_dStats.possession || null) : null;
var _dAttacks    = _dStats ? (_dStats.attacks    || null) : null;
var _dDangerAtk  = _dStats ? (_dStats.dangerAtk  || null) : null;
%>

<!-- ════════ DESKTOP LIVE ROOM ════════ -->
<div class="dlr-wrap">

  <!-- ═══ 1. TOP HEADER BAR: score widgets | teams | navigation ═══ -->
  <div class="dlr-top-bar">
    <div class="dlr-mini-scores">
      <% if (_dLiveBlvs.length > 0) { _dLiveBlvs.slice(0,2).forEach(function(b){ %>
        <div class="dlr-chip-blv">
          <% if (b.avatar) { %><img src="<%= b.avatar %>" alt=""><% } else { %><span class="dlr-blv-emoji">🎙</span><% } %>
          <span><%= (b.name||'').slice(0,8) %></span>
          <% if (b.isLive) { %><span class="dlr-live-dot"></span><% } %>
        </div>
      <% }); } else { %>
        <span class="dlr-mini-label">XOSO66 TV · LIVE</span>
      <% } %>
    </div>

    <div class="dlr-teams-center">
      <div class="dlr-team-info dlr-team-home">
        <span class="dlr-team-name"><%= match.home %></span>
        <% if (match.homeBadge) { %>
          <img src="<%= match.homeBadge %>" alt="<%= match.home %>" class="dlr-team-logo" onerror="this.style.display='none'">
        <% } else { %>
          <span class="dlr-team-logo-fb" style="background:#dc2626"><%= _dHomeShort.slice(0,2) %></span>
        <% } %>
      </div>
      <div class="dlr-score-box">
        <div class="dlr-score-status">
          <% if (match.status === 'finished') { %>HẾT TRẬN
          <% } else if (match.status === 'live') { %>ĐANG ĐÁ
          <% } else { %><%= match.time || '--:--' %><% } %>
        </div>
        <div class="dlr-score-nums">
          <%= match.score ? match.score[0] : '-' %> : <%= match.score ? match.score[1] : '-' %>
        </div>
      </div>
      <div class="dlr-team-info dlr-team-away">
        <% if (match.awayBadge) { %>
          <img src="<%= match.awayBadge %>" alt="<%= match.away %>" class="dlr-team-logo" onerror="this.style.display='none'">
        <% } else { %>
          <span class="dlr-team-logo-fb" style="background:#3b82f6"><%= _dAwayShort.slice(0,2) %></span>
        <% } %>
        <span class="dlr-team-name"><%= match.away %></span>
      </div>
    </div>

    <div class="dlr-nav-right">
      <span class="dlr-nav-label"><%= match.league %></span>
    </div>
  </div>

  <!-- ═══ 2. ODDS ROW: 4 cột (1X2 / AH / OU / Phạt góc) - LUÔN hiện, dùng "—" nếu chưa có ═══ -->
  <div class="dlr-odds-row">
    <div class="dlr-odds-head">
      <div class="dlr-odds-bookmaker-label">Nhà cái</div>
      <div class="dlr-odds-col-label">CHÂU ÂU (1X2)</div>
      <div class="dlr-odds-col-label">CHÂU Á (Chấp)</div>
      <div class="dlr-odds-col-label">TÀI/XỈU</div>
      <div class="dlr-odds-col-label">PHẠT GÓC</div>
    </div>
    <div class="dlr-odds-body">
      <div class="dlr-odds-bookmaker">XOSO66</div>
      <div class="dlr-odds-cells">
        <span class="dlr-odd-cell"><%= _dX12Home ? _dX12Home.toFixed(2) : '—' %></span>
        <span class="dlr-odd-cell"><%= _dX12Draw ? _dX12Draw.toFixed(2) : '—' %></span>
        <span class="dlr-odd-cell"><%= _dX12Away ? _dX12Away.toFixed(2) : '—' %></span>
      </div>
      <div class="dlr-odds-cells">
        <span class="dlr-odd-cell"><%= _dAhHome ? _dAhHome.toFixed(2) : '—' %></span>
        <span class="dlr-odd-cell dlr-odd-line"><%= _dAhLine %></span>
        <span class="dlr-odd-cell"><%= _dAhAway ? _dAhAway.toFixed(2) : '—' %></span>
      </div>
      <div class="dlr-odds-cells">
        <span class="dlr-odd-cell"><%= _dOuTai ? _dOuTai.toFixed(2) : '—' %></span>
        <span class="dlr-odd-cell dlr-odd-line"><%= _dOuLine %></span>
        <span class="dlr-odd-cell"><%= _dOuXiu ? _dOuXiu.toFixed(2) : '—' %></span>
      </div>
      <div class="dlr-odds-cells dlr-odds-empty">
        <a href="<%= partner.sportbet %>" target="_blank" rel="noopener" class="dlr-odd-cta">Cược ngay</a>
      </div>
    </div>
  </div>

  <!-- ═══ 3. NAV TABS (SVG icons, click → switch panel chat aside / scroll section) ═══ -->
  <div class="dlr-nav-tabs" role="tablist">
    <button type="button" class="dlr-nav-tab" data-dtab="lineup" data-mtab-link="lineup" title="Sơ đồ chiến thuật 11 cầu thủ + HLV">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><rect x="3" y="3" width="18" height="18" rx="1"/><path d="M3 12h18M12 3v18M8 9a4 4 0 1 0 0 6 4 4 0 0 0 0-6zM16 9a4 4 0 1 1 0 6 4 4 0 0 1 0-6z"/></svg>
      Đội hình
    </button>
    <button type="button" class="dlr-nav-tab active" data-dtab="odds" data-mtab-link="odds" title="Tỷ lệ kèo realtime">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><line x1="6" y1="20" x2="6" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="18" y1="20" x2="18" y2="14"/></svg>
      Tỷ lệ
    </button>
    <button type="button" class="dlr-nav-tab" data-dtab="h2h" data-mtab-link="h2h" title="10 trận đối đầu gần nhất">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><path d="M14.5 17.5L3 6V3h3l11.5 11.5"/><path d="M13 19l6-6"/><path d="M16 16l4 4"/><path d="M19 21l2-2"/><path d="M9.5 6.5L6 3"/></svg>
      Đối đầu
    </button>
    <button type="button" class="dlr-nav-tab" data-dtab="form" data-mtab-link="stats" title="Phong độ 5 trận + thống kê">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
      Phong độ
    </button>
    <button type="button" class="dlr-nav-tab" data-dtab="livescore" data-mtab-link="stats" title="Diễn biến trận đấu trực tiếp">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><circle cx="12" cy="12" r="3"/><path d="M5 5a14 14 0 0 0 0 14M19 5a14 14 0 0 1 0 14M2 12a18 18 0 0 0 0 0M22 12a18 18 0 0 1 0 0"/></svg>
      Trực tiếp
    </button>
    <button type="button" class="dlr-nav-tab" data-dtab="bxh" title="Bảng xếp hạng giải">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>
      BXH
    </button>
    <button type="button" class="dlr-nav-tab" data-dtab="info" data-section="dlrInfoSection" title="Thông tin trận đấu + bình luận">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
      Thông tin
    </button>
  </div>

  <!-- ═══ 4. BANNER CTA PARTNER (đồng hành) ═══ -->
  <a href="<%= partner.sportbet %>" target="_blank" rel="noopener" class="dlr-banner-cta">
    <span class="dlr-banner-brand">XOSO66</span>
    <span class="dlr-banner-icons">⚽ ⚽ ⚽</span>
    <span class="dlr-banner-text">Đồng hành chính thức · Hoàn 100% vé cược đầu tiên</span>
    <span class="dlr-banner-btn">CƯỢC NGAY →</span>
  </a>

  <!-- ═══ 5. MAIN GRID 2/3 + 1/3: PLAYER + CHAT ═══ -->
  <div class="dlr-main-grid">

    <!-- ── LEFT COLUMN: PLAYER ── -->
    <div class="dlr-player-col">
      <!-- Tabs row (Trực tiếp / Mô phỏng / Chia sẻ) -->
      <div class="dlr-player-tabs">
        <button type="button" class="dlr-pt active" data-ptab="live">▶ TRỰC TIẾP</button>
        <button type="button" class="dlr-pt" data-ptab="sim">🏟 MÔ PHỎNG</button>
        <button type="button" id="dlrShareBtn" class="dlr-pt dlr-pt-share">🔗 CHIA SẺ</button>
      </div>

      <!-- Status strip -->
      <div class="dlr-status-strip">
        <span>Phát sóng trực tiếp <b><%= match.home %> vs <%= match.away %></b> lúc <b><%= match.time %></b> ngày <b><%= match.date %></b></span>
        <a href="<%= partner.sportbet %>" target="_blank" rel="noopener" class="dlr-status-cta">⭐ Đặt cược XOSO66</a>
      </div>

      <!-- PLAYER SLOT: JS sẽ TELEPORT #livePlayer (từ render trong tw-live.ejs) vào đây -->
      <div id="dlrPlayerSlot" class="dlr-player-slot">
        <!-- Overlay info top-left -->
        <div class="dlr-ov-score">
          <span class="dlr-ov-time"><%= match.time || '--:--' %></span>
          <% if (match.homeBadge) { %><img src="<%= match.homeBadge %>" alt=""><% } %>
          <span><%= match.score ? match.score[0] : '0' %></span>
          <span class="dlr-ov-sep">-</span>
          <span><%= match.score ? match.score[1] : '0' %></span>
          <% if (match.awayBadge) { %><img src="<%= match.awayBadge %>" alt=""><% } %>
        </div>
        <div class="dlr-ov-brand">XOSO66.TV</div>
        <% if (_dHasBlvStream || _dHasObs) { %>
        <div class="dlr-ov-live"><span></span>LIVE</div>
        <% } %>
        <div class="dlr-ov-viewers">👁 <%= _dViewers.toLocaleString('vi-VN') %></div>
      </div>

      <!-- Banner WC mini -->
      <a href="<%= partner.sportbet %>" target="_blank" rel="noopener" class="dlr-wc-banner">
        <span class="dlr-wc-brand">XOSO66</span>
        <span class="dlr-wc-icons">⚽⚽⚽</span>
        <span class="dlr-wc-text">WORLD CUP 2026 · THAM GIA VÀO CUỘC VUI</span>
        <span class="dlr-wc-btn">CƯỢC NGAY</span>
      </a>

      <!-- Quality bar: chỉ 4 quality thực (MAX/HD/SD/Mobile) + CHIA SẺ -->
      <div class="dlr-quality-bar" id="dlrQualityBar">
        <button type="button" class="dlr-qbtn active" data-quality="max">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="4" width="4" height="16" rx="1"/><rect x="14" y="4" width="4" height="16" rx="1"/></svg>
          MAX (1080p)
        </button>
        <button type="button" class="dlr-qbtn" data-quality="720">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21"/></svg>
          HD MAX (720p)
        </button>
        <button type="button" class="dlr-qbtn" data-quality="480">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21"/></svg>
          SD (480p)
        </button>
        <button type="button" class="dlr-qbtn" data-quality="mobile">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21"/></svg>
          Mobile (360p)
        </button>
        <button type="button" id="dlrQualityShareBtn" class="dlr-qbtn dlr-qbtn-share">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
          CHIA SẺ
        </button>
      </div>
    </div>

    <!-- ── RIGHT COLUMN: CHAT SLOT (JS teleport #liveChatAside vào) ── -->
    <div id="dlrChatSlot" class="dlr-chat-slot"></div>

  </div>

  <!-- ═══ 6. BANNER PARTNER LẦN 2 ═══ -->
  <a href="<%= partner.register %>" target="_blank" rel="noopener" class="dlr-banner-cta dlr-banner-cta-2">
    <span class="dlr-banner-brand">XOSO66</span>
    <span class="dlr-banner-text">🎁 Đăng ký nhận 100% tiền thưởng · Cào game cực hấp dẫn</span>
    <span class="dlr-banner-btn">ĐĂNG KÝ →</span>
  </a>

  <!-- ═══ 7. GRID 2/3 + 1/3: MÔ PHỎNG TRẬN ĐẤU + TOP CTA ═══ -->
  <div class="dlr-sim-grid">

    <!-- Mô phỏng trận đấu (stats) -->
    <div>
      <div class="dlr-section-h"><span></span><h3>MÔ PHỎNG <span>TRẬN ĐẤU</span></h3></div>
      <!-- ═══ 3D PITCH — NGUYÊN code SVG thesports01, CHỈ thay brand → xoso66tv ═══ -->
      <div class="animate-svg" style="position:relative; transform:translateY(0px); perspective:590.85px; background:#0a1628; border:1px solid #1a1f29; border-radius:8px; overflow:hidden;">

        <!-- Stadium PNG background -->
        <img src="https://cdn.thesports01.com/tracker/config/assets/2ac837bf6eceb392bb677fec829d8dc9.png!w800"
             alt="" loading="lazy"
             style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; opacity:0.85; pointer-events:none; z-index:1;"
             onerror="this.style.display='none'">

        <!-- SVG 1: DEFS (theo thesports01) -->
        <svg version="1.1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" preserveAspectRatio="xMinYMin meet" viewBox="0 0 800 404" width="100%" height="auto" style="position:relative; z-index:2; pointer-events:none; display:block;">
          <defs>
            <linearGradient id="dgradient-home"><stop offset="0%" stop-color="rgb(21,60,0)" stop-opacity="0.1"/><stop offset="100%" stop-color="rgb(9,28,0)" stop-opacity="0.45"/></linearGradient>
            <linearGradient id="dgradient-away"><stop offset="0%" stop-color="rgb(9,28,0)" stop-opacity="0.45"/><stop offset="100%" stop-color="rgb(21,60,0)" stop-opacity="0.1"/></linearGradient>
            <g id="dflag-defs">
              <polygon fill="#FF7457" points="1 0 10 5.00646222 1 9"/>
              <path d="M0.8,0 C1.2418278,-8.11624501e-17 1.6,0.3581722 1.6,0.8 L1.6,17.2 C1.6,17.6418278 1.2418278,18 0.8,18 C0.3581722,18 -5.01003212e-16,17.6418278 0,17.2 L0,0.8 C-5.41083001e-17,0.3581722 0.3581722,8.11624501e-17 0.8,0 Z" fill="#FFFFFF"/>
            </g>
            <g id="dqm-g" fill-rule="evenodd"><g fill="#fff">
              <polygon opacity="0.2" points="23.741 20.0457821 11.5726356 20.0457821 0.758332737 40.7351071 23.9416045 40.7351071"/>
              <polygon opacity="0.1" points="0.758332737 40.7351071 19.5413668 20.1756914 28.4357949 0.801607034 11.5726356 20.0457821"/>
              <polygon opacity="0.15" points="38.9844875 0.801607034 28.4357949 0.801607034 19.5413668 20.1756914 38.9844875 20.1756914"/>
              <polygon opacity="0.15" points="23.4997592 20.0457821 38.9844875 0.801607034 28.4357949 0.801607034 11.5726356 20.0457821"/>
            </g></g>
            <!-- Center bar = rect cam + text XOSO66TV.COM (thay 4 image cdn.thesports01) -->
            <g id="dcenter-bar">
              <rect width="63.2" height="12" fill="#ff7a18" rx="0.5"/>
              <text x="31.6" y="8.5" font-size="6" font-weight="700" fill="#fff" text-anchor="middle" letter-spacing="0.5">XOSO66TV.COM</text>
            </g>
            <!-- Ball SVG inline (quả bóng đá thật: trắng + 6 pentagons đen) -->
            <g id="dball-svg">
              <circle cx="0" cy="0" r="11" fill="#fff" stroke="#222" stroke-width="0.5"/>
              <polygon points="0,-4.5 4.3,-1.4 2.6,3.6 -2.6,3.6 -4.3,-1.4" fill="#000"/>
              <polygon points="0,-10.5 3.2,-7.8 0,-4.5 -3.2,-7.8" fill="#000"/>
              <polygon points="4.3,-1.4 9.5,-2.5 10.5,1.5 6.5,4" fill="#000"/>
              <polygon points="-4.3,-1.4 -9.5,-2.5 -10.5,1.5 -6.5,4" fill="#000"/>
              <polygon points="2.6,3.6 6.5,4 5.5,9 1,8.5" fill="#000"/>
              <polygon points="-2.6,3.6 -6.5,4 -5.5,9 -1,8.5" fill="#000"/>
              <line x1="0" y1="-4.5" x2="0" y2="-10.5" stroke="#000" stroke-width="0.4"/>
              <line x1="4.3" y1="-1.4" x2="9.5" y2="-2.5" stroke="#000" stroke-width="0.4"/>
              <line x1="-4.3" y1="-1.4" x2="-9.5" y2="-2.5" stroke="#000" stroke-width="0.4"/>
              <line x1="2.6" y1="3.6" x2="6.5" y2="4" stroke="#000" stroke-width="0.4"/>
              <line x1="-2.6" y1="3.6" x2="-6.5" y2="4" stroke="#000" stroke-width="0.4"/>
            </g>
          </defs>
        </svg>

        <!-- SVG 2: LINE BOX + LIVE BOX + SCORE BOX (NGUYÊN code thesports01) -->
        <svg version="1.1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" preserveAspectRatio="xMinYMin meet" viewBox="0 0 800 404" width="100%" height="auto" class="dzs-svg-box pointer-events-none" style="position:absolute; inset:0; z-index:3; display:block;">
          <g class="g-line-box">
            <g transform="translate(0 135)">
              <g transform="translate(-116 0)">
                <path fill="rgba(0,58,120,1)" d="M242.490174,5.68434189e-14 L791.913953,5.68434189e-14 C797.154057,7.36443957e-14 802.134027,2.28348675 805.553436,6.25417083 L1034.40413,272 L1034.40413,272 L0,272 L228.850691,6.25417083 C232.2701,2.28348675 237.25007,1.02641442e-13 242.490174,5.68434189e-14 Z"/>
              </g>
              <use xlink:href="#dcenter-bar" x="-23" y="103" transform="skewX(22) skewY(-40)"/>
              <use xlink:href="#dcenter-bar" x="744" y="-569" transform="skewX(-22) skewY(40)"/>
              <use xlink:href="#dcenter-bar" x="174.4" y="7"/>
