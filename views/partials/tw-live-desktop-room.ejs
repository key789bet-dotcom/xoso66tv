  display: none !important;
}
</style>

<!-- ════════ JS: TELEPORT + TABS + QUALITY + SHARE ════════ -->
<script>
(function dlrInit(){
  // ─── 1. TELEPORT #livePlayer → #dlrPlayerSlot, #liveChatAside → #dlrChatSlot ───
  function dlrTeleport(){
    var player = document.getElementById('livePlayer');
    var slot   = document.getElementById('dlrPlayerSlot');
    var chat   = document.getElementById('liveChatAside');
    var cslot  = document.getElementById('dlrChatSlot');
    if (player && slot && player.parentNode !== slot) {
      // Player chứa video element + overlays nội bộ
      player.classList.remove('aspect-video','rounded-xl','bg-black');
      player.style.position = 'absolute';
      player.style.inset = '0';
      player.style.width = '100%';
      player.style.height = '100%';
      slot.appendChild(player);
    }
    if (chat && cslot && chat.parentNode !== cslot) {
      cslot.appendChild(chat);
    }
  }
  // Run sau khi DOM ready
  if (document.readyState !== 'loading') dlrTeleport();
  else document.addEventListener('DOMContentLoaded', dlrTeleport);

  // ─── 2. NAV TABS — click → switch panel chat aside (mini-tab tương ứng) + scroll vào view ───
  var navTabs = document.querySelectorAll('.dlr-nav-tab');
  navTabs.forEach(function(btn){
    btn.addEventListener('click', function(ev){
      ev.preventDefault();
      navTabs.forEach(function(b){ b.classList.remove('active'); });
      btn.classList.add('active');
      var dtab = btn.dataset.dtab;
      var mtabLink = btn.dataset.mtabLink;
      var sectionId = btn.dataset.section;

      // Case 1: BXH → open trang /bxh
      if (dtab === 'bxh') {
        window.open('/bxh', '_blank', 'noopener');
        return;
      }

      // Case 2: section riêng (info → scroll xuống section bình luận / mô phỏng)
      if (sectionId) {
        var target = document.getElementById(sectionId) ||
                     document.querySelector('.dlr-section-h h3') || // fallback
                     document.querySelector('#dlrInfoSection');
        if (target) {
          target.scrollIntoView({ behavior:'smooth', block:'start' });
        } else {
          // Fallback: scroll xuống cuối player để thấy mô phỏng/bình luận
          window.scrollTo({ top: window.innerHeight, behavior:'smooth' });
        }
        return;
      }

      // Case 3: mtabLink → trigger mini-tab tương ứng ở chat aside + scroll vào view
      if (mtabLink) {
        var miniBtn = document.querySelector('#liveMiniTabs button[data-mtab="' + mtabLink + '"]');
        if (miniBtn) {
          miniBtn.click();
        }
        // Scroll chat aside vào view (nếu out-of-viewport)
        var aside = document.getElementById('liveChatAside') ||
                    document.querySelector('.dlr-side-panel') ||
                    document.querySelector('[data-panel]');
        if (aside) {
          // Smooth scroll, anchor về đầu chat aside
          var rect = aside.getBoundingClientRect();
          var inView = rect.top >= 0 && rect.bottom <= window.innerHeight;
          if (!inView) {
            aside.scrollIntoView({ behavior:'smooth', block:'start' });
          }
        }
      }
    });
  });

  // ─── 3. PLAYER TABS (Trực tiếp / Mô phỏng / Chia sẻ) ───
  var pTabs = document.querySelectorAll('.dlr-pt:not(.dlr-pt-share)');
  pTabs.forEach(function(btn){
    btn.addEventListener('click', function(){
      pTabs.forEach(function(b){ b.classList.remove('active'); });
      btn.classList.add('active');
    });
  });

  // ─── 4. QUALITY BAR ───
  var qBtns = document.querySelectorAll('.dlr-qbtn:not(.dlr-qbtn-share)');
  qBtns.forEach(function(btn){
    btn.addEventListener('click', function(){
      qBtns.forEach(function(b){ b.classList.remove('active'); });
      btn.classList.add('active');
      var quality = btn.dataset.quality;
      if (window.x66SwapStreamQuality) window.x66SwapStreamQuality(null, quality);
    });
  });

  // ─── 5. SHARE BUTTONS (2 buttons) ───
  function dlrShare(btn){
    btn.addEventListener('click', function(){
      var url = location.href, title = document.title;
      if (navigator.share) navigator.share({ title:title, url:url }).catch(function(){});
      else if (navigator.clipboard) {
        navigator.clipboard.writeText(url).then(function(){
          var orig = btn.innerHTML;
          btn.innerHTML = '✓ ĐÃ COPY';
          setTimeout(function(){ btn.innerHTML = orig; }, 1500);
        });
      } else prompt('Copy link:', url);
    });
  }
  var sb1 = document.getElementById('dlrShareBtn'); if (sb1) dlrShare(sb1);
  var sb2 = document.getElementById('dlrQualityShareBtn'); if (sb2) dlrShare(sb2);
})();
</script>
