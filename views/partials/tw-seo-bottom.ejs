<% var _content = (typeof seoContent !== 'undefined') ? seoContent : null; %>
<% if (_content) { %>
<section class="bg-bg-card border border-line rounded-xl p-6 mt-8 text-muted leading-relaxed text-sm">
  <% if (_content.h2) { %>
    <h2 class="text-white text-xl font-extrabold mb-3 pb-2.5 border-b border-line flex items-center gap-2"><span class="w-1 h-5 bg-pri rounded-sm"></span><%= _content.h2 %></h2>
  <% } %>
  <% if (_content.intro) { %><p class="mb-3 [&_strong]:text-white [&_a]:text-pri-light [&_a]:underline hover:[&_a]:text-pri"><%- _content.intro %></p><% } %>
  <% (_content.sections || []).forEach(function(s){ %>
    <h3 class="text-pri-light text-base font-bold mt-4 mb-2"><%= s.h3 %></h3>
    <p class="mb-3 [&_strong]:text-white [&_a]:text-pri-light [&_a]:underline hover:[&_a]:text-pri"><%- s.p %></p>
  <% }); %>
  <%
     /* Filter FAQs hợp lệ (q + a phải có text). Google flag invalid nếu thiếu. */
     var _validFaqs = (_content.faqs || []).filter(function(f){
       return f && typeof f.q === 'string' && f.q.trim() && typeof f.a === 'string' && f.a.trim();
     });
  %>
  <% if (_validFaqs.length) { %>
    <h3 class="text-pri-light text-base font-bold mt-4 mb-2">FAQ - Câu hỏi thường gặp</h3>
    <%# Bỏ microdata (itemscope/itemprop) để KHÔNG duplicate với JSON-LD bên dưới %>
    <div class="space-y-2">
      <% _validFaqs.forEach(function(f){ %>
        <details class="bg-bg-soft border border-line rounded-lg overflow-hidden transition-colors open:border-pri group">
          <summary class="px-4 py-3 cursor-pointer font-bold text-white flex items-center gap-2 select-none list-none">
            <span class="w-6 h-6 bg-bg-deep rounded-full grid place-items-center font-extrabold shrink-0 group-open:bg-pri transition-all">+</span>
            <%= f.q %>
          </summary>
          <div class="px-4 pb-4 text-muted text-[13.5px] leading-relaxed [&_a]:text-pri-light [&_a]:underline">
            <p><%- f.a %></p>
          </div>
        </details>
      <% }); %>
    </div>
    <%# Note: Google 2023 update đã restrict FAQ rich result chỉ cho .gov/.edu sites.
        Trang giải trí KHÔNG được hiển thị FAQ rich result dù schema đúng.
        → Bỏ JSON-LD FAQPage để Google Rich Results Test KHÔNG báo lỗi spam.
        Giữ details/summary HTML cho UX (vẫn collapse/expand được). %>
  <% } %>
</section>
<% } %>
