<%
// ARTICLE HERO SVG partial — render khi article.image rỗng
// Args: n (article object) + compact (boolean)
// GUARD: nếu n undefined/null → render empty placeholder thay vì crash
var _n = (typeof n !== 'undefined' && n) ? n : {};
function _ahEsc(s) {
  return String(s == null ? '' : s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
var _uid;
try {
  _uid = (_n.id != null && _n.id !== '')
    ? String(_n.id).replace(/[^a-z0-9]/gi,'').slice(0,10) || ('a' + Math.random().toString(36).slice(2,8))
    : ('a' + Math.random().toString(36).slice(2,8));
} catch (e) { _uid = 'a' + Math.random().toString(36).slice(2,8); }
var _home    = _n.home || 'Đội nhà';
var _away    = _n.away || 'Đội khách';
var _homeBg  = _n.homeBadge || '';
var _awayBg  = _n.awayBadge || '';
var _league  = _n.league || '';
var _score   = _n.predictedScore || '';
var _isCompact = (typeof compact !== 'undefined') ? !!compact : false;
%>
<svg viewBox="0 0 800 450" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice" style="width:100%; height:100%; display:block;">
  <defs>
    <linearGradient id="ahBg<%= _uid %>" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#0a0d12"/>
      <stop offset="50%" stop-color="#1a1f29"/>
      <stop offset="100%" stop-color="#0a0d12"/>
    </linearGradient>
    <radialGradient id="ahGlow<%= _uid %>" cx="50%" cy="50%" r="65%">
      <stop offset="0%" stop-color="#ff7a18" stop-opacity="0.28"/>
      <stop offset="100%" stop-color="#ff7a18" stop-opacity="0"/>
    </radialGradient>
    <linearGradient id="ahYel<%= _uid %>" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#fde047"/>
      <stop offset="100%" stop-color="#eab308"/>
    </linearGradient>
  </defs>

  <!-- Background -->
  <rect width="800" height="450" fill="url(#ahBg<%= _uid %>)"/>
  <ellipse cx="400" cy="225" rx="380" ry="220" fill="url(#ahGlow<%= _uid %>)"/>

  <% if (!_isCompact) { %>
    <!-- Tag góc trên trái -->
    <g transform="translate(30, 28)">
      <rect x="0" y="0" width="248" height="38" rx="6" fill="#ff7a18"/>
      <text x="124" y="25" fill="#fff" font-size="15" font-weight="900" text-anchor="middle" font-family="Arial,'Helvetica Neue',sans-serif" letter-spacing="1.2">NHẬN ĐỊNH BÓNG ĐÁ</text>
    </g>
    <!-- League tag góc trên phải -->
    <% if (_league) { %>
      <g transform="translate(770, 28)">
        <rect x="-210" y="0" width="210" height="38" rx="6" fill="rgba(255,122,24,0.08)" stroke="#ff7a18" stroke-width="2"/>
        <text x="-105" y="25" fill="#ff9a3a" font-size="13" font-weight="900" text-anchor="middle" font-family="Arial,sans-serif" letter-spacing=".6"><%= _ahEsc(_league.slice(0,24).toUpperCase()) %></text>
      </g>
    <% } %>
  <% } %>

  <!-- Logo HOME (left circle) -->
  <g transform="translate(180, 225)">
    <circle r="100" fill="#fff" stroke="#ff7a18" stroke-width="5"/>
    <% if (_homeBg) { %>
      <image href="<%= _ahEsc(_homeBg) %>" x="-78" y="-78" width="156" height="156" preserveAspectRatio="xMidYMid meet"/>
    <% } else { %>
      <text y="22" fill="#ff7a18" font-size="62" font-weight="900" text-anchor="middle" font-family="Arial,sans-serif"><%= _ahEsc(String(_home).replace(/[^A-Za-zÀ-ỹ ]/g,'').slice(0,3).toUpperCase()) %></text>
    <% } %>
    <% if (!_isCompact) { %>
      <text y="148" fill="#e2e8f0" font-size="22" font-weight="800" text-anchor="middle" font-family="Arial,sans-serif"><%= _ahEsc(String(_home).slice(0, 18)) %></text>
    <% } %>
  </g>

  <!-- DỰ ĐOÁN box ở giữa (hoặc VS nếu chưa có score) -->
  <g transform="translate(400, 225)">
    <% if (_score) { %>
      <rect x="-95" y="-65" width="190" height="130" rx="14" fill="url(#ahYel<%= _uid %>)" stroke="#a16207" stroke-width="3"/>
      <text y="-22" fill="#7c2d12" font-size="16" font-weight="900" text-anchor="middle" font-family="Arial,sans-serif" letter-spacing="2">DỰ ĐOÁN</text>
      <line x1="-70" y1="-8" x2="70" y2="-8" stroke="#a16207" stroke-width="1.5" opacity="0.4"/>
      <text y="42" fill="#1f2937" font-size="56" font-weight="900" text-anchor="middle" font-family="Arial,sans-serif"><%= _ahEsc(_score) %></text>
    <% } else { %>
      <circle r="55" fill="rgba(255,122,24,.12)" stroke="#ff7a18" stroke-width="3"/>
      <text y="20" fill="#ff9a3a" font-size="42" font-weight="900" text-anchor="middle" font-family="Arial,sans-serif">VS</text>
    <% } %>
  </g>

  <!-- Logo AWAY (right circle) -->
  <g transform="translate(620, 225)">
    <circle r="100" fill="#fff" stroke="#ff7a18" stroke-width="5"/>
    <% if (_awayBg) { %>
      <image href="<%= _ahEsc(_awayBg) %>" x="-78" y="-78" width="156" height="156" preserveAspectRatio="xMidYMid meet"/>
    <% } else { %>
      <text y="22" fill="#ff7a18" font-size="62" font-weight="900" text-anchor="middle" font-family="Arial,sans-serif"><%= _ahEsc(String(_away).replace(/[^A-Za-zÀ-ỹ ]/g,'').slice(0,3).toUpperCase()) %></text>
    <% } %>
    <% if (!_isCompact) { %>
      <text y="148" fill="#e2e8f0" font-size="22" font-weight="800" text-anchor="middle" font-family="Arial,sans-serif"><%= _ahEsc(String(_away).slice(0, 18)) %></text>
    <% } %>
  </g>

  <% if (!_isCompact) { %>
    <!-- Brand bottom -->
    <text x="400" y="430" fill="#ff7a18" font-size="13" font-weight="800" text-anchor="middle" font-family="Arial,sans-serif" opacity="0.65" letter-spacing="3">XOSO66 TV · PHÂN TÍCH CHUYÊN SÂU</text>
  <% } %>
</svg>
