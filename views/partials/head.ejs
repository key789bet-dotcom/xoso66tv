<!DOCTYPE html>
<html lang="vi" prefix="og: https://ogp.me/ns#" class="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<%# 🛡️ Mục 21: CSRF token — JS đọc qua document.querySelector('meta[name=csrf-token]').content %>
<% if (typeof csrfToken !== 'undefined' && csrfToken) { %><meta name="csrf-token" content="<%= csrfToken %>"><% } %>
<link rel="icon" type="image/webp" href="/static/img/favicon.webp">
<link rel="apple-touch-icon" href="/static/img/favicon.webp">
<!-- PWA -->
<link rel="manifest" href="/manifest.json">
<meta name="theme-color" content="#ff7a18">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="XOSO66 TV">
<meta name="mobile-web-app-capable" content="yes">
<meta name="application-name" content="XOSO66 TV">
<!-- Preconnect: thiết lập sớm TCP+TLS cho domain critical (vẫn giữ - cái này nhẹ + có lợi) -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="preconnect" href="https://cdn.tailwindcss.com">
<link rel="dns-prefetch" href="https://api.thethaoviet.vip">
<link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<script>(function(){try{var t=localStorage.getItem('x66_theme');if(t==='light')document.documentElement.classList.remove('dark');}catch(e){}})();</script>
<!-- Anti-inspect: chặn F12 / right-click / Ctrl+U / detect DevTools. Bypass bằng ?dev=1 -->
<script src="/static/js/anti-inspect.js?v=1" defer></script>
<%- include('tailwind-config') %>
<%- include('seo-head') %>
</head>
<body class="bg-bg text-gray-100 font-sans text-sm leading-normal antialiased">
<div class="fixed inset-0 bg-black/60 z-40 hidden md:hidden" id="sidebarOverlay" onclick="toggleSidebar()"></div>
<div id="appLayout" class="min-h-screen md:grid md:grid-cols-[260px_1fr]">
