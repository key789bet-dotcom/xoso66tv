<%# 🎨 Mục 17: Theme respect system preference — apply NGAY để tránh FOUC.
    Logic:
      - localStorage.x66_theme = 'dark'  → force dark
      - localStorage.x66_theme = 'light' → force light
      - localStorage.x66_theme = 'auto' OR null → follow OS prefers-color-scheme
    Default class trên <html> = "dark" (set ở dòng 2). Script này chỉ xử lý 2 trường hợp khác. %>
<script>(function(){try{
  var t = localStorage.getItem('x66_theme');
  var html = document.documentElement;
  var osLight = window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches;
  if (t === 'light')      html.classList.remove('dark');
  else if (t === 'dark')  html.classList.add('dark');
  else { /* auto or null */
    if (osLight) html.classList.remove('dark');
    else         html.classList.add('dark');
  }
  // Live listener: khi user đổi OS theme + đang chế độ AUTO → site tự switch
  if (window.matchMedia) {
    try {
      window.matchMedia('(prefers-color-scheme: light)').addEventListener('change', function(e){
        var cur = localStorage.getItem('x66_theme');
        if (cur && cur !== 'auto') return; // user đã override manual → KHÔNG auto-switch
        if (e.matches) html.classList.remove('dark');
        else           html.classList.add('dark');
        // Notify other JS (header icon update) qua custom event
        try { window.dispatchEvent(new CustomEvent('x66:themechange', { detail:{ mode:'auto', isDark:!e.matches } })); } catch(_){}
      });
    } catch(e2){}
  }
}catch(e){}})();</script>
