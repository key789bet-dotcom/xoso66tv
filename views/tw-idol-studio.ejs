<%
seo = {
  title: 'Idol Studio - Lên Sóng Trực Tiếp - ' + brand.name,
  description: 'Studio cho idol và BLV lên sóng trực tiếp từ điện thoại hoặc OBS. Stream WebRTC mobile + RTMP OBS.',
  canonical: '/idol-studio',
  noindex: true
};
var idolsActive = (typeof dbIdols !== 'undefined' && dbIdols) ? dbIdols : [];
var myObs = (typeof myObs !== 'undefined') ? myObs : null;
%>
<%- include('partials/tw-layout-start') %>

<%
  // myIdol = idol record của user đang login (server detect tự động)
  var _autoIdol = (typeof myIdol !== 'undefined' && myIdol) ? myIdol : null;
  var _isAdmin  = (typeof isAdmin !== 'undefined' && isAdmin) ? true : false;
  var _cur = _autoIdol ? (_autoIdol.category || 'idol') : 'idol';
  var _lbl = _cur === 'bongda' ? '⚽ Bóng đá' : _cur === 'casino' ? '🎰 Sòng bài' : _cur === 'esport' ? '🎮 Esports' : '👑 Idol Show';
%>
<section class="max-w-md md:max-w-4xl mx-auto mb-6">

  <!-- ════════════ HERO PRO - all-in-one card ════════════ -->
  <div class="relative overflow-hidden rounded-2xl mb-4 border border-pri/40 shadow-2xl shadow-pri/20">
    <!-- BG gradient + sparkle -->
    <div class="absolute inset-0 bg-gradient-to-br from-pri via-rose-600 to-violet-700 opacity-90"></div>
    <div class="absolute inset-0" style="background:radial-gradient(circle at 80% 20%,rgba(255,255,255,.18),transparent 50%),radial-gradient(circle at 20% 80%,rgba(255,122,24,.3),transparent 60%)"></div>

    <div class="relative p-5 md:p-6">
      <!-- Top: title + status pill -->
      <div class="flex items-center justify-between mb-4">
        <div class="flex items-center gap-2">
          <span class="text-3xl drop-shadow-lg">🎙️</span>
          <div>
            <div class="text-[10px] uppercase tracking-[.2em] text-white/70 font-bold">XOSO66 TV</div>
            <h1 class="text-xl md:text-2xl font-black text-white leading-none drop-shadow">Studio Live</h1>
          </div>
        </div>
        <div class="flex items-center gap-2">
          <span class="hidden md:inline-flex items-center gap-1.5 bg-white/15 backdrop-blur text-white text-[10px] font-bold px-2.5 py-1 rounded-full border border-white/20">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span> OFFLINE
          </span>
          <span class="inline-flex items-center gap-1 bg-white/10 backdrop-blur text-white text-[10px] font-bold px-2.5 py-1 rounded-full border border-white/20" id="stuLiveStatus">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
            <span class="hidden" id="stuLiveTime">00:00</span>
            <span>READY</span>
          </span>
        </div>
      </div>

      <!-- Bottom: avatar + identity + category compact -->
      <div class="flex items-center gap-3">
        <% if (_autoIdol) { %>
          <div class="w-16 h-16 rounded-2xl bg-white/20 backdrop-blur grid place-items-center text-4xl shrink-0 border-2 border-white/30 shadow-xl" id="stuAvatar"><%= _autoIdol.emoji || '👑' %></div>
        <% } else { %>
          <div class="w-16 h-16 rounded-2xl bg-white/20 backdrop-blur grid place-items-center text-4xl shrink-0 border-2 border-white/30" id="stuAvatar">👑</div>
        <% } %>
        <div class="flex-1 min-w-0">
          <div class="text-[10px] uppercase tracking-wider text-white/70 font-bold mb-0.5">Streamer</div>
          <div class="font-black text-white text-lg md:text-xl truncate drop-shadow" id="stuIdentityName"><%= _autoIdol ? _autoIdol.name : 'Chưa có profile idol' %></div>
          <% if (_autoIdol) { %>
            <div class="flex items-center gap-1.5 mt-0.5 text-[11px] text-white/85">
              <span class="font-mono"><%= _autoIdol.id %></span>
              <span>·</span>
              <span class="truncate"><%= _autoIdol.room || 'Phòng FREE' %></span>
            </div>
          <% } %>
        </div>
        <% if (_isAdmin) { %>
          <button onclick="stuChangeIdentity()" class="bg-white/15 hover:bg-white/25 backdrop-blur text-white text-xs font-bold px-3 py-1.5 rounded-lg border border-white/30" title="Switch idol">🔁</button>
        <% } %>
      </div>

      <% if (!_autoIdol && !_isAdmin) { %>
        <div class="mt-3 bg-yellow-900/40 border border-yellow-500/50 rounded-lg p-3 text-[12px] text-yellow-100 backdrop-blur">
          ⚠ Chưa có profile idol. <a href="/dang-ky-idol" class="text-yellow-200 underline font-bold">Đăng ký làm Idol</a>
        </div>
      <% } %>
    </div>

    <% if (_isAdmin) { %>
    <div id="stuIdentityDropdown" class="hidden relative border-t border-white/20 bg-black/30 backdrop-blur p-4">
      <label class="text-[11px] text-white/70 uppercase font-bold block mb-1.5">🛡 Admin: chọn idol</label>
      <select id="stuIdolSelect" class="w-full bg-bg-deep border border-line text-white px-3 py-2 rounded-lg text-sm">
        <option value="">-- Chọn idol --</option>
        <% dbIdols.forEach(function(i){ %>
          <option value="<%= i.id %>" data-name="<%= i.name %>" data-emoji="<%= i.emoji %>" <%= (_autoIdol && i.id === _autoIdol.id) ? 'selected' : '' %>><%= i.emoji %> <%= i.name %> (<%= i.room %>)</option>
        <% }); %>
      </select>
      <button onclick="stuSelectIdentity()" class="mt-2 w-full bg-gradient-to-r from-pri to-live text-white py-2 rounded-lg font-bold text-sm">Xác nhận</button>
    </div>
    <% } %>
  </div>

  <!-- 🎯 CHỌN CHUYÊN MỤC LIVE - compact pills ngang -->
  <% if (_autoIdol) { %>
  <div class="bg-bg-card border border-line rounded-xl p-3 mb-4">
    <div class="flex items-center justify-between mb-2">
      <div class="text-[10px] text-muted uppercase tracking-wider font-bold">Chuyên Mục Đang Live</div>
      <span class="text-[10px] text-pri-light font-bold" id="stuCatLabel"><%= _lbl %></span>
    </div>
    <div class="grid grid-cols-4 gap-1.5">
      <button onclick="stuSetCategory('idol')" data-cat="idol" class="stu-cat-btn bg-bg-deep border border-line hover:border-pri text-white py-2 rounded-lg font-bold text-[11px] flex flex-col items-center active:scale-95 transition-all">
        <span class="text-base mb-0.5">👑</span><span class="text-[9.5px]">Idol</span>
      </button>
      <button onclick="stuSetCategory('bongda')" data-cat="bongda" class="stu-cat-btn bg-bg-deep border border-line hover:border-pri text-white py-2 rounded-lg font-bold text-[11px] flex flex-col items-center active:scale-95 transition-all">
        <span class="text-base mb-0.5">⚽</span><span class="text-[9.5px]">Bóng đá</span>
      </button>
      <button onclick="stuSetCategory('casino')" data-cat="casino" class="stu-cat-btn bg-bg-deep border border-line hover:border-pri text-white py-2 rounded-lg font-bold text-[11px] flex flex-col items-center active:scale-95 transition-all">
        <span class="text-base mb-0.5">🎰</span><span class="text-[9.5px]">Sòng bài</span>
      </button>
      <button onclick="stuSetCategory('esport')" data-cat="esport" class="stu-cat-btn bg-bg-deep border border-line hover:border-pri text-white py-2 rounded-lg font-bold text-[11px] flex flex-col items-center active:scale-95 transition-all">
        <span class="text-base mb-0.5">🎮</span><span class="text-[9.5px]">Esports</span>
      </button>
    </div>
    <div class="text-[10px] text-muted mt-1.5">💡 Hiển thị trên tab <span class="text-pri-light font-bold" id="stuCatHint"><%= _lbl %></span></div>
  </div>
  <script>
    // Auto-set state.identity từ server (không cần user chọn)
    <% if (_autoIdol) { %>
    window.__autoIdol = {
      id: '<%= _autoIdol.id %>',
      name: <%- JSON.stringify(_autoIdol.name) %>,
      emoji: <%- JSON.stringify(_autoIdol.emoji || '👑') %>,
      category: <%- JSON.stringify(_autoIdol.category || 'idol') %>
    };
    <% } %>

    // Highlight category button đã chọn
    (function(){
      var cur = (window.__autoIdol && window.__autoIdol.category) || 'idol';
      document.querySelectorAll('.stu-cat-btn').forEach(function(b){
        if (b.dataset.cat === cur) {
          b.classList.remove('bg-bg-deep','border-line');
          b.classList.add('bg-gradient-to-br','from-pri','to-pri-dark','border-pri','shadow-pri');
        }
      });
    })();

    // User click chọn chuyên mục
    window.stuSetCategory = function(cat){
      // Update UI
      document.querySelectorAll('.stu-cat-btn').forEach(function(b){
        b.classList.remove('bg-gradient-to-br','from-pri','to-pri-dark','border-pri','shadow-pri');
        b.classList.add('bg-bg-deep','border-line');
      });
      var btn = document.querySelector('.stu-cat-btn[data-cat="'+cat+'"]');
      if (btn) {
        btn.classList.remove('bg-bg-deep','border-line');
        btn.classList.add('bg-gradient-to-br','from-pri','to-pri-dark','border-pri','shadow-pri');
      }
      var labels = { idol:'👑 Idol Show', bongda:'⚽ Bóng đá', casino:'🎰 Sòng bài', esport:'🎮 Esports' };
      document.getElementById('stuCatLabel').textContent = labels[cat] || cat;
      document.getElementById('stuCatHint').textContent = labels[cat] || cat;
      if (window.__autoIdol) window.__autoIdol.category = cat;
      // Save lên DB ngay
      if (window.state && window.state.identity) {
        window.state.identity.category = cat;
      }
      fetch('/api/idol-self/set-category', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ category: cat })
      }).then(function(r){ return r.json(); }).then(function(j){
        if (j.ok && typeof showToast === 'function') showToast('✓ Đã chuyển chuyên mục: ' + (labels[cat]||cat), 'success');
      }).catch(function(){});
    };
  </script>
  <% } %>

  <!-- HTTPS warning chỉ hiện trong dev (localhost) - production luôn HTTPS -->
  <div id="stuHttpsWarn" class="hidden bg-yellow-900/30 border border-yellow-500/40 rounded-lg px-3 py-2 mb-3 text-yellow-200 text-[12px] flex items-center gap-2">
    <span>⚠️</span><span>Camera cần HTTPS. Dev local cần dùng ngrok hoặc mkcert.</span>
  </div>
  <div id="stuHttpsOk" class="hidden"></div>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- 📅 ĐĂNG KÝ LỊCH LIVE - bắt buộc cho cả Mobile + OBS             -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <div class="bg-gradient-to-br from-pri/15 via-bg-card to-bg-soft border-2 border-pri/40 rounded-xl p-4 mb-4">
    <div class="flex items-center justify-between mb-3">
      <div class="flex items-center gap-2">
        <span class="text-2xl">📅</span>
        <h3 class="text-white font-extrabold text-base">Đăng ký lịch live</h3>
      </div>
      <span id="schActiveStatus" class="text-[11px] font-bold"></span>
    </div>

    <!-- Tabs -->
    <div class="flex gap-1 bg-bg-deep rounded-lg p-1 mb-3">
      <button id="schTabMy" class="flex-1 py-1.5 text-xs font-bold rounded transition-colors bg-pri text-white">📋 Lịch của tôi</button>
      <button id="schTabNew" class="flex-1 py-1.5 text-xs font-bold rounded transition-colors text-gray-200">➕ Đăng ký mới</button>
    </div>

    <!-- TAB 1: List lịch của tôi -->
    <div id="schMyPanel">
      <div id="schMyList" class="space-y-2 min-h-[60px]">
        <div class="text-center text-muted text-xs py-4">Đang tải...</div>
      </div>
    </div>

    <!-- TAB 2: Form đăng ký mới -->
    <div id="schNewPanel" class="hidden">
      <div class="flex gap-1.5 mb-3">
        <button id="schTypeTime" class="sch-type-btn flex-1 py-2 text-xs font-bold rounded-lg border bg-pri text-white border-pri" data-type="time">⏰ Theo giờ tự do</button>
        <button id="schTypeMatch" class="sch-type-btn flex-1 py-2 text-xs font-bold rounded-lg border bg-bg-deep text-gray-200 border-line" data-type="match">⚽ Theo trận đấu</button>
      </div>

      <div id="schFormTime" class="space-y-2.5">
        <div>
          <label class="text-[10px] text-muted uppercase font-bold block mb-1">Tiêu đề show</label>
          <input id="schTitle" maxlength="120" placeholder="VD: Live show hát cover tối T7" class="w-full bg-bg-deep border border-line text-white text-sm px-3 py-2 rounded-lg outline-none focus:border-pri">
        </div>
        <div class="grid grid-cols-2 gap-2">
          <div>
            <label class="text-[10px] text-muted uppercase font-bold block mb-1">Bắt đầu</label>
            <input id="schStartTime" type="datetime-local" class="w-full bg-bg-deep border border-line text-white text-sm px-2 py-2 rounded-lg outline-none focus:border-pri">
          </div>
          <div>
            <label class="text-[10px] text-muted uppercase font-bold block mb-1">Kết thúc</label>
            <input id="schEndTime" type="datetime-local" class="w-full bg-bg-deep border border-line text-white text-sm px-2 py-2 rounded-lg outline-none focus:border-pri">
          </div>
        </div>
        <div>
          <label class="text-[10px] text-muted uppercase font-bold block mb-1">Mô tả (tuỳ chọn)</label>
          <textarea id="schDescription" maxlength="500" rows="2" placeholder="Nội dung show, theme..." class="w-full bg-bg-deep border border-line text-white text-sm px-3 py-2 rounded-lg outline-none focus:border-pri resize-none"></textarea>
        </div>
      </div>

      <div id="schFormMatch" class="hidden space-y-2.5">
        <div>
          <label class="text-[10px] text-muted uppercase font-bold block mb-1">Chọn trận đấu</label>
          <select id="schMatchSelect" class="w-full bg-bg-deep border border-line text-white text-sm px-3 py-2 rounded-lg outline-none focus:border-pri">
            <option value="">Đang tải lịch...</option>
          </select>
        </div>
        <div class="text-[11px] text-muted">⚠️ BLV sẽ được duyệt bình luận trận đã chọn (thời gian tự auto theo trận).</div>
      </div>

      <button id="schSubmitBtn" class="w-full bg-gradient-to-r from-pri to-live hover:brightness-110 text-white font-bold py-2.5 rounded-lg mt-3 active:scale-95">
        📤 Gửi cho admin duyệt
      </button>
    </div>

    <div class="text-[10.5px] text-muted mt-3 leading-relaxed">
      💡 <b>Quy tắc:</b> Lịch cần admin duyệt trước. Sau khi duyệt, bạn được lên sóng từ <b>30 phút trước</b> giờ start đến <b>3 giờ sau</b> giờ end (áp dụng cho cả Mobile + OBS).
    </div>
  </div>

  <!-- Tab nav -->
  <nav class="flex bg-bg-card rounded-xl p-1 mb-4 border border-line">
    <button onclick="stuSwitchTab('mobile')" id="stuTabMobile" class="flex-1 py-2.5 rounded-lg bg-pri text-white font-bold text-sm flex items-center justify-center gap-2">
      📱 <span>Stream Mobile</span>
    </button>
    <button onclick="stuSwitchTab('obs')" id="stuTabObs" class="flex-1 py-2.5 rounded-lg text-gray-300 font-bold text-sm flex items-center justify-center gap-2">
      🎮 <span>Stream OBS</span>
    </button>
  </nav>

  <!-- ============ TAB 1: MOBILE STREAM (WebRTC) ============ -->
  <div id="stuPanelMobile" class="space-y-4">
    <!-- Camera preview -->
    <div class="bg-black rounded-2xl overflow-hidden relative aspect-video border-2 border-pri/40 shadow-xl">
      <video id="stuVideo" autoplay muted playsinline class="w-full h-full object-cover bg-black"></video>
      <!-- Overlay status -->
      <div class="absolute top-3 left-3 z-10 flex items-center gap-2">
        <span id="stuLiveBadge" class="hidden bg-live text-white px-3 py-1 rounded-md font-extrabold text-xs flex items-center gap-1.5">
          <span class="w-1.5 h-1.5 bg-white rounded-full animate-pulse"></span>LIVE
        </span>
        <span id="stuPreviewBadge" class="bg-yellow-500 text-black px-2 py-0.5 rounded text-[11px] font-extrabold">PREVIEW</span>
      </div>
      <div class="absolute top-3 right-3 z-10 bg-black/60 text-gold px-2 py-0.5 rounded text-[11px] font-bold tabular-nums flex items-center gap-1">
        👁 <span id="stuLiveViewers">0</span>
      </div>
      <!-- Empty state -->
      <div id="stuNoCam" class="absolute inset-0 grid place-items-center text-center p-4 text-white">
        <div>
          <div class="text-6xl mb-2 opacity-40">📷</div>
          <div class="font-bold mb-1">Chưa bật camera</div>
          <div class="text-xs text-muted mb-3">Bấm "Bật camera" để xem trước</div>
          <button onclick="stuStartCamera()" class="bg-gradient-to-r from-pri to-live text-white px-5 py-2 rounded-full font-bold text-sm shadow-lg">📷 Bật camera</button>
        </div>
      </div>
    </div>

    <!-- ===== CHAT MONITOR ngay dưới video (visible khi LIVE) ===== -->
    <div id="stuChatMonitor" class="hidden bg-bg-card border-2 border-pri/40 rounded-2xl overflow-hidden shadow-xl mt-3 -mb-1">
      <header class="px-3 py-2 bg-gradient-to-r from-pri to-pri-dark flex items-center gap-2 text-white">
        <span class="text-base">💬</span>
        <h3 class="font-extrabold text-sm">Chat từ viewer</h3>
        <span class="ml-auto bg-white/20 text-[10px] font-bold px-2 py-0.5 rounded-full" id="stuChatOnlineCount">0 online</span>
      </header>
      <!-- Chat list -->
      <div id="stuChatList" class="h-48 md:h-56 overflow-y-auto p-2 space-y-1 bg-gradient-to-b from-bg-deep to-bg-card scrollbar-thin"></div>
      <!-- Reply input -->
      <div class="flex gap-1.5 p-2 border-t border-line bg-bg-soft">
        <input id="stuChatInput" maxlength="200" class="flex-1 bg-bg-deep border border-line text-white px-3 py-2 rounded-lg outline-none text-sm focus:border-pri" placeholder="Trả lời viewer..." onkeydown="if(event.key==='Enter')stuSendChatReply()">
        <button onclick="stuSendChatReply()" class="bg-gradient-to-br from-pri to-live text-white px-4 rounded-lg font-bold text-xs active:scale-95 whitespace-nowrap">Gửi</button>
      </div>
    </div>

    <!-- Camera controls -->
    <div class="grid grid-cols-4 gap-2">
      <button onclick="stuSwitchCamera()" id="stuSwitchCamBtn" class="bg-bg-card border border-line hover:border-pri text-white py-2.5 rounded-xl font-bold text-xs flex flex-col items-center gap-1 active:scale-95">
        <span class="text-lg">🔄</span><span>Đảo cam</span>
      </button>
      <button onclick="stuToggleMic()" id="stuMicBtn" class="bg-bg-card border border-line hover:border-pri text-white py-2.5 rounded-xl font-bold text-xs flex flex-col items-center gap-1 active:scale-95">
        <span class="text-lg">🎤</span><span>Mic ON</span>
      </button>
      <button onclick="stuToggleBeauty()" id="stuBeautyBtn" class="bg-bg-card border border-line hover:border-pri text-white py-2.5 rounded-xl font-bold text-xs flex flex-col items-center gap-1 active:scale-95">
        <span class="text-lg">✨</span><span>Filter OFF</span>
      </button>
      <button onclick="stuStopCamera()" class="bg-bg-card border border-line hover:border-live text-white py-2.5 rounded-xl font-bold text-xs flex flex-col items-center gap-1 active:scale-95">
        <span class="text-lg">⏹</span><span>Dừng</span>
      </button>
    </div>

    <!-- ===== QUALITY SELECTOR (chọn 1080p / 720p / 480p / 360p) ===== -->
    <div class="bg-bg-card border border-line rounded-xl p-3">
      <div class="flex items-center justify-between mb-2">
        <label class="text-[11px] text-muted uppercase font-bold flex items-center gap-1.5">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
          Chất lượng stream
        </label>
        <span id="stuQualityBadge" class="hidden text-white text-[10px] font-extrabold px-2 py-0.5 rounded">720p</span>
      </div>
      <div class="grid grid-cols-4 gap-1.5">
        <button onclick="stuSetQuality('1080p')" data-q="1080p" class="stu-q-btn bg-bg-deep border border-line hover:border-pri text-white py-2 rounded-lg font-bold text-[11px] flex flex-col items-center active:scale-95">
          <span class="text-[14px] leading-tight">1080p</span>
          <span class="text-[8px] opacity-70 mt-0.5">Full HD</span>
        </button>
        <button onclick="stuSetQuality('720p')" data-q="720p" class="stu-q-btn bg-bg-deep border border-line hover:border-pri text-white py-2 rounded-lg font-bold text-[11px] flex flex-col items-center active:scale-95">
          <span class="text-[14px] leading-tight">720p</span>
          <span class="text-[8px] opacity-70 mt-0.5">HD</span>
        </button>
        <button onclick="stuSetQuality('480p')" data-q="480p" class="stu-q-btn bg-bg-deep border border-line hover:border-pri text-white py-2 rounded-lg font-bold text-[11px] flex flex-col items-center active:scale-95">
          <span class="text-[14px] leading-tight">480p</span>
          <span class="text-[8px] opacity-70 mt-0.5">SD</span>
        </button>
        <button onclick="stuSetQuality('360p')" data-q="360p" class="stu-q-btn bg-bg-deep border border-line hover:border-pri text-white py-2 rounded-lg font-bold text-[11px] flex flex-col items-center active:scale-95">
          <span class="text-[14px] leading-tight">360p</span>
          <span class="text-[8px] opacity-70 mt-0.5">LOW</span>
        </button>
      </div>
      <div class="text-[10px] text-muted mt-1.5 leading-relaxed">
        💡 <b class="text-pri-light">720p (HD)</b> được khuyến nghị cho hầu hết mạng 4G/Wi-Fi.
        Chọn 480p nếu mạng yếu.
      </div>
    </div>
    <script>
      // Highlight quality đang chọn
      (function highlightQuality(){
        var saved = (function(){ try { return localStorage.getItem('x66_stu_quality') || '720p'; } catch(e){ return '720p'; } })();
        document.querySelectorAll('.stu-q-btn').forEach(function(b){
          if (b.dataset.q === saved) {
            b.classList.remove('bg-bg-deep','border-line');
            b.classList.add('bg-gradient-to-br','from-pri','to-pri-dark','border-pri','shadow-pri');
          }
        });
      })();
      // Update highlight khi đổi
      var _origSetQ = window.stuSetQuality;
