<script>
(function(){
  // ===== STATE =====
  var state = {
    identity: null, // { id, name, emoji }
    stream: null,
    mediaStream: null,
    facingMode: 'user',
    micOn: true,
    beautyOn: false,
    category: 'show',
    isLive: false,
    liveStartTime: 0,
    durationTimer: null
  };

  // ===== HTTPS / SECURE CONTEXT CHECK =====
  document.getElementById('stuCurrentUrl').textContent = location.protocol + '//' + location.host;
  var isSecure = window.isSecureContext || location.protocol === 'https:' 
              || location.hostname === 'localhost' || location.hostname === '127.0.0.1';
  if (!isSecure) {
    document.getElementById('stuHttpsWarn').classList.remove('hidden');
  } else {
    // Only show OK badge if accessed from non-localhost (means user followed tunnel)
    if (location.protocol === 'https:' && location.hostname !== 'localhost') {
      document.getElementById('stuHttpsOk').classList.remove('hidden');
    }
  }

  // ===== AUTH CHECK =====
  try {
    var u = JSON.parse(localStorage.getItem('x66_user')||'{}');
    if (!u.username) {
      if (confirm('Cần đăng nhập để lên sóng. Đăng nhập ngay?')) location.href='/dang-nhap';
      else location.href='/idol-live';
      return;
    }
  } catch(e){}

  // ===== TAB SWITCH =====
  window.stuSwitchTab = function(tab){
    var mobile = document.getElementById('stuPanelMobile');
    var obs    = document.getElementById('stuPanelObs');
    var tabM   = document.getElementById('stuTabMobile');
    var tabO   = document.getElementById('stuTabObs');
    if (tab === 'mobile'){
      mobile.classList.remove('hidden'); obs.classList.add('hidden');
      tabM.className = 'flex-1 py-2.5 rounded-lg bg-pri text-white font-bold text-sm flex items-center justify-center gap-2';
      tabO.className = 'flex-1 py-2.5 rounded-lg text-gray-300 font-bold text-sm flex items-center justify-center gap-2';
    } else {
      mobile.classList.add('hidden'); obs.classList.remove('hidden');
      tabO.className = 'flex-1 py-2.5 rounded-lg bg-pri text-white font-bold text-sm flex items-center justify-center gap-2';
      tabM.className = 'flex-1 py-2.5 rounded-lg text-gray-300 font-bold text-sm flex items-center justify-center gap-2';
    }
  };

  // ===== IDENTITY =====
  function loadIdentity(){
    // 🆕 ƯU TIÊN auto-detect từ server (user đang login)
    if (window.__autoIdol && window.__autoIdol.id) {
      state.identity = {
        id: window.__autoIdol.id,
        name: window.__autoIdol.name,
        emoji: window.__autoIdol.emoji,
        category: window.__autoIdol.category || 'idol'
      };
      // Lưu vào localStorage để các module khác đọc
      try { localStorage.setItem('x66_idol_identity', JSON.stringify(state.identity)); } catch(e){}
      loadStreamKey();
      return;
    }
    // Fallback: load từ localStorage (admin đã từng switch)
    try {
      var saved = JSON.parse(localStorage.getItem('x66_idol_identity')||'null');
      if (saved && saved.id) {
        state.identity = saved;
        var nameEl = document.getElementById('stuIdentityName');
        var avEl   = document.getElementById('stuAvatar');
        if (nameEl) nameEl.textContent = saved.name;
        if (avEl) avEl.textContent = saved.emoji;
        loadStreamKey();
      }
    } catch(e){}
  }
  window.stuChangeIdentity = function(){
    document.getElementById('stuIdentityDropdown').classList.toggle('hidden');
  };
  window.stuSelectIdentity = function(){
    var sel = document.getElementById('stuIdolSelect');
    if (!sel.value) { alert('Chọn idol trước'); return; }
    var opt = sel.options[sel.selectedIndex];
    state.identity = { id: sel.value, name: opt.dataset.name, emoji: opt.dataset.emoji };
    localStorage.setItem('x66_idol_identity', JSON.stringify(state.identity));
    document.getElementById('stuIdentityName').textContent = state.identity.name;
    document.getElementById('stuAvatar').textContent = state.identity.emoji;
    document.getElementById('stuIdentityDropdown').classList.add('hidden');
    loadStreamKey();
  };
  loadIdentity();

  // ===== QUALITY PRESETS =====
  var QUALITY_PRESETS = {
    '1080p': { width: 1920, height: 1080, frameRate: 30, bitrate: 3500000, label: 'Full HD', badge:'1080p', color:'#10b981' },
    '720p':  { width: 1280, height: 720,  frameRate: 30, bitrate: 2000000, label: 'HD',      badge:'720p',  color:'#3b82f6' },
    '480p':  { width: 854,  height: 480,  frameRate: 25, bitrate: 1000000, label: 'SD',      badge:'480p',  color:'#f59e0b' },
    '360p':  { width: 640,  height: 360,  frameRate: 25, bitrate: 600000,  label: 'LOW',     badge:'360p',  color:'#ef4444' }
  };
  // Quality mặc định lấy từ localStorage hoặc 720p
  state.quality = (function(){
    try { return localStorage.getItem('x66_stu_quality') || '720p'; } catch(e) { return '720p'; }
  })();

  window.stuSetQuality = async function(q) {
    if (!QUALITY_PRESETS[q]) return;
    state.quality = q;
    try { localStorage.setItem('x66_stu_quality', q); } catch(e){}
    // Update UI badge
    var badge = document.getElementById('stuQualityBadge');
    if (badge) {
      badge.textContent = QUALITY_PRESETS[q].badge;
      badge.style.background = QUALITY_PRESETS[q].color;
    }
    // Nếu camera đang chạy → restart với quality mới
    if (state.mediaStream) {
      state.mediaStream.getTracks().forEach(function(t){ t.stop(); });
      state.mediaStream = null;
      await stuStartCamera();
      // Nếu đang live → restart stream với quality mới
      if (state.isLive && typeof stuRestartLive === 'function') stuRestartLive();
    }
    if (typeof showToast === 'function') showToast('✓ Đã chuyển sang ' + QUALITY_PRESETS[q].label + ' (' + q + ')', 'success');
  };

  // ===== MOBILE CAMERA (WebRTC getUserMedia) =====
  window.stuStartCamera = async function(){
    try {
      var preset = QUALITY_PRESETS[state.quality] || QUALITY_PRESETS['720p'];
      var stream = await navigator.mediaDevices.getUserMedia({
        video: {
          facingMode: state.facingMode,
          width:  { ideal: preset.width },
          height: { ideal: preset.height },
          frameRate: { ideal: preset.frameRate, max: preset.frameRate }
        },
        audio: state.micOn ? {
          echoCancellation: true,
          noiseSuppression: true,
          autoGainControl: true
        } : false
      });
      state.mediaStream = stream;
      var video = document.getElementById('stuVideo');
      video.srcObject = stream;
      document.getElementById('stuNoCam').classList.add('hidden');

      // Update quality badge sau khi camera ready
      var badge = document.getElementById('stuQualityBadge');
      if (badge) {
        badge.textContent = preset.badge;
        badge.style.background = preset.color;
        badge.classList.remove('hidden');
      }

      // Lưu quality lên DB để viewer biết
      try {
        await fetch('/api/streamer/set-quality', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ quality: state.quality })
        });
      } catch(e){}
    } catch(e) {
      var msg = 'Không thể truy cập camera: ' + e.message;
      if (!window.isSecureContext) msg += '\n\n⚠ Trang đang HTTP non-secure → camera bị chặn.\n→ Xem hướng dẫn HTTPS ở banner vàng phía trên.';
      else msg += '\n\n• Kiểm tra quyền camera trong cài đặt trình duyệt\n• Đóng app khác đang dùng camera (Zoom, Skype...)';
      alert(msg);
    }
  };
  window.stuStopCamera = function(){
    if (state.mediaStream) {
      state.mediaStream.getTracks().forEach(function(t){ t.stop(); });
      state.mediaStream = null;
    }
    document.getElementById('stuVideo').srcObject = null;
    document.getElementById('stuNoCam').classList.remove('hidden');
    if (state.isLive) stuEndLive();
  };
  window.stuSwitchCamera = async function(){
    state.facingMode = state.facingMode === 'user' ? 'environment' : 'user';
    if (state.mediaStream) {
      state.mediaStream.getTracks().forEach(function(t){ t.stop(); });
      await stuStartCamera();
    }
  };
  window.stuToggleMic = function(){
    state.micOn = !state.micOn;
    if (state.mediaStream) {
      state.mediaStream.getAudioTracks().forEach(function(t){ t.enabled = state.micOn; });
    }
    var btn = document.getElementById('stuMicBtn');
    btn.querySelector('span:last-child').textContent = state.micOn ? 'Mic ON' : 'Mic OFF';
    btn.classList.toggle('border-live', !state.micOn);
    btn.classList.toggle('text-live', !state.micOn);
  };
  window.stuToggleBeauty = function(){
    state.beautyOn = !state.beautyOn;
    var video = document.getElementById('stuVideo');
