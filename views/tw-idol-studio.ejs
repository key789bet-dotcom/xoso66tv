  // ===== SRS RTC PUBLISH (browser native live, support SRS 5 & 6) =====
  state.pc = null;
  async function whipPublish(streamKey){
    // SRS native publish API (work với cả SRS 5/6) - JSON body
    var PUBLISH_URL = 'https://xoso66tv.com/rtc/v1/publish/';
    var STREAM_URL  = 'webrtc://xoso66tv.com/live/' + streamKey;
    var pc = new RTCPeerConnection({
      iceServers: [{ urls: ['stun:stun.cloudflare.com:3478'] }]
    });
    state.mediaStream.getTracks().forEach(function(t){ pc.addTrack(t, state.mediaStream); });

    // 🎬 FORCE codec H264 (SRS chỉ bridge H264 sang FLV, VP8/VP9 không work)
    try {
      var transceivers = pc.getTransceivers();
      transceivers.forEach(function(tr){
        if (tr.sender && tr.sender.track && tr.sender.track.kind === 'video') {
          var caps = RTCRtpSender.getCapabilities('video');
          if (caps && caps.codecs) {
            var h264 = caps.codecs.filter(function(c){ return c.mimeType.toLowerCase().indexOf('h264') > -1; });
            var others = caps.codecs.filter(function(c){ return c.mimeType.toLowerCase().indexOf('h264') === -1; });
            if (h264.length > 0) {
              tr.setCodecPreferences(h264.concat(others));
              console.log('[WHIP] Forced H264 video codec for SRS compatibility');
            }
          }
        }
      });
    } catch(e) { console.log('[WHIP] Codec preference not supported:', e.message); }

    var offer = await pc.createOffer({ offerToReceiveAudio: false, offerToReceiveVideo: false });
    await pc.setLocalDescription(offer);

    var resp = await fetch(PUBLISH_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        api: PUBLISH_URL,
        streamurl: STREAM_URL,
        sdp: pc.localDescription.sdp
      })
    });
    if (!resp.ok) throw new Error('SRS Publish HTTP ' + resp.status);
    var j = await resp.json();
    if (j.code !== 0) throw new Error('SRS error code ' + j.code);
    await pc.setRemoteDescription({ type: 'answer', sdp: j.sdp });
    console.log('[SRS] Stream published:', streamKey, '→', STREAM_URL);
    return pc;
  }
  async function whipUnpublish(){
    if (state.pc) { try { state.pc.close(); } catch(e){} state.pc = null; }
  }

  // ===== GO LIVE / END LIVE =====
  window.stuGoLive = async function(){
    if (!state.identity) { alert('Chọn idol trước'); return; }
    if (!state.mediaStream) { alert('Bật camera trước khi lên sóng'); return; }
    var title = document.getElementById('stuTitle').value.trim();
    if (!title) { alert('Nhập tiêu đề buổi live'); document.getElementById('stuTitle').focus(); return; }
    if (!confirm('Bắt đầu lên sóng với tư cách ' + state.identity.name + '?\n\n📡 Stream sẽ phát qua WebRTC (browser native, latency ~1s)')) return;

    // STEP 1: Publish WebRTC stream lên SRS server
    try {
      state.pc = await whipPublish(state.identity.id);
    } catch(e) {
      alert('❌ Lỗi WebRTC: ' + e.message + '\n\n(SRS server có thể chưa sẵn sàng. Vẫn tiếp tục với mode demo)');
      console.error('[WHIP]', e);
    }

    // STEP 2: Call API to mark stream active (kèm category đang chọn)
    var _cat = (state.identity && state.identity.category) ||
               (window.__autoIdol && window.__autoIdol.category) || 'idol';
    fetch('/api/studio/go-live', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ idolId: state.identity.id, title: title, category: _cat, goal: parseInt(document.getElementById('stuGoal').value||0) })
    }).then(function(r){ return r.json(); }).then(function(j){
      if (j.ok) {
        state.isLive = true;
        state.liveStartTime = Date.now();
        document.getElementById('stuGoLiveBtn').classList.add('hidden');
        document.getElementById('stuEndLiveBtn').classList.remove('hidden');
        document.getElementById('stuLiveBadge').classList.remove('hidden');
        document.getElementById('stuPreviewBadge').classList.add('hidden');
        document.getElementById('stuLiveStats').classList.remove('hidden');
        document.getElementById('stuLiveStatus').classList.remove('hidden');
        document.getElementById('stuChatMonitor').classList.remove('hidden');
        var openBtn = document.getElementById('stuOpenRoomBtn');
        openBtn.classList.remove('hidden');
        openBtn.href = '/idol/' + state.identity.id;
        startDurationTimer();
        startFakeStats();
        startChatMonitor();
        alert('🎉 ĐANG LIVE! Viewer có thể vào xem tại /idol/' + state.identity.id);
      } else {
        alert('Lỗi: ' + (j.error || 'Không thể lên sóng'));
      }
    }).catch(function(e){
      // Fallback: just toggle UI locally
      state.isLive = true; state.liveStartTime = Date.now();
      document.getElementById('stuGoLiveBtn').classList.add('hidden');
      document.getElementById('stuEndLiveBtn').classList.remove('hidden');
      document.getElementById('stuLiveBadge').classList.remove('hidden');
      document.getElementById('stuPreviewBadge').classList.add('hidden');
      document.getElementById('stuLiveStats').classList.remove('hidden');
      document.getElementById('stuLiveStatus').classList.remove('hidden');
      document.getElementById('stuChatMonitor').classList.remove('hidden');
      var ob = document.getElementById('stuOpenRoomBtn');
      ob.classList.remove('hidden');
      ob.href = '/idol/' + state.identity.id;
      startDurationTimer(); startFakeStats(); startChatMonitor();
      alert('🎉 ĐANG LIVE (Demo mode)');
    });
  };
  window.stuEndLive = async function(){
    if (!confirm('Kết thúc buổi live?')) return;
    // Close WebRTC connection
    await whipUnpublish();
    fetch('/api/studio/end-live', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ idolId: state.identity ? state.identity.id : '' })
    }).catch(function(){});
    state.isLive = false;
    document.getElementById('stuGoLiveBtn').classList.remove('hidden');
    document.getElementById('stuEndLiveBtn').classList.add('hidden');
    document.getElementById('stuLiveBadge').classList.add('hidden');
    document.getElementById('stuPreviewBadge').classList.remove('hidden');
    document.getElementById('stuLiveStats').classList.add('hidden');
    document.getElementById('stuLiveStatus').classList.add('hidden');
    document.getElementById('stuChatMonitor').classList.add('hidden');
    document.getElementById('stuOpenRoomBtn').classList.add('hidden');
    if (state.durationTimer) clearInterval(state.durationTimer);
    if (state.chatTimer) clearInterval(state.chatTimer);
  };

  function startDurationTimer(){
    if (state.durationTimer) clearInterval(state.durationTimer);
    state.durationTimer = setInterval(function(){
      var sec = Math.floor((Date.now() - state.liveStartTime)/1000);
      var h = Math.floor(sec/3600), m = Math.floor((sec%3600)/60), s = sec%60;
      var str = (h>0?(h<10?'0':'')+h+':':'') + (m<10?'0':'')+m+':'+(s<10?'0':'')+s;
      document.getElementById('stuStatDuration').textContent = str;
