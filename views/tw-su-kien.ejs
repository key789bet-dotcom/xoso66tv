<%
seo = {
  title: 'Sự Kiện & Khuyến Mãi Hot Nhất - '+brand.name,
  description: 'Khuyến mãi nạp tiền 100%, voucher miễn phí tại '+brand.name+' x '+brand.domain+'. Cập nhật hàng ngày.',
  keywords: 'khuyến mãi, sự kiện, thưởng nạp, voucher',
  canonical: '/su-kien',
  breadcrumb: [{ name:'Sự kiện & Khuyến mãi', url:'/su-kien' }]
};
%>
<%- include('partials/tw-layout-start') %>
<%- include('partials/tw-breadcrumb') %>

<header class="hero-animated-bg bg-gradient-to-br from-bg-card to-bg-soft border border-line rounded-xl px-6 py-5 mb-4"><div class="hero-sparkles" aria-hidden="true"><span></span><span></span><span></span><span></span><span></span></div>
  <h1 class="text-xl md:text-2xl font-black text-white mb-2.5"><span class="text-2xl">&#127873;</span> <span class="text-shimmer">Sự Kiện & Khuyến Mãi Hot Nhất Tháng</span></h1>
  <p class="text-muted text-sm">Cập nhật các chương trình thưởng siêu hấp dẫn từ <a href="<%= partner.home %>" target="_blank" rel="noopener" class="text-pri-light font-bold"><%= brand.domain %></a>.</p>
</header>

<section aria-label="Khuyến mãi">
  <div class="grid gap-4 grid-cols-[repeat(auto-fill,minmax(360px,1fr))]">
    <% var _promos = (typeof promos !== 'undefined' && promos && promos.length) ? promos : banners.concat(banners).slice(0,6); _promos.forEach(function(b, i){ %>
      <% var _pBg = 'background:'+b.bg+';' + (b.image ? 'background-image:url('+b.image+');background-size:cover;background-position:center;' : ''); %>
      <article class="p-6 rounded-xl text-white relative overflow-hidden min-h-[220px]" style="<%= _pBg %>">
        <% if (b.image) { %><div class="absolute inset-0 bg-gradient-to-br from-black/55 to-black/15"></div><% } %>
        <div class="relative z-10">
          <div class="text-[11px] tracking-widest uppercase opacity-90 font-bold">KHUYẾN MÃI <%= i+1 %></div>
          <h2 class="text-xl font-black my-2 leading-tight"><%= b.title %></h2>
          <p class="text-sm opacity-95 mb-3.5"><%= b.desc %></p>
          <a href="<%= b.url %>" target="_blank" rel="noopener" class="inline-block bg-white text-red-700 px-5 py-2 rounded-md font-extrabold"><%= b.cta %> &rarr;</a>
        </div>
        <div class="absolute -top-5 -right-5 w-32 h-32 bg-white/10 rounded-full"></div>
      </article>
    <% }); %>
  </div>

  <aside class="mt-7 bg-bg-card border border-line rounded-xl p-5">
    <h2 class="text-pri-light text-lg font-bold mb-3">&#127919; Cách tham gia khuyến mãi</h2>
    <ol class="text-muted text-sm leading-loose pl-6 list-decimal space-y-1">
      <li><a href="/dang-ky" class="text-pri-light">Đăng ký tài khoản</a> miễn phí</li>
      <li>Hoàn tất xác thực thông tin cá nhân</li>
      <li>Nạp tiền lần đầu để kích hoạt khuyến mãi</li>
      <li>Click "Nhận ngay" trên mỗi chương trình</li>
      <li>Liên hệ <a href="<%= partner.telegram %>" target="_blank" class="text-pri-light">CSKH Telegram 24/7</a> nếu cần hỗ trợ</li>
    </ol>
  </aside>
</section>

<%- include('partials/tw-seo-bottom', { seoContent: {
  h2:'Khuyến mãi cập nhật và hấp dẫn nhất thị trường',
  intro:brand.name+' tổng hợp toàn bộ khuyến mãi mới nhất từ <strong>'+brand.domain+'</strong>. Tất cả đều minh bạch, không điều khoản ẩn.',
  sections: [
    { h3:'Thưởng nạp lần đầu 100%', p:'Đăng ký mới + nạp tối thiểu 200K - Nhận ngay 100% giá trị nạp lên đến 5.000.000đ.' },
    { h3:'Vé cược thua hoàn 100%', p:'Vé cược thể thao đầu tiên thua trong 30 ngày sau đăng ký được hoàn 100% (tối đa 5.000.000đ).' },
    { h3:'Vòng quay may mắn miễn phí', p:'Mỗi ngày <a href="/qua-tang">quay 1 lần miễn phí</a>, trúng voucher hoặc tiền thưởng trực tiếp đến 10.000.000đ.' }
  ],
  faqs: [
    { q:'Khuyến mãi có giới hạn không?', a:'Có, mỗi chương trình áp dụng theo điều kiện riêng.' },
    { q:'Có thể nhận nhiều khuyến mãi cùng lúc?', a:'Có. Thưởng nạp + cashback + voucher có thể cộng dồn.' }
  ]
}}) %>

<%- include('partials/tw-footer') %>
