<%
seo = {
  title: 'Tài Xỉu 1 Phút - Casino Online - '+brand.name,
  description: 'Tài Xỉu casino online phiên 1 phút, cược X COIN thắng x2. Mobile-first.',
  canonical: '/game/tai-xiu'
};
%>
<%- include('../partials/tw-layout-start') %>

<script>
(function(){ try { if (!localStorage.getItem('x66_user')) { if(confirm('Cần đăng nhập để chơi. Đăng nhập ngay?')) location.href='/dang-nhap'; else location.href='/mini-game'; } } catch(e){} })();
</script>

<section class="max-w-md md:max-w-2xl mx-auto mb-6 select-none">

  <!-- ============ TOP BAR (compact mobile) ============ -->
  <header class="bg-gradient-to-r from-amber-950 via-yellow-900 to-amber-950 border-2 border-yellow-600/50 rounded-t-2xl px-2.5 md:px-5 py-2 md:py-3 flex items-center gap-2 shadow-2xl">
    <a href="/mini-game" class="w-8 h-8 rounded-full bg-black/40 grid place-items-center text-yellow-300 hover:bg-black/60 shrink-0" aria-label="Thoát">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
    </a>
    <div class="flex items-center gap-1.5 bg-black/40 backdrop-blur px-2 py-1 rounded-lg border border-yellow-600/40 min-w-0">
      <div class="w-6 h-6 md:w-9 md:h-9 rounded-full bg-gradient-to-br from-amber-500 to-yellow-700 grid place-items-center text-white font-black text-xs md:text-sm shadow-lg shrink-0" id="txAvatar">U</div>
      <div class="text-[9px] md:text-[10px] text-yellow-200/70 font-bold uppercase truncate" id="txUsername">guest</div>
    </div>
    <div class="flex-1 text-center min-w-0">
      <div class="text-[9px] md:text-[10px] text-yellow-300 uppercase tracking-widest">💎 JACKPOT</div>
      <div class="text-yellow-300 font-black text-sm md:text-xl drop-shadow-[0_0_8px_rgba(252,211,77,.8)] tabular-nums truncate" id="txJackpot">128,700,000</div>
    </div>
    <div class="flex items-center gap-1 bg-black/40 backdrop-blur px-2 md:px-4 py-1 md:py-2 rounded-lg border border-yellow-600/40 shrink-0">
      <span class="text-yellow-300 text-sm md:text-base">🪙</span>
      <span class="text-yellow-300 font-black tabular-nums text-xs md:text-base" id="txBalance">0</span>
    </div>
  </header>

  <!-- ============ MAIN GAME ============ -->
  <main class="bg-gradient-to-b from-red-950 via-red-900 to-red-950 border-x-2 border-yellow-600/50 px-2.5 md:px-6 py-3 md:py-5 shadow-2xl" style="background-image:radial-gradient(circle at 20% 30%,rgba(255,200,80,.1),transparent 60%),radial-gradient(circle at 80% 70%,rgba(255,150,50,.1),transparent 60%)">

    <!-- Round + Countdown bar -->
    <div class="flex items-center justify-between mb-2.5 px-1">
      <div class="flex items-center gap-1.5">
        <span class="text-base md:text-xl">🎲</span>
        <span class="text-[11px] md:text-sm font-extrabold text-yellow-200">Phiên #<span id="txRoundId" class="tabular-nums">000001</span></span>
      </div>
      <div class="flex items-center gap-1.5 bg-black/50 backdrop-blur px-2 py-0.5 rounded-full border border-yellow-600/40">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-yellow-300"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <span class="text-[10px] md:text-xs text-yellow-200">Đóng cược:</span>
        <span id="txCountdown" class="font-black text-sm text-yellow-300 tabular-nums">60s</span>
      </div>
    </div>

    <!-- DICE CENTER (3D wooden bowl) -->
    <div class="flex flex-col items-center mb-3">
      <div class="relative tx-bowl-wrap">
        <!-- Ground shadow under bowl -->
        <div class="absolute left-1/2 -bottom-2 -translate-x-1/2 w-[88%] h-3 rounded-full blur-md bg-black/65"></div>

        <!-- 3D BOWL -->
        <div class="tx-bowl3d w-32 h-32 md:w-44 md:h-44 relative" id="txDiceWrap">
          <div class="tx-rim absolute inset-0 rounded-full"></div>
          <div class="tx-inner absolute inset-[8%] rounded-full"></div>
          <div class="tx-gloss absolute inset-[9%] rounded-full pointer-events-none"></div>

          <!-- Dice arena -->
          <div class="absolute inset-0 grid place-items-center z-10">
            <div class="flex items-center justify-center gap-1.5 md:gap-2.5" id="txDice"></div>
          </div>

          <!-- Lid (closes during shake) -->
          <div id="txLid" class="hidden tx-lid absolute inset-0 rounded-full grid place-items-center z-20"></div>
        </div>

        <!-- Sum badge -->
        <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-gradient-to-r from-yellow-600 via-yellow-400 to-yellow-600 text-red-900 text-[11px] md:text-xs font-black px-3 py-0.5 rounded-full shadow-[0_2px_8px_rgba(255,200,0,.6)] min-w-[36px] text-center border border-yellow-200" id="txSumBadge">?</div>

        <!-- LOCK overlay when ≤5s -->
        <div id="txLockBanner" class="hidden absolute left-1/2 -translate-x-1/2 -bottom-7 bg-red-600/95 border-2 border-yellow-300 text-white text-[11px] font-black px-3 py-1 rounded-full shadow-2xl animate-pulse whitespace-nowrap z-30">
          🔒 ĐÓNG CƯỢC SAU <span id="txLockSec">5</span>s
        </div>
      </div>
    </div>

    <!-- HISTORY STRIP (always visible compact) -->
    <div class="flex items-center gap-1 mb-3 px-1 overflow-x-auto scrollbar-hide">
      <span class="text-[10px] text-yellow-200/70 font-bold shrink-0 mr-1">Lịch sử:</span>
      <div class="flex gap-1" id="txHistoryStrip"></div>
    </div>

    <!-- 2 BET PANELS: TAI | XIU side-by-side (2 col on mobile) -->
    <div class="grid grid-cols-2 gap-2 mb-3">

      <!-- TÀI panel -->
      <button onclick="selectSide('tai')" id="txTaiBox" class="ts-side group bg-gradient-to-br from-red-700 via-red-800 to-red-950 border-2 border-yellow-500/60 hover:border-yellow-300 rounded-xl px-2 py-3 text-center transition-all hover:-translate-y-1 hover:shadow-[0_8px_24px_rgba(239,68,68,.5)] relative overflow-hidden">
        <div class="absolute top-1 left-1 bg-black/40 text-[8px] text-yellow-300 font-black px-1.5 py-0.5 rounded">x2.0</div>
        <div class="text-3xl md:text-5xl font-black text-white drop-shadow-[0_2px_8px_rgba(0,0,0,.5)]" style="text-shadow:0 0 12px rgba(255,200,80,.6)">TÀI</div>
        <div class="text-[9px] md:text-[10px] text-yellow-200/80 font-bold mt-0.5">Tổng 11–17</div>
        <div class="mt-1.5 flex items-center justify-center gap-1 text-[9px] text-yellow-200/70">
          <span>👥</span><span class="tabular-nums" id="txTaiCount">2.093</span>
        </div>
        <div class="mt-1 bg-black/40 backdrop-blur rounded-md py-1 text-yellow-300 font-extrabold tabular-nums text-[11px] md:text-sm truncate px-1" id="txTaiPool">741M</div>
        <div class="text-[9px] text-yellow-200/60 mt-0.5">Cược: <b class="text-yellow-300 tabular-nums" id="txTaiMyBet">0</b></div>
      </button>

      <!-- XỈU panel -->
      <button onclick="selectSide('xiu')" id="txXiuBox" class="ts-side group bg-gradient-to-br from-blue-700 via-blue-800 to-indigo-950 border-2 border-yellow-500/60 hover:border-yellow-300 rounded-xl px-2 py-3 text-center transition-all hover:-translate-y-1 hover:shadow-[0_8px_24px_rgba(59,130,246,.5)] relative overflow-hidden">
        <div class="absolute top-1 right-1 bg-black/40 text-[8px] text-yellow-300 font-black px-1.5 py-0.5 rounded">x2.0</div>
        <div class="text-3xl md:text-5xl font-black text-white drop-shadow-[0_2px_8px_rgba(0,0,0,.5)]" style="text-shadow:0 0 12px rgba(255,200,80,.6)">XỈU</div>
        <div class="text-[9px] md:text-[10px] text-yellow-200/80 font-bold mt-0.5">Tổng 4–10</div>
        <div class="mt-1.5 flex items-center justify-center gap-1 text-[9px] text-yellow-200/70">
          <span>👥</span><span class="tabular-nums" id="txXiuCount">1.805</span>
        </div>
        <div class="mt-1 bg-black/40 backdrop-blur rounded-md py-1 text-yellow-300 font-extrabold tabular-nums text-[11px] md:text-sm truncate px-1" id="txXiuPool">741M</div>
        <div class="text-[9px] text-yellow-200/60 mt-0.5">Cược: <b class="text-yellow-300 tabular-nums" id="txXiuMyBet">0</b></div>
      </button>
    </div>

    <!-- Selected amount display + result text -->
    <div class="bg-black/40 backdrop-blur rounded-xl py-2 md:py-3 text-center mb-3 border border-yellow-600/30">
      <div class="text-[9px] md:text-[10px] text-yellow-200/70 uppercase tracking-widest font-bold">Số cược đã chọn</div>
      <div class="text-2xl md:text-3xl font-black text-yellow-300 tabular-nums drop-shadow" id="txSelectedAmt">0</div>
      <div class="text-[10px] text-yellow-200/60 mt-0.5 px-2" id="txResultText">Chọn mức cược → Click TÀI hoặc XỈU</div>
    </div>

    <!-- BET CHIPS (4 cols mobile, 8 cols desktop) -->
    <div class="grid grid-cols-4 md:grid-cols-8 gap-1.5 mb-3">
      <% [
        { v:10,    l:'10' },
        { v:50,    l:'50' },
        { v:100,   l:'100' },
        { v:500,   l:'500' },
        { v:1000,  l:'1K' },
        { v:5000,  l:'5K' },
        { v:10000, l:'10K' },
        { v:50000, l:'50K' }
      ].forEach(function(c){ %>
        <button class="tx-chip relative px-2 py-2 bg-gradient-to-br from-yellow-500 to-amber-700 hover:from-yellow-400 hover:to-amber-600 text-red-900 rounded-full font-black text-xs md:text-sm shadow-[0_3px_0_rgba(0,0,0,.3),inset_0_2px_0_rgba(255,255,255,.4)] active:translate-y-0.5 active:shadow-[0_1px_0_rgba(0,0,0,.3)] transition-all border-2 border-yellow-300" data-amt="<%= c.v %>"><span class="tx-chip-label"><%= c.l %></span></button>
      <% }); %>
    </div>

    <!-- ACTION BUTTONS -->
    <div class="grid grid-cols-3 gap-1.5">
      <button onclick="allIn()" class="bg-gradient-to-br from-purple-600 to-pink-700 hover:brightness-110 text-white py-2.5 rounded-full font-black text-[11px] md:text-sm shadow-lg border-2 border-pink-400 active:scale-95 transition-transform">💎 ALL-IN</button>
      <button onclick="confirmBet()" class="bg-gradient-to-br from-emerald-500 to-green-700 hover:brightness-110 text-white py-2.5 rounded-full font-black text-[11px] md:text-sm shadow-lg border-2 border-emerald-300 active:scale-95 transition-transform">✓ XÁC NHẬN</button>
      <button onclick="cancelBet()" class="bg-gradient-to-br from-red-600 to-red-800 hover:brightness-110 text-white py-2.5 rounded-full font-black text-[11px] md:text-sm shadow-lg border-2 border-red-400 active:scale-95 transition-transform">✕ HỦY</button>
    </div>

  </main>

  <!-- ============ BOTTOM TABS ============ -->
  <footer class="bg-gradient-to-r from-amber-950 via-yellow-900 to-amber-950 border-2 border-yellow-600/50 border-t-0 rounded-b-2xl px-2 py-1.5 grid grid-cols-4 gap-1">
    <button onclick="toggleSection('history')" class="text-yellow-200 hover:text-yellow-300 text-[10px] md:text-[11px] font-bold flex flex-col items-center gap-0.5 py-1 active:scale-95">
      <span class="text-base md:text-lg">📊</span><span>Lịch sử</span>
    </button>
    <button onclick="toggleSection('rules')" class="text-yellow-200 hover:text-yellow-300 text-[10px] md:text-[11px] font-bold flex flex-col items-center gap-0.5 py-1 active:scale-95">
      <span class="text-base md:text-lg">📖</span><span>Luật</span>
    </button>
    <button onclick="toggleSection('top')" class="text-yellow-200 hover:text-yellow-300 text-[10px] md:text-[11px] font-bold flex flex-col items-center gap-0.5 py-1 active:scale-95">
      <span class="text-base md:text-lg">🏆</span><span>Xếp hạng</span>
    </button>
    <a href="<%= partner.telegram %>" target="_blank" class="text-yellow-200 hover:text-yellow-300 text-[10px] md:text-[11px] font-bold flex flex-col items-center gap-0.5 py-1 active:scale-95">
      <span class="text-base md:text-lg">💬</span><span>Hotline</span>
    </a>
  </footer>

  <!-- EXPANDABLE SECTIONS -->
  <div id="txHistory" class="hidden bg-bg-card border border-line rounded-xl p-3 mt-3">
    <h3 class="text-sm font-extrabold text-white mb-2">📊 Lịch sử 10 phiên gần nhất</h3>
    <div class="flex gap-1.5 flex-wrap" id="txHistoryList"><div class="text-muted text-sm">Chưa có lịch sử...</div></div>
  </div>
  <div id="txRules" class="hidden bg-bg-card border border-line rounded-xl p-3 mt-3 text-[12px] text-gray-200">
    <h3 class="text-sm font-extrabold text-white mb-2">📖 Luật chơi Tài Xỉu</h3>
    <ul class="space-y-1 leading-relaxed">
      <li>• Mỗi phiên <strong>60 giây</strong>, hệ thống tự tung 3 xúc xắc</li>
      <li>• <strong class="text-red-400">TÀI</strong> = tổng <strong>11-17</strong>, <strong class="text-blue-400">XỈU</strong> = tổng <strong>4-10</strong></li>
      <li>• Đoán đúng → <strong class="text-yellow-300">x2 tiền cược</strong></li>
      <li>• <strong class="text-yellow-400">BÃO</strong>: 3 xúc xắc giống nhau → cả 2 đều thua</li>
      <li>• Trước khi đóng cược 5s, không thể đặt thêm</li>
    </ul>
  </div>
  <div id="txTop" class="hidden bg-bg-card border border-line rounded-xl p-3 mt-3">
    <h3 class="text-sm font-extrabold text-white mb-2">🏆 Top thắng hôm nay</h3>
    <div class="space-y-1.5">
      <% ['highRoller_88','luckyTai99','xiu_master','vipFan88','BoMy_X66'].forEach(function(n,i){ var amt=(5-i)*2300+800; %>
        <div class="flex items-center gap-2 bg-bg-soft border border-line rounded-lg p-2 text-[12px]">
          <span class="text-base"><%= ['🥇','🥈','🥉','4️⃣','5️⃣'][i] %></span>
          <span class="flex-1 font-bold text-white truncate"><%= n %></span>
          <span class="text-yellow-300 font-extrabold tabular-nums shrink-0">+<%= amt.toLocaleString('vi-VN') %> 🪙</span>
        </div>
      <% }); %>
    </div>
  </div>
</section>

<style>
/* ============ 3D WOODEN BOWL ============ */
.tx-bowl-wrap { perspective: 800px; }
.tx-bowl3d { transform-style: preserve-3d; filter: drop-shadow(0 12px 18px rgba(0,0,0,.55)); }
.tx-rim {
  background: radial-gradient(circle at 30% 25%, #fff8c4 0%, #ffe07a 18%, #e6a82e 45%, #8a5a14 80%, #4a2f0a 100%);
  box-shadow:
    inset 0 4px 8px rgba(255,255,255,.55),
    inset 0 -6px 12px rgba(0,0,0,.55),
    inset 6px 0 8px rgba(255,200,80,.3),
    inset -6px 0 8px rgba(60,30,0,.4);
}
.tx-rim::before {
  content:''; position:absolute; inset:0; border-radius:50%;
  background: repeating-conic-gradient(from 0deg, rgba(0,0,0,.18) 0deg 2deg, transparent 2deg 8deg);
  mix-blend-mode: multiply; opacity: .35;
}
.tx-inner {
  background: radial-gradient(ellipse at 50% 30%, #5a1e0a 0%, #3a0f04 45%, #150500 100%);
  box-shadow:
    inset 0 6px 14px rgba(0,0,0,.85),
    inset 0 -3px 8px rgba(255,100,50,.25),
    inset 0 0 22px rgba(0,0,0,.6);
}
.tx-gloss { background: radial-gradient(ellipse 70% 35% at 50% 15%, rgba(255,255,255,.18), rgba(255,255,255,0) 70%); }

/* ============ 3D LID ============ */
.tx-lid {
  background: radial-gradient(circle at 35% 30%, #fff4b8 0%, #f4c34a 25%, #b07820 55%, #5a3a0c 100%);
  box-shadow:
    inset 0 8px 16px rgba(255,255,255,.5),
    inset 0 -8px 18px rgba(0,0,0,.6),
    0 6px 18px rgba(0,0,0,.5);
  overflow: hidden;
}
.tx-lid::before { content:'🍵'; font-size:56px; filter: drop-shadow(0 2px 4px rgba(0,0,0,.4)); animation: txLidShake .15s linear infinite; }
@media (min-width: 768px) { .tx-lid::before { font-size: 78px; } }
.tx-lid::after {
  content:''; position:absolute; inset:0; border-radius:50%;
  background: repeating-conic-gradient(from 0deg, rgba(0,0,0,.22) 0deg 2deg, transparent 2deg 6deg);
  opacity: .25;
}
@keyframes txLidShake { 0%,100%{transform:translate(-2px,-1px) rotate(-3deg)} 50%{transform:translate(2px,1px) rotate(3deg)} }

/* ============ 3D DICE (real cube look with depth + pips) ============ */
.tx-dice3d {
  width: 32px; height: 32px;
  position: relative;
  display: inline-block;
  perspective: 200px;
  filter: drop-shadow(0 4px 5px rgba(0,0,0,.7));
}
@media (min-width: 768px) { .tx-dice3d { width: 44px; height: 44px; } }
.tx-dice3d .face {
  position: absolute; inset: 0;
  background:
    radial-gradient(ellipse at 30% 25%, #ffffff 0%, #f4f4f4 40%, #d8d8d8 80%, #b8b8b8 100%);
  border-radius: 7px;
  border: 1px solid rgba(0,0,0,.18);
  box-shadow:
    inset 2px 2px 4px rgba(255,255,255,.95),
    inset -2px -2px 4px rgba(0,0,0,.28),
    inset 0 0 0 1px rgba(255,255,255,.5);
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  grid-template-rows: repeat(3, 1fr);
  padding: 3px;
  gap: 1px;
}
.tx-pip {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: radial-gradient(circle at 30% 30%, #555 0%, #1a0808 100%);
  box-shadow: inset 1px 1px 1px rgba(255,255,255,.15), inset -.5px -.5px 1px rgba(0,0,0,.5), 0 .5px 0 rgba(255,255,255,.7);
  align-self: center; justify-self: center;
}
@media (min-width: 768px) { .tx-pip { width: 8px; height: 8px; } }
.tx-pip.p1{grid-area:1/1} .tx-pip.p2{grid-area:1/2} .tx-pip.p3{grid-area:1/3}
.tx-pip.p4{grid-area:2/1} .tx-pip.p5{grid-area:2/2} .tx-pip.p6{grid-area:2/3}
.tx-pip.p7{grid-area:3/1} .tx-pip.p8{grid-area:3/2} .tx-pip.p9{grid-area:3/3}

.tx-dice3d.rolling { animation: txDiceTumble .35s ease-in-out infinite; }
@keyframes txDiceTumble {
  0%,100% { transform: translateY(0) rotateX(0) rotateY(0); }
  25%     { transform: translateY(-8px) rotateX(180deg) rotateY(90deg); }
  50%     { transform: translateY(0) rotateX(360deg) rotateY(180deg); }
  75%     { transform: translateY(-6px) rotateX(540deg) rotateY(270deg); }
}
.tx-dice3d:nth-child(1).rolling { animation-delay: 0s; }
.tx-dice3d:nth-child(2).rolling { animation-delay: .08s; }
.tx-dice3d:nth-child(3).rolling { animation-delay: .16s; }
@keyframes txDiceReveal {
  0%   { transform: rotateY(180deg) scale(.4); opacity: 0; }
  60%  { transform: rotateY(0deg) scale(1.18); opacity: 1; }
  100% { transform: rotateY(0deg) scale(1); opacity: 1; }
}

/* ============ TÀI/XỈU 3D CARDS ============ */
.ts-side {
  position: relative;
  transform: perspective(600px);
  transition: transform .25s, box-shadow .25s, filter .25s;
  background-image:
    radial-gradient(ellipse at 50% 0%, rgba(255,255,255,.22), transparent 50%),
    linear-gradient(180deg, transparent 0%, rgba(0,0,0,.35) 100%);
}
.ts-side::before {
  content:''; position:absolute; inset:0; border-radius:inherit;
  box-shadow: inset 0 2px 0 rgba(255,255,255,.4), inset 0 -3px 0 rgba(0,0,0,.5), inset 0 0 30px rgba(0,0,0,.3);
  pointer-events:none;
}
.ts-side.is-selected { box-shadow: 0 0 0 3px #fde047, 0 0 30px rgba(253,224,71,.7) !important; transform: translateY(-3px) scale(1.03); }
/* Lock state when <5s */
.ts-side.is-locked { filter: grayscale(.7) brightness(.5); cursor: not-allowed; pointer-events: none; }
.ts-side.is-locked::after {
  content:'🔒'; position:absolute; inset:0;
  display:grid; place-items:center;
  font-size: 28px;
  background: rgba(0,0,0,.55);
  border-radius:inherit;
  text-shadow: 0 2px 6px rgba(0,0,0,.7);
}

/* ============ 3D CASINO CHIPS ============ */
.tx-chip {
  position: relative;
  width: 100% !important;
  aspect-ratio: 1;
  border-radius: 50% !important;
  padding: 0 !important;
  border: 0 !important;
  display: grid; place-items: center;
  font-size: 11px !important;
  text-shadow: 0 1px 1px rgba(0,0,0,.4);
  box-shadow:
    0 4px 0 rgba(0,0,0,.4),
    0 6px 12px rgba(0,0,0,.3),
    inset 0 2px 3px rgba(255,255,255,.5),
    inset 0 -3px 4px rgba(0,0,0,.35) !important;
  transition: all .15s ease-out;
}
@media (min-width: 768px) { .tx-chip { font-size: 14px !important; } }
.tx-chip::before {
  content:''; position:absolute; inset:0; border-radius:50%;
  background: repeating-conic-gradient(from 0deg, rgba(255,255,255,.85) 0deg 14deg, transparent 14deg 60deg);
  -webkit-mask: radial-gradient(circle, transparent 60%, #000 61%, #000 88%, transparent 89%);
          mask: radial-gradient(circle, transparent 60%, #000 61%, #000 88%, transparent 89%);
  opacity: .85;
}
.tx-chip::after {
  content:''; position:absolute; inset:14%; border-radius:50%;
  background: inherit;
  box-shadow: inset 0 0 0 2px rgba(255,255,255,.4), inset 0 1px 2px rgba(255,255,255,.4), inset 0 -2px 3px rgba(0,0,0,.3);
}
.tx-chip > * { position: relative; z-index: 5; }
.tx-chip-label {
  position: relative;
  z-index: 5;
  color: #fff;
  font-weight: 900;
  font-size: 12px;
  text-shadow: 0 1px 2px rgba(0,0,0,.8), 0 0 4px rgba(0,0,0,.6);
  letter-spacing: .3px;
}
@media (min-width: 768px) { .tx-chip-label { font-size: 15px; } }
.tx-chip::after { z-index: 1; }
.tx-chip::before { z-index: 2; }
.tx-chip:active { transform: translateY(2px); box-shadow: 0 2px 0 rgba(0,0,0,.4), inset 0 2px 3px rgba(0,0,0,.3) !important; }
.tx-chip.is-selected {
  transform: scale(1.18) translateY(-2px);
  box-shadow: 0 0 22px rgba(252,211,77,.95), 0 6px 0 rgba(0,0,0,.4), inset 0 2px 3px rgba(255,255,255,.5) !important;
  outline: 3px solid #fde047;
  outline-offset: -3px;
}

.win-flash { animation: winFlash .5s ease-in-out 3; }
@keyframes winFlash { 0%,100%{box-shadow:0 0 0 4px #10b981} 50%{box-shadow:0 0 32px 8px #10b981} }
.tx-shaking { animation: txShake .14s linear infinite; }
@keyframes txShake {
  0%   { transform: translate(-2px,-3px) rotate(-3deg); }
  25%  { transform: translate(3px,2px) rotate(3deg); }
  50%  { transform: translate(-3px,3px) rotate(-2deg); }
  75%  { transform: translate(2px,-2px) rotate(2deg); }
  100% { transform: translate(-2px,-3px) rotate(-3deg); }
}
</style>

<script>
(function(){
  if (typeof window.showToast !== 'function') {
    window.showToast = function(msg, kind){
      var t=document.createElement('div'); var col=kind==='error'?'#ff3b3b':kind==='success'?'#27ae60':'#ff7a18';
      t.style.cssText='position:fixed;bottom:20px;right:20px;background:#161a22;color:#fff;padding:12px 18px;border-radius:8px;border-left:4px solid '+col+';z-index:9999;font-size:13px;font-weight:600;box-shadow:0 8px 24px rgba(0,0,0,.4);max-width:90vw;';
      t.textContent=msg; document.body.appendChild(t);
      setTimeout(function(){ t.style.opacity='0'; t.style.transition='opacity .3s'; }, 2500);
      setTimeout(function(){ t.remove(); }, 3000);
    };
  }

  // 3D dice pip layout (1=center, 2/9=diag, etc.)
  var DICE_PIPS_3D = {
    1: [5], 2: [1,9], 3: [1,5,9],
    4: [1,3,7,9], 5: [1,3,5,7,9], 6: [1,3,4,6,7,9]
  };
  function makeDie3D(n){
    n = parseInt(n,10) || 1; if (n<1) n=1; if (n>6) n=6;
    var pips = (DICE_PIPS_3D[n] || [5]).map(function(p){ return '<span class="tx-pip p'+p+'"></span>'; }).join('');
    return '<span class="tx-dice3d"><span class="face">'+pips+'</span></span>';
  }
  function renderDice3D(d1, d2, d3, rolling){
    var box = document.getElementById('txDice'); if (!box) return;
    box.innerHTML = makeDie3D(d1) + makeDie3D(d2) + makeDie3D(d3);
    if (rolling) box.querySelectorAll('.tx-dice3d').forEach(function(d){ d.classList.add('rolling'); });
  }
  // Initial render
  setTimeout(function(){ renderDice3D(1, 1, 1, false); }, 30);

  function fmtCompact(n){
    if (n >= 1e9) return (n/1e9).toFixed(2) + 'B';
    if (n >= 1e6) return (n/1e6).toFixed(1) + 'M';
    if (n >= 1e3) return (n/1e3).toFixed(1) + 'K';
    return n.toLocaleString('vi-VN');
  }

  var ROUND_DURATION = 60;
  var state = {
    roundId: 1, secLeft: 60, selectedAmt: 0,
    selectedSide: null, myBet: null, history: [], rolling: false,
    taiPool: 741648460, xiuPool: 741648460, taiCount: 2093, xiuCount: 1805,
    jackpot: 128700000
  };

  function getUser(){ try { return JSON.parse(localStorage.getItem('x66_user')||'{}'); } catch(e){ return {}; } }
  function setUser(u){ try { localStorage.setItem('x66_user', JSON.stringify(u)); } catch(e){} }
  function getCoin(){ var u=getUser(); return typeof u.coin==='number'?u.coin:79; }
  function setCoin(c){ var u=getUser(); u.coin=c; setUser(u); refresh(); }

  function refresh(){
    var u = getUser();
    document.getElementById('txBalance').textContent = getCoin().toLocaleString('vi-VN');
    document.getElementById('txUsername').textContent = (u.username||'guest').toLowerCase();
    document.getElementById('txAvatar').textContent = (u.username||'U').charAt(0).toUpperCase();
  }

  try { var ss = JSON.parse(localStorage.getItem('x66_tx_state')||'null'); if (ss) { state.roundId = ss.roundId||1; state.history = ss.history||[]; } } catch(e){}
  function saveState(){ try { localStorage.setItem('x66_tx_state', JSON.stringify({roundId:state.roundId, history:state.history.slice(0,30)})); } catch(e){} }

  function isMobile(){ return window.innerWidth < 768; }

  function updateRound(){
    document.getElementById('txRoundId').textContent = String(state.roundId).padStart(6,'0');
    var sec = state.secLeft, el = document.getElementById('txCountdown');
    el.textContent = sec + 's';
    el.className = 'font-black text-sm tabular-nums ' + (sec>30?'text-emerald-400':sec>10?'text-yellow-300':'text-red-400 animate-pulse');
    // Pool display: compact on mobile, full on desktop
    document.getElementById('txTaiPool').textContent = isMobile() ? fmtCompact(state.taiPool) : state.taiPool.toLocaleString('vi-VN');
    document.getElementById('txXiuPool').textContent = isMobile() ? fmtCompact(state.xiuPool) : state.xiuPool.toLocaleString('vi-VN');
    document.getElementById('txTaiCount').textContent = state.taiCount.toLocaleString('vi-VN');
    document.getElementById('txXiuCount').textContent = state.xiuCount.toLocaleString('vi-VN');
    document.getElementById('txJackpot').textContent = isMobile() ? fmtCompact(state.jackpot) : state.jackpot.toLocaleString('vi-VN');

    // ===== 5-SECOND LOCKOUT (đóng cược 5s trước khi xóc) =====
    var lockBanner = document.getElementById('txLockBanner');
    var lockSec    = document.getElementById('txLockSec');
    var taiBox = document.getElementById('txTaiBox');
    var xiuBox = document.getElementById('txXiuBox');
    if (!state.rolling && sec <= 5 && sec > 0){
      // Show lock banner + grey out bet sides
      lockBanner.classList.remove('hidden');
      lockSec.textContent = sec;
      taiBox.classList.add('is-locked');
      xiuBox.classList.add('is-locked');
    } else if (!state.rolling) {
      lockBanner.classList.add('hidden');
      taiBox.classList.remove('is-locked');
      xiuBox.classList.remove('is-locked');
    }
  }

  document.querySelectorAll('.tx-chip').forEach(function(b){
    b.addEventListener('click', function(){
      document.querySelectorAll('.tx-chip').forEach(function(x){ x.classList.remove('is-selected'); });
      this.classList.add('is-selected');
      state.selectedAmt = parseInt(this.getAttribute('data-amt'),10);
      document.getElementById('txSelectedAmt').textContent = state.selectedAmt.toLocaleString('vi-VN');
      document.getElementById('txResultText').textContent = 'Đã chọn ' + state.selectedAmt + ' 🪙 - Click TÀI hoặc XỈU';
    });
  });

  window.selectSide = function(side){
    if (state.rolling) { showToast('Đang ra kết quả','error'); return; }
    if (state.secLeft <= 5) {
      // Vibrate mobile (nếu hỗ trợ)
      try { if (navigator.vibrate) navigator.vibrate([60,40,60]); } catch(e){}
      showToast('🔒 ĐÓNG CƯỢC: Còn ' + state.secLeft + 's chuẩn bị xóc!','error');
      return;
    }
    if (state.selectedAmt <= 0) { showToast('Chọn mức cược trước (chip vàng)','error'); return; }
    var coin = getCoin();
    if (coin < state.selectedAmt) { showToast('X COIN không đủ! Còn ' + coin, 'error'); return; }
    if (state.myBet && state.myBet.side !== side) { showToast('Đã đặt vào ' + (state.myBet.side==='tai'?'TÀI':'XỈU'),'error'); return; }
    setCoin(coin - state.selectedAmt);
    if (!state.myBet) state.myBet = { side: side, amt: 0 };
    state.myBet.amt += state.selectedAmt;
    if (side === 'tai') { state.taiPool += state.selectedAmt; document.getElementById('txTaiMyBet').textContent = state.myBet.amt.toLocaleString('vi-VN'); }
    else                { state.xiuPool += state.selectedAmt; document.getElementById('txXiuMyBet').textContent = state.myBet.amt.toLocaleString('vi-VN'); }
    document.getElementById('tx'+(side==='tai'?'Tai':'Xiu')+'Box').classList.add('is-selected');
    showToast('Đặt ' + state.selectedAmt + ' 🪙 vào ' + (side==='tai'?'TÀI':'XỈU'), 'success');
  };

  window.allIn = function(){
    var coin = getCoin();
    if (coin <= 0) { showToast('Không có X COIN để all-in','error'); return; }
    state.selectedAmt = coin;
    document.getElementById('txSelectedAmt').textContent = coin.toLocaleString('vi-VN');
    document.querySelectorAll('.tx-chip').forEach(function(x){ x.classList.remove('is-selected'); });
    showToast('All-in: ' + coin + ' 🪙. Chọn TÀI hoặc XỈU!', 'info');
  };

  window.confirmBet = function(){
    if (!state.myBet) { showToast('Bạn chưa đặt cược','error'); return; }
    showToast('✓ Đã xác nhận ' + state.myBet.amt + ' 🪙 vào ' + (state.myBet.side==='tai'?'TÀI':'XỈU'), 'success');
  };

  window.cancelBet = function(){
    if (!state.myBet) { showToast('Chưa có cược để hủy','error'); return; }
    if (state.secLeft < 10) { showToast('Còn dưới 10s, không thể hủy','error'); return; }
    setCoin(getCoin() + state.myBet.amt);
    if (state.myBet.side === 'tai') state.taiPool -= state.myBet.amt; else state.xiuPool -= state.myBet.amt;
    state.myBet = null;
    document.getElementById('txTaiMyBet').textContent = '0';
    document.getElementById('txXiuMyBet').textContent = '0';
    document.getElementById('txTaiBox').classList.remove('is-selected');
    document.getElementById('txXiuBox').classList.remove('is-selected');
    showToast('Đã hủy cược, hoàn tiền', 'success');
  };

  window.toggleSection = function(name){
    var ids = ['history','rules','top'];
    ids.forEach(function(id){
      var el = document.getElementById('tx' + id.charAt(0).toUpperCase()+id.slice(1));
      if (!el) return;
      if (id === name) el.classList.toggle('hidden');
      else el.classList.add('hidden');
    });
  };

  function rollAndReveal(){
    state.rolling = true;
    // Đóng nắp + lắc đĩa
    var wrap = document.getElementById('txDiceWrap');
    var lid  = document.getElementById('txLid');
    lid.classList.remove('hidden');
    wrap.classList.add('tx-shaking');
    // Hide lock banner during roll
    document.getElementById('txLockBanner').classList.add('hidden');
    document.getElementById('txTaiBox').classList.remove('is-locked');
    document.getElementById('txXiuBox').classList.remove('is-locked');
    document.getElementById('txSumBadge').textContent = '...';
    document.getElementById('txResultText').textContent = '🎲 Đang lắc xúc xắc...';

    setTimeout(function(){
      var d1 = Math.floor(Math.random()*6)+1, d2 = Math.floor(Math.random()*6)+1, d3 = Math.floor(Math.random()*6)+1;
      var sum = d1+d2+d3;
      var isBao = (d1===d2 && d2===d3);
      var result = isBao ? 'bao' : (sum >= 11 ? 'tai' : 'xiu');

      // Mở nắp + dừng lắc
      lid.classList.add('hidden');
      wrap.classList.remove('tx-shaking');
      // Render dice 3D với mặt đã ra + reveal flip animation
      renderDice3D(d1, d2, d3, false);
      var dEls3D = document.querySelectorAll('#txDice .tx-dice3d');
      [].forEach.call(dEls3D, function(el, i){
        el.style.animation = 'none'; el.offsetHeight;
        el.style.animation = 'txDiceReveal .6s ' + (i*.1) + 's both';
      });
      document.getElementById('txSumBadge').textContent = sum;

      var resultLabel = isBao ? '⚡ BÃO' : result==='tai' ? '🔴 TÀI' : '🔵 XỈU';
      document.getElementById('txResultText').innerHTML = '<span class="text-yellow-300 text-base font-black">' + resultLabel + ' · Tổng ' + sum + '</span>';

      if (state.myBet) {
        var win = !isBao && state.myBet.side === result;
        if (win) {
          var payout = state.myBet.amt * 2;
          setCoin(getCoin() + payout);
          showToast('🎉 THẮNG! +' + payout.toLocaleString('vi-VN') + ' 🪙', 'success');
          document.getElementById('tx'+(state.myBet.side==='tai'?'Tai':'Xiu')+'Box').classList.add('win-flash');
        } else {
          showToast(isBao?'⚡ BÃO - thua':'😢 Thua ' + state.myBet.amt + ' 🪙', 'error');
        }
      }

      state.history.unshift({ round: state.roundId, dice:[d1,d2,d3], sum:sum, result:result });
      saveState();
      renderHistory();
      renderHistoryStrip();

      setTimeout(function(){
        state.roundId++;
        state.secLeft = ROUND_DURATION;
        state.myBet = null; state.rolling = false;
        document.getElementById('txTaiMyBet').textContent = '0';
        document.getElementById('txXiuMyBet').textContent = '0';
        document.getElementById('txTaiBox').classList.remove('is-selected','win-flash');
        document.getElementById('txXiuBox').classList.remove('is-selected','win-flash');
        state.taiPool = 700000000 + Math.floor(Math.random()*100000000);
        state.xiuPool = 700000000 + Math.floor(Math.random()*100000000);
        state.taiCount = 1800 + Math.floor(Math.random()*500);
        state.xiuCount = 1700 + Math.floor(Math.random()*500);
        state.jackpot += Math.floor(Math.random()*200000);
        updateRound();
      }, 4000);
    }, 1500);
  }

  function renderHistory(){
    var el = document.getElementById('txHistoryList');
    if (!el) return;
    if (!state.history.length) { el.innerHTML = '<div class="text-muted text-sm">Chưa có lịch sử...</div>'; return; }
    el.innerHTML = state.history.slice(0,10).map(function(h){
      var clr = h.result==='tai'?'bg-red-600':h.result==='xiu'?'bg-blue-600':'bg-yellow-500';
      var lbl = h.result==='tai'?'T':h.result==='xiu'?'X':'B';
      return '<div class="text-center" title="Phiên #'+h.round+' = '+h.sum+'"><div class="w-9 h-9 rounded-full '+clr+' grid place-items-center text-white font-black text-sm">'+lbl+'</div><div class="text-[10px] text-muted mt-0.5">'+h.sum+'</div></div>';
    }).join('');
  }

  function renderHistoryStrip(){
    var el = document.getElementById('txHistoryStrip');
    if (!el) return;
    if (!state.history.length) { el.innerHTML = '<span class="text-[10px] text-yellow-200/40">Chưa có</span>'; return; }
    el.innerHTML = state.history.slice(0,12).map(function(h){
      var clr = h.result==='tai'?'bg-red-600':h.result==='xiu'?'bg-blue-600':'bg-yellow-500';
      var lbl = h.result==='tai'?'T':h.result==='xiu'?'X':'B';
      return '<div class="w-5 h-5 rounded-full '+clr+' grid place-items-center text-white font-black text-[10px] shrink-0" title="Phiên '+h.round+' = '+h.sum+'">'+lbl+'</div>';
    }).join('');
  }

  function tick(){
    try {
      if (!state.rolling) {
        state.secLeft--;
        state.taiPool += Math.floor(Math.random()*50000);
        state.xiuPool += Math.floor(Math.random()*50000);
        state.taiCount += Math.floor(Math.random()*3);
        state.xiuCount += Math.floor(Math.random()*3);
        state.jackpot += Math.floor(Math.random()*5000);
        if (state.secLeft <= 0) rollAndReveal();
        else updateRound();
      }
    } catch(e){ console.error('tick err:', e); }
  }

  refresh();
  updateRound();
  renderHistory();
  renderHistoryStrip();
  setInterval(tick, 1000);
  window.addEventListener('resize', updateRound);
})();
</script>

