<%
var _matchName = match.home + ' vs ' + match.away;
var _scoreStr = match.score ? (' '+match.score[0]+'-'+match.score[1]) : '';
seo = {
  title: 'Xem Trực Tiếp '+_matchName + _scoreStr + ' '+match.league+' | XOSO66 TV',
  description: 'Xem trực tiếp bóng đá '+_matchName+' - '+match.league+(match.venue?' tại '+match.venue:'')+' ngày '+match.date+' Full HD miễn phí tại XOSO66 TV (xổ số 66). BLV tiếng Việt, không quảng cáo.',
  keywords: 'xem trực tiếp '+_matchName+', '+match.home+' vs '+match.away+', '+match.league+', xoso66, xổ số 66, xem trực tiếp bóng đá',
  canonical: '/live/'+(match.slug||match.id),
  ogType: 'video.other',
  breadcrumb: [
    { name:match.sport==='Soccer'?'Bóng đá':match.sport==='Basketball'?'Bóng rổ':match.sport==='Tennis'?'Tennis':match.sport, url:'/the-thao/'+(match.sport==='Soccer'?'bong-da':match.sport==='Basketball'?'bong-ro':'tennis') },
    { name:_matchName, url:'/live/'+(match.slug||match.id) }
  ]
};
// SportsEvent schema cho Rich Snippet trên Google Search
var _matchStart = match.matchTs ? new Date(match.matchTs).toISOString() : new Date().toISOString();
var _matchStatus = match.status === 'live' ? 'EventInProgress' : (match.status === 'finished' ? 'EventCompleted' : 'EventScheduled');
%>
<%- include('partials/tw-layout-start') %>

<!-- ═══ JSON-LD SportsEvent + BroadcastEvent schema (Rich Snippet) ═══ -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "SportsEvent",
  "name": "<%= _matchName %> - <%= match.league %>",
  "description": "Xem trực tiếp <%= _matchName %> tại <%= match.league %> ngày <%= match.date %> Full HD miễn phí tại XOSO66 TV.",
  "startDate": "<%= _matchStart %>",
  "eventStatus": "https://schema.org/<%= _matchStatus %>",
  "eventAttendanceMode": "https://schema.org/OnlineEventAttendanceMode",
  "location": {
    "@type": "VirtualLocation",
    "url": "https://xoso66tv.com/live/<%= match.slug || match.id %>"
  },
  "competitor": [
    {
      "@type": "SportsTeam",
      "name": "<%= match.home %>"<% if (match.homeBadge) { %>,
      "logo": "<%= match.homeBadge %>"<% } %>
    },
    {
      "@type": "SportsTeam",
      "name": "<%= match.away %>"<% if (match.awayBadge) { %>,
      "logo": "<%= match.awayBadge %>"<% } %>
    }
  ],
  "sport": "<%= match.sport === 'Soccer' ? 'Soccer' : match.sport %>",
  "organizer": {
    "@type": "Organization",
    "name": "<%= match.league %>"
  },
  "broadcastOfEvent": {
    "@type": "BroadcastEvent",
    "name": "Trực tiếp <%= _matchName %>",
    "isLiveBroadcast": <%= match.status === 'live' ? 'true' : 'false' %>,
    "videoFormat": "HD",
    "inLanguage": "vi-VN",
    "publishedOn": {
      "@type": "BroadcastService",
      "name": "XOSO66 TV",
      "broadcastDisplayName": "XOSO66 TV - Xem Trực Tiếp Bóng Đá",
      "url": "https://xoso66tv.com/"
    }
  },
  "offers": {
    "@type": "Offer",
    "url": "https://xoso66tv.com/live/<%= match.slug || match.id %>",
    "price": "0",
    "priceCurrency": "VND",
    "availability": "https://schema.org/InStock",
    "validFrom": "<%= _matchStart %>"
  }
}
</script>

<%- include('partials/tw-skin-overlay') %>
<%- include('partials/tw-breadcrumb') %>

<article class="grid lg:grid-cols-[1fr_340px] gap-4">
  <div>
    <div id="livePlayer" class="bg-black aspect-video rounded-xl relative overflow-hidden grid place-items-center">
      <% var _hasBlvStream = (typeof blvStreamKey !== 'undefined' && blvStreamKey); %>
      <% if (_hasBlvStream) { %>
        <!-- 🆕 BLV CUSTOM STREAM: FLV player thực với key từ schedule -->
        <%- include('partials/tw-live-video-player', { streamKey: blvStreamKey }) %>
        <!-- Placeholder visible khi player chưa load -->
        <div class="text-center text-white p-5 absolute inset-0 grid place-items-center pointer-events-none" id="playerPh" data-title="<%= _matchName %>">
          <div>
            <h2 class="font-extrabold text-lg"><%= match.home %> vs <%= match.away %></h2>
            <div class="text-muted text-[13px] mt-1.5"><%= match.league %></div>
          </div>
        </div>
      <% } else if (typeof hasObs !== 'undefined' && hasObs) { %>
        <%
          // 🏆 Ảnh nền giải đấu (admin set) cho placeholder "click để play"
          var _phBgs = (typeof leagueBgs !== 'undefined' && leagueBgs) ? leagueBgs : {};
          function _phNormLg(s){ return String(s||'').toLowerCase().replace(/\./g,'').replace(/\s+/g,' ').trim(); }
          var _phBg = '';
          if (match.league) {
            if (_phBgs[match.league]) _phBg = _phBgs[match.league];
            else {
              var _pht = _phNormLg(match.league);
              for (var _phk in _phBgs) {
                if (_phk === '__default__') continue;
                if (_phNormLg(_phk) === _pht) { _phBg = _phBgs[_phk]; break; }
              }
            }
          }
          if (!_phBg && _phBgs['__default__']) _phBg = _phBgs['__default__'];
        %>
        <% if (_phBg) { %>
          <img src="<%= _phBg %>" alt="" class="absolute inset-0 w-full h-full object-cover opacity-50 pointer-events-none" onerror="this.style.display='none'">
          <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/45 to-black/55 pointer-events-none"></div>
        <% } %>
        <!-- BLV da len song (legacy click-to-play) -->
        <div class="text-center text-white p-5 relative z-[2]" id="playerPh" data-title="<%= _matchName %>">
          <div class="w-20 h-20 rounded-full bg-gradient-to-br from-pri to-live grid place-items-center mx-auto mb-3.5 text-3xl cursor-pointer shadow-live hover:scale-110 transition-transform" onclick="startStream()" role="button" aria-label="Phát stream">&#9654;</div>
          <h2 class="font-extrabold text-lg"><%= match.home %> vs <%= match.away %></h2>
          <div class="text-muted text-[13px] mt-1.5"><%= match.league %> &middot; <time datetime="<%= match.date %>"><%= match.date %></time> <%= match.time %></div>
          <div class="mt-3.5 text-pri-light text-xs">Click &#9654; để vào phòng xem HD</div>
        </div>
      <% } else { %>
        <%
          // 🏆 Ảnh nền giải đấu (admin set) cho block "BLV chưa lên sóng"
          var _offBgs = (typeof leagueBgs !== 'undefined' && leagueBgs) ? leagueBgs : {};
          function _offNormLg(s){ return String(s||'').toLowerCase().replace(/\./g,'').replace(/\s+/g,' ').trim(); }
          var _offBg = '';
          if (match.league) {
            if (_offBgs[match.league]) _offBg = _offBgs[match.league];
            else {
              var _offt = _offNormLg(match.league);
              for (var _offk in _offBgs) {
                if (_offk === '__default__') continue;
                if (_offNormLg(_offk) === _offt) { _offBg = _offBgs[_offk]; break; }
              }
            }
          }
          if (!_offBg && _offBgs['__default__']) _offBg = _offBgs['__default__'];
        %>
        <% if (_offBg) { %>
          <img src="<%= _offBg %>" alt="" class="absolute inset-0 w-full h-full object-cover opacity-45 pointer-events-none" onerror="this.style.display='none'">
          <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/55 to-black/65 pointer-events-none"></div>
        <% } %>
        <!-- BLV chua len song -->
        <div class="text-center text-white p-5 max-w-md relative z-[2]">
          <div class="text-7xl mb-3 opacity-70 drop-shadow-lg">📡</div>
          <h2 class="font-extrabold text-xl mb-2 drop-shadow-lg"><%= match.home %> vs <%= match.away %></h2>
          <div class="text-gray-300 text-[13px] mb-4 drop-shadow"><%= match.league %> &middot; <%= match.date %> <%= match.time %></div>
          <div class="bg-live/25 backdrop-blur border border-live/50 rounded-lg p-4 inline-block shadow-xl">
            <div class="text-live font-extrabold text-base mb-1">🔴 BLV chưa lên sóng</div>
            <div class="text-gray-200 text-xs mb-2.5">Trận này đang chờ BLV kết nối OBS<br>Vui lòng quay lại sau hoặc xem trận khác</div>
            <a href="/lich-phat-song" class="inline-block bg-pri hover:bg-pri-dark text-white text-xs font-bold px-4 py-2 rounded">→ Xem lịch phát sóng</a>
          </div>
        </div>
      <% } %>
    </div>

    <div id="liveScoreRow" class="bg-bg-card border border-line rounded-xl p-3.5 mt-3 grid grid-cols-[1fr_auto_1fr_auto] gap-3.5 items-center">
      <div class="flex items-center gap-2.5 font-bold">
        <% if (match.homeBadge) { %><img src="<%= match.homeBadge %>" alt="<%= match.home %>" class="w-8 h-8 bg-white rounded-full p-0.5" onerror="this.style.display='none'"><% } %>
        <span><%= match.home %></span>
      </div>
      <div class="text-2xl font-black text-gold px-3.5 border-l border-r border-line"><% if (match.score) { %><%= match.score[0] %> : <%= match.score[1] %><% } else { %>-- : --<% } %></div>
      <div class="flex items-center gap-2.5 font-bold justify-end">
        <span><%= match.away %></span>
        <% if (match.awayBadge) { %><img src="<%= match.awayBadge %>" alt="<%= match.away %>" class="w-8 h-8 bg-white rounded-full p-0.5" onerror="this.style.display='none'"><% } %>
      </div>
      <div class="flex gap-2">
        <a href="<%= partner.sportbet %>" target="_blank" rel="noopener" class="px-3.5 py-2 rounded-md bg-gradient-to-br from-live to-red-700 text-white text-xs font-bold">&#128176; Đặt cược</a>
        <a href="#chatBody" class="px-3.5 py-2 rounded-md bg-pri text-white text-xs font-bold hidden md:inline">Chat</a>
      </div>
    </div>

    <%
      // BLV list THẬT: từ data.schedules approved + matchId trùng + đang trong khung giờ
      var _liveBlvs = (typeof liveBlvs !== 'undefined' && Array.isArray(liveBlvs)) ? liveBlvs : [];
    %>
    <% if (_liveBlvs.length > 0) { %>
    <div class="flex gap-2 mt-3 flex-wrap" role="tablist" aria-label="BLV">
      <% _liveBlvs.forEach(function(b, i){ %>
        <div class="flex items-center gap-2 bg-bg-card border border-line px-2.5 py-1.5 rounded-full text-xs font-semibold cursor-pointer transition-colors <%= i===0 ? 'border-pri text-pri-light' : 'hover:border-pri hover:text-pri-light' %>" role="tab" onclick="document.querySelectorAll('[role=tab]').forEach(function(x){x.className=x.className.replace('border-pri text-pri-light','').trim()});this.classList.add('border-pri','text-pri-light')">
          <% if (b.avatar) { %>
            <img src="<%= b.avatar %>" alt="" class="w-5.5 h-5.5 rounded-full">
          <% } else { %>
            <span class="w-5.5 h-5.5 rounded-full bg-gradient-to-br from-pri to-rose-500 grid place-items-center text-[10px]">🎙️</span>
          <% } %>
          <span><%= b.name %></span>
          <% if (b.isLive) { %><span class="w-1.5 h-1.5 bg-live rounded-full animate-pulse-live"></span><% } %>
        </div>
      <% }); %>
    </div>
    <% } %>

    <!-- ═══ PREDICT WIDGET — Tài Xỉu + Kèo Chấp cả trận ═══ -->
    <% var _showPredict = match && match.home && match.away && match.status !== 'finished'; %>
    <%
      // 🎯 ƯU TIÊN line từ Live odds API (Bet365/Pinnacle/Betano) — không dùng cache predict-store
      var _hasLiveOdds = (typeof liveOdds !== 'undefined' && liveOdds && (liveOdds.ah || liveOdds.ou || liveOdds.x12));
      var _ouLine = (_hasLiveOdds && liveOdds.ou && typeof liveOdds.ou.line === 'number') ? liveOdds.ou.line : 2.5;
      var _ahLine = (_hasLiveOdds && liveOdds.ah && typeof liveOdds.ah.line === 'number') ? liveOdds.ah.line : 0.5;
      var _predLines = { ouLine: _ouLine, ahLine: _ahLine };
      var _bookmaker = _hasLiveOdds ? ((liveOdds.ou && liveOdds.ou.bookmaker) || (liveOdds.ah && liveOdds.ah.bookmaker) || (liveOdds.x12 && liveOdds.x12.bookmaker)) : null;
      var _ouTai = (_hasLiveOdds && liveOdds.ou && typeof liveOdds.ou.taiOdds === 'number') ? liveOdds.ou.taiOdds : null;
      var _ouXiu = (_hasLiveOdds && liveOdds.ou && typeof liveOdds.ou.xiuOdds === 'number') ? liveOdds.ou.xiuOdds : null;
      var _ahHome = (_hasLiveOdds && liveOdds.ah && typeof liveOdds.ah.homeOdds === 'number') ? liveOdds.ah.homeOdds : null;
      var _ahAway = (_hasLiveOdds && liveOdds.ah && typeof liveOdds.ah.awayOdds === 'number') ? liveOdds.ah.awayOdds : null;
      // ahLine âm = đội nhà mạnh (chấp). dương = đội khách mạnh. 0 = kèo cân (Pick)
      var _ahLineAbs = Math.abs(_ahLine);
      var _ahIsEven = (_ahLine === 0 || _ahLineAbs < 0.001);  // kèo cân
      var _homeIsFav = _ahLine < 0;  // âm = đội nhà chấp
      function _ahBadgeText() {
        if (_ahIsEven) return 'Kèo cân';
        return (_homeIsFav ? (match.home||'').slice(0,10) : (match.away||'').slice(0,10)) + ' chấp ' + _ahLineAbs;
      }
      function _ahPickLabel(side) {
        if (_ahIsEven) return 'PK';  // Pick (kèo cân, hòa = trả tiền)
        if (side === 'home') return _homeIsFav ? '−' + _ahLineAbs : '+' + _ahLineAbs;
        return _homeIsFav ? '+' + _ahLineAbs : '−' + _ahLineAbs;
      }
    %>
    <% if (_showPredict) { %>
    <section class="predict-widget relative overflow-hidden rounded-xl mt-3" id="predictWidget">
      <div class="predict-bg"></div>

      <div class="relative px-3 py-2.5 z-10">
        <!-- Compact header: 1 dòng -->
        <div class="flex items-center justify-between mb-2 gap-2">
          <div class="flex items-center gap-1.5 min-w-0">
            <span class="text-base">🎯</span>
            <span class="text-white text-[12px] font-black uppercase tracking-wide truncate">Dự đoán</span>
            <span class="text-[10px] text-pri-light/70 hidden sm:inline">·</span>
            <span class="text-[10px] text-pri-light/70 hidden sm:inline">Đúng nhận X COIN</span>
            <% if (_hasLiveOdds) { %>
              <span class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded bg-emerald-400/15 border border-emerald-400/30">
                <span class="inline-block w-1 h-1 rounded-full bg-emerald-400 animate-pulse"></span>
                <span class="text-[9px] font-bold text-emerald-300 uppercase">LIVE</span>
                <% if (_bookmaker) { %><span class="text-[9px] text-emerald-200/70 hidden sm:inline"><%= _bookmaker.slice(0, 10) %></span><% } %>
              </span>
            <% } %>
          </div>
          <a href="/cao-thu" class="text-[10px] text-pri-light hover:text-yellow-300 font-bold flex items-center gap-0.5 flex-shrink-0">
            🏆 <span class="hidden sm:inline">BXH</span>
          </a>
        </div>

        <form id="predictForm" data-match-id="<%= match.id %>" data-match-time="<%= match.matchTs || '' %>" data-ou-line="<%= _predLines.ouLine %>" data-ah-line="<%= _predLines.ahLine %>">

          <!-- ─── ROW 1: TÀI / XỈU (mốc từ API) ─── -->
          <div class="mb-1.5">
            <div class="flex items-center justify-between mb-1 px-0.5">
              <span class="text-[10px] font-bold text-pri-light/90 uppercase">Tài/Xỉu</span>
              <span class="text-[9px] font-bold text-yellow-300/90">Mốc <%= _predLines.ouLine %></span>
            </div>
            <div class="grid grid-cols-2 gap-1.5">
              <label class="predict-pick-c">
                <input type="radio" name="pickOU" value="tai">
                <div class="predict-pick-c-inner">
                  <div class="flex items-center gap-1.5">
                    <span class="text-[11px] font-black text-white">TÀI</span>
                    <span class="text-[9px] text-white/60">&gt;<%= _predLines.ouLine %></span>
                  </div>
                  <% if (_ouTai) { %><span class="predict-odds-c"><%= _ouTai.toFixed(2) %></span><% } %>
                </div>
              </label>
              <label class="predict-pick-c">
                <input type="radio" name="pickOU" value="xiu">
                <div class="predict-pick-c-inner">
                  <div class="flex items-center gap-1.5">
                    <span class="text-[11px] font-black text-white">XỈU</span>
                    <span class="text-[9px] text-white/60">&lt;<%= _predLines.ouLine %></span>
                  </div>
                  <% if (_ouXiu) { %><span class="predict-odds-c"><%= _ouXiu.toFixed(2) %></span><% } %>
                </div>
              </label>
            </div>
          </div>

          <!-- ─── ROW 2: ASIAN HANDICAP (line từ API) ─── -->
          <div class="mb-2">
            <div class="flex items-center justify-between mb-1 px-0.5">
              <span class="text-[10px] font-bold text-pri-light/90 uppercase">Kèo chấp</span>
              <span class="text-[9px] font-bold text-yellow-300/90"><%= _ahBadgeText() %></span>
            </div>
            <div class="grid grid-cols-2 gap-1.5">
              <label class="predict-pick-c">
                <input type="radio" name="pickAH" value="home">
                <div class="predict-pick-c-inner">
                  <div class="flex items-center gap-1.5 min-w-0">
                    <span class="text-[11px] font-black text-white truncate" title="<%= match.home %>"><%= (match.home||'').slice(0, 10) %></span>
                    <span class="text-[9px] text-white/60 flex-shrink-0"><%= _ahPickLabel('home') %></span>
                  </div>
                  <% if (_ahHome) { %><span class="predict-odds-c"><%= _ahHome.toFixed(2) %></span><% } %>
                </div>
              </label>
              <label class="predict-pick-c">
                <input type="radio" name="pickAH" value="away">
                <div class="predict-pick-c-inner">
                  <div class="flex items-center gap-1.5 min-w-0">
                    <span class="text-[11px] font-black text-white truncate" title="<%= match.away %>"><%= (match.away||'').slice(0, 10) %></span>
                    <span class="text-[9px] text-white/60 flex-shrink-0"><%= _ahPickLabel('away') %></span>
                  </div>
                  <% if (_ahAway) { %><span class="predict-odds-c"><%= _ahAway.toFixed(2) %></span><% } %>
                </div>
              </label>
            </div>
          </div>

          <!-- Compact submit + reward inline -->
          <button type="submit" id="predictBtn" class="predict-submit-btn-c">
            <span class="btn-shine"></span>
            <span class="relative z-10 flex items-center justify-center gap-1.5">
              <span class="text-sm">🎯</span>
              <span class="text-[12px] font-black uppercase tracking-wide">Dự đoán</span>
              <span class="text-[9px] text-yellow-200/90 font-bold">· +30/100 X COIN</span>
            </span>
          </button>
          <div id="predictResult" class="mt-2 text-center text-[11px] hidden font-bold"></div>
        </form>
      </div>
    </section>

    <style>
    .predict-widget { isolation:isolate; }
    .predict-bg {
      position:absolute; inset:0; z-index:0;
      background: linear-gradient(135deg, #1a0f08 0%, #2a1810 30%, #1a1410 70%, #0f0a08 100%);
      border:1px solid rgba(255,122,24,.4);
      border-radius:16px;
    }
    .predict-bg::before {
      content:''; position:absolute; inset:-2px; z-index:-1;
      background: linear-gradient(135deg, #ff7a18, #ef4444, #facc15, #ff7a18);
      background-size:300% 300%;
      border-radius:18px;
      animation: predict-border 6s ease infinite;
      filter:blur(8px); opacity:.5;
    }
    @keyframes predict-border {
      0%,100% { background-position:0% 50%; }
      50% { background-position:100% 50%; }
    }
    .predict-shimmer {
      position:absolute; top:0; left:-100%; width:60%; height:100%; z-index:1; pointer-events:none;
      background: linear-gradient(105deg, transparent 40%, rgba(255,212,128,.15) 50%, transparent 60%);
      animation: predict-shimmer 4s ease-in-out infinite;
    }
    @keyframes predict-shimmer {
      0%,100% { left:-100%; }
      50% { left:140%; }
    }
    .predict-reward-sticker {
      position:absolute; top:8px; right:8px; z-index:2;
      background: linear-gradient(135deg, #ff7a18, #ef4444);
      color:#fff; padding:6px 10px; border-radius:10px;
      transform:rotate(8deg);
      box-shadow:0 4px 15px rgba(255,122,24,.5);
      animation: predict-bounce 2s ease infinite;
    }
    @keyframes predict-bounce {
      0%,100% { transform:rotate(8deg) translateY(0); }
      50% { transform:rotate(8deg) translateY(-4px); }
    }
    /* ─── Section (Tài Xỉu / Kèo Chấp) ─── */
    .predict-section { margin-bottom:14px; }
    .predict-section-header {
      display:flex; align-items:center; gap:8px;
      margin-bottom:8px; padding:6px 10px;
      background:rgba(255,122,24,.08);
      border-left:3px solid #ff7a18;
      border-radius:6px;
    }
    .predict-section-icon { font-size:16px; }
    .predict-section-title {
      flex:1; font-size:12px; font-weight:800; color:#ffd9a8;
      letter-spacing:.3px;
    }
    .predict-line-badge {
      background:linear-gradient(135deg,#facc15,#f59e0b);
      color:#1a0f08; font-size:10px; font-weight:900;
      padding:3px 8px; border-radius:6px;
      box-shadow:0 2px 6px rgba(250,204,21,.3);
    }
    /* ─── Pick options ─── */
    .predict-pick-grid {
      display:grid; grid-template-columns:1fr 1fr; gap:8px;
    }
    .predict-pick { position:relative; cursor:pointer; display:block; }
    .predict-pick input[type="radio"] {
      position:absolute; opacity:0; pointer-events:none;
    }
    .predict-pick-inner {
      background:rgba(255,255,255,.03);
      border:2px solid rgba(255,255,255,.08);
      border-radius:12px;
      padding:10px 8px;
      text-align:center;
      transition:all .2s ease;
    }
    .predict-pick:hover .predict-pick-inner {
      background:rgba(255,122,24,.08);
      border-color:rgba(255,122,24,.35);
      transform:translateY(-1px);
    }
    .predict-pick input[type="radio"]:checked + .predict-pick-inner {
      background:linear-gradient(135deg,rgba(255,122,24,.25),rgba(239,68,68,.2));
      border-color:#facc15;
      box-shadow:0 0 0 3px rgba(250,204,21,.2), 0 6px 18px rgba(255,122,24,.35);
      transform:translateY(-2px);
    }
