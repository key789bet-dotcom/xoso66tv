    <!-- ════ PANEL: STATS (data thật từ thethaoviet `summary`: cards + corners + score) ════ -->
    <div class="dlr-side-panel" data-panel="stats">
      <h4>📊 Thống kê trận đấu</h4>
      <%
        var _sStats = (typeof matchInsights !== 'undefined' && matchInsights && matchInsights.stats) ? matchInsights.stats : null;
        var _sCardsH = (_sStats && _sStats.cards && _sStats.cards.home) || { yellow:0, red:0 };
        var _sCardsA = (_sStats && _sStats.cards && _sStats.cards.away) || { yellow:0, red:0 };
        var _sCornersH = (_sStats && _sStats.corners && _sStats.corners.home) || 0;
        var _sCornersA = (_sStats && _sStats.corners && _sStats.corners.away) || 0;
        var _sGoalsH = (match.score && match.score[0]) || 0;
        var _sGoalsA = (match.score && match.score[1]) || 0;
        function _v(k) { return _sStats && _sStats[k] || null; }
        function _has(o) { return o && (Number(o.home) || Number(o.away)); }
        // 18 chỉ số đầy đủ theo schema thật của thethaoviet, ưu tiên theo screenshot user
        var _sRows = [
          { label:'Bàn thắng', icon:'⚽', h:_sGoalsH, a:_sGoalsA }
        ];
        var _poss = _v('possession');
        if (_has(_poss)) _sRows.push({ label:'Kiểm soát bóng', icon:'%', h:_poss.home, a:_poss.away, suffix:'%' });
        var _shots = _v('shots');
        if (_has(_shots)) _sRows.push({ label:'Tổng cú sút', icon:'🎯', h:_shots.home, a:_shots.away });
        var _shotsOn = _v('shotsOn');
        if (_has(_shotsOn)) _sRows.push({ label:'Sút trúng đích', icon:'⊕', h:_shotsOn.home, a:_shotsOn.away });
        var _shotsOff = _v('shotsOff');
        if (_has(_shotsOff)) _sRows.push({ label:'Sút trượt', icon:'⊘', h:_shotsOff.home, a:_shotsOff.away });
        var _shotsBl = _v('shotsBlocked');
        if (_has(_shotsBl)) _sRows.push({ label:'Sút bị chặn', icon:'⛔', h:_shotsBl.home, a:_shotsBl.away });
        var _shotsIn = _v('shotsInBox');
        if (_has(_shotsIn)) _sRows.push({ label:'Sút trong vòng cấm', icon:'▣', h:_shotsIn.home, a:_shotsIn.away });
        var _shotsOut = _v('shotsOutBox');
        if (_has(_shotsOut)) _sRows.push({ label:'Sút ngoài vòng cấm', icon:'▢', h:_shotsOut.home, a:_shotsOut.away });
        _sRows.push({ label:'Phạt góc', icon:'∟', h:_sCornersH, a:_sCornersA });
        var _fouls = _v('fouls');
        if (_has(_fouls)) _sRows.push({ label:'Phạm lỗi', icon:'⚠', h:_fouls.home, a:_fouls.away });
        var _off = _v('offsides');
        if (_has(_off)) _sRows.push({ label:'Việt vị', icon:'⚑', h:_off.home, a:_off.away });
        _sRows.push({ label:'Thẻ vàng', icon:'🟨', h:_sCardsH.yellow, a:_sCardsA.yellow });
        _sRows.push({ label:'Thẻ đỏ', icon:'🟥', h:_sCardsH.red, a:_sCardsA.red });
        var _saves = _v('saves');
        if (_has(_saves)) _sRows.push({ label:'Thủ môn cứu thua', icon:'🧤', h:_saves.home, a:_saves.away });
        var _passes = _v('passes');
        if (_has(_passes)) _sRows.push({ label:'Tổng đường chuyền', icon:'➥', h:_passes.home, a:_passes.away });
        var _passesAcc = _v('passesAccurate');
        if (_has(_passesAcc)) _sRows.push({ label:'Chuyền chính xác', icon:'✓', h:_passesAcc.home, a:_passesAcc.away });
        var _passesPct = _v('passesPct');
        if (_has(_passesPct)) _sRows.push({ label:'Độ chính xác chuyền', icon:'%', h:_passesPct.home, a:_passesPct.away, suffix:'%' });
        var _xg = _v('xG');
        if (_has(_xg)) _sRows.push({ label:'Bàn thắng kỳ vọng (xG)', icon:'⭐', h:_xg.home, a:_xg.away });
        var _gp = _v('goalsPrevented');
        if (_has(_gp) || (_gp && (_gp.home !== 0 || _gp.away !== 0))) _sRows.push({ label:'Bàn ngăn chặn (xGP)', icon:'🛡', h:_gp.home, a:_gp.away });
        function _sBarPct(h,a){ var t=(Number(h)||0)+(Number(a)||0); return t>0?Math.round((Number(h)||0)/t*100):50; }
      %>

      <!-- Legend events compact (giống xoilac) -->
      <% var _sEvents = (typeof matchInsights !== 'undefined' && matchInsights && Array.isArray(matchInsights.events)) ? matchInsights.events : []; %>
      <% if (_sEvents.length > 0) { %>
        <div style="display:flex; flex-wrap:wrap; gap:4px 10px; padding:6px 0; font-size:10px; color:#94a3b8; border-bottom:1px dashed rgba(255,255,255,.08); margin-bottom:8px;">
          <span>⚽ Ghi bàn</span><span>🅿 Penalty</span><span>🔄 Phản lưới</span>
          <span>🟨 Vàng</span><span>🟥 Đỏ</span><span>🔁 Thay người</span><span>VAR</span>
        </div>
      <% } %>
      <% _sRows.forEach(function(r){ var pct = _sBarPct(r.h, r.a); var sfx = r.suffix || ''; %>
      <div class="dlr-stat-row-bar">
        <div class="dlr-stat-vals">
          <span style="color:rgb(0,118,255); font-weight:900; font-size:13px;"><%= r.h %><%= sfx %></span>
          <span style="color:#fff; font-size:11px; font-weight:600;"><%= r.icon %> <%= r.label %></span>
          <span style="color:rgb(10,201,0); font-weight:900; font-size:13px;"><%= r.a %><%= sfx %></span>
        </div>
        <div class="dlr-stat-bar">
          <div class="dlr-stat-bar-l" style="width:<%= pct %>%; background:rgb(0,118,255);"></div>
          <div class="dlr-stat-bar-r" style="width:<%= 100-pct %>%; background:rgb(10,201,0);"></div>
        </div>
      </div>
      <% }); %>

      <!-- ════ DIỄN BIẾN TRẬN ĐẤU ════ -->
      <% if (_sEvents.length > 0) { %>
        <h4 style="margin-top:14px;">📋 Diễn biến trận đấu</h4>
        <div class="dlr-events-list">
          <% _sEvents.forEach(function(e){
               var icon = '⚪'; var iconColor = '#94a3b8'; var label = '';
               if (e.type === 'goal') {
                 if (e.subType === 'own')        { icon = '🔄'; iconColor = '#f97316'; label = 'Phản lưới'; }
                 else if (e.subType === 'penalty'){ icon = '🅿'; iconColor = '#10b981'; label = 'Phạt đền'; }
                 else if (e.subType === 'missed_pen') { icon = '❌'; iconColor = '#dc2626'; label = 'Hỏng pen'; }
                 else                            { icon = '⚽'; iconColor = '#10b981'; label = 'Ghi bàn'; }
               } else if (e.type === 'yellow')   { icon = '🟨'; iconColor = '#facc15'; label = 'Thẻ vàng'; }
                 else if (e.type === 'red')     { icon = '🟥'; iconColor = '#dc2626'; label = 'Thẻ đỏ'; }
                 else if (e.type === 'sub')     { icon = '🔁'; iconColor = '#3b82f6'; label = 'Thay người'; }
                 else if (e.type === 'var')     { icon = '📺'; iconColor = '#a855f7'; label = 'VAR'; }
               var minStr = e.minute + (e.extra ? '+' + e.extra : '') + "'";
               var bgSide = e.team === 'home' ? 'rgba(0,118,255,.08)' : 'rgba(10,201,0,.08)';
               var brdSide = e.team === 'home' ? '3px solid rgb(0,118,255)' : '3px solid rgb(10,201,0)';
          %>
            <div class="dlr-event-row" style="background:<%= bgSide %>; border-left:<%= brdSide %>;">
              <span class="dlr-event-min"><%= minStr %></span>
              <span class="dlr-event-icon" style="color:<%= iconColor %>;"><%= icon %></span>
              <span class="dlr-event-body">
                <% if (e.type === 'sub') { %>
                  <b style="color:#dc2626;">⬇ <%= e.player %></b>
                  <% if (e.assist) { %><br><b style="color:#10b981;">⬆ <%= e.assist %></b><% } %>
                <% } else { %>
                  <b><%= e.player %></b>
                  <% if (e.assist) { %><br><span style="color:#94a3b8; font-size:10px;">Kiến tạo: <%= e.assist %></span><% } %>
                <% } %>
                <% if (e.type === 'goal' && e.subType !== 'normal') { %>
                  <span style="color:<%= iconColor %>; font-size:9px; margin-left:4px;">(<%= label %>)</span>
                <% } else if (e.type === 'var') { %>
                  <span style="color:<%= iconColor %>; font-size:9px; display:block;"><%= e.detail %></span>
                <% } %>
              </span>
            </div>
          <% }); %>
        </div>
      <% } %>

      <h4 style="margin-top:14px;">📈 Phong độ 5 trận gần nhất</h4>
      <% var _sFormH = matchInsights && matchInsights.formHome; var _sFormA = matchInsights && matchInsights.formAway; %>
      <% if (_sFormH || _sFormA) { %>
        <% if (_sFormH) { %>
        <div style="display:flex; align-items:center; gap:6px; padding:6px 0;">
          <span style="flex:1; color:#cbd5e1; font-size:11px;"><%= match.home %></span>
          <% _sFormH.forEach(function(f){
            var c = f === 'W' ? '#10b981' : (f === 'L' ? '#dc2626' : '#94a3b8');
            var l = f === 'W' ? 'T' : (f === 'L' ? 'B' : 'H'); %>
            <span style="width:18px; height:18px; background:<%= c %>; color:#fff; border-radius:3px; display:grid; place-items:center; font-size:10px; font-weight:900;"><%= l %></span>
          <% }); %>
        </div>
        <% } %>
        <% if (_sFormA) { %>
        <div style="display:flex; align-items:center; gap:6px; padding:6px 0;">
          <span style="flex:1; color:#cbd5e1; font-size:11px;"><%= match.away %></span>
          <% _sFormA.forEach(function(f){
            var c = f === 'W' ? '#10b981' : (f === 'L' ? '#dc2626' : '#94a3b8');
            var l = f === 'W' ? 'T' : (f === 'L' ? 'B' : 'H'); %>
            <span style="width:18px; height:18px; background:<%= c %>; color:#fff; border-radius:3px; display:grid; place-items:center; font-size:10px; font-weight:900;"><%= l %></span>
          <% }); %>
        </div>
        <% } %>
      <% } else { %>
        <p style="color:#94a3b8; font-size:11px; text-align:center; padding:10px 0;">Đang cập nhật phong độ...</p>
      <% } %>
      <p style="color:#94a3b8; font-size:10px; line-height:1.5; margin-top:12px; padding-top:10px; border-top:1px solid #1a1f29;">
        💡 Data realtime từ API thethaoviet — cập nhật 60s/lần. Số liệu chi tiết (kiểm soát bóng, sút trúng đích...) chỉ hiện khi giải có cung cấp.
      </p>
    </div>
    <style>
      .dlr-stat-row-bar { padding:8px 0; border-bottom:1px solid rgba(255,255,255,.04); }
      .dlr-stat-vals { display:flex; align-items:center; justify-content:space-between; margin-bottom:5px; gap:8px; }
      .dlr-stat-vals span:nth-child(2) { flex:1; text-align:center; }
      .dlr-stat-bar { display:flex; height:6px; background:#0a0d12; border-radius:3px; overflow:hidden; gap:2px; }
      .dlr-stat-bar-l, .dlr-stat-bar-r { height:100%; transition:width .3s; }
      /* Events list */
      .dlr-events-list { display:flex; flex-direction:column; gap:4px; max-height:340px; overflow-y:auto; padding-right:2px; margin-top:6px; }
      .dlr-events-list::-webkit-scrollbar { width:4px; }
      .dlr-events-list::-webkit-scrollbar-thumb { background:#1a1f29; border-radius:2px; }
      .dlr-event-row { display:grid; grid-template-columns:38px 22px 1fr; gap:6px; align-items:center; padding:5px 8px; border-radius:4px; font-size:11px; }
      .dlr-event-min { color:#facc15; font-weight:900; font-size:11px; text-align:right; }
      .dlr-event-icon { font-size:15px; text-align:center; }
      .dlr-event-body { color:#e2e8f0; line-height:1.3; min-width:0; }
      .dlr-event-body b { color:#fff; font-weight:700; }
    </style>

    <!-- ════ PANEL: LINEUP (schema thethaoviet: {formation, coach, startXI[], substitutes[]}) ════ -->
    <style>
      .dlr-lu-team { margin-bottom:14px; }
      .dlr-lu-header { display:flex; justify-content:space-between; align-items:center; padding:6px 8px; background:#0a0d12; border-radius:4px; margin-bottom:6px; font-size:12px; }
      .dlr-lu-header b { color:#fff; }
      .dlr-lu-header .form-badge { background:#ff7a18; color:#fff; padding:2px 8px; border-radius:3px; font-size:11px; font-weight:900; }
      .dlr-lu-coach { font-size:11px; color:#94a3b8; padding:2px 8px; margin-bottom:6px; }
      .dlr-lu-row { display:flex; align-items:center; padding:4px 8px; font-size:11px; border-bottom:1px solid rgba(255,255,255,.04); gap:8px; }
      .dlr-lu-row b { color:#facc15; min-width:22px; text-align:center; background:rgba(250,204,21,.1); border-radius:3px; padding:1px 0; }
      .dlr-lu-row .pos { color:#94a3b8; font-size:10px; padding:0 4px; }
      .dlr-lu-row .name { flex:1; color:#e2e8f0; }
      .dlr-lu-row .rating { color:#10b981; font-weight:900; font-size:10px; min-width:24px; text-align:right; }
      .dlr-lu-sub-title { margin-top:8px; padding:4px 8px; font-size:11px; color:#94a3b8; border-top:1px dashed rgba(255,255,255,.08); }
    </style>
    <div class="dlr-side-panel" data-panel="lineup">
      <h4>⚽ Đội hình ra sân</h4>
      <% var _sLineup = (typeof matchInsights !== 'undefined' && matchInsights && matchInsights.lineup) ? matchInsights.lineup : null; %>
      <% var _hasLU = _sLineup && ((_sLineup.home && _sLineup.home.startXI && _sLineup.home.startXI.length) || (_sLineup.away && _sLineup.away.startXI && _sLineup.away.startXI.length)); %>
      <% if (_hasLU) { %>
        <% ['home','away'].forEach(function(side){
             var tm = _sLineup[side];
             if (!tm || !tm.startXI || !tm.startXI.length) return;
             var teamName = side === 'home' ? match.home : match.away;
        %>
          <div class="dlr-lu-team">
            <div class="dlr-lu-header">
              <b><%= teamName %></b>
              <% if (tm.formation) { %><span class="form-badge"><%= tm.formation %></span><% } %>
            </div>
            <% if (tm.coach) { %><div class="dlr-lu-coach">🎯 HLV: <%= tm.coach %></div><% } %>
            <% tm.startXI.forEach(function(p){ %>
              <div class="dlr-lu-row">
                <b><%= p.number || '?' %></b>
                <span class="pos"><%= p.pos || '' %></span>
                <span class="name"><%= p.name %></span>
                <% if (p.rating) { %><span class="rating"><%= Number(p.rating).toFixed(1) %></span><% } %>
              </div>
            <% }); %>
            <% if (tm.substitutes && tm.substitutes.length) { %>
              <div class="dlr-lu-sub-title">📋 Dự bị (<%= tm.substitutes.length %>)</div>
              <% tm.substitutes.slice(0,7).forEach(function(p){ %>
                <div class="dlr-lu-row" style="opacity:.7;">
                  <b><%= p.number || '?' %></b>
                  <span class="pos"><%= p.pos || '' %></span>
                  <span class="name"><%= p.name %></span>
                </div>
              <% }); %>
            <% } %>
          </div>
        <% }); %>
      <% } else { %>
        <div class="dlr-side-empty">⚽<br>Đội hình sẽ cập nhật<br>15-30 phút trước trận</div>
      <% } %>
    </div>

    <!-- ════ PANEL: H2H (schema thethaoviet: home/away + logo + halftime + league) ════ -->
    <style>
      .dlr-h2h-row { display:grid; grid-template-columns:auto 1fr auto 1fr auto; gap:6px; align-items:center; padding:6px 4px; border-bottom:1px solid rgba(255,255,255,.05); font-size:11px; }
      .dlr-h2h-date { color:#94a3b8; font-size:10px; }
      .dlr-h2h-team { display:flex; align-items:center; gap:4px; min-width:0; }
      .dlr-h2h-team img { width:14px; height:14px; object-fit:contain; }
      .dlr-h2h-team .nm { white-space:nowrap; overflow:hidden; text-overflow:ellipsis; color:#e2e8f0; }
      .dlr-h2h-team.home { justify-content:flex-end; text-align:right; }
      .dlr-h2h-score { background:rgba(255,122,24,.15); color:#facc15; padding:2px 6px; border-radius:3px; font-weight:900; min-width:36px; text-align:center; font-size:11px; }
      .dlr-h2h-ht { color:#64748b; font-size:9px; display:block; margin-top:1px; }
    </style>
    <div class="dlr-side-panel" data-panel="h2h">
      <h4>⚔ Lịch sử đối đầu</h4>
      <% var _sH2H = (typeof matchInsights !== 'undefined' && matchInsights && Array.isArray(matchInsights.h2h)) ? matchInsights.h2h : []; %>
      <% if (_sH2H.length > 0) { %>
        <% _sH2H.slice(0, 10).forEach(function(m){ %>
          <div class="dlr-h2h-row">
            <span class="dlr-h2h-date"><%= (m.date || '').slice(5) %></span>
            <span class="dlr-h2h-team home">
              <span class="nm"><%= m.home || '' %></span>
              <% if (m.homeLogo) { %><img src="<%= m.homeLogo %>" alt="" loading="lazy"><% } %>
            </span>
            <span class="dlr-h2h-score">
              <%= m.score || '0-0' %>
              <% if (m.halftime) { %><span class="dlr-h2h-ht">HT <%= m.halftime %></span><% } %>
            </span>
            <span class="dlr-h2h-team away">
              <% if (m.awayLogo) { %><img src="<%= m.awayLogo %>" alt="" loading="lazy"><% } %>
              <span class="nm"><%= m.away || '' %></span>
            </span>
            <span></span>
          </div>
        <% }); %>
      <% } else { %>
        <div class="dlr-side-empty">⚔<br>Chưa có dữ liệu đối đầu</div>
      <% } %>
    </div>

    <!-- ════ PANEL: ODDS (live odds) ════ -->
    <div class="dlr-side-panel" data-panel="odds">
      <% var _sHasOdds = (typeof liveOdds !== 'undefined' && liveOdds && (liveOdds.ah || liveOdds.ou || liveOdds.x12)); %>
      <% if (_sHasOdds) { %>
        <% if (liveOdds.x12) { %>
          <h4>📊 Châu Âu (1X2)</h4>
          <div class="dlr-side-odds-row">
            <span class="dlr-side-odds-cell"><%= liveOdds.x12.homeOdds ? liveOdds.x12.homeOdds.toFixed(2) : '—' %></span>
            <span class="dlr-side-odds-cell"><%= liveOdds.x12.drawOdds ? liveOdds.x12.drawOdds.toFixed(2) : '—' %></span>
            <span class="dlr-side-odds-cell"><%= liveOdds.x12.awayOdds ? liveOdds.x12.awayOdds.toFixed(2) : '—' %></span>
          </div>
        <% } %>
        <% if (liveOdds.ah) { %>
          <h4>⚖ Châu Á (Chấp)</h4>
          <div class="dlr-side-odds-row">
            <span class="dlr-side-odds-cell"><%= liveOdds.ah.homeOdds ? liveOdds.ah.homeOdds.toFixed(2) : '—' %></span>
            <span class="dlr-side-odds-cell dlr-side-odds-line"><%= liveOdds.ah.line %></span>
            <span class="dlr-side-odds-cell"><%= liveOdds.ah.awayOdds ? liveOdds.ah.awayOdds.toFixed(2) : '—' %></span>
          </div>
        <% } %>
        <% if (liveOdds.ou) { %>
          <h4>📈 Tài/Xỉu</h4>
          <div class="dlr-side-odds-row">
            <span class="dlr-side-odds-cell"><%= liveOdds.ou.taiOdds ? liveOdds.ou.taiOdds.toFixed(2) : '—' %></span>
            <span class="dlr-side-odds-cell dlr-side-odds-line"><%= liveOdds.ou.line %></span>
            <span class="dlr-side-odds-cell"><%= liveOdds.ou.xiuOdds ? liveOdds.ou.xiuOdds.toFixed(2) : '—' %></span>
          </div>
        <% } %>
        <a href="<%= partner.sportbet %>" target="_blank" rel="noopener" style="display:block; background:#ff7a18; color:#fff; text-align:center; padding:8px; border-radius:4px; font-size:11px; font-weight:900; text-decoration:none; margin-top:10px;">💰 CƯỢC NGAY</a>
      <% } else { %>
        <div class="dlr-side-empty">📈<br>Tỷ lệ đang cập nhật...</div>
      <% } %>
    </div>

    <!-- ════ PANEL: PREDICT (#predictWidget JS sẽ teleport vào slot này) ════ -->
    <div class="dlr-side-panel" data-panel="predict">
      <h4>🎯 Dự đoán nhận X COIN</h4>
      <div id="dlrPredictSlot" style="margin-top:8px;">
        <p style="color:#94a3b8; font-size:11px; text-align:center; padding:20px 0;">Đang tải widget dự đoán...</p>
      </div>
      <a href="/cao-thu" style="display:block; text-align:center; margin-top:12px; color:#ff9a3a; font-size:11px; text-decoration:none; padding:6px; border:1px solid rgba(255,122,24,.3); border-radius:4px;">🏆 BXH Cao Thủ →</a>
    </div>

    <!-- ════ PANEL: SHARE ════ -->
    <div class="dlr-side-panel" data-panel="share">
      <h4>🔗 Chia sẻ trận đấu</h4>
      <p style="color:#cbd5e1; font-size:12px; margin:0 0 10px;">Sao chép link hoặc chia sẻ qua mạng xã hội:</p>
      <input type="text" readonly value="" id="dlrShareUrl" style="width:100%; background:#0a0d12; border:1px solid #1a1f29; padding:6px 8px; border-radius:4px; color:#fff; font-size:11px; margin-bottom:8px;" onclick="this.select()">
      <button type="button" onclick="(function(){var u=location.href;if(navigator.share){navigator.share({title:document.title,url:u}).catch(function(){})}else if(navigator.clipboard){navigator.clipboard.writeText(u).then(function(){alert('✓ Đã copy link!')})}else{prompt('Copy link:',u)}})()" style="display:block; width:100%; background:#ff7a18; color:#fff; padding:8px; border-radius:4px; font-size:12px; font-weight:900; border:none; cursor:pointer;">📤 Chia sẻ ngay</button>
      <div style="display:flex; gap:6px; margin-top:10px;">
        <a href="https://t.me/share/url?url=https://xoso66tv.com<%= match.slug ? '/live/'+match.slug : '' %>" target="_blank" rel="noopener" style="flex:1; background:#0088cc; color:#fff; text-align:center; padding:6px; border-radius:4px; font-size:10px; font-weight:700; text-decoration:none;">Telegram</a>
        <a href="https://www.facebook.com/sharer/sharer.php?u=https://xoso66tv.com<%= match.slug ? '/live/'+match.slug : '' %>" target="_blank" rel="noopener" style="flex:1; background:#1877f2; color:#fff; text-align:center; padding:6px; border-radius:4px; font-size:10px; font-weight:700; text-decoration:none;">Facebook</a>
      </div>
    </div>

    <!-- ════ PANEL: CHAT (default active) - wrap content cũ ════ -->
    <div class="dlr-side-panel active" data-panel="chat">

    <%
      // 🎨 Render 1 chat tab: ảnh nếu admin đã upload, fallback emoji+text
      var _cti = (typeof tabIcons !== 'undefined' && tabIcons) ? tabIcons : {};
      function _renderChatTab(key, emoji, label, isActive) {
        var base = 'chat-tab flex-1 flex items-center justify-center border-b-2 transition-all';
        var active = isActive
          ? 'bg-bg-card text-pri-light font-bold border-pri'
          : 'bg-transparent text-muted hover:text-white font-bold border-transparent';
        if (_cti[key]) {
          // Ảnh chiếm nguyên tab, height ~40px (matched py-3)
          return '<button class="' + base + ' ' + active + ' p-1 h-10" onclick="switchChatTab(this)" aria-label="' + label + '">' +
                   '<img src="' + _cti[key] + '" alt="' + label + '" class="max-h-full w-auto object-contain">' +
                 '</button>';
        }
        return '<button class="' + base + ' ' + active + ' py-3 text-xs" onclick="switchChatTab(this)">' + emoji + ' ' + label + '</button>';
      }
    %>
    <div class="flex border-b border-line bg-bg-soft" role="tablist">
      <%- _renderChatTab('chat_room',     '&#128172;', 'Chat phòng', true)  %>
      <%- _renderChatTab('chat_telegram', '&#128238;', 'Telegram',   false) %>
      <%- _renderChatTab('chat_facebook', '&#128276;', 'Facebook',   false) %>
    </div>

    <!-- 🎀 3 BANNER GIF (admin upload) -->
    <% var _cb = (typeof chatBanners !== 'undefined' && Array.isArray(chatBanners)) ? chatBanners : []; %>
    <% if (_cb.length > 0) { %>
    <div class="grid gap-1.5 p-2 bg-bg-soft border-b border-line" style="grid-template-columns: repeat(<%= _cb.length %>, 1fr);">
      <% _cb.forEach(function(bn){ %>
        <a href="<%= bn.link || '#' %>" target="_blank" rel="noopener" class="block rounded-lg overflow-hidden border border-line hover:border-pri transition-colors aspect-[4/3] bg-bg-deep">
          <img src="<%= bn.image %>" alt="<%= bn.label %>" class="w-full h-full object-cover" loading="lazy">
        </a>
      <% }); %></div>
    <% } %>
    <div class="px-3 py-2 bg-bg-soft border-b border-line text-xs text-muted flex items-center justify-between">
      <span class="text-emerald-500 flex items-center gap-1"><span class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse-live"></span>2.487 online</span>
      <span>Bình luận: <b class="text-pri-light"><%= (Math.random()*5000|0)+1000 %></b></span>
    </div>
    <div class="flex-1 overflow-y-auto py-1 scrollbar-thin" id="chatBody"></div>
    <% if (_cti.cta_register) { %>
      <a href="<%= partner.register %>" target="_blank" rel="noopener" class="block mx-2 mt-2 mb-1 rounded-lg overflow-hidden hover:opacity-90 transition-opacity">
        <img src="<%= _cti.cta_register %>" alt="Đăng ký nhận 100% tiền thưởng" class="w-full h-auto object-cover">
      </a>
    <% } else { %>
      <div class="mx-2 mt-2 mb-1 p-2 bg-gradient-to-r from-purple to-pink rounded-lg text-white text-[11px] font-bold text-center cursor-pointer" onclick="window.open('<%= partner.register %>','_blank')">&#127873; ĐĂNG KÝ NHẬN 100% TIỀN THƯỞNG</div>
    <% } %>
    <div class="px-2.5 pt-1 text-[10px] text-dim italic flex items-center gap-1" id="chatHint">&#128274; Khách giới hạn 1 tin mỗi 5 phút</div>
    <div class="flex gap-1.5 p-2.5 border-t border-line bg-bg-soft">
      <input id="chatInput" maxlength="200" class="flex-1 bg-bg-deep border border-line text-gray-100 px-3 py-2 rounded-md outline-none text-[13px] focus:border-pri disabled:opacity-50 disabled:cursor-not-allowed" placeholder="Gõ tin nhắn..." onkeydown="if(event.key==='Enter')sendChat('chatInput','chatBody')">
      <button id="chatBtn" class="bg-gradient-to-br from-pri to-live text-white px-4 rounded-md font-bold text-xs min-w-[64px] tabular-nums" onclick="sendChat('chatInput','chatBody')">Gửi</button>
    </div>
    </div><!-- /dlr-side-panel data-panel="chat" -->

    <!-- JS: switch panel + teleport #predictWidget vào panel Dự đoán -->
    <script>
    (function(){
      var tabsRoot = document.getElementById('liveMiniTabs');
      var label = document.getElementById('liveMiniTabLabel');
      var shareUrlInput = document.getElementById('dlrShareUrl');
      if (shareUrlInput) shareUrlInput.value = location.href;
      if (!tabsRoot) return;
      var LABELS = { stats:'THỐNG KÊ', lineup:'ĐỘI HÌNH', chat:'CHAT', h2h:'ĐỐI ĐẦU', odds:'TỶ LỆ', predict:'DỰ ĐOÁN', share:'CHIA SẺ' };
      var icons = tabsRoot.querySelectorAll('.dlr-mini-icon[data-mtab]');
      icons.forEach(function(btn){
        btn.addEventListener('click', function(){
          var key = btn.dataset.mtab;
          icons.forEach(function(b){ b.classList.remove('dlr-mini-active'); });
          btn.classList.add('dlr-mini-active');
          if (label) label.textContent = LABELS[key] || key.toUpperCase();
          document.querySelectorAll('#liveChatAside .dlr-side-panel').forEach(function(p){
            p.classList.toggle('active', p.dataset.panel === key);
          });
        });
      });

      // Teleport #predictWidget từ article cũ → panel Dự đoán
      function teleportPredict(){
        var w = document.getElementById('predictWidget');
        var slot = document.getElementById('dlrPredictSlot');
        if (!w || !slot) return;
        if (w.parentNode === slot) return; // đã teleport rồi
        slot.innerHTML = ''; // bỏ placeholder "Đang tải..."
        slot.appendChild(w);
        // Compact lại padding/margin cho fit panel hẹp
        w.style.marginTop = '0';
        w.style.maxWidth = '100%';
      }
      if (document.readyState !== 'loading') teleportPredict();
      else document.addEventListener('DOMContentLoaded', teleportPredict);
    })();
    </script>
  </aside>
</article>
</div>
<!-- ════ END DESKTOP LAYOUT ════ -->

<script src="/static/js/chat-v2.js?v=8c-chat-sys-class"></script>
<script>
  // Flag để chat-v2 + gift-panel biết phòng có đang live thật không
  window.__x66HasObs = <%= hasObs ? 'true' : 'false' %>;
  // ─── Init chat panel theo viewport hiện tại ───
  // Desktop ≥768px → init #chatBody (aside).
  // Mobile  <768px → init #mobileChatBody (đã được init trong partial mobile khi load).
  // KHÔNG init cả 2 cùng lúc để tránh duplicate polling + tốn bandwidth.
  (function initChatByViewport(){
    var isDesktop = window.matchMedia('(min-width: 768px)').matches;
    if (isDesktop && document.getElementById('chatBody')) {
      try { startChat('chatBody', { isLive: window.__x66HasObs }); } catch(e){}
    }
    // Mobile: partial tw-live-mobile-room.ejs đã tự gọi startChat('mobileChatBody', ...)
  })();
</script>

