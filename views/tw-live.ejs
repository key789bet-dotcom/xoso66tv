    <script>
    function adjPredScore(id, delta) {
      var el = document.getElementById(id);
      if (!el) return;
      var v = (parseInt(el.value, 10) || 0) + delta;
      if (v < 0) v = 0;
      if (v > 20) v = 20;
      el.value = v;
      el.dispatchEvent(new Event('input', { bubbles: true }));
    }
    </script>
    <script>
    (function(){
      var form = document.getElementById('predictForm');
      if (!form) return;
      var btn = document.getElementById('predictBtn');
      var res = document.getElementById('predictResult');
      var matchId = form.dataset.matchId;
      var matchTime = form.dataset.matchTime;

      // Odds lock từ server
      var oddsTai    = parseFloat(form.dataset.oddsTai) || null;
      var oddsXiu    = parseFloat(form.dataset.oddsXiu) || null;
      var oddsAhHome = parseFloat(form.dataset.oddsAhHome) || null;
      var oddsAhAway = parseFloat(form.dataset.oddsAhAway) || null;

      var stakeInput = document.getElementById('predictStake');
      var potential  = document.getElementById('potentialWin');

      // ═══ Stake chips ═══
      document.querySelectorAll('.stake-chip').forEach(function(chip){
        chip.addEventListener('click', function(){
          var v = parseInt(chip.dataset.stake, 10);
          if (stakeInput) { stakeInput.value = v; stakeInput.dispatchEvent(new Event('input')); }
          document.querySelectorAll('.stake-chip').forEach(function(c){ c.classList.remove('active'); });
          chip.classList.add('active');
        });
      });

      // ═══ Calc tiềm năng thắng ═══
      function calcWin() {
        if (!potential) return;
        var stake = parseInt(stakeInput && stakeInput.value, 10) || 0;
        if (stake < 10) { potential.innerHTML = 'Tiềm năng thắng: <span class="text-emerald-300 font-bold">— X COIN</span>'; return; }
        var pickOU = (form.querySelector('input[name="pickOU"]:checked') || {}).value;
        var pickAH = (form.querySelector('input[name="pickAH"]:checked') || {}).value;
        var totalWin = 0;
        var bothPicks = (pickOU && pickAH);
        var perPick = bothPicks ? Math.floor(stake / 2) : stake;
        if (pickOU) {
          var o = pickOU === 'tai' ? oddsTai : oddsXiu;
          if (o) totalWin += Math.round(perPick * o);
        }
        if (pickAH) {
          var o2 = pickAH === 'home' ? oddsAhHome : oddsAhAway;
          if (o2) totalWin += Math.round(perPick * o2);
        }
        if (bothPicks) totalWin = Math.round(totalWin * 1.1);  // parlay bonus 10%
        if (totalWin === 0 && (pickOU || pickAH)) {
          potential.innerHTML = '<span class="text-orange-300">⚠️ Chưa có odds — thắng cố định 50 X COIN/kèo</span>';
        } else if (totalWin > 0) {
          var profit = totalWin - stake;
          potential.innerHTML = 'Tiềm năng thắng: <span class="text-emerald-300 font-black">' + totalWin + ' X COIN</span> <span class="text-white/40">(+' + profit + ')</span>';
        } else {
          potential.innerHTML = 'Tiềm năng thắng: <span class="text-white/50">chọn kèo trước</span>';
        }
      }
      form.addEventListener('change', calcWin);
      if (stakeInput) stakeInput.addEventListener('input', calcWin);
      calcWin();

      // ═══ Load existing prediction ═══
      fetch('/api/predict/my/' + encodeURIComponent(matchId), { credentials: 'same-origin' })
        .then(function(r){ return r.json(); })
        .then(function(j){
          if (j.ok && j.prediction) {
            var p = j.prediction;
            if (p.pickOU) { var r1 = form.querySelector('input[name="pickOU"][value="' + p.pickOU + '"]'); if (r1) r1.checked = true; }
            if (p.pickAH) { var r2 = form.querySelector('input[name="pickAH"][value="' + p.pickAH + '"]'); if (r2) r2.checked = true; }
            if (stakeInput && p.stake) stakeInput.value = p.stake;
            res.className = 'mt-2 text-center text-[11px] text-emerald-300 font-bold';
            var rewardMsg = p.settled
              ? (p.reward > 0 ? ' · 🏆 Thắng +' + p.reward + ' X COIN' : ' · ❌ Thua ' + (p.stake || 0) + ' X COIN')
              : ' (chờ kết quả · cược ' + (p.stake || 0) + ')';
            res.textContent = '✅ Đã đặt cược' + rewardMsg;
            res.classList.remove('hidden');
            if (p.settled) btn.disabled = true;
            else btn.querySelector('span:last-child').textContent = 'Cập nhật cược';
            calcWin();
          }
        })
        .catch(function(){});

      // ═══ Submit ═══
      form.addEventListener('submit', function(e){
        e.preventDefault();
        var pickOU = (form.querySelector('input[name="pickOU"]:checked') || {}).value;
        var pickAH = (form.querySelector('input[name="pickAH"]:checked') || {}).value;
        if (!pickOU && !pickAH) {
          res.className = 'mt-2 text-center text-[11px] text-live font-bold';
          res.textContent = '⚠️ Chọn ít nhất 1 kèo (Tài/Xỉu hoặc Kèo chấp)';
          res.classList.remove('hidden');
          return;
        }
        var stake = parseInt(stakeInput && stakeInput.value, 10) || 50;
        btn.disabled = true;
        var btnText = btn.querySelector('span:last-child');
        var origText = btnText.textContent;
        btnText.textContent = 'Đang gửi...';

        var data = {
          matchId: matchId,
          home: <%- JSON.stringify(match.home) %>,
          away: <%- JSON.stringify(match.away) %>,
          league: <%- JSON.stringify(match.league || '') %>,
          pickOU: pickOU || null,
          pickAH: pickAH || null,
          stake: stake,
          oddsOU: pickOU === 'tai' ? oddsTai : (pickOU === 'xiu' ? oddsXiu : null),
          oddsAH: pickAH === 'home' ? oddsAhHome : (pickAH === 'away' ? oddsAhAway : null),
          matchTime: matchTime ? +matchTime : null
        };
        fetch('/api/predict', {
          method: 'POST',
          headers: {'Content-Type':'application/json'},
          credentials: 'same-origin',
          body: JSON.stringify(data)
        })
        .then(function(r){ return r.json(); })
        .then(function(j){
          btn.disabled = false;
          res.className = 'mt-2 text-center text-[11px] font-bold ' + (j.ok ? 'text-emerald-300' : 'text-live');
          res.textContent = j.ok ? ('✅ ' + j.message) : ('❌ ' + (j.error || 'Lỗi'));
          res.classList.remove('hidden');
          btnText.textContent = j.ok ? 'Cập nhật cược' : origText;
          if (j.error && j.error.indexOf('đăng nhập') !== -1) {
            setTimeout(function(){ window.location.href = '/dang-nhap?redirect=' + encodeURIComponent(location.pathname); }, 1500);
          }
        })
        .catch(function(){
          btn.disabled = false; btnText.textContent = origText;
          res.className = 'mt-2 text-center text-[11px] text-live font-bold';
          res.textContent = '❌ Lỗi kết nối';
          res.classList.remove('hidden');
        });
      });
    })();
    </script>
