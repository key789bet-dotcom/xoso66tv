<%
var _matchName = match.home + ' vs ' + match.away;
var _scoreStr = match.score ? (' '+match.score[0]+'-'+match.score[1]) : '';
seo = {
  title: 'Xem Trực Tiếp '+_matchName + _scoreStr + ' '+match.league+' | XOSO66 TV',
  description: 'Xem trực tiếp bóng đá '+_matchName+' - '+match.league+(match.venue?' tại '+match.venue:'')+' ngày '+match.date+' Full HD miễn phí tại XOSO66 TV (xổ số 66). BLV tiếng Việt, không quảng cáo.',
  keywords: 'xem trực tiếp '+_matchName+', '+match.home+' vs '+match.away+', '+match.league+', xoso66, xổ số 66, xem trực tiếp bóng đá',
  canonical: '/live/'+(match.slug||match.id),
  ogType: 'video.other',
  breadcrumb: [
    { name:match.sport==='Soccer'?'Bóng đá':match.sport==='Basketball'?'Bóng rổ':match.sport==='Tennis'?'Tennis':match.sport, url:'/the-thao/'+(match.sport==='Soccer'?'bong-da':match.sport==='Basketball'?'bong-ro':'tennis') },
    { name:_matchName, url:'/live/'+(match.slug||match.id) }
  ]
};
// SportsEvent schema cho Rich Snippet trên Google Search
var _matchStart = match.matchTs ? new Date(match.matchTs).toISOString() : new Date().toISOString();
var _matchStatus = match.status === 'live' ? 'EventInProgress' : (match.status === 'finished' ? 'EventCompleted' : 'EventScheduled');
%>
<%- include('partials/tw-layout-start') %>

<!-- ═══ JSON-LD SportsEvent + BroadcastEvent schema (Rich Snippet) ═══ -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "SportsEvent",
  "name": "<%= _matchName %> - <%= match.league %>",
  "description": "Xem trực tiếp <%= _matchName %> tại <%= match.league %> ngày <%= match.date %> Full HD miễn phí tại XOSO66 TV.",
  "startDate": "<%= _matchStart %>",
  "eventStatus": "https://schema.org/<%= _matchStatus %>",
  "eventAttendanceMode": "https://schema.org/OnlineEventAttendanceMode",
  "location": {
    "@type": "VirtualLocation",
    "url": "https://xoso66tv.com/live/<%= match.slug || match.id %>"
  },
  "competitor": [
    {
      "@type": "SportsTeam",
      "name": "<%= match.home %>"<% if (match.homeBadge) { %>,
      "logo": "<%= match.homeBadge %>"<% } %>
    },
    {
      "@type": "SportsTeam",
      "name": "<%= match.away %>"<% if (match.awayBadge) { %>,
      "logo": "<%= match.awayBadge %>"<% } %>
    }
  ],
  "sport": "<%= match.sport === 'Soccer' ? 'Soccer' : match.sport %>",
  "organizer": {
    "@type": "Organization",
    "name": "<%= match.league %>"
  },
  "broadcastOfEvent": {
    "@type": "BroadcastEvent",
    "name": "Trực tiếp <%= _matchName %>",
    "isLiveBroadcast": <%= match.status === 'live' ? 'true' : 'false' %>,
    "videoFormat": "HD",
    "inLanguage": "vi-VN",
    "publishedOn": {
      "@type": "BroadcastService",
      "name": "XOSO66 TV",
      "broadcastDisplayName": "XOSO66 TV - Xem Trực Tiếp Bóng Đá",
      "url": "https://xoso66tv.com/"
    }
  },
  "offers": {
    "@type": "Offer",
    "url": "https://xoso66tv.com/live/<%= match.slug || match.id %>",
    "price": "0",
    "priceCurrency": "VND",
    "availability": "https://schema.org/InStock",
    "validFrom": "<%= _matchStart %>"
  }
}
</script>

<%- include('partials/tw-skin-overlay') %>
<%- include('partials/tw-breadcrumb') %>

<article class="grid lg:grid-cols-[1fr_340px] gap-4">
  <div>
    <div id="livePlayer" class="bg-black aspect-video rounded-xl relative overflow-hidden grid place-items-center">
      <% var _hasBlvStream = (typeof blvStreamKey !== 'undefined' && blvStreamKey); %>
      <% if (_hasBlvStream) { %>
        <!-- 🆕 BLV CUSTOM STREAM: FLV player thực với key từ schedule -->
        <%- include('partials/tw-live-video-player', { streamKey: blvStreamKey }) %>
        <!-- Placeholder visible khi player chưa load -->
        <div class="text-center text-white p-5 absolute inset-0 grid place-items-center pointer-events-none" id="playerPh" data-title="<%= _matchName %>">
          <div>
            <h2 class="font-extrabold text-lg"><%= match.home %> vs <%= match.away %></h2>
            <div class="text-muted text-[13px] mt-1.5"><%= match.league %></div>
          </div>
        </div>
      <% } else if (typeof hasObs !== 'undefined' && hasObs) { %>
        <%
          // 🏆 Ảnh nền giải đấu (admin set) cho placeholder "click để play"
          var _phBgs = (typeof leagueBgs !== 'undefined' && leagueBgs) ? leagueBgs : {};
          function _phNormLg(s){ return String(s||'').toLowerCase().replace(/\./g,'').replace(/\s+/g,' ').trim(); }
          var _phBg = '';
          if (match.league) {
            if (_phBgs[match.league]) _phBg = _phBgs[match.league];
            else {
              var _pht = _phNormLg(match.league);
              for (var _phk in _phBgs) {
                if (_phk === '__default__') continue;
                if (_phNormLg(_phk) === _pht) { _phBg = _phBgs[_phk]; break; }
              }
            }
          }
          if (!_phBg && _phBgs['__default__']) _phBg = _phBgs['__default__'];
        %>
        <% if (_phBg) { %>
          <img src="<%= _phBg %>" alt="" class="absolute inset-0 w-full h-full object-cover opacity-50 pointer-events-none" onerror="this.style.display='none'">
          <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/45 to-black/55 pointer-events-none"></div>
        <% } %>
        <!-- BLV da len song (legacy click-to-play) -->
        <div class="text-center text-white p-5 relative z-[2]" id="playerPh" data-title="<%= _matchName %>">
          <div class="w-20 h-20 rounded-full bg-gradient-to-br from-pri to-live grid place-items-center mx-auto mb-3.5 text-3xl cursor-pointer shadow-live hover:scale-110 transition-transform" onclick="startStream()" role="button" aria-label="Phát stream">&#9654;</div>
          <h2 class="font-extrabold text-lg"><%= match.home %> vs <%= match.away %></h2>
          <div class="text-muted text-[13px] mt-1.5"><%= match.league %> &middot; <time datetime="<%= match.date %>"><%= match.date %></time> <%= match.time %></div>
          <div class="mt-3.5 text-pri-light text-xs">Click &#9654; để vào phòng xem HD</div>
        </div>
      <% } else { %>
        <%
          // 🏆 Ảnh nền giải đấu (admin set) cho block "BLV chưa lên sóng"
          var _offBgs = (typeof leagueBgs !== 'undefined' && leagueBgs) ? leagueBgs : {};
          function _offNormLg(s){ return String(s||'').toLowerCase().replace(/\./g,'').replace(/\s+/g,' ').trim(); }
          var _offBg = '';
          if (match.league) {
            if (_offBgs[match.league]) _offBg = _offBgs[match.league];
            else {
              var _offt = _offNormLg(match.league);
              for (var _offk in _offBgs) {
                if (_offk === '__default__') continue;
                if (_offNormLg(_offk) === _offt) { _offBg = _offBgs[_offk]; break; }
              }
            }
          }
          if (!_offBg && _offBgs['__default__']) _offBg = _offBgs['__default__'];
        %>
        <% if (_offBg) { %>
          <img src="<%= _offBg %>" alt="" class="absolute inset-0 w-full h-full object-cover opacity-45 pointer-events-none" onerror="this.style.display='none'">
          <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/55 to-black/65 pointer-events-none"></div>
        <% } %>
        <!-- BLV chua len song -->
        <div class="text-center text-white p-5 max-w-md relative z-[2]">
          <div class="text-7xl mb-3 opacity-70 drop-shadow-lg">📡</div>
          <h2 class="font-extrabold text-xl mb-2 drop-shadow-lg"><%= match.home %> vs <%= match.away %></h2>
          <div class="text-gray-300 text-[13px] mb-4 drop-shadow"><%= match.league %> &middot; <%= match.date %> <%= match.time %></div>
          <div class="bg-live/25 backdrop-blur border border-live/50 rounded-lg p-4 inline-block shadow-xl">
            <div class="text-live font-extrabold text-base mb-1">🔴 BLV chưa lên sóng</div>
            <div class="text-gray-200 text-xs mb-2.5">Trận này đang chờ BLV kết nối OBS<br>Vui lòng quay lại sau hoặc xem trận khác</div>
            <a href="/lich-phat-song" class="inline-block bg-pri hover:bg-pri-dark text-white text-xs font-bold px-4 py-2 rounded">→ Xem lịch phát sóng</a>
          </div>
        </div>
      <% } %>
    </div>

    <div id="liveScoreRow" class="bg-bg-card border border-line rounded-xl p-3.5 mt-3 grid grid-cols-[1fr_auto_1fr_auto] gap-3.5 items-center">
      <div class="flex items-center gap-2.5 font-bold">
        <% if (match.homeBadge) { %><img src="<%= match.homeBadge %>" alt="<%= match.home %>" class="w-8 h-8 bg-white rounded-full p-0.5" onerror="this.style.display='none'"><% } %>
        <span><%= match.home %></span>
      </div>
      <div class="text-2xl font-black text-gold px-3.5 border-l border-r border-line"><% if (match.score) { %><%= match.score[0] %> : <%= match.score[1] %><% } else { %>-- : --<% } %></div>
      <div class="flex items-center gap-2.5 font-bold justify-end">
        <span><%= match.away %></span>
        <% if (match.awayBadge) { %><img src="<%= match.awayBadge %>" alt="<%= match.away %>" class="w-8 h-8 bg-white rounded-full p-0.5" onerror="this.style.display='none'"><% } %>
      </div>
      <div class="flex gap-2">
        <a href="<%= partner.sportbet %>" target="_blank" rel="noopener" class="px-3.5 py-2 rounded-md bg-gradient-to-br from-live to-red-700 text-white text-xs font-bold">&#128176; Đặt cược</a>
        <a href="#chatBody" class="px-3.5 py-2 rounded-md bg-pri text-white text-xs font-bold hidden md:inline">Chat</a>
      </div>
    </div>

    <%
      // BLV list THẬT: từ data.schedules approved + matchId trùng + đang trong khung giờ
      var _liveBlvs = (typeof liveBlvs !== 'undefined' && Array.isArray(liveBlvs)) ? liveBlvs : [];
    %>
    <% if (_liveBlvs.length > 0) { %>
    <div class="flex gap-2 mt-3 flex-wrap" role="tablist" aria-label="BLV">
      <% _liveBlvs.forEach(function(b, i){ %>
        <div class="flex items-center gap-2 bg-bg-card border border-line px-2.5 py-1.5 rounded-full text-xs font-semibold cursor-pointer transition-colors <%= i===0 ? 'border-pri text-pri-light' : 'hover:border-pri hover:text-pri-light' %>" role="tab" onclick="document.querySelectorAll('[role=tab]').forEach(function(x){x.className=x.className.replace('border-pri text-pri-light','').trim()});this.classList.add('border-pri','text-pri-light')">
          <% if (b.avatar) { %>
            <img src="<%= b.avatar %>" alt="" class="w-5.5 h-5.5 rounded-full">
          <% } else { %>
            <span class="w-5.5 h-5.5 rounded-full bg-gradient-to-br from-pri to-rose-500 grid place-items-center text-[10px]">🎙️</span>
          <% } %>
          <span><%= b.name %></span>
          <% if (b.isLive) { %><span class="w-1.5 h-1.5 bg-live rounded-full animate-pulse-live"></span><% } %>
        </div>
      <% }); %>
    </div>
    <% } %>

    <!-- ═══ PREDICT WIDGET — Dự đoán tỉ số inline (chỉ hiện khi trận chưa bắt đầu) ═══ -->
    <% if (match.status !== 'live' && match.status !== 'finished' && match.sport === 'Soccer') { %>
    <section class="bg-gradient-to-br from-emerald-900/40 to-emerald-700/20 border border-emerald-500/40 rounded-xl p-4 mt-3.5 relative overflow-hidden">
      <div class="absolute -top-6 -right-6 text-7xl opacity-10">🎯</div>
      <h3 class="text-emerald-300 text-sm font-extrabold mb-2.5 flex items-center gap-1.5">🎯 Dự đoán tỉ số — Nhận X COIN</h3>
      <p class="text-[11px] text-emerald-100/80 mb-3">Đúng chính xác: <strong class="text-yellow-300">100 X COIN</strong> · Đúng kết quả: <strong class="text-yellow-200">10-30 X COIN</strong></p>

      <form id="predictForm" class="flex items-center gap-2 mb-2" data-match-id="<%= match.id %>" data-match-time="<%= match.matchTs || '' %>">
        <div class="flex-1 text-right">
          <div class="text-[11px] text-muted mb-1 truncate"><%= match.home %></div>
          <input type="number" id="predHome" min="0" max="20" value="1" required class="w-16 bg-bg-deep border-2 border-emerald-500/50 text-white text-center text-2xl font-black rounded-lg py-1.5 focus:border-emerald-400 outline-none">
        </div>
        <div class="text-3xl font-black text-emerald-400 px-1">-</div>
        <div class="flex-1 text-left">
          <div class="text-[11px] text-muted mb-1 truncate"><%= match.away %></div>
          <input type="number" id="predAway" min="0" max="20" value="1" required class="w-16 bg-bg-deep border-2 border-emerald-500/50 text-white text-center text-2xl font-black rounded-lg py-1.5 focus:border-emerald-400 outline-none">
        </div>
      </form>
      <button type="submit" form="predictForm" id="predictBtn" class="w-full py-2.5 bg-gradient-to-r from-emerald-500 to-emerald-600 hover:brightness-110 text-white font-extrabold text-[13px] rounded-lg shadow-lg shadow-emerald-500/30 transition-all">
        🎯 DỰ ĐOÁN NGAY
      </button>
      <div id="predictResult" class="mt-2 text-center text-[12px] hidden"></div>
      <div class="mt-3 pt-3 border-t border-emerald-500/30 text-center">
        <a href="/cao-thu" class="text-[11px] text-emerald-300 hover:text-emerald-200 underline">🏆 Xem BXH Cao Thủ Dự Đoán →</a>
      </div>
    </section>
    <script>
    (function(){
      var form = document.getElementById('predictForm');
      if (!form) return;
      var btn = document.getElementById('predictBtn');
      var res = document.getElementById('predictResult');
      var matchId = form.dataset.matchId;
      var matchTime = form.dataset.matchTime;

      // Load existing prediction
      fetch('/api/predict/my/' + encodeURIComponent(matchId), { credentials: 'same-origin' })
        .then(function(r){ return r.json(); })
        .then(function(j){
          if (j.ok && j.prediction) {
            document.getElementById('predHome').value = j.prediction.homeScore;
            document.getElementById('predAway').value = j.prediction.awayScore;
            res.className = 'mt-2 text-center text-[12px] text-emerald-300 font-bold';
            res.textContent = '✅ Đã dự đoán: ' + j.prediction.homeScore + '-' + j.prediction.awayScore + (j.prediction.settled ? ' · +' + j.prediction.reward + ' X COIN' : ' (chờ kết quả)');
            res.classList.remove('hidden');
            if (j.prediction.settled) btn.disabled = true;
            else btn.textContent = '🔄 CẬP NHẬT DỰ ĐOÁN';
          }
        })
        .catch(function(){});

      form.addEventListener('submit', function(e){
        e.preventDefault();
        btn.disabled = true; btn.textContent = 'Đang gửi...';
        var data = {
          matchId: matchId,
          home: <%- JSON.stringify(match.home) %>,
          away: <%- JSON.stringify(match.away) %>,
          league: <%- JSON.stringify(match.league || '') %>,
          homeScore: parseInt(document.getElementById('predHome').value, 10),
          awayScore: parseInt(document.getElementById('predAway').value, 10),
          matchTime: matchTime ? +matchTime : null
        };
        fetch('/api/predict', {
          method: 'POST',
          headers: {'Content-Type':'application/json'},
          credentials: 'same-origin',
          body: JSON.stringify(data)
        })
        .then(function(r){ return r.json(); })
        .then(function(j){
          btn.disabled = false;
          res.className = 'mt-2 text-center text-[12px] font-bold ' + (j.ok ? 'text-emerald-300' : 'text-live');
          res.textContent = j.ok ? ('✅ ' + j.message) : ('❌ ' + (j.error || 'Lỗi'));
          res.classList.remove('hidden');
          btn.textContent = j.ok ? '🔄 CẬP NHẬT DỰ ĐOÁN' : '🎯 THỬ LẠI';
          if (j.error && j.error.indexOf('đăng nhập') !== -1) {
            setTimeout(function(){ window.location.href = '/dang-nhap?redirect=' + encodeURIComponent(location.pathname); }, 1500);
          }
        })
        .catch(function(e){
          btn.disabled = false; btn.textContent = '🎯 DỰ ĐOÁN NGAY';
          res.className = 'mt-2 text-center text-[12px] text-live font-bold';
          res.textContent = '❌ Lỗi kết nối';
          res.classList.remove('hidden');
        });
      });
    })();
    </script>
    <% } %>

    <aside class="bg-bg-card border border-line rounded-xl p-4 mt-3.5">
      <h3 class="text-pri-light text-sm font-bold mb-2.5 flex items-center gap-1.5">&#128203; Thông tin trận đấu</h3>
      <div class="space-y-1.5 text-[13px]">
        <div class="flex gap-2.5 text-muted py-1 border-b border-dashed border-line"><b class="text-white min-w-[120px]">&#127942; Giải đấu:</b> <%= match.league %></div>
        <div class="flex gap-2.5 text-muted py-1 border-b border-dashed border-line"><b class="text-white min-w-[120px]">&#9917; Môn:</b> <%= match.sport %></div>
        <div class="flex gap-2.5 text-muted py-1 border-b border-dashed border-line"><b class="text-white min-w-[120px]">&#9200; Thời gian:</b> <%= match.date %> lúc <%= match.time %></div>
        <% if (match.venue) { %><div class="flex gap-2.5 text-muted py-1 border-b border-dashed border-line"><b class="text-white min-w-[120px]">&#127967; Sân:</b> <%= match.venue %></div><% } %>
        <% if (match.round) { %><div class="flex gap-2.5 text-muted py-1 border-b border-dashed border-line"><b class="text-white min-w-[120px]">&#128290; Vòng:</b> <%= match.round %></div><% } %>
        <% if (match.season) { %><div class="flex gap-2.5 text-muted py-1 border-b border-dashed border-line"><b class="text-white min-w-[120px]">&#128197; Mùa giải:</b> <%= match.season %></div><% } %>
        <div class="flex gap-2.5 text-muted py-1"><b class="text-white min-w-[120px]">&#128250; Chất lượng:</b> Full HD 1080p, bình luận tiếng Việt</div>
      </div>
    </aside>

    <% if (others && others.length) { %>
    <section class="mt-5">
      <div class="flex items-center gap-2.5 mb-3.5"><span class="w-1 h-5 bg-pri rounded-sm"></span><h2 class="text-lg font-extrabold text-white">&#128308; Phòng khác đang LIVE</h2></div>
      <div class="grid gap-2 md:gap-3.5 grid-cols-2 md:grid-cols-[repeat(auto-fill,minmax(220px,1fr))]"><%- include('partials/tw-stream-card', { list: others }) %></div>
    </section>
    <% } %>
  </div>

  <aside class="bg-bg-card border border-line rounded-xl flex flex-col overflow-hidden mb-3 lg:mb-0" aria-label="Chat" id="liveChatAside"
         style="height:360px;max-height:55vh;">
    <style>
      @media (min-width: 1024px) {
        #liveChatAside { height: 640px !important; max-height: none !important; }
      }
    </style>
    <%
      // 🎨 Render 1 chat tab: ảnh nếu admin đã upload, fallback emoji+text
      var _cti = (typeof tabIcons !== 'undefined' && tabIcons) ? tabIcons : {};
      function _renderChatTab(key, emoji, label, isActive) {
        var base = 'chat-tab flex-1 flex items-center justify-center border-b-2 transition-all';
        var active = isActive
          ? 'bg-bg-card text-pri-light font-bold border-pri'
          : 'bg-transparent text-muted hover:text-white font-bold border-transparent';
        if (_cti[key]) {
          // Ảnh chiếm nguyên tab, height ~40px (matched py-3)
          return '<button class="' + base + ' ' + active + ' p-1 h-10" onclick="switchChatTab(this)" aria-label="' + label + '">' +
                   '<img src="' + _cti[key] + '" alt="' + label + '" class="max-h-full w-auto object-contain">' +
                 '</button>';
        }
        return '<button class="' + base + ' ' + active + ' py-3 text-xs" onclick="switchChatTab(this)">' + emoji + ' ' + label + '</button>';
      }
    %>
    <div class="flex border-b border-line bg-bg-soft" role="tablist">
      <%- _renderChatTab('chat_room',     '&#128172;', 'Chat phòng', true)  %>
      <%- _renderChatTab('chat_telegram', '&#128238;', 'Telegram',   false) %>
      <%- _renderChatTab('chat_facebook', '&#128276;', 'Facebook',   false) %>
    </div>

    <!-- 🎀 3 BANNER GIF (admin upload) -->
    <% var _cb = (typeof chatBanners !== 'undefined' && Array.isArray(chatBanners)) ? chatBanners : []; %>
    <% if (_cb.length > 0) { %>
    <div class="grid gap-1.5 p-2 bg-bg-soft border-b border-line" style="grid-template-columns: repeat(<%= _cb.length %>, 1fr);">
      <% _cb.forEach(function(bn){ %>
        <a href="<%= bn.link || '#' %>" target="_blank" rel="noopener" class="block rounded-lg overflow-hidden border border-line hover:border-pri transition-colors aspect-[4/3] bg-bg-deep">
          <img src="<%= bn.image %>" alt="<%= bn.label %>" class="w-full h-full object-cover" loading="lazy">
        </a>
      <% }); %></div>
    <% } %>
    <div class="px-3 py-2 bg-bg-soft border-b border-line text-xs text-muted flex items-center justify-between">
      <span class="text-emerald-500 flex items-center gap-1"><span class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse-live"></span>2.487 online</span>
      <span>Bình luận: <b class="text-pri-light"><%= (Math.random()*5000|0)+1000 %></b></span>
    </div>
    <div class="flex-1 overflow-y-auto py-1 scrollbar-thin" id="chatBody"></div>
    <% if (_cti.cta_register) { %>
      <a href="<%= partner.register %>" target="_blank" rel="noopener" class="block mx-2 mt-2 mb-1 rounded-lg overflow-hidden hover:opacity-90 transition-opacity">
        <img src="<%= _cti.cta_register %>" alt="Đăng ký nhận 100% tiền thưởng" class="w-full h-auto object-cover">
      </a>
    <% } else { %>
      <div class="mx-2 mt-2 mb-1 p-2 bg-gradient-to-r from-purple to-pink rounded-lg text-white text-[11px] font-bold text-center cursor-pointer" onclick="window.open('<%= partner.register %>','_blank')">&#127873; ĐĂNG KÝ NHẬN 100% TIỀN THƯỞNG</div>
    <% } %>
    <div class="px-2.5 pt-1 text-[10px] text-dim italic flex items-center gap-1" id="chatHint">&#128274; Khách giới hạn 1 tin mỗi 5 phút</div>
    <div class="flex gap-1.5 p-2.5 border-t border-line bg-bg-soft">
      <input id="chatInput" maxlength="200" class="flex-1 bg-bg-deep border border-line text-gray-100 px-3 py-2 rounded-md outline-none text-[13px] focus:border-pri disabled:opacity-50 disabled:cursor-not-allowed" placeholder="Gõ tin nhắn..." onkeydown="if(event.key==='Enter')sendChat('chatInput','chatBody')">
      <button id="chatBtn" class="bg-gradient-to-br from-pri to-live text-white px-4 rounded-md font-bold text-xs min-w-[64px] tabular-nums" onclick="sendChat('chatInput','chatBody')">Gửi</button>
    </div>
  </aside>
</article>

<script src="/static/js/chat-v2.js"></script>
<script>
  // Flag để chat-v2 + gift-panel biết phòng có đang live thật không
  window.__x66HasObs = <%= hasObs ? 'true' : 'false' %>;
  startChat('chatBody', { isLive: window.__x66HasObs });

  // 📱 MOBILE: thứ tự = Video → Score row → Chat → Info → Phòng khác
  (function moveChatMobile(){
    var mql = window.matchMedia('(max-width: 1023px)');
    var chat = document.getElementById('liveChatAside');
    var scoreRow = document.getElementById('liveScoreRow');
    if (!chat || !scoreRow) return;
    function apply(){
      if (mql.matches) {
        // Mobile: chat NGAY SAU score row (video → score → chat → info)
        if (scoreRow.nextElementSibling !== chat) {
          scoreRow.parentNode.insertBefore(chat, scoreRow.nextElementSibling);
        }
      } else {
        // Desktop: chat trở về <article> (right column)
        var article = document.querySelector('article.grid');
        if (article && chat.parentNode !== article) {
          article.appendChild(chat);
        }
      }
    }
    apply();
    if (mql.addEventListener) mql.addEventListener('change', apply);
    else mql.addListener(apply); // Safari legacy
  })();
</script>

