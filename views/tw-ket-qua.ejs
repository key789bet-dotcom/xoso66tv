</style>

<script>
// ════════ Lazy fetch HT/Corners/Cards khi row vào viewport ════════
(function(){
  if (!('IntersectionObserver' in window) || !window.fetch) return;
  var rows = document.querySelectorAll('.kq-row[data-mid]');
  if (!rows.length) return;

  function pairHtml(htH, htA, ftH, ftA, accentClass){
    var ht = (htH != null && htA != null) ? (htH + '-' + htA) : '0-0';
    var ft = (ftH != null && ftA != null) ? (ftH + '-' + ftA) : '0-0';
    var ac = accentClass || '';
    return '<span class="kq-pair-grey">'+ht+'</span><span class="kq-pair-gap">&nbsp;&nbsp;</span><span class="'+ac+'">'+ft+'</span>';
  }
  function fillRow(row, data){
    if (!data || !data.ok) return;
    // HT score
    var htCell = row.querySelector('.kq-col-ht');
    if (htCell && data.ht && data.ht[0] != null && data.ht[1] != null) {
      htCell.innerHTML = '<span class="kq-ht-val">' + data.ht[0] + ' : ' + data.ht[1] + '</span>';
    }
    // Corners (chỉ FT vì API không tách HT)
    var corCell = row.querySelector('.kq-col-corners');
    if (corCell && data.corners && (data.corners.h != null || data.corners.a != null)) {
      var ch = data.corners.h != null ? data.corners.h : 0;
      var ca = data.corners.a != null ? data.corners.a : 0;
      corCell.innerHTML = '<span class="kq-pair-grey">-</span><span class="kq-pair-gap">&nbsp;&nbsp;</span><span class="kq-pair-green">'+ch+'-'+ca+'</span>';
    }
    // Yellow cards (chỉ FT)
    var crdCell = row.querySelector('.kq-col-cards');
    if (crdCell && data.yellow && (data.yellow.h != null || data.yellow.a != null)) {
      var yh = data.yellow.h != null ? data.yellow.h : 0;
      var ya = data.yellow.a != null ? data.yellow.a : 0;
      var rh = (data.red && data.red.h) || 0;
      var ra = (data.red && data.red.a) || 0;
      var redBadge = (rh + ra > 0) ? ' <span class="kq-red-dot" title="Thẻ đỏ '+rh+'-'+ra+'">●</span>' : '';
      crdCell.innerHTML = '<span class="kq-pair-grey">-</span><span class="kq-pair-gap">&nbsp;&nbsp;</span><span class="kq-pair-yellow">'+yh+'-'+ya+'</span>' + redBadge;
    }
  }
  // Throttle: max 3 concurrent fetches
  var queue = [], active = 0, seen = new Set();
  function next(){
    while (active < 3 && queue.length > 0) {
      var item = queue.shift();
      active++;
      fetch('/api/match-stats/' + item.mid, { credentials: 'same-origin' })
        .then(function(r){ return r.json(); })
        .then(function(d){ fillRow(item.row, d); })
        .catch(function(){})
        .then(function(){ active--; next(); });
    }
  }
  var io = new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if (!e.isIntersecting) return;
      var row = e.target;
      var mid = row.getAttribute('data-mid');
      if (!mid || seen.has(mid)) return;
      seen.add(mid);
      io.unobserve(row);
      queue.push({ mid: mid, row: row });
      next();
    });
  }, { rootMargin: '300px 0px' });
  rows.forEach(function(r){ io.observe(r); });
})();
</script>

<script>
(function(){
  // League filter chips
  var chips = document.querySelectorAll('#kqLeagueChips .kq-lg-chip');
  var groups = document.querySelectorAll('.kq-lg-group');
  chips.forEach(function(c){
    c.addEventListener('click', function(){
      chips.forEach(function(x){ x.classList.remove('is-active'); });
      c.classList.add('is-active');
      var lg = c.getAttribute('data-lg');
      groups.forEach(function(g){
        if (lg === '__all__' || g.getAttribute('data-lg') === lg) g.style.display = '';
        else g.style.display = 'none';
      });
    });
  });
})();
</script>

