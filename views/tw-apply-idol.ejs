<%
seo = {
  title: 'Đăng ký làm Idol Live - ' + brand.name,
  description: 'Trở thành idol live trên ' + brand.domain + '. Kiếm thu nhập từ X COIN, follower, quà tặng.',
  canonical: '/dang-ky-idol',
  noindex: true
};
%>
<%- include('partials/tw-layout-start') %>

<section class="max-w-2xl mx-auto mb-8 px-3">
  <!-- Hero header -->
  <div class="relative bg-gradient-to-br from-pink-600 via-purple-600 to-fuchsia-700 rounded-2xl p-6 mb-5 overflow-hidden">
    <div class="absolute -top-10 -right-10 text-9xl opacity-10">💃</div>
    <div class="absolute -bottom-10 -left-10 text-9xl opacity-10">🎀</div>
    <h1 class="text-3xl font-black text-white mb-2">🌟 Đăng ký làm Idol</h1>
    <p class="text-pink-100 text-sm">Trở thành idol live, kiếm thu nhập từ <b>X COIN</b>, quà tặng và follower. <b>Miễn phí</b>, không phí đăng ký.</p>
    <div class="mt-4 grid grid-cols-3 gap-2 text-center">
      <div class="bg-white/15 backdrop-blur rounded-lg p-2">
        <div class="text-2xl">💰</div>
        <div class="text-[10px] text-white font-bold mt-1">Thu nhập từ quà</div>
      </div>
      <div class="bg-white/15 backdrop-blur rounded-lg p-2">
        <div class="text-2xl">👥</div>
        <div class="text-[10px] text-white font-bold mt-1">Cộng đồng fan</div>
      </div>
      <div class="bg-white/15 backdrop-blur rounded-lg p-2">
        <div class="text-2xl">📱</div>
        <div class="text-[10px] text-white font-bold mt-1">Live mobile/web</div>
      </div>
    </div>
  </div>

  <!-- Status đơn nếu đã apply -->
  <div id="myStatusBox" class="hidden mb-4"></div>

  <!-- Form -->
  <form id="applyIdolForm" class="bg-bg-card border border-line rounded-2xl p-5 shadow-2xl space-y-4">
    <h2 class="text-white font-extrabold text-lg mb-1">📝 Thông tin đăng ký</h2>
    <p class="text-muted text-xs mb-3">User đăng nhập: <code class="text-pri-light"><%= user.username %></code></p>

    <!-- Tên nghệ danh -->
    <div>
      <label class="text-[11px] text-muted uppercase font-bold block mb-1.5">Tên nghệ danh <span class="text-live">*</span></label>
      <input name="stageName" type="text" required minlength="2" maxlength="30"
             class="w-full bg-bg-deep border border-line text-white px-3 py-2.5 rounded-lg outline-none focus:border-pri"
             placeholder="VD: Linh Trang, Mai Anh..."/>
    </div>

    <!-- Tuổi + chiều cao + cân nặng -->
    <div class="grid grid-cols-3 gap-2">
      <div>
        <label class="text-[11px] text-muted uppercase font-bold block mb-1.5">Tuổi <span class="text-live">*</span></label>
        <input name="age" type="number" required min="18" max="50" class="w-full bg-bg-deep border border-line text-white px-3 py-2.5 rounded-lg outline-none focus:border-pri" placeholder="22"/>
      </div>
      <div>
        <label class="text-[11px] text-muted uppercase font-bold block mb-1.5">Cao (cm)</label>
        <input name="height" type="number" min="140" max="200" class="w-full bg-bg-deep border border-line text-white px-3 py-2.5 rounded-lg outline-none focus:border-pri" placeholder="165"/>
      </div>
      <div>
        <label class="text-[11px] text-muted uppercase font-bold block mb-1.5">Nặng (kg)</label>
        <input name="weight" type="number" min="35" max="100" class="w-full bg-bg-deep border border-line text-white px-3 py-2.5 rounded-lg outline-none focus:border-pri" placeholder="48"/>
      </div>
    </div>

    <!-- Thành phố -->
    <div>
      <label class="text-[11px] text-muted uppercase font-bold block mb-1.5">Thành phố <span class="text-live">*</span></label>
      <select name="city" required class="w-full bg-bg-deep border border-line text-white px-3 py-2.5 rounded-lg outline-none focus:border-pri">
        <option value="">-- Chọn thành phố --</option>
        <option>Hà Nội</option>
        <option>TP. Hồ Chí Minh</option>
        <option>Đà Nẵng</option>
        <option>Hải Phòng</option>
        <option>Cần Thơ</option>
        <option>Nha Trang</option>
        <option>Huế</option>
        <option>Đà Lạt</option>
        <option>Quy Nhơn</option>
        <option>Vũng Tàu</option>
        <option>Khác</option>
      </select>
    </div>

    <!-- Nghề nghiệp -->
    <div>
      <label class="text-[11px] text-muted uppercase font-bold block mb-1.5">Nghề nghiệp</label>
      <input name="job" type="text" maxlength="60" class="w-full bg-bg-deep border border-line text-white px-3 py-2.5 rounded-lg outline-none focus:border-pri" placeholder="VD: Sinh viên, Model, Tự do..."/>
    </div>

    <!-- Sở thích -->
    <div>
      <label class="text-[11px] text-muted uppercase font-bold block mb-1.5">Sở thích</label>
      <input name="hobby" type="text" maxlength="100" class="w-full bg-bg-deep border border-line text-white px-3 py-2.5 rounded-lg outline-none focus:border-pri" placeholder="VD: Hát, nhảy, du lịch, đọc sách..."/>
    </div>

    <!-- Bio -->
    <div>
      <label class="text-[11px] text-muted uppercase font-bold block mb-1.5">Giới thiệu bản thân <span class="text-live">*</span> (≥20 ký tự)</label>
      <textarea name="bio" required minlength="20" maxlength="500" rows="3" class="w-full bg-bg-deep border border-line text-white px-3 py-2.5 rounded-lg outline-none focus:border-pri resize-none" placeholder="Vd: Cô gái Hà Nội yêu nghệ thuật, mong muốn kết nối với mọi người qua live show..."></textarea>
    </div>

    <!-- Avatar UPLOAD từ máy/điện thoại -->
    <div>
      <label class="text-[11px] text-muted uppercase font-bold block mb-1.5">📸 Ảnh đại diện (tùy chọn)</label>
      <div id="avatarBox" class="border-2 border-dashed border-line rounded-lg p-4 bg-bg-deep hover:border-pri/60 transition-colors">
        <div id="avatarPreview" class="hidden mb-3 text-center">
          <img id="avatarImg" alt="Preview" class="w-28 h-28 mx-auto rounded-full object-cover border-2 border-pri shadow-lg" style="object-fit:cover;">
          <button type="button" id="avatarRemove" class="mt-2 text-xs text-live hover:text-red-400 font-bold">✕ Xóa ảnh</button>
        </div>
        <div id="avatarEmpty" class="text-center">
          <div class="text-3xl mb-1.5 opacity-60">📷</div>
          <p class="text-xs text-muted mb-2">Chụp ảnh bằng điện thoại hoặc chọn từ thư viện</p>
          <div class="flex gap-2 justify-center flex-wrap">
            <label class="cursor-pointer px-3 py-2 bg-pri/20 hover:bg-pri/30 border border-pri/50 text-pri-light text-xs font-bold rounded-lg flex items-center gap-1.5">
              📸 Chụp ảnh
              <input type="file" name="avatarCapture" accept="image/*" capture="user" class="hidden" data-avatar-input>
            </label>
            <label class="cursor-pointer px-3 py-2 bg-bg-card hover:bg-bg-soft border border-line text-white text-xs font-bold rounded-lg flex items-center gap-1.5">
              🖼️ Chọn từ máy
              <input type="file" name="avatarPick" accept="image/*" class="hidden" data-avatar-input>
            </label>
          </div>
          <p class="text-[10px] text-dim mt-2">JPG/PNG/WEBP/GIF/HEIC — tối đa 5MB. Để trống = tự sinh ảnh mặc định</p>
        </div>
        <!-- Hidden field giữ file thật khi submit (gán từ JS) -->
        <input type="file" name="avatarFile" accept="image/*" class="hidden" id="avatarFinal">
      </div>
    </div>

    <!-- Emoji icon -->
    <div>
      <label class="text-[11px] text-muted uppercase font-bold block mb-1.5">Icon đại diện</label>
      <div class="flex gap-2 flex-wrap">
        <% ['👑','💃','🌸','🎀','💖','🌹','🦋','✨','🌟','💎'].forEach(function(e){ %>
          <label class="cursor-pointer">
            <input type="radio" name="emoji" value="<%= e %>" class="hidden peer">
            <span class="w-12 h-12 grid place-items-center bg-bg-deep border-2 border-line peer-checked:border-pri peer-checked:bg-pri/20 rounded-lg text-2xl transition-all"><%= e %></span>
          </label>
        <% }); %>
      </div>
    </div>

    <!-- Điều khoản -->
    <div class="bg-bg-deep border border-pri/30 rounded-lg p-3 text-[12px] text-muted leading-relaxed">
      <h3 class="text-white font-bold mb-1.5 text-sm">📋 Điều khoản idol</h3>
      <ul class="space-y-1 list-disc list-inside">
        <li>Không cởi đồ, không nội dung 18+, không tục tĩu</li>
        <li>Không quảng cáo sản phẩm bất hợp pháp</li>
        <li>Tuân thủ pháp luật Việt Nam khi live stream</li>
        <li>XOSO66 TV giữ % phí 30% trên doanh thu quà tặng (đã trừ ở X COIN)</li>
        <li>Bị ban vĩnh viễn nếu vi phạm 3 lần</li>
      </ul>
    </div>

    <label class="flex items-center gap-2 text-sm text-muted cursor-pointer">
      <input type="checkbox" name="agree" required class="w-4 h-4 accent-pri">
      Tôi đồng ý với điều khoản và xác nhận thông tin chính xác
    </label>

    <button type="submit" id="submitBtn" class="w-full py-3.5 bg-gradient-to-r from-pink-500 via-purple-500 to-fuchsia-600 hover:brightness-110 text-white font-extrabold text-base rounded-xl shadow-lg shadow-pink-500/30 active:scale-95 transition-all">
      🌟 GỬI ĐƠN ĐĂNG KÝ IDOL
    </button>

    <p class="text-center text-[11px] text-muted">
      Admin sẽ duyệt trong 24h · <a href="/dang-ky-blv" class="text-pri-light hover:underline">Muốn làm BLV thể thao? →</a>
    </p>
  </form>
</section>

<div id="toast" class="fixed top-20 right-5 bg-bg-card border border-line border-l-4 border-l-pri px-4 py-3 rounded-lg text-white text-sm font-semibold z-[100] shadow-2xl translate-x-[120%] transition-transform"></div>

<script>
function showToast(msg, kind){
  var t = document.getElementById('toast');
  var col = kind==='success' ? '!border-l-emerald-500' : kind==='error' ? '!border-l-live' : '!border-l-pri';
  t.className = 'fixed top-20 right-5 bg-bg-card border border-line border-l-4 px-4 py-3 rounded-lg text-white text-sm font-semibold z-[100] shadow-2xl translate-x-0 transition-transform ' + col;
  t.textContent = msg;
  setTimeout(function(){ t.className = t.className.replace('translate-x-0','translate-x-[120%]'); }, 4000);
}

// Check existing application
fetch('/api/apply/my-status', { credentials:'same-origin' })
  .then(function(r){ return r.json(); })
  .then(function(j){
    if (j.ok && j.idol) {
      var box = document.getElementById('myStatusBox');
      var st = j.idol.status;
      var color = st==='active' ? 'emerald' : st==='pending' ? 'yellow' : 'live';
      var icon  = st==='active' ? '✅' : st==='pending' ? '⏳' : '❌';
      var label = st==='active' ? 'ĐÃ DUYỆT - Bạn là idol' : st==='pending' ? 'ĐANG CHỜ DUYỆT' : 'ĐƠN BỊ TỪ CHỐI';
      box.innerHTML = '<div class="bg-'+color+'-500/15 border-2 border-'+color+'-500/50 rounded-xl p-4 text-center">'
        + '<div class="text-4xl mb-2">'+icon+'</div>'
        + '<div class="text-white font-extrabold text-lg">'+label+'</div>'
        + '<div class="text-muted text-xs mt-1">Tên idol: <b class="text-pri-light">'+j.idol.name+'</b></div>'
        + (j.idol.rejectReason ? '<div class="text-live text-sm mt-2">Lý do: '+j.idol.rejectReason+'</div>' : '')
        + (st==='active' ? '<a href="/idol-studio" class="inline-block mt-3 px-5 py-2 bg-gradient-to-r from-pink-500 to-purple-600 text-white font-bold rounded-lg">📡 Vào Studio Live</a>' : '')
        + '</div>';
      box.classList.remove('hidden');
      // Disable form nếu đang chờ hoặc đã active
      if (st === 'pending' || st === 'active') {
        document.getElementById('applyIdolForm').style.display = 'none';
      }
    }
  });

// ═══ AVATAR UPLOAD HANDLER ═══
(function(){
  var inputs = document.querySelectorAll('[data-avatar-input]');
  var preview = document.getElementById('avatarPreview');
  var empty = document.getElementById('avatarEmpty');
  var img = document.getElementById('avatarImg');
  var final = document.getElementById('avatarFinal');
  var removeBtn = document.getElementById('avatarRemove');
  function handleFile(file) {
    if (!file) return;
    if (file.size > 5 * 1024 * 1024) { showToast('Ảnh quá lớn (max 5MB)', 'error'); return; }
    if (!/^image\//i.test(file.type)) { showToast('Chỉ chấp nhận file ảnh', 'error'); return; }
    // Gán file vào input ẩn (DataTransfer trick để submit kèm form)
    var dt = new DataTransfer(); dt.items.add(file); final.files = dt.files;
    // Preview
    var r = new FileReader();
    r.onload = function(e){ img.src = e.target.result; preview.classList.remove('hidden'); empty.classList.add('hidden'); };
    r.readAsDataURL(file);
  }
  inputs.forEach(function(inp){
    inp.addEventListener('change', function(e){ if (e.target.files && e.target.files[0]) handleFile(e.target.files[0]); });
  });
  removeBtn.addEventListener('click', function(){
    final.value = ''; img.src = ''; preview.classList.add('hidden'); empty.classList.remove('hidden');
    inputs.forEach(function(inp){ inp.value = ''; });
  });
})();

document.getElementById('applyIdolForm').addEventListener('submit', async function(e){
  e.preventDefault();
  var f = this;
  // Dùng FormData để gửi multipart (text fields + file)
  var fd = new FormData();
  // Lấy các field cần thiết (bỏ qua avatarCapture/avatarPick — chỉ giữ avatarFile)
  var fields = ['stageName','age','height','weight','city','job','hobby','bio','emoji'];
  fields.forEach(function(k){ if (f[k]) fd.append(k, f[k].value || ''); });
  fd.append('agree', f.agree.checked ? '1' : '');
  // Avatar file (nếu có)
  var avatarFinal = document.getElementById('avatarFinal');
  if (avatarFinal && avatarFinal.files && avatarFinal.files[0]) fd.append('avatarFile', avatarFinal.files[0]);
  var btn = document.getElementById('submitBtn');
  btn.disabled = true; btn.textContent = 'Đang gửi...';
  try {
    var r = await fetch('/api/apply/idol', {
      method:'POST',
      credentials:'same-origin',
      body: fd  // KHÔNG set Content-Type — browser auto-set multipart boundary
    });
    var j = await r.json();
    if (j.ok) {
      showToast('🎉 ' + j.message,'success');
      setTimeout(function(){ location.reload(); }, 2000);
    } else {
      showToast(j.error || 'Lỗi không xác định','error');
      btn.disabled = false; btn.textContent = '🌟 GỬI ĐƠN ĐĂNG KÝ IDOL';
    }
  } catch(err){
    showToast('Lỗi kết nối','error');
    btn.disabled = false; btn.textContent = '🌟 GỬI ĐƠN ĐĂNG KÝ IDOL';
  }
});
</script>

<%- include('partials/tw-footer') %>
