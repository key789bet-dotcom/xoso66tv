            <a href="#" class="flex items-center gap-2 px-3 py-2 hover:bg-bg-soft transition-colors">
              <span class="text-[10px] text-emerald-400">●</span>
              <span class="flex-1 text-[11px] text-gray-200 line-clamp-1"><%= lg %></span>
              <span class="text-[10px] text-dim"><%= _leagues[lg] %></span>
            </a>
          </li>
        <% }); %>
      </ul>
    </div>
  </aside>
</section>

<style>
.news-flt.active { background:#f97316 !important; color:#fff !important; border-color:#f97316 !important; box-shadow:0 4px 12px rgba(249,115,22,.3); }
.news-hero:hover { box-shadow:0 12px 40px rgba(249,115,22,.25); transform:translateY(-2px); }
</style>
<script>
(function(){
  var flts = document.querySelectorAll('.news-flt');
  var cards = document.querySelectorAll('#newsGrid .news-card');
  flts.forEach(function(b){
    b.addEventListener('click', function(){
      flts.forEach(function(x){ x.classList.remove('active'); });
      b.classList.add('active');
      var v = b.dataset.flt;
      cards.forEach(function(c){
        c.style.display = (v==='all' || c.dataset.league===v) ? '' : 'none';
      });
    });
  });
})();
</script>

<% } %>

