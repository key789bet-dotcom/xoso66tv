    <% }); %>
  </div>
</section>

<% if (!list || list.length === 0) { %>
  <div class="p-12 text-center bg-bg-card border border-dashed border-line rounded-xl text-muted">
    <div class="text-5xl mb-2 opacity-60">📰</div>
    <div>Chưa có bài viết. AI sẽ tự động sinh bài mỗi sáng 6:00.</div>
  </div>
<% } else { %>

<!-- ╔════ FEATURED LAYOUT 2 cột: 1 hero LEFT + 4 cards RIGHT ════╗ -->
