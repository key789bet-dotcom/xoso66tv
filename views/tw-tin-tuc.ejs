    <a href="<%= partner.register %>" target="_blank" class="px-3 py-1.5 bg-emerald-600 hover:bg-emerald-500 text-white text-xs font-bold rounded-lg flex items-center gap-1.5">🔐 Đăng nhập đăng bài</a>
