<!-- ═══════════ FORUM LAYOUT — Plain CSS (NO Tailwind arbitrary) ═══════════ -->
<style>
.fr-wrap{max-width:1240px;margin:0 auto;}
.fr-hero-img{height:280px !important;width:100%;overflow:hidden;position:relative;background:#1a2030;}
.fr-hero-img img{width:100% !important;height:100% !important;object-fit:cover !important;display:block;}
.fr-thumb{width:80px !important;height:80px !important;flex:0 0 80px;overflow:hidden;background:#1a2030;border-radius:8px;}
.fr-thumb img{width:100% !important;height:100% !important;object-fit:cover !important;display:block;}
.fr-thumb-lg{width:110px !important;height:110px !important;flex:0 0 110px;overflow:hidden;background:#1a2030;border-radius:8px;}
.fr-thumb-lg img{width:100% !important;height:100% !important;object-fit:cover !important;display:block;}
.fr-grid-2{display:grid;grid-template-columns:1fr;gap:14px;}
.fr-grid-3{display:grid;grid-template-columns:1fr;gap:14px;}
.fr-grid-main{display:grid;grid-template-columns:1fr;gap:14px;}
.fr-sb-card{display:flex;gap:10px;padding:8px;background:var(--bg-card,#171c28);border:1px solid #232a3a;border-radius:10px;text-decoration:none;align-items:center;}
.fr-sb-card:hover{border-color:#10b981;}
.fr-news-row{display:flex;gap:12px;padding:12px;border-bottom:1px solid #232a3a;text-decoration:none;}
.fr-news-row:hover{background:#1a2030;}
@media(min-width:900px){
  .fr-grid-2{grid-template-columns:minmax(0,1.6fr) minmax(0,1fr);}
  .fr-grid-3{grid-template-columns:1fr 1fr 1fr;}
  .fr-grid-main{grid-template-columns:minmax(0,1fr) 280px;}
}
.fr-widget-head{padding:10px 12px;background:linear-gradient(90deg,#064e3b,#047857);border-bottom:1px solid #232a3a;display:flex;align-items:center;gap:8px;}
.fr-card{background:var(--bg-card,#171c28);border:1px solid #232a3a;border-radius:12px;overflow:hidden;}
.fr-emerald-bar{background:linear-gradient(90deg,#064e3b,#047857);}
.fr-chip{padding:6px 10px;border-radius:6px;font-size:11px;font-weight:700;background:#1a2030;color:#cbd5e1;border:1px solid #232a3a;white-space:nowrap;cursor:pointer;}
.fr-chip:hover{background:#232a3a;}
.fr-chip.active{background:linear-gradient(135deg,#059669,#047857);color:#fff;border-color:#10b981;}
.fr-chip .cnt{color:#34d399;font-weight:800;}
</style>

<!-- ═══════════ DESKTOP — Layout DIỄN ĐÀN BÓNG ĐÁ ═══════════ -->
<div class="hidden md:block fr-wrap">
<%- include('partials/tw-breadcrumb') %>

<%
  // Group bài theo league để filter
  var _leagues = {};
  (list||[]).forEach(function(n){
    var lg = n.league || 'Khác';
    _leagues[lg] = (_leagues[lg] || 0) + 1;
  });
  var _leagueList = Object.keys(_leagues).sort(function(a,b){ return _leagues[b]-_leagues[a]; });
  // Format "x giờ trước"
  function _hoursAgo(t){
    var ms = Date.now() - new Date(t).getTime();
    var h = Math.floor(ms/3600000);
    if (h < 1) return Math.max(1, Math.floor(ms/60000)) + ' phút trước';
    if (h < 24) return h + ' giờ trước';
    return Math.floor(h/24) + ' ngày trước';
  }
  // Mock view count ổn định từ id (không random)
  function _viewCount(n){
    var s = (n.slug || n.id || '').split('').reduce(function(a,c){ return a + c.charCodeAt(0); }, 0);
    return 200 + (s % 800);
  }
%>

