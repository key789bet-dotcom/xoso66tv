<%
var _today = new Date(); var _todayVi = _today.getDate()+'/'+(_today.getMonth()+1)+'/'+_today.getFullYear();
seo = {
  title: 'Tin Tức Thể Thao Hôm Nay '+_todayVi+' - '+brand.name,
  description: 'Cập nhật tin tức thể thao nóng hổi 24/7: kết quả, chuyển nhượng, phân tích. '+list.length+' bài viết mới nhất.',
  keywords: 'tin tức thể thao, tin bóng đá hôm nay, chuyển nhượng, tin nhanh thể thao',
  canonical: '/tin-tuc',
  breadcrumb: [{ name:'Tin tức', url:'/tin-tuc' }]
};
function _iso(d){ try{return new Date(d).toISOString();}catch(e){return new Date().toISOString();} }
%>
<%- include('partials/tw-layout-start') %>
<%- include('partials/tw-breadcrumb') %>

<header class="hero-animated-bg bg-gradient-to-br from-bg-card to-bg-soft border border-line rounded-xl px-6 py-5 mb-4"><div class="hero-sparkles" aria-hidden="true"><span></span><span></span><span></span><span></span><span></span></div>
  <h1 class="text-xl md:text-2xl font-black text-white mb-2.5"><span class="text-2xl">&#128240;</span> <span class="text-shimmer">Tin Tức Thể Thao Hôm Nay <%= _todayVi %> - Cập Nhật 24/7</span></h1>
  <p class="text-muted text-sm">Tin nóng hổi từ làng thể thao thế giới và Việt Nam: <a href="/lich-phat-song?mon=bong-da" class="text-pri-light">bóng đá</a>, <a href="/the-thao/bong-ro" class="text-pri-light">bóng rổ</a>, <a href="/the-thao/tennis" class="text-pri-light">tennis</a>, <a href="/esports" class="text-pri-light">esports</a>.</p>
</header>

<section aria-label="Tin tức">
  <% if (!list || list.length === 0) { %>
    <div class="p-12 text-center bg-bg-card border border-dashed border-line rounded-xl text-muted"><div class="text-5xl mb-2 opacity-60">&#128240;</div>Chưa có bài viết.</div>
  <% } else { %>
    <div class="grid gap-3.5 grid-cols-[repeat(auto-fill,minmax(280px,1fr))]">
      <% list.forEach(function(m){ %>
        <article class="bg-bg-card border border-line rounded-xl overflow-hidden transition-all hover:border-pri hover:-translate-y-1" itemscope itemtype="https://schema.org/NewsArticle">
          <a href="/live/<%= m.slug || m.id %>" itemprop="url" class="block">
            <div class="aspect-video bg-gradient-to-br from-[#1a2030] to-bg overflow-hidden">
              <% if (m.poster) { %>
                <img src="<%= m.poster %>" loading="lazy" alt="<%= m.home %> vs <%= m.away %>" class="w-full h-full object-cover" itemprop="image" onerror="this.style.display='none'">
              <% } else { %>
                <div class="w-full h-full grid place-items-center text-muted text-4xl">&#128240;</div>
              <% } %>
            </div>
            <div class="p-3">
              <h2 class="text-[14px] font-bold text-white leading-snug mb-1.5 line-clamp-2" itemprop="headline"><%= m.headline %></h2>
              <p class="text-xs text-muted mb-2 line-clamp-2" itemprop="description"><%= m.excerpt %></p>
              <div class="flex justify-between text-[11px] text-dim">
                <span>&#127942; <span itemprop="about"><%= m.league %></span></span>
                <time datetime="<%= _iso(m.date) %>" itemprop="datePublished">&#128197; <%= m.date %></time>
              </div>
              <meta itemprop="author" content="<%= brand.name %>">
              <meta itemprop="publisher" content="<%= brand.name %>">
            </div>
          </a>
        </article>
      <% }); %>
    </div>
  <% } %>
</section>

<%- include('partials/tw-seo-bottom', { seoContent: {
  h2:'Về trang Tin tức thể thao của '+brand.name,
  intro:'<strong>'+brand.name+'</strong> là nguồn tin tức thể thao nhanh, chính xác và toàn diện nhất Việt Nam. Tin tức sync trực tiếp từ các nguồn chính thức quốc tế.',
  sections: [
    { h3:'Bao phủ mọi giải đấu', p:'Premier League, La Liga, Serie A, Bundesliga, Champions League, World Cup, V-League, NBA, ATP/WTA, esports... Tất cả đều có chuyên mục riêng.' },
    { h3:'Cộng đồng BLV và chuyên gia', p:'Sau mỗi tin, bạn có thể thảo luận, soi kèo, dự đoán tỉ số cùng hàng nghìn fan. <a href="/dang-ky">Đăng ký miễn phí</a> để tham gia.' }
  ],
  faqs: [
    { q:'Tin tức có chính xác không?', a:'Có. Dữ liệu sync trực tiếp từ TheSportsDB - nguồn chuẩn quốc tế.' },
    { q:'Tin được cập nhật bao lâu một lần?', a:'Tin kết quả: ngay khi trận kết thúc. Tin chuyển nhượng: mỗi giờ. Tin highlight: 1-2 giờ sau trận.' }
  ]
}}) %>

<%- include('partials/tw-footer') %>
