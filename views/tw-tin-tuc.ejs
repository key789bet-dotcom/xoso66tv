<%
var _today = new Date(); var _todayVi = _today.getDate()+'/'+(_today.getMonth()+1)+'/'+_today.getFullYear();
seo = {
  title: 'Nhận Định & Soi Kèo Bóng Đá Hôm Nay '+_todayVi+' - '+brand.name,
  description: 'Tổng hợp nhận định, soi kèo bóng đá cập nhật mỗi ngày: phong độ, đối đầu, dự đoán tỉ số. '+list.length+' bài viết mới nhất từ chuyên gia AI.',
  keywords: 'nhận định bóng đá, soi kèo, dự đoán tỉ số, phân tích trận đấu, '+brand.short,
  canonical: '/tin-tuc',
  breadcrumb: [{ name:'Tin tức & Nhận định', url:'/tin-tuc' }]
};
function _iso(d){ try{return new Date(d).toISOString();}catch(e){return new Date().toISOString();} }
function _fmtDate(d){
  try { var dt = new Date(d); return dt.getDate()+'/'+(dt.getMonth()+1)+'/'+dt.getFullYear(); }
  catch(e) { return ''; }
}
%>
<%- include('partials/tw-layout-start') %>

<!-- ═══════════ DESKTOP — Layout DIỄN ĐÀN BÓNG ĐÁ ═══════════ -->
<div class="hidden md:block">
<%- include('partials/tw-breadcrumb') %>

<%
  // Group bài theo league để filter
  var _leagues = {};
  (list||[]).forEach(function(n){
    var lg = n.league || 'Khác';
    _leagues[lg] = (_leagues[lg] || 0) + 1;
  });
  var _leagueList = Object.keys(_leagues).sort(function(a,b){ return _leagues[b]-_leagues[a]; });
  // Format "x giờ trước"
  function _hoursAgo(t){
    var ms = Date.now() - new Date(t).getTime();
    var h = Math.floor(ms/3600000);
    if (h < 1) return Math.max(1, Math.floor(ms/60000)) + ' phút trước';
    if (h < 24) return h + ' giờ trước';
    return Math.floor(h/24) + ' ngày trước';
  }
  // Mock view count ổn định từ id (không random)
  function _viewCount(n){
    var s = (n.slug || n.id || '').split('').reduce(function(a,c){ return a + c.charCodeAt(0); }, 0);
    return 200 + (s % 800);
  }
%>

<!-- ╔════ HERO HEADER DIỄN ĐÀN ════╗ -->
<header class="bg-gradient-to-r from-emerald-900/40 via-bg-card to-bg-card border border-line rounded-xl px-5 py-4 mb-4">
  <div class="flex items-center gap-3 mb-2">
    <div class="w-10 h-10 rounded-full bg-emerald-500/20 border border-emerald-500/40 grid place-items-center text-2xl">⚽</div>
    <div class="flex-1">
      <h1 class="text-lg font-black text-white">Diễn Đàn Bóng Đá <span class="text-emerald-400">XOSO66</span> — Nhận Định, Soi Kèo, Dự Đoán Tỉ Số</h1>
      <p class="text-[12px] text-muted mt-0.5">Cộng đồng nhận định bóng đá Việt Nam #1 · tham gia thảo luận với <strong class="text-white">10K+</strong> thành viên BLV và chuyên gia về <a href="#" class="text-pri-light">Ngoại Hạng Anh</a>, <a href="#" class="text-pri-light">La Liga</a>, <a href="#" class="text-pri-light">Champions League</a>, <a href="#" class="text-pri-light">V-League</a> và nhiều giải đấu khác. Đăng bài soi kèo, dự đoán tỉ số trận đấu, kiếm XP từ <a href="#" class="text-pri-light">BXH Cao Thủ</a></p>
    </div>
  </div>
</header>

<!-- ╔════ SECTION: BÀI VIẾT & NHẬN ĐỊNH MỚI NHẤT ════╗ -->
