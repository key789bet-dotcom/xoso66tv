        <% if (_hot.image) { %>
          <img src="<%= _hot.image %>" alt="<%= _hot.title %>" class="w-full h-full object-cover">
        <% } %>
        <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-transparent"></div>
        <% if (_hot.predictedScore) { %>
          <span class="absolute top-2 left-2 bg-pri text-white text-[11px] font-extrabold px-2 py-1 rounded">🎯 <%= _hot.predictedScore %></span>
        <% } %>
        <span class="absolute top-2 right-2 bg-emerald-500/90 text-white text-[10px] font-bold px-2 py-0.5 rounded">🔥 HOT</span>
        <div class="absolute bottom-0 inset-x-0 p-3 text-white">
          <h2 class="text-sm font-extrabold leading-tight line-clamp-2"><%= _hot.title %></h2>
          <div class="flex items-center justify-between mt-1 text-[10px] opacity-80">
            <span>📅 <%= _fmtDate(_hot.publishedAt) %></span>
            <% if (_hot.league) { %><span>🏆 <%= _hot.league %></span><% } %>
          </div>
        </div>
      </div>
    </a>

    <!-- List còn lại: image trái + text phải -->
    <div class="space-y-2.5 mb-4">
      <% list.slice(1).forEach(function(n){ %>
      <a href="/tin-tuc/<%= n.slug %>" class="flex gap-2.5 bg-bg-card border border-line rounded-xl p-2 active:scale-[.98] transition-transform">
        <div class="w-24 h-24 shrink-0 rounded-lg overflow-hidden bg-gradient-to-br from-[#1a2030] to-bg grid place-items-center relative">
          <% if (n.image) { %>
            <img src="<%= n.image %>" alt="<%= n.title %>" class="w-full h-full object-cover" onerror="this.style.display='none'">
          <% } else { %>
            <span class="text-3xl opacity-60">⚽</span>
          <% } %>
          <% if (n.predictedScore) { %>
            <span class="absolute top-1 left-1 bg-pri text-white text-[9px] font-extrabold px-1 py-0.5 rounded"><%= n.predictedScore %></span>
          <% } %>
        </div>
        <div class="flex-1 min-w-0 flex flex-col">
          <h3 class="text-[12.5px] font-bold text-white leading-tight line-clamp-2 mb-1"><%= n.title %></h3>
          <p class="text-[10.5px] text-muted line-clamp-2 mb-1"><%= n.excerpt %></p>
          <div class="flex items-center justify-between text-[9.5px] text-dim mt-auto">
            <% if (n.league) { %><span class="truncate max-w-[100px]">🏆 <%= n.league %></span><% } else { %><span></span><% } %>
            <span>📅 <%= _fmtDate(n.publishedAt) %></span>
          </div>
        </div>
      </a>
      <% }); %>
    </div>
  <% } %>
</div>

<%- include('partials/tw-footer') %>
