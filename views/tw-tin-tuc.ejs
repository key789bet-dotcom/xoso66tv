  <!-- Filter chips theo giải (2 dòng tablist) -->
  <div class="flex flex-wrap gap-1.5">
    <button data-flt="all" class="news-flt active px-3 py-1.5 rounded-md text-[11px] font-bold whitespace-nowrap bg-emerald-600 text-white">⚡ Tất cả <span class="opacity-80">(<%= list.length %>)</span></button>
    <button class="px-3 py-1.5 rounded-md text-[11px] font-bold whitespace-nowrap bg-bg-soft text-gray-300 hover:bg-bg-deep border border-line">💬 Thảo Luận Chung</button>
