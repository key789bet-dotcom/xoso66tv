<%
var _today = new Date(); var _todayVi = _today.getDate()+'/'+(_today.getMonth()+1)+'/'+_today.getFullYear();
seo = {
  title: 'Nhận Định & Soi Kèo Bóng Đá Hôm Nay '+_todayVi+' - '+brand.name,
  description: 'Tổng hợp nhận định, soi kèo bóng đá cập nhật mỗi ngày: phong độ, đối đầu, dự đoán tỉ số. '+list.length+' bài viết mới nhất từ chuyên gia AI.',
  keywords: 'nhận định bóng đá, soi kèo, dự đoán tỉ số, phân tích trận đấu, '+brand.short,
  canonical: '/tin-tuc',
  breadcrumb: [{ name:'Tin tức & Nhận định', url:'/tin-tuc' }]
};
function _iso(d){ try{return new Date(d).toISOString();}catch(e){return new Date().toISOString();} }
function _fmtDate(d){
  try { var dt = new Date(d); return dt.getDate()+'/'+(dt.getMonth()+1)+'/'+dt.getFullYear(); }
  catch(e) { return ''; }
}
%>
<%- include('partials/tw-layout-start') %>

<!-- ═══════════ DESKTOP — Layout chuẩn báo thể thao ═══════════ -->
<div class="hidden md:block">
<%- include('partials/tw-breadcrumb') %>

<!-- HEADER nhỏ gọn + filter chips theo giải -->
<%
  // Group bài theo league để filter
  var _leagues = {};
  (list||[]).forEach(function(n){
    var lg = n.league || 'Khác';
    _leagues[lg] = (_leagues[lg] || 0) + 1;
  });
  var _leagueList = Object.keys(_leagues).sort(function(a,b){ return _leagues[b]-_leagues[a]; }).slice(0, 8);
%>
<header class="bg-bg-card border border-line rounded-xl px-5 py-4 mb-4">
  <div class="flex items-center justify-between flex-wrap gap-3 mb-3">
    <div>
      <h1 class="text-xl font-black text-white mb-1">📰 Nhận Định & Soi Kèo Bóng Đá <%= _todayVi %></h1>
      <p class="text-[12px] text-muted"><strong class="text-pri-light"><%= list.length %> bài</strong> phân tích chuyên sâu · cập nhật mỗi sáng 6:00 bởi AI</p>
    </div>
    <a href="/lich-phat-song?mon=bong-da" class="px-3 py-1.5 bg-pri/15 hover:bg-pri/25 text-pri-light text-xs font-bold rounded-lg border border-pri/30 transition-all">📅 Lịch thi đấu →</a>
  </div>
  <% if (_leagueList.length > 1) { %>
  <!-- Filter chips theo league -->
  <div class="flex gap-1.5 overflow-x-auto pb-1 scrollbar-hide">
    <button data-flt="all" class="news-flt active shrink-0 px-3 py-1.5 rounded-md text-xs font-bold whitespace-nowrap bg-pri text-white shadow-pri transition-all">Tất cả <%= list.length %></button>
    <% _leagueList.forEach(function(lg){ %>
      <button data-flt="<%= lg %>" class="news-flt shrink-0 px-3 py-1.5 rounded-md text-xs font-bold whitespace-nowrap bg-bg-soft text-gray-200 hover:bg-bg-deep border border-line transition-all">🏆 <%= lg %> <span class="text-pri-light"><%= _leagues[lg] %></span></button>
    <% }); %>
  </div>
  <% } %>
</header>

<% if (!list || list.length === 0) { %>
  <div class="p-12 text-center bg-bg-card border border-dashed border-line rounded-xl text-muted">
    <div class="text-5xl mb-2 opacity-60">📰</div>
    <div>Chưa có bài viết. AI sẽ tự động sinh bài mỗi sáng 6:00.</div>
  </div>
<% } else { %>

<!-- ╔════ HERO FEATURED + TOP 2 PICKS ════╗ -->
<% var _hero = list[0]; %>
<section class="grid grid-cols-1 lg:grid-cols-[2fr_1fr] gap-4 mb-5" aria-label="Nổi bật">
  <!-- Hero article LỚN -->
  <article class="news-hero relative overflow-hidden rounded-xl border-2 border-pri/40 hover:border-pri transition-all cursor-pointer group" itemscope itemtype="https://schema.org/NewsArticle">
    <a href="/tin-tuc/<%= _hero.slug %>" class="block" itemprop="url">
      <div class="aspect-[16/9] bg-gradient-to-br from-[#1a2030] to-bg overflow-hidden relative">
        <% if (_hero.image) { %>
          <img src="<%= _hero.image %>" alt="<%= _hero.title %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" itemprop="image">
        <% } else { %>
          <div class="w-full h-full grid place-items-center text-8xl opacity-30">⚽</div>
        <% } %>
        <!-- Gradient overlay cho text dễ đọc -->
        <div class="absolute inset-0 bg-gradient-to-t from-black via-black/50 to-transparent"></div>
        <!-- HOT badge top-left -->
        <span class="absolute top-3 left-3 bg-gradient-to-r from-red-600 to-orange-500 text-white text-[11px] font-black px-3 py-1.5 rounded-full shadow-lg flex items-center gap-1"><span class="w-1.5 h-1.5 bg-white rounded-full animate-pulse-live"></span>HOT PICK</span>
        <!-- Predicted score top-right -->
        <% if (_hero.predictedScore) { %>
          <span class="absolute top-3 right-3 bg-pri text-white text-sm font-black px-3 py-1.5 rounded-lg shadow-lg">🎯 <%= _hero.predictedScore %></span>
        <% } %>
        <!-- Title + meta overlay bottom -->
        <div class="absolute bottom-0 left-0 right-0 p-5">
          <% if (_hero.league) { %>
            <div class="inline-flex items-center gap-1.5 bg-pri/90 text-white text-[10px] font-bold uppercase tracking-wider px-2 py-1 rounded mb-2">🏆 <%= _hero.league %></div>
          <% } %>
          <h2 class="text-2xl font-black text-white mb-2 line-clamp-2 drop-shadow-lg" itemprop="headline"><%= _hero.title %></h2>
          <p class="text-sm text-gray-200 line-clamp-2 mb-3 drop-shadow" itemprop="description"><%= _hero.excerpt %></p>
          <div class="flex items-center gap-3 text-[11px] text-gray-300">
            <span>📰 AI Phân Tích</span>
            <span>•</span>
            <time datetime="<%= _iso(_hero.publishedAt) %>" itemprop="datePublished">📅 <%= _fmtDate(_hero.publishedAt) %></time>
            <span class="ml-auto bg-white/10 backdrop-blur px-2.5 py-1 rounded text-white font-bold">Đọc ngay →</span>
          </div>
        </div>
        <meta itemprop="author" content="<%= _hero.author %>">
        <meta itemprop="publisher" content="<%= brand.name %>">
      </div>
    </a>
  </article>

  <!-- Top 2 picks bên cạnh (horizontal layout) -->
  <div class="flex flex-col gap-3">
    <% (list.slice(1, 3)).forEach(function(n){ %>
      <article class="bg-bg-card border border-line rounded-xl overflow-hidden hover:border-pri transition-all group" itemscope itemtype="https://schema.org/NewsArticle">
        <a href="/tin-tuc/<%= n.slug %>" class="grid grid-cols-[120px_1fr] h-full" itemprop="url">
          <div class="bg-gradient-to-br from-[#1a2030] to-bg overflow-hidden relative">
            <% if (n.image) { %>
              <img src="<%= n.image %>" alt="<%= n.title %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform" itemprop="image" loading="lazy">
            <% } else { %>
              <div class="w-full h-full grid place-items-center text-4xl opacity-30">⚽</div>
            <% } %>
            <% if (n.predictedScore) { %>
              <span class="absolute top-1.5 left-1.5 bg-pri text-white text-[10px] font-black px-1.5 py-0.5 rounded">🎯 <%= n.predictedScore %></span>
            <% } %>
          </div>
          <div class="p-3 flex flex-col justify-between">
            <div>
              <% if (n.league) { %><span class="text-[10px] text-pri-light font-bold uppercase">🏆 <%= n.league %></span><% } %>
              <h3 class="text-sm font-bold text-white mt-1 line-clamp-3 leading-tight" itemprop="headline"><%= n.title %></h3>
            </div>
            <time class="text-[10px] text-dim mt-2" datetime="<%= _iso(n.publishedAt) %>" itemprop="datePublished">📅 <%= _fmtDate(n.publishedAt) %></time>
            <meta itemprop="author" content="<%= n.author %>">
          </div>
        </a>
      </article>
    <% }); %>
  </div>
</section>

<!-- ╔════ MAIN GRID 2 cột + SIDEBAR widget ════╗ -->
<section class="grid grid-cols-1 lg:grid-cols-[1fr_280px] gap-5" aria-label="Nhận định bóng đá">

  <!-- Main grid: bài #4 trở đi, 2 cột -->
  <div>
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-base font-extrabold text-white flex items-center gap-2">📋 Tất cả nhận định <span class="text-[11px] text-muted font-normal">(<%= list.length - 3 %> bài)</span></h2>
      <div class="flex items-center gap-1 text-[10px] text-muted">
        <span>Sort:</span>
        <span class="text-pri-light font-bold">Mới nhất</span>
      </div>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4" id="newsGrid">
      <% list.slice(3).forEach(function(n){ %>
        <article class="news-card bg-bg-card border border-line rounded-xl overflow-hidden hover:border-pri hover:-translate-y-0.5 hover:shadow-lg hover:shadow-pri/20 transition-all flex flex-col" data-league="<%= n.league || 'Khác' %>" itemscope itemtype="https://schema.org/NewsArticle">
          <a href="/tin-tuc/<%= n.slug %>" itemprop="url" class="flex flex-col h-full">
            <div class="aspect-video bg-gradient-to-br from-[#1a2030] to-bg overflow-hidden relative">
              <% if (n.image) { %>
                <img src="<%= n.image %>" loading="lazy" alt="<%= n.title %>" class="w-full h-full object-cover" itemprop="image">
              <% } else { %>
                <div class="w-full h-full grid place-items-center text-5xl opacity-30">⚽</div>
              <% } %>
              <% if (n.predictedScore) { %>
                <span class="absolute top-2 left-2 bg-pri text-white text-[11px] font-extrabold px-2 py-1 rounded shadow">🎯 <%= n.predictedScore %></span>
              <% } %>
              <span class="absolute bottom-2 right-2 bg-black/75 backdrop-blur text-white text-[9px] font-bold px-2 py-0.5 rounded">AI Phân Tích</span>
            </div>
            <div class="p-3.5 flex-1 flex flex-col">
              <% if (n.league) { %><div class="text-[10px] text-pri-light font-bold uppercase tracking-wider mb-1.5">🏆 <%= n.league %></div><% } %>
              <h2 class="text-[14px] font-bold text-white leading-snug mb-2 line-clamp-2 group-hover:text-pri-light" itemprop="headline"><%= n.title %></h2>
              <p class="text-xs text-muted mb-3 line-clamp-2 flex-1" itemprop="description"><%= n.excerpt %></p>
              <div class="flex items-center justify-between text-[10px] text-dim pt-2 border-t border-line/50">
                <span>📰 <%= n.author || 'AI Editor' %></span>
                <time datetime="<%= _iso(n.publishedAt) %>" itemprop="datePublished">📅 <%= _fmtDate(n.publishedAt) %></time>
              </div>
              <meta itemprop="publisher" content="<%= brand.name %>">
            </div>
          </a>
        </article>
      <% }); %>
    </div>
  </div>

  <!-- SIDEBAR widgets -->
  <aside class="space-y-4">
    <!-- Widget: Top kèo hot -->
    <div class="bg-bg-card border border-line rounded-xl p-4 sticky top-4">
      <h3 class="text-sm font-extrabold text-white mb-3 flex items-center gap-2">🔥 Top kèo HOT</h3>
      <ul class="space-y-2.5">
        <% (list.slice(0, 5)).forEach(function(n, i){ %>
          <li>
            <a href="/tin-tuc/<%= n.slug %>" class="flex items-start gap-2.5 group">
              <span class="shrink-0 w-6 h-6 rounded grid place-items-center text-[11px] font-black <%= i===0?'bg-gradient-to-br from-pri to-live text-white':'bg-bg-soft text-pri-light border border-line' %>"><%= i+1 %></span>
              <div class="min-w-0 flex-1">
                <% if (n.predictedScore) { %>
                  <span class="inline-block text-[9px] bg-pri/20 text-pri-light font-bold px-1.5 py-0.5 rounded mr-1 align-middle">🎯 <%= n.predictedScore %></span>
                <% } %>
                <h4 class="inline text-xs font-bold text-gray-200 group-hover:text-pri-light line-clamp-2 leading-snug"><%= n.title %></h4>
                <% if (n.league) { %><div class="text-[10px] text-dim mt-0.5"><%= n.league %></div><% } %>
              </div>
            </a>
          </li>
        <% }); %>
      </ul>
    </div>

    <!-- Widget: Liên kết nhanh -->
    <div class="bg-bg-card border border-line rounded-xl p-4">
      <h3 class="text-sm font-extrabold text-white mb-3 flex items-center gap-2">⚡ Truy cập nhanh</h3>
      <div class="grid grid-cols-2 gap-2">
        <a href="/lich-phat-song" class="bg-bg-soft hover:bg-pri/15 border border-line hover:border-pri/40 rounded-lg p-2.5 text-center transition-all">
          <div class="text-xl mb-1">📅</div>
          <div class="text-[10px] text-gray-200 font-bold">Lịch thi đấu</div>
        </a>
        <a href="/" class="bg-bg-soft hover:bg-pri/15 border border-line hover:border-pri/40 rounded-lg p-2.5 text-center transition-all">
          <div class="text-xl mb-1">📺</div>
          <div class="text-[10px] text-gray-200 font-bold">Live trực tiếp</div>
        </a>
        <a href="<%= partner.register %>" target="_blank" class="bg-gradient-to-br from-pri/20 to-live/20 hover:from-pri/30 hover:to-live/30 border border-pri/40 rounded-lg p-2.5 text-center transition-all">
          <div class="text-xl mb-1">🎁</div>
          <div class="text-[10px] text-pri-light font-bold">Nhận 100%</div>
        </a>
        <a href="/khuyen-mai" class="bg-bg-soft hover:bg-pri/15 border border-line hover:border-pri/40 rounded-lg p-2.5 text-center transition-all">
          <div class="text-xl mb-1">🎊</div>
          <div class="text-[10px] text-gray-200 font-bold">Khuyến mãi</div>
        </a>
      </div>
    </div>

    <!-- Widget: Newsletter / Telegram -->
    <div class="bg-gradient-to-br from-pri/15 to-live/15 border border-pri/40 rounded-xl p-4 text-center">
      <div class="text-2xl mb-2">📢</div>
      <h3 class="text-sm font-extrabold text-white mb-1">Theo dõi Telegram</h3>
      <p class="text-[11px] text-gray-300 mb-3">Nhận kèo HOT mỗi ngày trước trận đấu</p>
      <a href="<%= partner.telegram || 'https://t.me/xoso66tv' %>" target="_blank" class="inline-block bg-pri hover:bg-pri-light text-white text-xs font-bold px-4 py-1.5 rounded-lg transition-all">Tham gia →</a>
    </div>
  </aside>
</section>

<style>
.news-flt.active { background:#f97316 !important; color:#fff !important; border-color:#f97316 !important; box-shadow:0 4px 12px rgba(249,115,22,.3); }
.news-hero:hover { box-shadow:0 12px 40px rgba(249,115,22,.25); transform:translateY(-2px); }
</style>
<script>
(function(){
  var flts = document.querySelectorAll('.news-flt');
  var cards = document.querySelectorAll('#newsGrid .news-card');
  flts.forEach(function(b){
    b.addEventListener('click', function(){
      flts.forEach(function(x){ x.classList.remove('active'); });
      b.classList.add('active');
      var v = b.dataset.flt;
      cards.forEach(function(c){
        c.style.display = (v==='all' || c.dataset.league===v) ? '' : 'none';
      });
    });
  });
})();
</script>

<% } %>

<%- include('partials/tw-seo-bottom', { seoContent: {
  h2:'Về trang Nhận định & Soi kèo của '+brand.name,
  intro:'<strong>'+brand.name+'</strong> tự động tổng hợp và phân tích trận đấu bằng AI chuyên dụng, kết hợp dữ liệu thống kê thực tế.',
  sections: [
    { h3:'Bao phủ mọi giải đấu', p:'Premier League, La Liga, Serie A, Bundesliga, Champions League, World Cup, V-League. Mỗi sáng có bài cho 5 trận hot nhất.' },
    { h3:'Phân tích chuyên sâu', p:'Mỗi bài có 6 mục: phong độ gần đây, lịch sử đối đầu, đội hình dự kiến, nhận định kèo châu Á/châu Âu/Tài Xỉu, dự đoán tỉ số, lời khuyên.' }
  ],
  faqs: [
    { q:'Bài viết có chính xác không?', a:'AI phân tích dựa trên dữ liệu thực tế. Tỉ lệ chính xác cao nhưng vẫn cần kết hợp với nhận định cá nhân.' },
    { q:'Bài được cập nhật bao lâu một lần?', a:'Tự động sinh mới mỗi sáng 6:00 giờ Việt Nam, cho các trận đấu trong ngày và sắp tới.' }
  ]
}}) %>
</div>

<!-- ═══════════ 📱 MOBILE ═══════════ -->
<div class="md:hidden px-3">
  <div class="flex items-center gap-2 mb-3 mt-1">
    <a href="/" class="text-pri-light text-2xl leading-none" aria-label="Back">‹</a>
    <h1 class="text-pri-light font-extrabold text-xl flex-1">Nhận Định 📰</h1>
    <span class="text-[10px] text-muted"><%= list.length %> bài</span>
  </div>

  <% if (!list || list.length === 0) { %>
    <div class="p-8 text-center bg-bg-card border border-dashed border-line rounded-xl text-muted">
      <div class="text-4xl mb-2 opacity-60">📰</div>
      <div class="text-sm">AI sẽ tự sinh bài mỗi sáng 6:00.</div>
    </div>
  <% } else { %>
    <!-- Featured: bài đầu tiên to nhất -->
    <% var _hot = list[0]; %>
    <a href="/tin-tuc/<%= _hot.slug %>" class="block bg-bg-card border border-pri/40 rounded-xl overflow-hidden mb-3 shadow-lg shadow-pri/20">
      <div class="aspect-[16/9] relative bg-gradient-to-br from-[#1a2030] to-bg">
        <% if (_hot.image) { %>
          <img src="<%= _hot.image %>" alt="<%= _hot.title %>" class="w-full h-full object-cover">
        <% } %>
        <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-transparent"></div>
        <% if (_hot.predictedScore) { %>
          <span class="absolute top-2 left-2 bg-pri text-white text-[11px] font-extrabold px-2 py-1 rounded">🎯 <%= _hot.predictedScore %></span>
        <% } %>
        <span class="absolute top-2 right-2 bg-emerald-500/90 text-white text-[10px] font-bold px-2 py-0.5 rounded">🔥 HOT</span>
        <div class="absolute bottom-0 inset-x-0 p-3 text-white">
          <h2 class="text-sm font-extrabold leading-tight line-clamp-2"><%= _hot.title %></h2>
          <div class="flex items-center justify-between mt-1 text-[10px] opacity-80">
            <span>📅 <%= _fmtDate(_hot.publishedAt) %></span>
            <% if (_hot.league) { %><span>🏆 <%= _hot.league %></span><% } %>
          </div>
        </div>
      </div>
    </a>

    <!-- List còn lại: image trái + text phải -->
    <div class="space-y-2.5 mb-4">
      <% list.slice(1).forEach(function(n){ %>
      <a href="/tin-tuc/<%= n.slug %>" class="flex gap-2.5 bg-bg-card border border-line rounded-xl p-2 active:scale-[.98] transition-transform">
        <div class="w-24 h-24 shrink-0 rounded-lg overflow-hidden bg-gradient-to-br from-[#1a2030] to-bg grid place-items-center relative">
          <% if (n.image) { %>
            <img src="<%= n.image %>" alt="<%= n.title %>" class="w-full h-full object-cover" onerror="this.style.display='none'">
          <% } else { %>
            <span class="text-3xl opacity-60">⚽</span>
          <% } %>
          <% if (n.predictedScore) { %>
            <span class="absolute top-1 left-1 bg-pri text-white text-[9px] font-extrabold px-1 py-0.5 rounded"><%= n.predictedScore %></span>
          <% } %>
        </div>
        <div class="flex-1 min-w-0 flex flex-col">
          <h3 class="text-[12.5px] font-bold text-white leading-tight line-clamp-2 mb-1"><%= n.title %></h3>
          <p class="text-[10.5px] text-muted line-clamp-2 mb-1"><%= n.excerpt %></p>
          <div class="flex items-center justify-between text-[9.5px] text-dim mt-auto">
            <% if (n.league) { %><span class="truncate max-w-[100px]">🏆 <%= n.league %></span><% } else { %><span></span><% } %>
            <span>📅 <%= _fmtDate(n.publishedAt) %></span>
          </div>
        </div>
      </a>
      <% }); %>
    </div>
  <% } %>
</div>

<%- include('partials/tw-footer') %>
