{
  "name": "xoso66tv-live",
  "version": "1.0.0",
  "description": "Xoso66TV - Trang phát sóng trực tiếp đa môn thể thao, liên kết affiliate xoso66tv.com",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build:css": "tailwindcss -i ./public/css/tailwind-input.css -o ./public/css/tailwind-built.css --minify",
    "watch:css": "tailwindcss -i ./public/css/tailwind-input.css -o ./public/css/tailwind-built.css --watch",
    "gen-vapid": "node -e \"const k=require('web-push').generateVAPIDKeys();console.log('VAPID_PUBLIC_KEY='+k.publicKey);console.log('VAPID_PRIVATE_KEY='+k.privateKey);console.log('VAPID_SUBJECT=mailto:admin@xoso66tv.com');\"",
    "backup": "node scripts/backup.js",
    "backup:upload": "node scripts/backup.js --upload",
    "backup:dry": "node scripts/backup.js --dry",
    "backup:list": "node scripts/restore.js list",
    "backup:restore": "node scripts/restore.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:report": "playwright show-report"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.6.0",
    "compression": "^1.7.5",
    "dotenv": "^17.4.2",
    "@sentry/node": "^8.45.0",
    "ejs": "^3.1.10",
    "express": "^4.21.0",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "socket.io": "^4.7.5",
    "@socket.io/redis-adapter": "^8.3.0",
    "prom-client": "^15.1.3",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "mysql2": "^3.11.0",
    "nodemailer": "^6.10.1",
    "qrcode": "^1.5.4",
    "sharp": "^0.33.5",
    "speakeasy": "^2.0.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.17",
    "@playwright/test": "^1.48.0"
  },
  "engines": {
    "node": ">=18"
  }
}
