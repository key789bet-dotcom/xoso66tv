  "description": "Xoso66TV - Trang phát sóng trực tiếp đa môn thể thao, liên kết affiliate xoso66tv.com",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build:css": "tailwindcss -i ./public/css/tailwind-input.css -o ./public/css/tailwind-built.css --minify",
    "watch:css": "tailwindcss -i ./public/css/tailwind-input.css -o ./public/css/tailwind-built.css --watch",
    "gen-vapid": "node -e \"const k=require('web-push').generateVAPIDKeys();console.log('VAPID_PUBLIC_KEY='+k.publicKey);console.log('VAPID_PRIVATE_KEY='+k.privateKey);console.log('VAPID_SUBJECT=mailto:admin@xoso66tv.com');\""
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.5",
    "dotenv": "^17.4.2",
    "ejs": "^3.1.10",
    "express": "^4.21.0",
    "express-rate-limit": "^7.5.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nodemailer": "^6.10.1",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.17"
  },
  "engines": {
    "node": ">=18"
  }
